eadInA2","FACIAL_R_ForeheadInA3","FACIAL_R_ForeheadInB1","FACIAL_R_ForeheadInB2","FACIAL_R_ForeheadInSkin","FACIAL_R_ForeheadMid1","FACIAL_R_ForeheadMid2","FACIAL_R_ForeheadMidSkin","FACIAL_R_ForeheadOutA1","FACIAL_R_ForeheadOutA2","FACIAL_R_ForeheadOutB1","FACIAL_R_ForeheadOutB2","FACIAL_R_ForeheadOutSkin","FACIAL_R_HairA1","FACIAL_R_HairA2","FACIAL_R_HairA3","FACIAL_R_HairA4","FACIAL_R_HairA5","FACIAL_R_HairA6","FACIAL_R_HairB1","FACIAL_R_HairB2","FACIAL_R_HairB3","FACIAL_R_HairB4","FACIAL_R_HairB5","FACIAL_R_HairC1","FACIAL_R_HairC2","FACIAL_R_HairC3","FACIAL_R_HairC4","FACIAL_R_JawBulge","FACIAL_R_JawRecess","FACIAL_R_Jawline1","FACIAL_R_Jawline2","FACIAL_R_LipCorner1","FACIAL_R_LipCorner2","FACIAL_R_LipCorner3","FACIAL_R_LipLower1","FACIAL_R_LipLower2","FACIAL_R_LipLower3","FACIAL_R_LipLowerOuter1","FACIAL_R_LipLowerOuter2","FACIAL_R_LipLowerOuter3","FACIAL_R_LipLowerOuterSkin","FACIAL_R_LipLowerSkin","FACIAL_R_LipUpper1","FACIAL_R_LipUpper2","FACIAL_R_LipUpper3","FACIAL_R_LipUpperOuter1","FACIAL_R_LipUpperOuter2","FACIAL_R_LipUpperOuter3","FACIAL_R_LipUpperOuterSkin","FACIAL_R_LipUpperSkin","FACIAL_R_NasolabialBulge1","FACIAL_R_NasolabialBulge2","FACIAL_R_NasolabialBulge3","FACIAL_R_NeckA1","FACIAL_R_NeckA2","FACIAL_R_NeckA3","FACIAL_R_NeckB1","FACIAL_R_NeckB2","FACIAL_R_NeckBackA","FACIAL_R_NeckBackB","FACIAL_R_NoseBridge","FACIAL_R_NoseUpper","FACIAL_R_NostrilThickness1","FACIAL_R_NostrilThickness2","FACIAL_R_NostrilThickness3","FACIAL_R_Pupil","FACIAL_R_Sideburn1","FACIAL_R_Sideburn2","FACIAL_R_Sideburn3","FACIAL_R_Sideburn4","FACIAL_R_Sideburn5","FACIAL_R_Sideburn6","FACIAL_R_TongueSide1","FACIAL_R_TongueSide2","FACIAL_R_TongueSide3","FACIAL_R_TongueSide4"};
		for ($i=0; $i<size($DeleteBone); $i++)
		{
			if (`objExists $DeleteBone[$i]`)
			{
				delete $DeleteBone[$i];
			}else
			{
				continue;
			}
		}
		//不烘焙动画
		FBXExportAnimationOnly -v false;
		//导出平滑组
		FBXExportSmoothingGroups -v true;
		//导出Z轴向上
		string $NowupAxis = `upAxis -q -ax`;
		FBXExportUpAxis $NowupAxis;
		FBXExport -f $GameFacialFbxField;
		print ($GameFacialFbxField + "已制作完成！\n");
	}
}
	//检查文件
global proc GameFacialCheck () 
{
	string $GameFacialFbxField = `optionVar -q WTFileName` + RigPathToEnginePath(("SK_Player_" + `textField -q -tx charactername` + "_Origin_Facial_Lod_01.fbx"));
	if (`textField -q -tx CeresRigtextField` == "")
	{
		error ("请载入角色数据！\n");
	}else
	{
		if (`file -exists -q $GameFacialFbxField` == 0)
		{
			error ("请先制作文件！\n");
		}else
		{
			file -f -new;
			//设置场景Y轴朝上
			upAxis -ax y -rv;
			file -f -import -options "v=0" $GameFacialFbxField;
			//居中场景
			viewSet -animate 0 -home;
			viewFit -animate 0 -all;
			print ("已成功导入：" + $GameFacialFbxField + "\n");
		}
	}
}

//整合动画编辑文件一键生成插件V.3 BodyWithFacial 文件3
	//拷文件至制作文件夹
global proc CopyFileToPre () 
{
	string $WTFileName = `optionVar -q WTFileName`;
	string $Charactername = `textField -q -tx charactername`;
	string $Characternum = `textField -q -tx characternum`;
	string $CeresRigtextField = `textField -q -tx CeresRigtextField`;
	string $AimPreFilePath = "Z:/WT/WT_maya/scenes/Rig/Player/" + $Characternum;

	//新版命名格式文件
	string $PreFilePaths[] = {
		$WTFileName + `textField -q -tx CeresRigtextField`,
		$WTFileName + RigPathToAnimationPath ( "/SK_Player_" + $Charactername + "_Origin_Facial_An_01.dna" ),
		$WTFileName + RigPathToAnimationPath ( "/SK_Player_" + $Charactername + "_Origin_An_01.fbx" ),
		$WTFileName + RigPathToAnimationPath ( "/SK_Player_" + $Charactername + "_Origin_An_01.ma" )
	};

	if (`textField -q -tx CeresRigtextField` == "")
	{
		error ("请载入角色数据！\n");
	}else
	{
		string $FilePath = `textField -q -tx errorlog`;
		int $existsPath = `file -exists -q $FilePath`;
		if (!$existsPath) {
			system("mkdir \"" + $FilePath + "\"");
			warning("当前文件路径未创建现已创建\n");
		}
		//检查拷贝的文件是否存在本地文件
		int $RunKey = 1;
		for ($i = 0 ; $i < size($PreFilePaths); $i++)
		{
			int $existsNewField = `file -exists -q $PreFilePaths[$i]`;
			if (!$existsNewField)
			{
				$RunKey = 0;
				warning("本地未存在 " + $PreFilePaths[$i] + "\n");
			}else
			{
				continue;
			}
		}
		
		if ($RunKey == 1){
			for ($i = 0 ; $i < size($PreFilePaths); $i++)
			{
				$PreFilePaths[$i] = toNativePath($PreFilePaths[$i]);
				$AimPreFilePath = toNativePath($AimPreFilePath);
				system("copy \"" + $PreFilePaths[$i] + "\" \"" + $AimPreFilePath + "\"");
			}
			print ("成功拷贝至" + $FilePath + "\n");
		}
	}
}
	//打开制作文件路径
global proc openfilepath () 
{
	string $FilePath = `textField -q -tx errorlog`;
	int $existsPath = `file -exists -q $FilePath`;
	if (!$existsPath) {
		system("mkdir \"" + $FilePath + "\"");
		system("explorer \"" + $FilePath + "\"");
		warning("当前文件路径已创建路径并打开\n");
	} else {
		system("explorer \"" + $FilePath + "\"");
		print("打开预设文件路径\n");
	}
}
	//刷新制作文件路径文本框
global proc flush () 
{
	string $FilePath = "Z:\\WT\\WT_maya\\scenes\\Rig\\Player\\" + `textField -q -tx characternum`;
	textField -e -tx $FilePath errorlog; 
	print ("刷新日志路径完成！\n");
}
	//制作勾选文件
global proc MakeCheckBoxFile()  
{ 
	string $Characternum = `textField -q -tx characternum`;
	string $Charactername = `textField -q -tx charactername`;
	int $StartKey = 1;
	string $AimPreFilePath = "Z:/WT/WT_maya/scenes/Rig/Player/" + $Characternum;
	string $AimPreFilePathWin = toNativePath($AimPreFilePath);
	string $SaveFacialAnMa = "Z:\\WT\\WT_maya\\scenes\\Rig\\Player\\" + $Characternum + "\\SK_Player_" + $Charactername + "_Origin_Facial_An_01.ma";
	string $SaveBodyWithFacialAnMa = "Z:\\WT\\WT_maya\\scenes\\Rig\\Player\\" + $Characternum + "\\SK_Player_" + $Charactername + "_Origin_BodyWithFacial_An_01.ma";
	$FacialKey = `checkBox -q -v FacialcheckBox`;
	$BodyWithFacialKey = `checkBox -q -v BodyWithFacialcheckBox`;

	//新版命名格式文件
	string $PreFilePaths[] =
	{
		"SK_Player_" + $Charactername + "_Origin_Facial_All_01.ma",
		"SK_Player_" + $Charactername + "_Origin_Facial_An_01.dna",
		"SK_Player_" + $Charactername + "_Origin_An_01.fbx",
		"SK_Player_" + $Charactername + "_Origin_An_01.ma"
	};
	string $fullPaths[];
	for ($i = 0; $i < size($PreFilePaths); $i++)
	{
		$fullPaths[$i] = $AimPreFilePath + "/" + $PreFilePaths[$i];
	}

	//检测角色对应路径是否存在并创建
	int $existsPath = `file -exists -q $AimPreFilePathWin`;
	if (!$existsPath)
	{
		system("mkdir \"" + $AimPreFilePathWin + "\"");
	}

	//检查预备文件是否存在
	for ($i = 0; $i < size($fullPaths); $i++)
	{
		int $existsNewNameFile = `file -exists -q $fullPaths[$i]`;
		if (!$existsNewNameFile)
		{
			warning($PreFilePaths[$i] + " 文件不存在，请从 Ceres 获取该文件并拷贝于 " + $AimPreFilePath + "\n");
			$StartKey = 0;
		}
	}
	
	if ($StartKey == 1)
	{
		if ($FacialKey == 1)
		{
			//创建一个新场景
			file -f -new;
			
			//不带名称空间打开PVFacialMa文件

			file -open -options "v=0;" $fullPaths[0];
			
			//设置场景Y轴朝上
			upAxis -ax y -rv;
			//设置关节旋转值
			setAttr "UnrealRoot.jointOrientX" -90;
			//居中场景
			viewSet -animate 0 -home;
			viewFit -animate 0 -all;
			
			//导入dna文件
			string $scriptsPath = `internalVar -userScriptDir`;
			$scriptsPath = dirname( $scriptsPath );
			string $filePath = $scriptsPath + "/modules/quixel.mod";
			$fileId=`fopen $filePath "r"`;
			string $TextLine = `fgetline $fileId`;
			fclose $fileId;
			string $ArrayTextLine[] = stringToStringArray( $TextLine, "scripts: " );
			python ("import sys\npath_ = '" + $ArrayTextLine[1]  + "'\nif path_ not in sys.path:\n    sys.path.append( path_ )\nfrom DHI.RigSetup import RigBuilder\nbuilder = RigBuilder()\nbuilder.build( '" + $fullPaths[1] + "' )");

			//对导入dna数据产生的对象进行打组
			select -cl;
			select -r GRP_faceGUI GRP_C_eyesAim LOC_C_eyeDriver L_lookDirection R_lookDirection L_lookDirStartHandle L_lookDirEndHandle R_lookDirStartHandle R_lookDirEndHandle;
			group -w -name "DNA_Group";

			//获取Head_M的世界坐标并将其数据设置到CTRL_faceGUI
			vector $Head_MworldPos = `xform -q -ws -t Head_M`;
			setAttr CTRL_faceGUI.t 50 ($Head_MworldPos.y) ($Head_MworldPos.z);
			
			//添加PV和LOD的显示层
			string $charactername = `textField -q -tx charactername`;
			select -cl;
			select -r "Facial_PV";
			createDisplayLayer -name "PV" -number 1;
			select -cl;
			select -r ($charactername + "_LOD");
			createDisplayLayer -name "LOD" -number 2;

			//保存文件
			file -force -pr -typ "mayaAscii" -ea $SaveFacialAnMa;
		}

		if ($BodyWithFacialKey == 1)
		{
			//创建一个新场景
			file -f -new;

			//带名称空间引用刚制作的ma文件
			string $FacialAnNamespace = $Charactername + "_Facial_An";
			file -reference -namespace $FacialAnNamespace $SaveFacialAnMa;
			
			//不带名称空间引用动捕文件
			file -reference -namespace ":" $fullPaths[2];

			//带名称空间引用ANBodyMa
			file -reference -namespace "" $fullPaths[3];
			
			//选择所有模型对象
			select `ls -type mesh`;
			//取消选择除角色An版fbx文件的所有模型对象
			string $selection1[] = `ls -sl`;
			for ($i = 0; $i < size($selection1); $i++)
			{
				if(`gmatch $selection1[$i] ("*:*")` != 0) 
				{
					select -d $selection1[$i];
				}
			}
			$selection1 = `ls -sl`;
			//选择模型对象而不是mesh节点
			string $selection1mesh[] = `listRelatives -p  $selection1`;
			select $selection1mesh;
			//隐藏选定对象
			hide;

			//开始执行约束
			OnlyRunConstrain();
			
			//保存文件
			file -force -pr -typ "mayaAscii" -ea $SaveBodyWithFacialAnMa;
		}
	}
}
