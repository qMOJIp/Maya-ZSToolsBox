//本地预设重命名
global proc LocPreRename ()
{
	if (`window -exists LocPreRename`)
	deleteUI -window LocPreRename;
	string $window = `window -title "重命名" -h 10 -w 100  -rtf 1  -s 0 -tlb 1 LocPreRename`;
	string $LocPreRenamew = `columnLayout -adjustableColumn true `;
	textField -w 100 -h 20 -tx `textScrollList -q -selectItem LocPretextScrollList` -ann "重命名输入框" LocPreRenametextField;
	button -parent $LocPreRenamew -c "LocPreRenamebutton" -label "重命名";
	showWindow $window;
}

global proc LocPreRenamebutton ()
{
	string $directoryPath = `optionVar -q LocPrePath`;
	string $SelectPre[] = `textScrollList -q -selectItem LocPretextScrollList`;
	string $AllPre[] = `textScrollList -q -allItems LocPretextScrollList`;
	int $NumLocPretextScrollList = `textScrollList -q -numberOfItems LocPretextScrollList`;
	int $SelectPreIndex[] = `textScrollList -q -selectIndexedItem LocPretextScrollList`;
	int $LocPreRenamebuttonKey = 0;
	string $NewSelectPre = `textField -q -tx LocPreRenametextField`;
	string $LocPrePathAll = $directoryPath + "/" + $SelectPre[0] + ".pre";
	$LocPrePathAll = toNativePath($LocPrePathAll);
	for ( $i = 0 ; $i <$NumLocPretextScrollList ; $i++)
	{
		if ($NewSelectPre == $AllPre[$i])
		{
			$LocPreRenamebuttonKey = $LocPreRenamebuttonKey + 1;
		}
	}
	if ($LocPreRenamebuttonKey < 1 && $NewSelectPre != "")
	{
		system("rename \"" + $LocPrePathAll + "\" \"" + $NewSelectPre + ".pre\"");
		textScrollList -e -removeIndexedItem $SelectPreIndex[0] LocPretextScrollList;
		textScrollList -e -appendPosition $SelectPreIndex[0] $NewSelectPre LocPretextScrollList;
		textScrollList -e -selectIndexedItem $SelectPreIndex[0] LocPretextScrollList;
		deleteUI -window LocPreRename;
	}else
	{
		if ($NewSelectPre == "")
		{
			warning("重命名为空，重命名失败！！！");
			//deleteUI -window LocPreRename;
		}else{
			warning("存在相同名称文件或名称未改变！！！");
			//deleteUI -window LocPreRename;
		}
	}
}

//导入预设
global proc AssetImport ()
{
	string $AssetExportImportPath = `textField -q -tx AssetExportImportPathtextField`;
	string $AssetExportImportFile = `textField -q -tx AssetExportImportFiletextField`;
	$AssetExportImportPath = strip($AssetExportImportPath);
	$AssetExportImportFile = strip($AssetExportImportFile);
	string $AssetExportImportAll;
	if ($AssetExportImportPath == "")
	{
		warning ("请输入路径！！！");
	}else
	{
		if(`gmatch $AssetExportImportPath ("*.pre")`)
		{
			$AssetExportImportAll = $AssetExportImportPath;
		}else
		{
			$AssetExportImportAll = $AssetExportImportPath + "/" + $AssetExportImportFile + ".pre";
		}
		string $mayaAssetExportImportAll = fromNativePath( $AssetExportImportAll );
		int $AssetPreexists = `file -exists -q $AssetExportImportAll`;
		if (!$AssetPreexists)
		{
			warning("当前预设文件不存在。\n");
		}else
		{
			eval("source \"" + $mayaAssetExportImportAll + "\"");
			print("预设文件已导入。\n");
		}
	}
}

//导出预设
global proc AssetExport ()
{
	string $Project = `optionVar -q CeresNowProject`;
	string $ProjectTextField = `textField -q -tx CeresProjectTextField`;
	string $AssetExportImportPath = `textField -q -tx AssetExportImportPathtextField`;
	string $AssetExportImportFile = `textField -q -tx AssetExportImportFiletextField`;
	$AssetExportImportPath = strip($AssetExportImportPath);
	$AssetExportImportFile = strip($AssetExportImportFile);
	string $mayaAssetExportImportPath = fromNativePath( $AssetExportImportPath );
	string $windowsAssetExportImportPath = toNativePath( $AssetExportImportPath );
	string $AssetCodeArray[] = `textScrollList -q -allItems AssetCodetextScrollList`;
	string $AssetNoteArray[] = `textScrollList -q -allItems AssetNotetextScrollList`;
	string $AssetPathArray[] = `textScrollList -q -allItems AssetPathtextScrollList`;
	string $AssetExportImportAll;
	string $getPreFilesInCurrentDirectory[] = getPreFilesInCurrentDirectory();
	int $numberOftextScrollList = `textScrollList -q -numberOfItems AssetCodetextScrollList`;
	if (!`gmatch $mayaAssetExportImportPath ("//192.168.20.102/projects/CIDA_RG/020 绑定公共数据/Ceres版本管理软件项目路径预设*")`)
	{	
		if ($AssetExportImportPath == "")
		{
			warning ("请输入路径！！！");
		}else
		{
			if(`gmatch $AssetExportImportPath ("*.pre")`)
			{
				$AssetExportImportAll = $mayaAssetExportImportPath;
			}else
			{
				$AssetExportImportAll = $mayaAssetExportImportPath + "/" + $AssetExportImportFile + ".pre";
			}
			//检测输入路径是否存在，不存在则创建
			string $AssetPreexistsPath = dirname($AssetExportImportAll);
			string $windowsAssetPreexistsPath = toNativePath($AssetPreexistsPath);
			int $AssetPreexists = `file -exists -q $AssetPreexistsPath`;
			if ($AssetPreexists == 0){
				system("mkdir \"" + $windowsAssetPreexistsPath + "\"");
			}
			//检测导出文件是否存在，存在则弹出警告窗口
			int $AssetPreFileexists = `file -exists -q $AssetExportImportAll`;
			if ($AssetPreFileexists == 1){
				AssetPrewarn ();
			}else if ($AssetExportImportFile != "" || `gmatch $AssetExportImportPath ("*.pre")`)
			{
				AssetExportCommend ( $AssetExportImportAll , $numberOftextScrollList , "$AssetCodeArray[]" , $AssetCodeArray );
				AssetExportCommend ( $AssetExportImportAll , $numberOftextScrollList , "$AssetNoteArray[]" , $AssetNoteArray );
				AssetExportCommend ( $AssetExportImportAll , $numberOftextScrollList , "$AssetPathArray[]" , $AssetPathArray );
				string $commendtextcontent = "AssetImportCommend ( $AssetCodeArray , $AssetNoteArray , $AssetPathArray );\n";
				writeFile ( $AssetExportImportAll , $commendtextcontent );
				string $projecttextcontent = "optionVar -sv CeresNowProject \"" + $Project + "\";\n" + "textField -e -tx \"" + $ProjectTextField + "\" CeresProjectTextField;\n";
				writeFile ( $AssetExportImportAll , $projecttextcontent );
			LocPreGet ();
			PublicPreGet ();
			}else
			{
				error("预设文件名不能为空！！！");
			}
		}
	}else{
		warning ("此为公盘路径，禁止修改！！！");
	}
}

//导出预设命令
global proc AssetExportCommend ( string $Path , int $Num , string $Name , string $textcontentArray[] )
{
	//资产代号
	string $textcontent1 = "string " + $Name + " = {";
	writeFile ( $Path , $textcontent1 );
	for ( $i = 0 ; $i < $Num-1 ; $i++)
	{
		string $textcontent2 = "\"" + $textcontentArray[$i] + "\",";
		writeFile ( $Path , $textcontent2 );
	}
	string $textcontent2 = "\"" + $textcontentArray[$Num-1] + "\"};\n";
	writeFile ( $Path , $textcontent2 );
}

//文件导出覆盖警告
global proc AssetPrewarn ()
{
	if (`window -exists AssetPrewarn`)
	deleteUI -window AssetPrewarn;
	window -title "警告！" -h 10 -w 100  -rtf 1  -s 0 -tlb 1 AssetPrewarn;
	columnLayout -adjustableColumn true;
	button -c "AssetPrewarnSurebutton" -label "覆盖文件" AssetPrewarnSurebutton;
	button -c "AssetPrewarnCancelbutton" -label "取消导出" AssetPrewarnCancelbutton;
	showWindow;
}

//取消覆盖
global proc AssetPrewarnCancelbutton ()
{
	deleteUI -window AssetPrewarn;
}

//确认覆盖
global proc AssetPrewarnSurebutton ()
{
	string $Project = `optionVar -q CeresNowProject`;
	string $ProjectTextField = `textField -q -tx CeresProjectTextField`;
	string $AssetExportImportPath = `textField -q -tx AssetExportImportPathtextField`;
	string $AssetExportImportFile = `textField -q -tx AssetExportImportFiletextField`;
	$AssetExportImportPath = strip($AssetExportImportPath);
	$AssetExportImportFile = strip($AssetExportImportFile);
	string $mayaAssetExportImportPath = fromNativePath( $AssetExportImportPath );
	string $AssetCodeArray[] = `textScrollList -q -allItems AssetCodetextScrollList`;
	string $AssetNoteArray[] = `textScrollList -q -allItems AssetNotetextScrollList`;
	string $AssetPathArray[] = `textScrollList -q -allItems AssetPathtextScrollList`;
	string $AssetExportImportAll;
	string $getPreFilesInCurrentDirectory[] = getPreFilesInCurrentDirectory();
	int $numberOftextScrollList = `textScrollList -q -numberOfItems AssetCodetextScrollList`;
	if(`gmatch $AssetExportImportPath ("*.pre")`)
	{
		$AssetExportImportAll = $mayaAssetExportImportPath;
	}else
	{
		$AssetExportImportAll = $mayaAssetExportImportPath + "/" + $AssetExportImportFile + ".pre";
	}
	cleanFile ( $AssetExportImportAll );
	if ($AssetExportImportFile != "" || `gmatch $AssetExportImportPath ("*.pre")`)
	{
		AssetExportCommend ( $AssetExportImportAll , $numberOftextScrollList , "$AssetCodeArray[]" , $AssetCodeArray );
		AssetExportCommend ( $AssetExportImportAll , $numberOftextScrollList , "$AssetNoteArray[]" , $AssetNoteArray );
		AssetExportCommend ( $AssetExportImportAll , $numberOftextScrollList , "$AssetPathArray[]" , $AssetPathArray );
		string $commendtextcontent = "AssetImportCommend ( $AssetCodeArray , $AssetNoteArray , $AssetPathArray );\n";
		writeFile ( $AssetExportImportAll , $commendtextcontent );
		string $projecttextcontent = "optionVar -sv CeresNowProject \"" + $Project + "\";\n" + "textField -e -tx \"" + $ProjectTextField + "\" CeresProjectTextField;\n";
		writeFile ( $AssetExportImportAll , $projecttextcontent );
	}else
	{
		error("预设文件名不能为空！！！");
	}
	deleteUI -window AssetPrewarn;
	print ("该预设已覆盖。\n");
}

//取消选择
global proc AssettextScrollListClean ()
{
	textScrollList -e -deselectAll AssetCodetextScrollList;
	textScrollList -e -deselectAll AssetNotetextScrollList;
	textScrollList -e -deselectAll AssetPathtextScrollList;
}

