//选择骨骼数据
global proc SelectKeepBone ()
{
	string $ExportKeepBonePath = `textField -q -tx KeepBoneINfField`;
	string $SelectKeepBoneArray[] = {};
	int $fileId = `fopen $ExportKeepBonePath "r"`;
	if ($fileId != 0) {
		int $i = 0;
		while (!`feof $fileId`)
		{
			string $line = `fgetline $fileId`;
			if ($line != "") 
			{
				$SelectKeepBoneArray[$i] = $line;
				$i++;
			}
		}
		select -r $SelectKeepBoneArray;
	}else
	{
		error ("当前数据文件不存在！！！");
	}
}

//打印骨骼数据
global proc PrintBone ()
{
	string $ExportKeepBonePath = `textField -q -tx KeepBoneINfField`;
	string $PrintContent = "";
	int $fileId = `fopen $ExportKeepBonePath "r"`;
	if ($fileId != 0) {
		while (!`feof $fileId`)
		{
			$PrintContent += `fgetline $fileId`;
		}
		fclose $fileId;
		print $PrintContent;
	}else
	{
		error ("当前数据文件不存在！！！");
	}
}

//导出骨骼数据
global proc ExportKeepBone ()
{
	string $ExportKeepBoneTextArray[] = `ls -sl -type "joint"`;
	string $ExportKeepBoneText = stringArrayToString($ExportKeepBoneTextArray , "\n");
	string $RigAllMessagePath = "//192.168.20.102/projects/CIDA_RG/020 绑定公共数据/RigAll角色数据/";
	string $WTABFMcharactername = `textField -q -tx WTABFMcharactername`;
	string $WTABFMcharacterskin = `textField -q -tx WTABFMcharacterskin`;
	string $WTABFMweaponname = `textField -q -tx WTABFMweaponname`;
	string $WTABFMparasitename = `textField -q -tx WTABFMparasitename`;
	string $KeepBoneMessagePath;
	string $result = `confirmDialog -title "数据类型" -message "储存为武器数据还是变异体数据？" -button "武器" -button "变异体" -button "取消"`;// -defaultButton "继续" -cancelButton "取消"
	int $RunKey = 0;
	if ($result == "武器")
	{
		$KeepBoneMessagePath = $RigAllMessagePath + $WTABFMcharactername + "_" + $WTABFMcharacterskin + "_" + $WTABFMweaponname + ".weaponkeepbone";
		$RunKey = 1;
	} else if ($result == "变异体")
	{
		if ($WTABFMparasitename == "" )
		{
			$KeepBoneMessagePath = $RigAllMessagePath + $WTABFMcharactername + "_" + $WTABFMcharacterskin + ".parasitekeepbone";
		}else
		{
			$KeepBoneMessagePath = $RigAllMessagePath + $WTABFMcharactername + "_" + $WTABFMcharacterskin + "_" + $WTABFMparasitename + ".parasitekeepbone";
		}
		$RunKey = 1;
	} else
	{
		$RunKey = 0;
	}
	if (!`file -exists -q $KeepBoneMessagePath` && $RunKey == 1)
	{
		writeFile ( $KeepBoneMessagePath, $ExportKeepBoneText );
	} else if (`file -exists -q $KeepBoneMessagePath` && $RunKey == 1)
	{
		string $result = `confirmDialog -title "警告" -message "确认覆盖已有文件？" -button "继续" -button "取消"`;// -defaultButton "继续" -cancelButton "取消"
		if ($result == "继续")
		{
			cleanFile ( $KeepBoneMessagePath );
			writeFile ( $KeepBoneMessagePath, $ExportKeepBoneText );
		} else
		{
			print("已取消导出。");
		}
	}
}

