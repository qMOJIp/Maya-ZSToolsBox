// ДАПк
global proc ImportExportKeyframesWindow()
{
	// ШчЙћДАПквбО­ДцдкЃЌдђЩОГ§Ыќ
	if (`window -exists "ImportExportKeyframesWindow"`) {
		deleteUI "ImportExportKeyframesWindow";
	}
	window -title "ЙиМќжЁЖЏЛ­ЕМШыЕМГі" -h 80 -w 150 -s 0 -tlb 1 ImportExportKeyframesWindow;
	columnLayout -columnAttach both 5 -adjustableColumn true ImportExportKeyframescolumnLayout;
		separator -h 5 -style "none";
		button -w 90 -c "CheckSelectObjects(1);ImportExportKeyPath(0)" -label "ЕМГіШЋВП";
		button -w 90 -c "CheckSelectObjects(0);ImportExportKeyPath(0)" -label "ЕМГібЁжа";
		button -w 90 -c "ImportExportKeyPath(1)" -label "ЕМШыЖЏЛ­";
		separator -h 5 -style "none";
	showWindow "ImportExportKeyframesWindow";
}

// ВщевКЌгаЙиМќжЁЕФЖдЯѓЙиМќжЁ
//global proc string[] GetAllKeyedObjects ()
//{
//	// ЛёШЁЫљгаБфЛЛНкЕу
//	string $AllTransforms[] = `ls -type "transform"`;
//	
//	// ЩИбЁГіКЌгаЙиМќжЁЕФЖдЯѓ
//	string $KeyedObjects[] = {};
//	for ($obj in $AllTransforms)
//	{
