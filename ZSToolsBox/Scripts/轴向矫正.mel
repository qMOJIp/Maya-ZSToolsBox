// MEL 脚本：找出三个点组成的三角形面积最大的点,以第一个点为基准
// 获取当前选择的点
global proc string[] TriangularAreaPoint(string $selection[]){
	// 存储最大的面积和对应的点对
	float $maxArea = 0;
	string $maxPoints[3];
	// 计算所有点对之间的面积
	int $i=0;
	for ($j = $i + 1; $j < size($selection) - 1; $j++) {
	    for ($k = $j + 1; $k < size($selection); $k++) {
	        // 获取三个点的坐标
	        vector $A = `pointPosition $selection[$i]`;
	        vector $B = `pointPosition $selection[$j]`;
	        vector $C = `pointPosition $selection[$k]`;
	        // 计算两个向量 AB 和 AC
	        vector $AB = $B - $A;
	        vector $AC = $C - $A;
	        // 计算叉积
	        vector $crossProduct = `cross $AB $AC`;
	        // 计算三角形的面积
	        float $area = 0.5 * `mag($crossProduct)`;
	        // 如果面积更大，更新最大面积和点对
	        if ($area > $maxArea) {
	            $maxArea = $area;
	            $maxPoints[0] = $selection[$i];
	            $maxPoints[1] = $selection[$j];
	            $maxPoints[2] = $selection[$k];
	        }
	    }
	}
	return $maxPoints;
}

///计算循环边的中心轴///
global proc float[] GetCentralSelComp(){
	ConvertSelectionToVertices;
	string $selectedPoints[] = `ls -sl -fl`;
	int $numPoints = size($selectedPoints);
	float $sumX;
	float $sumY;
	float $sumZ;
	for ($j = 0; $j < $numPoints; $j++) {
	    float $pointPos[] = `pointPosition $selectedPoints[$j]`;
	    $sumX += $pointPos[0];
	    $sumY += $pointPos[1];
	    $sumZ += $pointPos[2];
	}
	float $mid[]={};
	$mid[0] = $sumX / $numPoints;
	$mid[1] = $sumY / $numPoints;
	$mid[2] = $sumZ / $numPoints;
	return $mid;

}

//////////////////////////////
//计算三个点坐标围成的三角形的法线
global proc vector calculateNormal(vector $p1, vector $p2, vector $p3) {
    // Calculate two edge vectors
    vector $edge1 = <<($p2.x - $p1.x), ($p2.y - $p1.y), ($p2.z - $p1.z)>>;
    vector $edge2 = <<($p3.x - $p1.x), ($p3.y - $p1.y), ($p3.z - $p1.z)>>;
    
    // Calculate the cross product of the two edges
    vector $normal = <<($edge1.y * $edge2.z - $edge1.z * $edge2.y),
                       ($edge1.z * $edge2.x - $edge1.x * $edge2.z),
                       ($edge1.x * $edge2.y - $edge1.y * $edge2.x)>>;
    // Normalize the resulting vector
    float $length = mag($normal);
    if ($length > 0.0) {
        $normal /= $length;
    }
    return $normal;
}
//匹配两个物体轴
global proc MatchObjectAxes(string $objA_name,string $objB_name){
	float $pos[3];
	float $angleb[] = `xform -q -ws -ro $objB_name`; // 计算角度
	$pos = `xform -q -ws -rp $objB_name`;
	$cmd = ("xform -ws -piv "+$pos[0]+" "+ $pos[1]+" "+ $pos[2]+" \""+ $objA_name+ "\"");
	evalEcho $cmd;
	//select -r $sel_obj_name[0] ;
	rotate -r 0 0 (-$angleb[2]) $objA_name;
	rotate -r 0 (-$angleb[1]) 0 $objA_name;
	rotate -r (-$angleb[0]) 0 0 $objA_name;
	makeIdentity -apply true -t 0 -r 1 -s 0 -n 0 -pn 1 $objA_name;
	rotate -r ($angleb[0]) ($angleb[1]) ($angleb[2]) $objA_name;
}
//计算两个坐标的中点////////////
global proc vector calculateMidpoint(vector $center1, vector $center2) {
    // 计算两个中心点连线的中点
	vector $midpoint = ($center1 + $center2) / 2.0;
	// 打印结果
	print ("Midpoint Center: " + $midpoint + "\n");
	return $midpoint;
}
// 定义获取物体中心世界坐标的函数
global proc vector getWorldCenterA(string $object) {
	  select $object;
	  string $objects[] = `ls -sl -type "transform"`; // 筛选出变换节点（物体通常是 transform 类型）
	  print($objects);
    // 获取物体的包围盒
    if(size($objects)>0){
    	  float $boundingBox[] = `manipMoveContext -q -p "Move" $object`;
	    // 计算中心点坐标
	    float $centerX = $boundingBox[0];
	    float $centerY = $boundingBox[1];
	    float $centerZ = $boundingBox[2];
	    return <<$centerX, $centerY, $centerZ>>;
    }
    else{
    	  float $boundingBox[] = `xform -q -ws -boundingBox $object`;
	    // 计算中心点坐标
	    float $centerX = ($boundingBox[0] + $boundingBox[3]) / 2.0;
	    float $centerY = ($boundingBox[1] + $boundingBox[4]) / 2.0;
	    float $centerZ = ($boundingBox[2] + $boundingBox[5]) / 2.0;
	    return <<$centerX, $centerY, $centerZ>>;
    }
}
// 定义全局过程来获取并处理所选物体的坐标，返回坐标信息
global proc getSelectedObjectsCoordsA(float $returnPos[])
{
    string $selectedObjects[] = `ls -sl`;  // 获取当前选择的所有物体列表
    int $numSelected = size($selectedObjects);  // 获取选择物体的数量
    
    if ($numSelected == 0)  // 如果没有选择物体
    {
        print("请选择至少一个物体。\n");
        //return;
    }
    else if ($numSelected == 1)  // 如果只选择了一个物体
    {
        $returnPos = `getWorldCenterA($selectedObjects[0])`;  // 获取该物体在世界坐标下的平移坐标（位置）
        return;
    }
    else  // 如果选择了多个物体
    {
        float $totalPos[] = {0, 0, 0};  // 用于累计所有物体坐标的总和，初始化为0
        for ($i = 0; $i < $numSelected; $i++)  // 遍历每个所选物体
        {
            float $pos[] = `getWorldCenterA($selectedObjects[$i])`;  // 获取当前物体在世界坐标下的平移坐标
            $totalPos[0] += $pos[0];  // 累加X坐标
            $totalPos[1] += $pos[1];  // 累加Y坐标
            $totalPos[2] += $pos[2];  // 累加Z坐标
        }
        $totalPos[0] /= $numSelected;  // 计算平均X坐标
        $totalPos[1] /= $numSelected;  // 计算平均Y坐标
        $totalPos[2] /= $numSelected;  // 计算平均Z坐标
        
        $returnPos = $totalPos;
		return;
    }

}

//将物体枢轴和旋转匹配到loc
global proc ThroughEconomicReformsRo(string $objname,string $LocatorName){
	float $pos[3];
	$pos = `xform -q -ws -rp $LocatorName`;
	$cmd = ("xform -ws -piv "+$pos[0]+" "+ $pos[1]+" "+ $pos[2]+" \""+ $objname+ "\"");
	evalEcho $cmd;
	float $LocatorWsRo[]=`xform -q -ws -ro $LocatorName`;//获取loc修正后的世界旋转
	//string $templocname[] = `duplicate -n ($LocatorName+"temp") $LocatorName`;
	string $PaConstraintNam[] = `parentConstraint -mo -weight 1 $LocatorName $objname`;
	string $parentname[] = `listRelatives -p $objname`;//获取当前父物体
	if(size($parentname)>0){
		string $OrConstraintNam[] = `orientConstraint -offset 0 0 0 -weight 1 $parentname[0] $LocatorName`;//父级约束临时loc旋转
		delete $PaConstraintNam[0];//删除父子约束
		makeIdentity -apply true -t 1 -r 1 -s 1 -n 0 -pn 1 $objname;//冻结物体变换
		delete $OrConstraintNam[0];//删除旋转约束
		string $PaConstraintNamB[] = `parentConstraint -mo -weight 1 $LocatorName $objname`;//loc约束物体
		vector $SetLocatorWsRoB=`xform -ws -ro $LocatorWsRo[0] $LocatorWsRo[1] $LocatorWsRo[2] $LocatorName`;//loc当前世界旋转
		delete $PaConstraintNamB[0] ;//清理辅助物体和约束
	}
	else{
		vector $SetLocatorWsRoC=`xform -ws -ro 0 0 0 $LocatorName`;//loc当前世界旋转
		delete $PaConstraintNam[0];//删除父子约束
		makeIdentity -apply true -t 1 -r 1 -s 1 -n 0 -pn 1 $objname;//冻结物体变换
		string $PaConstraintNamB[] = `parentConstraint -mo -weight 1 $LocatorName $objname`;//loc约束物体
		vector $SetLocatorWsRoB=`xform -ws -ro $LocatorWsRo[0] $LocatorWsRo[1] $LocatorWsRo[2] $LocatorName`;//loc当前世界旋转
		delete $PaConstraintNamB[0] ;//清理辅助物体和约束
	}
}

