global proc WTAutoFacialFileMake()  
{  
	if (`window -exists "WTAutoFacialFileMakewindow"`)
	{  
		deleteUI -window "WTAutoFacialFileMakewindow";
	}  
window -title "自动WT头模工作流程V.4" -h 500 -w 405 -rtf 1 -s 0 -tlb 0 WTAutoFacialFileMakewindow;
//公用开头
	string $scriptsPath = `internalVar -userScriptDir`;
	string $filePath = $scriptsPath + "ZSToolsBox/PublicFiles/Projets.txt";
	$fileId=`fopen $filePath "r"`;
	string $TextLine = `fgetline $fileId`;
	fclose $fileId;
	string $ArrayTextLine[] = stringToStringArray( $TextLine, ";" );
	for ($i=0; $i<size($ArrayTextLine); $i++)
	{
		if (`gmatch $ArrayTextLine[$i] ("WT=*")` == 1){
			string $ProjetContent[] = stringToStringArray( $ArrayTextLine[$i], "=" );
			optionVar -sv WTFileName $ProjetContent[1];
		}
	}
columnLayout -h 500 -w 390 -columnAttach both 5 -adjustableColumn true WTAFFMcolumnLayout;
	separator -h 5 -style "none";
	text -h 20 -bgc 0.2 0.4 0.4 -label ("使用前确保对应角色的 Facial PV ma 文件已获取且按照规范制作");
	separator -h 5 -style "none";
scrollLayout -p WTAFFMcolumnLayout -h 470 -w 390 WTAFFMscrollLayout;
	rowLayout -adj 1 -p WTAFFMscrollLayout -nc 2 -columnWidth2 186 186; 
	text -w 186 -label ("角色名字");
	text -w 186 -label ("代号");
	rowLayout -adj 1 -p WTAFFMscrollLayout -nc 2 -columnWidth2 186 186; 
	textField -w 186 -tx "" charactername;
	textField -w 186 -tx "" characternum;
text -w 375 -p WTAFFMscrollLayout -label ("Ceres对应角色的Rig路径");
textField -w 375 -p WTAFFMscrollLayout -tx "" CeresRigtextField;

//制作 PV 的 Facial 文件（fbx）UI布局
frameLayout -w 375 -cl 1 -cll 1 -ann "含LOD_PV层级模型和855根骨骼" -label "制作 PV 的 Facial 文件（fbx）" -p WTAFFMscrollLayout WTAFFMframeLayout1;
	separator -parent WTAFFMframeLayout1 -h 1 -style "none";
	text -h 20 -w 375 -bgc 0.4 0.2 0.2 -label ("进行文件迭代制作时请确认要制作文件已检出");
	button -c "PVFacialCeres" -ann "通过项目文件快速打开插件在 Ceres 上定位到该文件以便快速检出" -label "Ceres 定位制作文件" -parent WTAFFMframeLayout1;
	button -c "PVFacialMake" -ann "在确认检出文件后根据 SK_Player_角色名字_Origin_Facial_PV_01.ma 文件制作"  -label "制作 SK_Player_角色名字_Origin_Facial_PV_01.fbx 文件" -parent WTAFFMframeLayout1;
	button -c "PVFacialCheck" -ann "新建场景导入 SK_Player_角色名字_Origin_Facial_PV_01.fbx 文件" -label "新建场景导入制作文件进行检查" -parent WTAFFMframeLayout1;
	separator -parent WTAFFMframeLayout1 -h 1 -style "shelf";

//制作 Game 的 Facial 文件（fbx）UI布局
frameLayout -w 375 -cl 1 -cll 1 -ann "除LOD_PV层级模型和98根骨骼" -label "制作 Game 的 Facial 文件（fbx）" -p WTAFFMscrollLayout WTAFFMframeLayout2;
	separator -parent WTAFFMframeLayout2 -h 1 -style "none";
	text -h 20 -w 375 -bgc 0.4 0.2 0.2 -label ("进行文件迭代制作时请确认要制作文件已检出");
	button -c "GameFacialCeres" -ann "通过项目文件快速打开插件在 Ceres 上定位到该文件以便快速检出" -label " Ceres 定位制作文件" -parent WTAFFMframeLayout2;
	button -c "GameFacialMake" -ann "在确认检出文件后根据 SK_Player_角色名字_Origin_Facial_PV_01.ma 文件制作" -label "制作 SK_Player_角色名字_Origin_Facial_Lod_01.fbx 文件" -parent WTAFFMframeLayout2;
	button -c "GameFacialCheck" -ann "新建场景导入 SK_Player_角色名字_Origin_Facial_Lod_01.fbx 文件" -label "新建场景导入制作文件进行检查" -parent WTAFFMframeLayout2;
	separator -parent WTAFFMframeLayout2 -h 1 -style "shelf";

//制作An的Facial和BodyWithFacial文件（ma）UI布局
frameLayout -w 375 -ec "HideConstrainframeLayout" -cl 1 -cll 1 -ann "整合动画编辑文件一键生成插件V.3" -label "制作An的Facial和BodyWithFacial文件（ma）" -p WTAFFMscrollLayout WTAFFMframeLayout3;
	//准备文件提示
	separator -parent WTAFFMframeLayout3 -h 1 -style "none";
	text -h 20 -w 375 -bgc 0.4 0.2 0.2 -label ("请从Ceres上获取以下文件最新版本");
	rowLayout -adj 1 -p WTAFFMframeLayout3 -nc 2 -columnWidth2 335 30; 
		text -h 20 -w 330 -bgc 0.2 0.1 0.1 -label ("SK_Player_角色名字_Origin_Facial_PV_01.ma（PV脸模MA文件）");
		button -w 30 -h 19 -bgc 0.4 0.2 0.2 -ann "在Ceres上定位" -label "Ceres" -c "CeresFacialPVma";
	rowLayout -adj 1 -p WTAFFMframeLayout3 -nc 2 -columnWidth2 335 30; 
		text -h 20 -w 330 -bgc 0.2 0.1 0.1 -label ("SK_Player_角色名字_Origin_Facial_An_01.dna（脸模DNA文件）");
		button -w 30 -h 19 -bgc 0.4 0.2 0.2 -ann "在Ceres上定位" -label "Ceres" -c "CeresFacialAndna";
	rowLayout -adj 1 -p WTAFFMframeLayout3 -nc 2 -columnWidth2 335 30; 
		text -h 20 -w 330 -bgc 0.2 0.1 0.1 -label ("SK_Player_角色名字_Origin_An_01.fbx（AN身体FBX文件）");
		button -w 30 -h 19 -bgc 0.4 0.2 0.2 -ann "在Ceres上定位" -label "Ceres" -c "CeresAnBodyfbx";
	rowLayout -adj 1 -p WTAFFMframeLayout3 -nc 2 -columnWidth2 335 30; 
		text -h 20 -w 330 -bgc 0.2 0.1 0.1 -label ("SK_Player_角色名字_Origin_An_01.ma（AN身体MA文件）");
		button -w 30 -h 19 -bgc 0.4 0.2 0.2 -ann "在Ceres上定位" -label "Ceres" -c "CeresAnBodyma";
	text -p WTAFFMframeLayout3 -h 20 -w 375 -bgc 0.1 0.1 0.2 -label ("制作完文件后打开制作路径复制制作文件到对应路径上传");
	//运行按钮
	button -ann "将文件拷贝到文件制作路径" -c "CopyFileToPre" -label "拷贝文件至制作文件夹" -parent WTAFFMframeLayout3;
	rowLayout -adj 1 -p WTAFFMframeLayout3 -nc 3 -columnWidth3 50 50 50;
		button -c "MakeCheckBoxFile" -ann "开始制作勾选需制作的文件" -label "制作勾选文件";
		checkBox -v 1 -label "Facial" -cc "TogetherBodyWithFacial" -ann "制作 Facial 文件" FacialcheckBox;
		checkBox -v 0 -label "BodyWithFacial" -cc "TogetherFacial" -ann "制作 BodyWithFacial 文件" BodyWithFacialcheckBox;
	rowLayout -adj 1 -p WTAFFMframeLayout3 -nc 2 -columnWidth2 50 50;
	button -ann "若出现约束失败修复后点击此按钮约束即可" -c "OnlyRunConstrain" -label "仅执行后续约束";
	button -w 25 -ann "展开约束组" -c "ShowConstrainframeLayout" -label "◆" ShowConstrainframeLayoutbutton;
	frameLayout -vis 0 -ann "展开约束组" -label "展开约束组" -p WTAFFMframeLayout3 OnlyRunConstrainframeLayout;
	//约束组一UI布局
	setParent OnlyRunConstrainframeLayout;
		text " ―――――――――――――    约束组一    ――――――――――――― ";
		scrollLayout -cr 30 -h 115 -w 350 scrollLayout1;
		for ($i = 0; $i < 70; $i++)
			{  
				string $rowLayout = `rowLayout -adj 2 -nc 4 -columnWidth4 55 115 55 110 -parent scrollLayout1`;
			
				text -label ("约束对象：") -parent $rowLayout;
				textField -w 110 -parent $rowLayout ("sourceConstrain1" + $i);
				text -label ("目标对象：") -parent $rowLayout;
				textField -w 110 -parent $rowLayout ("targetConstrain1" + $i);
			}
		//约束组一初始数据输入
		string $jeuseanfbxbone[] = {"Wrist_R","Wrist_L","Ankle_R","Ankle_L","Root_M","Spine1_M","Spine2_M","Chest_M","Neck_M","Neck1_M","Head_M","Hip_R","Knee_R","Ankle_R","Toes_R","Scapula_R","Shoulder_R","Elbow_R","Wrist_R","Hip_L","Knee_L","Ankle_L","Toes_L","Scapula_L","Shoulder_L","Elbow_L","Wrist_L","MiddleFinger1_R","MiddleFinger2_R","MiddleFinger3_R","ThumbFinger1_R","ThumbFinger2_R","ThumbFinger3_R","IndexFinger1_R","IndexFinger2_R","IndexFinger3_R","RingFinger1_R","RingFinger2_R","RingFinger3_R","PinkyFinger1_R","PinkyFinger2_R","PinkyFinger3_R","MiddleFinger1_L","MiddleFinger2_L","MiddleFinger3_L","ThumbFinger1_L","ThumbFinger2_L","ThumbFinger3_L","IndexFinger1_L","IndexFinger2_L","IndexFinger3_L","RingFinger1_L","RingFinger2_L","RingFinger3_L","PinkyFinger1_L","PinkyFinger2_L","PinkyFinger3_L"};
		string $jeuseanmactrl[] = {"IKArm_R","IKArm_L","IKLeg_R","IKLeg_L","RootX_M","FKSpine1_M","FKSpine2_M","FKChest_M","FKNeck_M","FKNeck1_M","FKHead_M","FKHip_R","FKKnee_R","FKAnkle_R","FKToes_R","FKScapula_R","FKShoulder_R","FKElbow_R","FKWrist_R","FKHip_L","FKKnee_L","FKAnkle_L","FKToes_L","FKScapula_L","FKShoulder_L","FKElbow_L","FKWrist_L","FKMiddleFinger1_R","FKMiddleFinger2_R","FKMiddleFinger3_R","FKThumbFinger1_R","FKThumbFinger2_R","FKThumbFinger3_R","FKIndexFinger1_R","FKIndexFinger2_R","FKIndexFinger3_R","FKRingFinger1_R","FKRingFinger2_R","FKRingFinger3_R","FKPinkyFinger1_R","FKPinkyFinger2_R","FKPinkyFinger3_R","FKMiddleFinger1_L","FKMiddleFinger2_L","FKMiddleFinger3_L","FKThumbFinger1_L","FKThumbFinger2_L","FKThumbFinger3_L","FKIndexFinger1_L","FKIndexFinger2_L","FKIndexFinger3_L","FKRingFinger1_L","FKRingFinger2_L","FKRingFinger3_L","FKPinkyFinger1_L","FKPinkyFinger2_L","FKPinkyFinger3_L"};
		for ($a = 0; $a < size($jeuseanfbxbone); $a++)  
			{  
				textField -e -tx $jeuseanfbxbone[$a] ("sourceConstrain1" + $a); 
				textField -e -tx $jeuseanmactrl[$a] ("targetConstrain1" + $a); 
			}
	//约束组二UI布局
	setParent OnlyRunConstrainframeLayout;
		text " ―――――――――――――    约束组二    ――――――――――――― ";
		scrollLayout -cr 30 -h 115 -w 350 scrollLayout2;
		for ($i = 0; $i < 30; $i++)  
			{  
				string $rowLayout = `rowLayout -adj 2 -nc 4 -columnWidth4 55 115 55 110 -parent scrollLayout2`;  
			
				text -label ("约束对象：") -parent $rowLayout;  
				textField -w 110 -parent $rowLayout ("sourceConstrain2" + $i);  
				text -label ("目标对象：") -parent $rowLayout;  
				textField -w 110 -parent $rowLayout ("targetConstrain2" + $i);  
			}
		//约束组二初始数据输入
		string $jeuseanmabone[] = {"UnrealRoot","Root_M","Spine1_M","Spine2_M","Chest_M","Neck_M","Neck1_M","Head_M","Scapula_L","Scapula_R","Shoulder_L","Shoulder_R"};
		string $headmabone[] = {"UnrealRoot","Root_M","Spine1_M","Spine2_M","Chest_M","Neck_M","Neck1_M","Head_M","Scapula_L","Scapula_R","Shoulder_L","Shoulder_R"};
		for ($a = 0; $a < size($jeuseanmabone); $a++)  
			{  
				textField -e -tx $jeuseanmabone[$a] ("sourceConstrain2" + $a); 
				textField -e -tx $headmabone[$a] ("targetConstrain2" + $a); 
			}
	setParent WTAFFMframeLayout3;
		rowLayout -adj 2 -nc 4 -columnWidth4 55 240 30 30;
		text -label ("制作路径：");
		textField -w 240 -tx "" errorlog;
		button -w 30 -h 20 -ann "刷新制作路径" -label "刷新" -c "flush";
		button -w 30 -h 20 -ann "打开制作路径" -label "打开" -c "openfilepath";
		string $Characternum = `textField -q -tx characternum`;
		string $FilePath = "Z:\\WT\\WT_maya\\scenes\\Rig\\Player\\" + $Characternum;
		textField -e -tx $FilePath errorlog; 
	rowLayout -adj 1 -p WTAFFMframeLayout3 -nc 2 -columnWidth2 335 30; 
		button -ann "将勾选文件拷贝到上传路径" -c "CopyFileToSend" -label "拷贝勾选文件至上传目录";
		button -ann "在Ceres上定位FacialAnMa" -label "Ceres" -c "CeresFacialAnMa";
	separator -h 5 -style "none" -p WTAFFMscrollLayout;
showWindow;  
}

	//拷贝勾选文件至上传目录
global proc CopyFileToSend () 
{
	$FacialKey = `checkBox -q -v FacialcheckBox`;
	$BodyWithFacialKey = `checkBox -q -v BodyWithFacialcheckBox`;
	string $WTFileName = `optionVar -q WTFileName`;
	string $Charactername = `textField -q -tx charactername`;
	string $Characternum = `textField -q -tx characternum`;
	string $CeresRigtextField = `textField -q -tx CeresRigtextField`;
	string $FacialSendFilePath = $WTFileName + $CeresRigtextField + "/Origin/An";
	string $BodyWithFacialSendFilePath = "/192.168.20.102/projects/CIDA_RG/临时文件/WT角色身体+表情文件";
	string $SaveFacialAnMa = "Z:/WT/WT_maya/scenes/Rig/Player/" + $Characternum + "/SK_Player_" + $Charactername + "_Origin_Facial_An_01.ma";
	string $SaveBodyWithFacialAnMa = "Z:/WT/WT_maya/scenes/Rig/Player/" + $Characternum + "/SK_Player_" + $Charactername + "_Origin_BodyWithFacial_An_01.ma";
	if ($FacialKey == 1)
	{
		$SaveFacialAnMa = toNativePath($SaveFacialAnMa);
		$FacialSendFilePath = toNativePath($FacialSendFilePath);
		system("copy \"" + $SaveFacialAnMa + "\" \"" + $FacialSendFilePath + "\"");
	}
	if ($BodyWithFacialKey == 1)
	{
		$SaveBodyWithFacialAnMa = toNativePath($SaveBodyWithFacialAnMa);
		$BodyWithFacialSendFilePath = toNativePath($BodyWithFacialSendFilePath);
		system("copy \"" + $SaveBodyWithFacialAnMa + "\" \"" + $BodyWithFacialSendFilePath + "\"");
	}
}

	//展开第三步制作时隐藏约束组
global proc HideConstrainframeLayout () 
{
	frameLayout -e -vis 0 OnlyRunConstrainframeLayout;
	button -e -label "◆" ShowConstrainframeLayoutbutton;
}

	//展开约束组
global proc ShowConstrainframeLayout () 
{
	int $ConstrainHeightGet = `frameLayout -q -vis OnlyRunConstrainframeLayout`;
	if ($ConstrainHeightGet == 0)
	{
		button -e -label "▼" ShowConstrainframeLayoutbutton;
		frameLayout -e -vis 1 OnlyRunConstrainframeLayout;
	}else{
		button -e -label "◆" ShowConstrainframeLayoutbutton;
		frameLayout -e -vis 0 OnlyRunConstrainframeLayout;
	}
}

	//勾选BodyWithFacial时同时勾选Facial
global proc TogetherFacial () 
{
	$BodyWithFacialKey = `checkBox -q -v BodyWithFacialcheckBox`;
	if ($BodyWithFacialKey == 1)
	{
		checkBox -e -v  1 FacialcheckBox;
	}
}

	//取消勾选Facial时同时取消勾选BodyWithFacial
global proc TogetherBodyWithFacial () 
{
	$FacialKey = `checkBox -q -v FacialcheckBox`;
	if ($FacialKey == 0)
	{
		checkBox -e -v  0 BodyWithFacialcheckBox;
	}
}

//制作PV的Facial文件（fbx）
	//制作文件
global proc PVFacialMake () 
{
	string $WTFileName = `optionVar -q WTFileName`;
	string $Charactername = `textField -q -tx charactername`;
	string $CeresRigtextField = `textField -q -tx CeresRigtextField`;
	string $PVFacialField = $WTFileName + $CeresRigtextField + "/Origin/PV/SK_Player_" + $Charactername + "_Origin_Facial_PV_01.ma";
	string $PVFacialOldField = $WTFileName + $CeresRigtextField + "/Origin/PV/SK_Player_" + $Charactername + "_White_Origin_Facial_PV_01.ma";
	int $existsPVFacialField = `file -exists -q $PVFacialField`;
	if (!$existsPVFacialField) {
		$PVFacialField = $PVFacialOldField;
	}
	string $PVFacialFbxField = $WTFileName + $CeresRigtextField + "/Origin/PV/SK_Player_" + $Charactername + "_Origin_Facial_PV_01.fbx";
	if ($Charactername == "")
	{
		error ("请载入角色数据！\n");
	}else
	{
		file -f -new;
		//设置场景Z轴朝上
		upAxis -ax z -rv;
		file -f -open -options "v=0;" $PVFacialField;
		delete ($Charactername + "_LOD");
		//不烘焙动画
		FBXExportAnimationOnly -v false;
		//导出Z轴向上
		FBXExportUpAxis z;
		FBXExport -f $PVFacialFbxField;
		print ($PVFacialFbxField + "已制作完成！\n");
	}
}

	//检查文件
global proc PVFacialCheck () 
{
	string $WTFileName = `optionVar -q WTFileName`;
	string $Charactername = `textField -q -tx charactername`;
	string $CeresRigtextField = `textField -q -tx CeresRigtextField`;
	string $PVFacialFbxField = $WTFileName + $CeresRigtextField + "/Origin/PV/SK_Player_" + $Charactername + "_Origin_Facial_PV_01.fbx";
	if ($Charactername == "")
	{
		error ("请载入角色数据！\n");
	}else
	{
		if (`file -exists -q $PVFacialFbxField` == 0)
		{
			error ("请先制作文件！\n");
		}else
		{
			file -f -new;
			//设置场景Y轴朝上
			upAxis -ax y -rv;
			file -f -import -f -options "v=0" $PVFacialFbxField;
			//居中场景
			viewSet -animate 0 -home;
			viewFit -animate 0 -all;
			print ("已成功导入：" + $PVFacialFbxField + "\n");
		}
	}
}

	//ceres定位
global proc PVFacialCeres () 
{
	string $Charactername = `textField -q -tx charactername`;
	string $CeresRigtextField = `textField -q -tx CeresRigtextField`;
	string $PVFacialFbxField = $CeresRigtextField + "/Origin/PV/SK_Player_" + $Charactername + "_Origin_Facial_PV_01.fbx";
	if ($Charactername == "")
	{
		error ("请载入角色数据！\n");
	}else
	{
		textField -e -tx $PVFacialFbxField quickopenFilePath;
		textField -e -tx "WT" ProjectTextField;
		optionVar -sv NowProject (`optionVar -q WTFileName`);
		changetoCeres ();
		print ("开始定位！\n");
	}
}

//制作Game的Facial文件（fbx）
	//制作文件
global proc GameFacialMake () 
{
	string $WTFileName = `optionVar -q WTFileName`;
	string $Charactername = `textField -q -tx charactername`;
	string $CeresRigtextField = `textField -q -tx CeresRigtextField`;
	string $PVFacialField = $WTFileName + $CeresRigtextField + "/Origin/PV/SK_Player_" + $Charactername + "_Origin_Facial_PV_01.ma";
	string $PVFacialOldField = $WTFileName + $CeresRigtextField + "/Origin/PV/SK_Player_" + $Charactername + "_White_Origin_Facial_PV_01.ma";
	int $existsPVFacialField = `file -exists -q $PVFacialField`;
	if (!$existsPVFacialField) {
		$PVFacialField = $PVFacialOldField;
	}
	string $GameFacialFbxField = $WTFileName + $CeresRigtextField + "/Origin/Game/SK_Player_" + $Charactername + "_Origin_Facial_Lod_01.fbx";
	if ($Charactername == "")
	{
		error ("请载入角色数据！\n");
	}else
	{
		file -f -new;
		//设置场景Z轴朝上
		upAxis -ax z -rv;
