global proc convertSoftSelectionToCluster()
{
   float $startTime = `timerX`;

   string $selectedItems[] = `ls -sl -fl`;
   
   if (size($selectedItems) == 0) {
       warning -n "Г»УРСЎФсИОєО¶ФПу»тЧйјю";
        inViewMessage
            -a .9
            -smg ("<font color=\"orange\">Г»УРСЎФсИОєО¶ФПу»тЧйјю ")
            -pos "topCenter"
            -bkc 0x00001100
            -fade
            -fadeInTime 100 -fadeStayTime 2200
            -fadeOutTime 600;
       return;
   }
   
   string $selectedObjects[] = {};
   int $objIndex = 0;
   
   for ($item in $selectedItems) {
       if (`gmatch $item "*.*"`) {
           int $dotPos = `match "\\." $item`;
           if ($dotPos > 0) {
               string $objName = `substring $item 1 $dotPos`;
               
               int $exists = 0;
               for ($i = 0; $i < size($selectedObjects); $i++) {
                   if ($selectedObjects[$i] == $objName) {
                       $exists = 1;
                       break;
                   }
               }
               
               if (!$exists) {
                   $selectedObjects[$objIndex] = $objName;
                   $objIndex++;
               }
           }
       } else {
           int $exists = 0;
           for ($i = 0; $i < size($selectedObjects); $i++) {
               if ($selectedObjects[$i] == $item) {
                   $exists = 1;
                   break;
               }
           }
           
           if (!$exists) {
               $selectedObjects[$objIndex] = $item;
               $objIndex++;
           }
       }
   }
   
   string $unsupportedObjects = "";
   int $hasUnsupported = 0;
   
   for ($obj in $selectedObjects) {
       string $objType = `objectType $obj`;
       
       if ($objType == "transform") {
           string $shapes[] = `listRelatives -s -path $obj`;
           
           if (size($shapes) == 0) {
               $unsupportedObjects += $obj + " ";
               $hasUnsupported = 1;
               continue;
           }
           
           int $hasSupportedShape = 0;
           for ($shape in $shapes) {
               string $shapeType = `objectType $shape`;
               
               if ($shapeType == "mesh" || 
                   $shapeType == "nurbsCurve" || 
                   $shapeType == "nurbsSurface" || 
                   $shapeType == "lattice") {
                   $hasSupportedShape = 1;
                   break;
               }
           }
           
           if (!$hasSupportedShape) {
               $unsupportedObjects += $obj + " ";
               $hasUnsupported = 1;
           }
       } else if ($objType == "mesh" || 
                  $objType == "nurbsCurve" || 
                  $objType == "nurbsSurface" || 
                  $objType == "lattice") {
           continue;
       } else {
           $unsupportedObjects += $obj + " ";
           $hasUnsupported = 1;
       }
   }
   
   if ($hasUnsupported) {
       warning -n ("ТФПВ¶ФПуІ»КЬЦ§іЦ: " + $unsupportedObjects + "\nЗлСЎФс¶а±ЯРОНшёсЎўNURBSЗъПЯЎўNURBSЗъГж»тѕ§ёсЎЈ");
        inViewMessage
            -a .9
            -smg ("<font color=\"orange\">ТФПВ¶ФПуІ»КЬЦ§іЦ: <font color=\"yellow\">" + $unsupportedObjects + "\n<font color=\"orange\">ЗлСЎФс¶а±ЯРОНшёсЎўNURBSЗъПЯЎўNURBSЗъГж»тѕ§ёсЎЈ")
            -pos "topCenter"
            -bkc 0x00001100
            -fade
            -fadeInTime 100 -fadeStayTime 2200
            -fadeOutTime 600;
       return;
   }
   
   int $hasComponentSelection = 0;
   for ($item in $selectedItems) {
       if (`gmatch $item "*.*"`) {
           $hasComponentSelection = 1;
           break;
       }
   }
   
   if (!$hasComponentSelection && size($selectedObjects) > 0) {
       string $obj = $selectedObjects[0];
       
       string $shapes[] = `listRelatives -s -path $obj`;
       
       if (size($shapes) == 0) {
           warning -n "ОЮ·Ё»сИЎ¶ФПуµДРОЧґЅЪµг";
            inViewMessage
                -a .9
                -smg ("<font color=\"orange\">ОЮ·Ё»сИЎ¶ФПуµДРОЧґЅЪµг ")
                -pos "topCenter"
                -bkc 0x00001100
                -fade
                -fadeInTime 100 -fadeStayTime 2200
                -fadeOutTime 600;
           return;
       }
       
       int $hasSupportedShape = 0;
       string $supportedShape = "";
       string $shapeType = "";
       
       for ($shape in $shapes) {
           $shapeType = `objectType $shape`;
           
           if ($shapeType == "mesh" || 
               $shapeType == "nurbsCurve" || 
               $shapeType == "nurbsSurface" || 
               $shapeType == "lattice") {
               $hasSupportedShape = 1;
               $supportedShape = $shape;
               break;
           }
       }
       
       if (!$hasSupportedShape) {
           warning -n ("ТФПВ¶ФПуІ»КЬЦ§іЦ: " + $obj + "\nЗлСЎФс¶а±ЯРОНшёсЎўNURBSЗъПЯЎўNURBSЗъГж»тѕ§ёсЎЈ");
            inViewMessage
                -a .9
                -smg ("<font color=\"orange\">ТФПВ¶ФПуІ»КЬЦ§іЦ: <font color=\"yellow\">" + $obj + "<font color=\"orange\">\nЗлСЎФс¶а±ЯРОНшёсЎўNURBSЗъПЯЎўNURBSЗъГж»тѕ§ёсЎЈ ")
                -pos "topCenter"
                -bkc 0x00001100
                -fade
                -fadeInTime 100 -fadeStayTime 2200
                -fadeOutTime 600;
           return;
       }
       
       string $allPoints[];
       int $pointCount = 0;
       
       if ($shapeType == "mesh") {
           int $countArray[] = `polyEvaluate -v $obj`;
           $pointCount = $countArray[0];
           for ($i = 0; $i < $pointCount; $i++) {
               $allPoints[$i] = $obj + ".vtx[" + $i + "]";
           }
       } else if ($shapeType == "nurbsCurve") {
           $pointCount = `getAttr ($supportedShape + ".spans")` + `getAttr ($supportedShape + ".degree")`;
           for ($i = 0; $i < $pointCount; $i++) {
               $allPoints[$i] = $obj + ".cv[" + $i + "]";
           }
       } else if ($shapeType == "nurbsSurface") {
           int $uCount = `getAttr ($supportedShape + ".spansU")` + `getAttr ($supportedShape + ".degreeU")`;
           int $vCount = `getAttr ($supportedShape + ".spansV")` + `getAttr ($supportedShape + ".degreeV")`;
           $pointCount = $uCount * $vCount;
           for ($i = 0; $i < $pointCount; $i++) {
               int $uIndex = $i % $uCount;
               int $vIndex = (int)($i / $uCount);
               $allPoints[$i] = $obj + ".cv[" + $uIndex + "][" + $vIndex + "]";
           }
       } else if ($shapeType == "lattice") {
           int $uCount = `getAttr ($supportedShape + ".sDivisions")`;
           int $vCount = `getAttr ($supportedShape + ".tDivisions")`;
           int $wCount = `getAttr ($supportedShape + ".uDivisions")`;
           $pointCount = $uCount * $vCount * $wCount;
           for ($i = 0; $i < $pointCount; $i++) {
               int $divisionsUV = $uCount * $vCount;
               int $wIndex = (int)($i / $divisionsUV);
               int $remainder = $i % $divisionsUV;
               int $vIndex = (int)($remainder / $uCount);
               int $uIndex = $remainder % $uCount;
               $allPoints[$i] = $obj + ".pt[" + $uIndex + "][" + $vIndex + "][" + $wIndex + "]";
           }
       }
       
       progressWindow -title "ґґЅЁґШ" -status "<font color='white'><b>»сИЎЛщУРµг..." -progress 0 -maxValue 100 -isInterruptable true;
       
       if ($pointCount > 0) {
           for ($i = 0; $i < $pointCount; $i++) {
               if (`progressWindow -query -isCancelled`) {
                   progressWindow -endProgress;
                   warning -n "ІЩЧчТСИЎПы";
                   inViewMessage
                   -a .9
                   -smg ("<font color=\"orange\">ІЩЧчТСИЎПы ")
                   -pos "topCenter"
                   -bkc 0x00001100
                   -fade
                   -fadeInTime 100 -fadeStayTime 2200
                   -fadeOutTime 600;
                   return;
               }
               int $currentProgress = 30.0 * ($i + 1) / $pointCount;
               progressWindow -edit -progress $currentProgress -status ("<font color='white'><b>»сИЎµг: <font color='yellow'>" + ($i + 1) + "<font color='white'> / <font color='limegreen'>" + $pointCount);
           }
       }
       
       progressWindow -edit -progress 30 -status "<font color='white'><b>µг»сИЎНкіЙ";
       
       select -r $allPoints;
       
       float $centerPos[] = `xform -q -ws -rp $obj`;
       
       string $clusterHandle[] = `cluster -rel -en 1`;
       
       move $centerPos[0] $centerPos[1] $centerPos[2] 
            ($clusterHandle[1] + ".scalePivot") ($clusterHandle[1] + ".rotatePivot");
       
       setAttr ($clusterHandle[1] + "Shape.origin") $centerPos[0] $centerPos[1] $centerPos[2];
       
       progressWindow -edit -progress 60 -status "<font color='white'><b>·ЦЕдИЁЦШ...";
       
       for ($i = 0; $i < $pointCount; $i++) {
           if (`progressWindow -query -isCancelled`) {
               progressWindow -endProgress;
               warning -n "ІЩЧчТСИЎПы";
                   inViewMessage
                   -a .9
                   -smg ("<font color=\"orange\">ІЩЧчТСИЎПы ")
                   -pos "topCenter"
                   -bkc 0x00001100
                   -fade
                   -fadeInTime 100 -fadeStayTime 2200
                   -fadeOutTime 600;
               return;
           }
           
           percent -v 1.0 $clusterHandle[0] $allPoints[$i];
           
           int $currentProgress = 60 + int(40.0 * ($i + 1) / $pointCount);
           progressWindow -edit -progress $currentProgress -status ("<font color='white'><b>·ЦЕдИЁЦШ: <font color='yellow'>" + ($i + 1) + "<font color='white'> / <font color='limegreen'>" + $pointCount);
       }
       
       progressWindow -endProgress;
       
       select -r $clusterHandle[1];
       
       float $endTime = `timerX`;
       float $duration = $endTime - $startTime;
       //print ("ТСОЄОпМе " + $obj + " ґґЅЁґШЈ¬°ьє¬ " + $pointCount + " ёцµгЈ¬єДК±: " + $duration + " Гл");
        inViewMessage
            -a .9
            -smg ("<font color=\"limegreen\">ТСОЄОпМе <font color=\"yellow\">" + $obj + "<font color=\"limegreen\"> ґґЅЁґШЈ¬°ьє¬ <font color=\"yellow\">" + $pointCount + "<font color=\"limegreen\"> ёцµгЈ¬єДК±: <font color=\"orange\">" + $duration + "<font\> Гл")
            -pos "topCenter"
            -bkc 0x00001100
            -fade
            -fadeInTime 100 -fadeStayTime 2200
            -fadeOutTime 600;
       return;
   }
   
   if (!`softSelect -q -softSelectEnabled`) {
       confirmDialog -title "ѕЇёж" -message "<font color=white><h2><b>ЗлПИЖфУГИнСЎФсЈЁ°ґBјьЈ©ІўСЎФсТ»Р©µг" 
                     -button "И·¶Ё" -defaultButton "И·¶Ё";
       return;
   }
   
   $selectedItems = `ls -sl -fl`;
   if (size($selectedItems) > 0) {
       int $hasNonVertex = 0;
       for ($sel in $selectedItems) {
           if (`gmatch $sel "*.*"`) {
               if (!`gmatch $sel "*.vtx[*"` && 
                   !`gmatch $sel "*.cv[*"` && 
                   !`gmatch $sel "*.pt[*"` &&
                   !`gmatch $sel "*.ep[*"` &&  
                   !`gmatch $sel "*.uv[*"`) {  
                   $hasNonVertex = 1;
                   break;
               }
           }
       }
       
       if ($hasNonVertex) {
           ConvertSelectionToVertices;
       }
   }
   
   string $selectedPoints[] = `ls -sl -fl`;
   if (size($selectedPoints) == 0) {
       warning -n "ЗлСЎФсТ»Р©µгЈЁ¶ҐµгЎўCVµг»тѕ§ёсµгЈ©";
                   inViewMessage
                   -a .9
                   -smg ("<font color=\"orange\">ЗлСЎФсТ»Р©µгЈЁ¶ҐµгЎўCVµг»тѕ§ёсµгЈ© ")
                   -pos "topCenter"
                   -bkc 0x00001100
                   -fade
                   -fadeInTime 100 -fadeStayTime 2200
                   -fadeOutTime 600;
       return;
   }
   
   float $selectedVertexPos[] = `pointPosition -w $selectedPoints[0]`;
   string $shapeNodes[] = `listRelatives -p $selectedPoints[0]`;
   if (size($shapeNodes) == 0) {
       warning -n "ОЮ·Ё»сИЎРОЧґЅЪµг";
                   inViewMessage
                   -a .9
                   -smg ("<font color=\"orange\">ОЮ·Ё»сИЎРОЧґЅЪµг ")
                   -pos "topCenter"
                   -bkc 0x00001100
                   -fade
                   -fadeInTime 100 -fadeStayTime 2200
                   -fadeOutTime 600;
       return;
   }
   
   string $transformNodes[] = `listRelatives -p $shapeNodes[0]`;
   if (size($transformNodes) == 0) {
       warning -n "ОЮ·Ё»сИЎ±д»»ЅЪµг";
                   inViewMessage
                   -a .9
                   -smg ("<font color=\"orange\">ОЮ·Ё»сИЎ±д»»ЅЪµг ")
                   -pos "topCenter"
                   -bkc 0x00001100
                   -fade
                   -fadeInTime 100 -fadeStayTime 2200
                   -fadeOutTime 600;
       return;
   }
   
   string $object = $transformNodes[0];
   string $shape = $shapeNodes[0];
   
   string $objectType = `objectType $shape`;
   string $pointType = "";
   string $pointPrefix = "";
   int $pointCount = 0;
   int $uCount = 0, $vCount = 0, $wCount = 0;
   
   if ($objectType == "mesh") {
       $pointType = "vtx";
       $pointPrefix = ".vtx[";
       int $countArray[] = `polyEvaluate -v $object`;
       $pointCount = $countArray[0];
   }
   else if ($objectType == "nurbsCurve") {
       $pointType = "cv";
       $pointPrefix = ".cv[";
       $pointCount = `getAttr ($shape + ".spans")` + `getAttr ($shape + ".degree")`;
   }
   else if ($objectType == "nurbsSurface") {
       $pointType = "cv";
       $pointPrefix = ".cv[";
       $uCount = `getAttr ($shape + ".spansU")` + `getAttr ($shape + ".degreeU")`;
       $vCount = `getAttr ($shape + ".spansV")` + `getAttr ($shape + ".degreeV")`;
       $pointCount = $uCount * $vCount;
   }
   else if ($objectType == "lattice") {
       $pointType = "pt";
       $pointPrefix = ".pt[";
       $uCount = `getAttr ($shape + ".sDivisions")`;
       $vCount = `getAttr ($shape + ".tDivisions")`;
       $wCount = `getAttr ($shape + ".uDivisions")`;
       $pointCount = $uCount * $vCount * $wCount;
   }
   else {
       warning -n ("І»Ц§іЦµД¶ФПуАаРН: " + $objectType);
                   inViewMessage
                   -a .9
                   -smg ("<font color=\"orange\">І»Ц§іЦµД¶ФПуАаРН: <font color=\"yellow\">" + $objectType)
                   -pos "topCenter"
                   -bkc 0x00001100
                   -fade
                   -fadeInTime 100 -fadeStayTime 2200
                   -fadeOutTime 600;
       return;
   }

   progressWindow -title "ґґЅЁґШ" -status "<font color='white'><b>»сИЎЛщУРµг..." -progress 0 -maxValue 100 -isInterruptable true;
   
   float $originalPositionsX[];
   float $originalPositionsY[];
   float $originalPositionsZ[];
   
   string $allPointNames[] = {};
   
   int $uIndices[];
   int $vIndices[];
   
   for ($i = 0; $i < $pointCount; $i++)
   {
        if (`progressWindow -query -isCancelled`) {
            progressWindow -endProgress;
            warning -n "ІЩЧчТСИЎПы";
                   inViewMessage
                   -a .9
                   -smg ("<font color=\"orange\">ІЩЧчТСИЎПы ")
                   -pos "topCenter"
                   -bkc 0x00001100
                   -fade
                   -fadeInTime 100 -fadeStayTime 2200
                   -fadeOutTime 600;
            return;
        }
        
        string $pointName = "";
        int $uIndex, $vIndex, $wIndex;
        
        if ($objectType == "nurbsSurface") {
            $uIndex = $i % $uCount;
            $vIndex = (int)($i / $uCount);
            $pointName = $object + ".cv[" + $uIndex + "][" + $vIndex + "]";
            $uIndices[$i] = $uIndex;
            $vIndices[$i] = $vIndex;
        }
        else if ($objectType == "lattice") {
            int $divisionsUV = $uCount * $vCount;
            $wIndex = (int)($i / $divisionsUV);
            int $remainder = $i % $divisionsUV;
            $vIndex = (int)($remainder / $uCount);
            $uIndex = $remainder % $uCount;
            $pointName = $object + ".pt[" + $uIndex + "][" + $vIndex + "][" + $wIndex + "]";
        }
        else {
            $pointName = $object + $pointPrefix + $i + "]";
        }
        
        $allPointNames[$i] = $pointName;
        
        float $pos[] = `pointPosition -w $pointName`;
        if (size($pos) >= 3) {
            $originalPositionsX[$i] = $pos[0];
            $originalPositionsY[$i] = $pos[1];
            $originalPositionsZ[$i] = $pos[2];
        }
        
        int $currentProgress = int(30.0 * ($i + 1) / $pointCount);
        progressWindow -edit -progress $currentProgress -status ("<font color='white'><b>»сИЎµг: <font color='yellow'>" + ($i + 1) + "<font color='white'> / <font color='limegreen'>" + $pointCount);
   }
   
   progressWindow -edit -progress 30 -status "<font color='white'><b>µг»сИЎНкіЙЈ¬Чј±ёјЖЛгИЁЦШ...";
   
   string $backupSelection[] = `ls -sl`;
   
   select -r $selectedPoints[0];
   move -r 1 0 0;
   
   float $movedPositionsX[];
   float $movedPositionsY[];
   float $movedPositionsZ[];
   
   progressWindow -edit -progress 30 -status "<font color='white'><b>јЖЛгµгИЁЦШ...";
   
   for ($i = 0; $i < $pointCount; $i++)
   {
        if (`progressWindow -query -isCancelled`) {
            move -r -1 0 0;
            select -r $backupSelection;
            progressWindow -endProgress;
            warning -n "ІЩЧчТСИЎПы";
                   inViewMessage
                   -a .9
                   -smg ("<font color=\"orange\">ІЩЧчТСИЎПы ")
                   -pos "topCenter"
                   -bkc 0x00001100
                   -fade
                   -fadeInTime 100 -fadeStayTime 2200
                   -fadeOutTime 600;
            return;
        }
        
        string $pointName = $allPointNames[$i];
        
        float $pos[] = `pointPosition -w $pointName`;
        if (size($pos) >= 3) {
            $movedPositionsX[$i] = $pos[0];
            $movedPositionsY[$i] = $pos[1];
            $movedPositionsZ[$i] = $pos[2];
        }
        
        int $currentProgress = 30 + int(30.0 * ($i + 1) / $pointCount);
        progressWindow -edit -progress $currentProgress -status ("<font color='white'><b>јЖЛгИЁЦШ: <font color='yellow'>" + ($i + 1) + "<font color='white'> / <font color='limegreen'>" + $pointCount);
   }
   
   move -r -1 0 0;
   
   select -r $backupSelection;
   
   float $weights[];
   string $affectedPoints[] = {};
   int $affectedCount = 0;
   
   int $selectedUIndex = -1;
   int $selectedVIndex = -1;
   
   if ($objectType == "nurbsSurface") {
       for ($i = 0; $i < $pointCount; $i++) {
           if ($allPointNames[$i] == $selectedPoints[0]) {
               $selectedUIndex = $uIndices[$i];
               $selectedVIndex = $vIndices[$i];
               break;
           }
       }
   }
   
   for ($i = 0; $i < $pointCount; $i++)
   {
        float $displacementX = $movedPositionsX[$i] - $originalPositionsX[$i];
        float $weight = abs($displacementX); 
        
        if ($objectType == "nurbsSurface" && $selectedUIndex >= 0 && $selectedVIndex >= 0) {
            float $uDist = abs($uIndices[$i] - $selectedUIndex) / (float)$uCount;
            float $vDist = abs($vIndices[$i] - $selectedVIndex) / (float)$vCount;
            float $uvDist = sqrt($uDist * $uDist + $vDist * $vDist);
            
            float $softSelectRadius = `softSelect -q -softSelectDistance`;
            float $softSelectFalloff = `softSelect -q -softSelectFalloff`;
            
            if ($softSelectRadius > 0) {
                float $normalizedUVDist = $uvDist;
                if ($normalizedUVDist > 1) {
                    $normalizedUVDist = 1;
                }
                
                if ($normalizedUVDist < 1) {
                    float $uvWeight = 1.0 - $normalizedUVDist;
                    
                    if ($softSelectFalloff > 0) {
                        $uvWeight = pow($uvWeight, $softSelectFalloff);
                    }
                    
                    $weight = $weight * $uvWeight;
                }
            }
        }
        
        $weights[$i] = $weight;
        
        if ($weight > 0.0001) {
            $affectedPoints[$affectedCount] = $allPointNames[$i];
            $affectedCount++;
        }
   }
   
   if ($affectedCount == 0) {
       for ($i = 0; $i < size($selectedPoints); $i++) {
           for ($j = 0; $j < $pointCount; $j++) {
               if ($allPointNames[$j] == $selectedPoints[$i]) {
                   $weights[$j] = 1.0; 
                   $affectedPoints[$affectedCount] = $allPointNames[$j];
                   $affectedCount++;
                   break;
               }
           }
       }
       
       if ($affectedCount == 0) {
           progressWindow -endProgress;
           warning -n "Г»УРХТµЅКЬИнСЎФсУ°ПмµДµгЈ¬ЗлИ·±ЈИнСЎФс°лѕ¶Чг№»ґу";
                   inViewMessage
                   -a .9
                   -smg ("<font color=\"orange\">Г»УРХТµЅКЬИнСЎФсУ°ПмµДµгЈ¬ЗлИ·±ЈИнСЎФс°лѕ¶Чг№»ґу ")
                   -pos "topCenter"
                   -bkc 0x00001100
                   -fade
                   -fadeInTime 100 -fadeStayTime 2200
                   -fadeOutTime 600;
           return;
       }
   }
   
   if ($objectType == "nurbsSurface") {
       for ($i = 0; $i < $affectedCount; $i++) {
           string $currentPoint = $affectedPoints[$i];
           
           int $weightIndex = -1;
           for ($j = 0; $j < $pointCount; $j++) {
               if ($allPointNames[$j] == $currentPoint) {
                   $weightIndex = $j;
                   break;
               }
           }
           
           if ($weightIndex >= 0) {
               float $dx = $movedPositionsX[$weightIndex] - $originalPositionsX[$weightIndex];
               float $dy = $movedPositionsY[$weightIndex] - $originalPositionsY[$weightIndex];
               float $dz = $movedPositionsZ[$weightIndex] - $originalPositionsZ[$weightIndex];
               float $displacementLength = sqrt($dx*$dx + $dy*$dy + $dz*$dz);
               
               $weights[$weightIndex] = $displacementLength;
           }
       }
   }

   select -r $affectedPoints;
   
   string $clusterHandle[] = `cluster -rel -en 1`;
   
   move $selectedVertexPos[0] $selectedVertexPos[1] $selectedVertexPos[2] 
        ($clusterHandle[1] + ".scalePivot") ($clusterHandle[1] + ".rotatePivot");
   
   setAttr ($clusterHandle[1] + "Shape.origin") $selectedVertexPos[0] $selectedVertexPos[1] $selectedVertexPos[2];
   
   progressWindow -edit -progress 60 -status "<font color='white'><b>·ЦЕдИЁЦШ...";
   
   for ($i = 0; $i < $affectedCount; $i++)
   {
        if (`progressWindow -query -isCancelled`) {
            progressWindow -endProgress;
            warning -n "ІЩЧчТСИЎПы";
                   inViewMessage
                   -a .9
                   -smg ("<font color=\"orange\">ІЩЧчТСИЎПы ")
                   -pos "topCenter"
                   -bkc 0x00001100
                   -fade
                   -fadeInTime 100 -fadeStayTime 2200
                   -fadeOutTime 600;
            return;
        }
        
        string $currentPoint = $affectedPoints[$i];
        
        int $weightIndex = -1;
        for ($j = 0; $j < $pointCount; $j++) {
            if ($allPointNames[$j] == $currentPoint) {
                $weightIndex = $j;
                break;
            }
        }
        
        if ($weightIndex >= 0 && $weights[$weightIndex] > 0.0001) {
            percent -v $weights[$weightIndex] $clusterHandle[0] $currentPoint;
        }
        
        int $currentProgress = 60 + int(40.0 * ($i + 1) / $affectedCount);
        progressWindow -edit -progress $currentProgress -status ("<font color='white'><b>·ЦЕдИЁЦШ: <font color='yellow'>" + ($i + 1) + "<font color='white'> / <font color='limegreen'>" + $affectedCount );
   }
   
   progressWindow -endProgress;
   
   select -r $clusterHandle[1];

   float $endTime = `timerX`;
   float $duration = $endTime - $startTime;
   //print ("ТСґґЅЁґШЈ¬°ьє¬ " + $affectedCount + " ёцКЬУ°ПмµгЈ¬єДК±: " + $duration + " Гл");
    inViewMessage
        -a .9
        -smg ("<font color=\"limegreen\">ТСґґЅЁґШЈ¬°ьє¬ <font color=\"yellow\">" + $affectedCount + "<font color=\"limegreen\"> ёцКЬУ°ПмµгЈ¬єДК±: <font color=\"orange\">" + $duration + "<font\> Гл")
        -pos "topCenter"
        -bkc 0x00001100
        -fade
        -fadeInTime 100 -fadeStayTime 2200
        -fadeOutTime 600;
}

