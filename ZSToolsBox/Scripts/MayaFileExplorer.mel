//ЩОГ§бЁжаЮФМў
global proc MFBdeleteSelected ( int $List )
{
	if ($List == 1)
	{
		// Statements;
	}else
	{
		string $Path = `text -q -label MFBShowPathtext`;
		if (`filetest -d $Path`)
        {
            // ЩОГ§ЮФМўМаМАЦфЫљгаФкШн
			$Path = toNativePath($Path);
            string $command = "rmdir /s /q \"" + $Path + "\"";
			system($command);
        }
        else
        {
            // ЩОГ§ЮФМў
			$Path = toNativePath($Path);
            string $command = "del /f /q \"" + $Path + "\"";
			system($command);
        }
	}
}

