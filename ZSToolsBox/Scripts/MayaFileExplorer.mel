//дкЮФМўзЪдДЙмРэЦїжаДђПЊЮФМўМа
global proc MFBopenFolder ( int $List )
{
	if ($List == 1)
	{
		// Statements;
	}else
	{
		string $Path = toNativePath(`text -q -label MFBShowPathtext`);
		if ($Path == "ЕчФдДХХЬ")
		{
			string $command = "explorer shell:MyComputerFolder";
			system($command);
		}else
		{
			string $command = "explorer \"" + $Path + "\"";
			system($command);
		}
	}
}

