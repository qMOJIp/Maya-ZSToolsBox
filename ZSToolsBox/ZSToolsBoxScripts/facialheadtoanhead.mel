PV_Chin11","FACIAL_R_12IPV_Chin11","FACIAL_L_12IPV_Chin12","FACIAL_R_12IPV_Chin12","FACIAL_L_12IPV_Chin13","FACIAL_R_12IPV_Chin13","FACIAL_L_12IPV_Chin14","FACIAL_R_12IPV_Chin14","FACIAL_C_Chin"
	};
	for ($i = 0;$i <size($seletion);$i++){
		print ("\n\n当前转移模型：" + $seletion[$i] + "\n");
		//添加缺失影响物
		select -r $seletion[$i];
		select -add $KeepBone;
		skinClusterInfluence 1 "-ug -dr 4 -ps 0 -ns 10 -lw true -wt 0";
		//开始转移权重
		select -r $seletion[$i];
		WeightTransform ( $NeckChildBones , "Neck_M" , $seletion[$i] );
		print ("Neck_M骨骼转移完成\n");
		WeightTransform ( $Neck1ChildBones , "Neck1_M" , $seletion[$i] );
		print ("Neck1_M骨骼转移完成\n");
		WeightTransform ( $HeadChildBones , "Head_M" , $seletion[$i] );
		print ("Head_M骨骼转移完成\n");
		//返回位移编辑防止权重编辑下删除模型导致卡死
		TranslateToolWithSnapMarkingMenu;
		//移除未影响权重
		select -r $seletion[$i];
		removeUnusedInfluences;
	}
}

global proc AutoSelectHead () 
{
	string $SelectMesh[] = `ls -g -ni "*Head*"`;
	$SelectMesh = `listRelatives -p $SelectMesh`;
	select -r $SelectMesh;
	$SelectMesh = `ls -g -ni "*H?01*"`;
	$SelectMesh = `listRelatives -p $SelectMesh`;
	select -add $SelectMesh;
}

global proc ANFacialBoneTransformHeadForLod () 
{
	string $seletion[] = `ls -sl`;
	string $KeepBone[] = {
		"Shoulder_R","Scapula_R","Shoulder_L","Scapula_L","Chest_M","Neck_M","Neck1_M","Head_M","FACIAL_C_AdamsApple"
	};
	string $NeckChildBones[] = {
		"FACIAL_C_Neck1Root","FACIAL_C_NeckB","FACIAL_L_NeckB1","FACIAL_R_NeckB1","FACIAL_L_NeckB2","FACIAL_R_NeckB2","FACIAL_C_12IPV_NeckB1","FACIAL_C_12IPV_NeckB2","FACIAL_L_12IPV_NeckB3","FACIAL_R_12IPV_NeckB3","FACIAL_L_12IPV_NeckB4","FACIAL_R_12IPV_NeckB4","FACIAL_L_12IPV_NeckB5","FACIAL_R_12IPV_NeckB5","FACIAL_L_12IPV_NeckB6","FACIAL_R_12IPV_NeckB6","FACIAL_L_12IPV_NeckB7","FACIAL_R_12IPV_NeckB7","FACIAL_C_NeckBackB","FACIAL_L_NeckBackB","FACIAL_R_NeckBackB","FACIAL_C_12IPV_NeckBackB1","FACIAL_C_12IPV_NeckBackB2","FACIAL_L_12IPV_NeckBackB1","FACIAL_R_12IPV_NeckBackB1","FACIAL_L_12IPV_NeckBackB2","FACIAL_R_12IPV_NeckBackB2"
