/*通过循环边修正轴
用法，选择三个以上的点，或者选择循环边运行（选点时候三个点尽量离得远）*/
/*用法，选择三个以上的点，或者选择循环边运行（选点时候三个点尽量离得远）*/
global proc XunHuanBianXZ() {
	string $sel[] = `ls -selection -fl`;
	ConvertSelectionToVertices;
	string $selponit[] = `ls -selection -fl`;
	int $del_loc = `checkBox -q -value del_loc_checkBox`;//是否删除辅助定位器
	int $obj_pp_loc = `checkBox -q -value obj_pp_loc_checkBox`;//是否将模型坐标匹配到loc
	if(size($selponit)<3){
		select -r $sel;
		ZhouToSclPoint;
	}else{
		// 声明一个字符串数组用来存储分割结果
		string $sel_obj_name[];
		// 使用 tokenize 命令按 "." 分割字符串
		tokenize($sel[0], ".", $sel_obj_name);
		///计算循环边的中心轴///
		float $central[] = GetCentralSelComp();
		string $zj_loc_name[] = `spaceLocator -p 0 0 0`;//创建定位器
		move -r $central[0] $central[1] $central[2] $zj_loc_name[0];
		//找出三个点组成的三角形面积最大的点
		select -r $selponit;
		string $selection[] = `ls -selection -fl`;//转换选择为点
		string $point_out_nam[] = TriangularAreaPoint($selection);
		print($point_out_nam);
		//获取三角形三个点的坐标
		vector $world_PosA = `pointPosition -w $point_out_nam[0]`;
		vector $world_PosB = `pointPosition -w $point_out_nam[1]`;
		vector $world_PosC = `pointPosition -w $point_out_nam[2]`;
		vector $normal = calculateNormal($world_PosA, $world_PosB, $world_PosC);//计算三角形法线
		print ($normal + "\n");
		vector $loc_pos=`pointPosition -w $zj_loc_name[0]`;//获取loc的pos
		vector $targetA = $normal+$loc_pos;//将法线坐标偏移到loc
	
		////将loc定位器旋转匹配到法线方向
		vector $target = $targetA; // 替换为目标坐标
		string $object = $zj_loc_name[0]; // 替换为你的物体名
		
		vector $pos = `xform -q -ws -t $object`; // 获取物体当前位置
		vector $dir = unit($target - $pos); // 计算方向向量
		
		float $angleb[] = `angleBetween -euler -v1 1 0 0 -v2 ($dir.x) ($dir.y) ($dir.z)`; // 计算角度
		rotate -a -ws $angleb[0] $angleb[1] $angleb[2] $object; // 应用旋转
		
		///////////////将物体轴匹配到loc//////////////////
		string $objectB = $zj_loc_name[0]; // 替换为你的物体名
		//select -cl  ;
		//将物体轴向匹配到loc
		if($obj_pp_loc == 1){
			ThroughEconomicReformsRo($sel_obj_name[0],$objectB);
		}
		//删除辅助物体
		if($del_loc==0){
			delete $zj_loc_name[0]; 
		}
		select -cl;
		select $sel_obj_name[0];
	}

}

////////////////////////////////////////////////////////////
/*修正圆柱体轴向
这个脚本用来获取丢失轴向的圆柱或者管状物体的选装轴向，主要用来修正汽车和机械类齿轮，机械轴，和轮胎类的轴向。脚本思路是通过两条循环边创建圆环曲线，获取曲线的中心轴位置，并且创建定位器，然后用一个圆环目标约束定位器，获取旋转轴
用法，选择可循环的边，远端和近端各选择一条边，必须是独立的两条边（例如：pCylinder1.e[0] pCylinder1.e[9] 中括号的0和1为独立的边编号，不能超过两个独立边）。*/
//////////////////////////////
//通过两个循环边对齐圆柱坐标//////
global proc XiuZhengYZTZX(){
	string $sel[] = `ls -selection`;
	int $del_loc = `checkBox -q -value del_loc_checkBoxB`;//是否删除辅助定位器
	int $obj_pp_loc = `checkBox -q -value obj_pp_loc_checkBoxB`;//是否将模型坐标匹配到loc
	
	if (size ($sel) < 2)
	{
	    error ("未选择足够的对象..退出\n");
	}
	if (size($sel) > 2)
	{
	    warning ("选择了两个以上的对象。将取前两个对象计算。");
	}
	    
	// 声明一个字符串数组用来存储分割结果
	string $sel_obj_name[];
	// 使用 tokenize 命令按 "." 分割字符串
	tokenize($sel[0], ".", $sel_obj_name);
	string $dd;
	float $pos_A[]={};
	float $pos_B[]={};
	////////////////////
	for ($i=0;$i<2;$i++){
	    string $dd = $sel[$i];
	    select -r $dd;
	    SelectContiguousEdges;
	    if($i==0){
	    	  $pos_A = GetCentralSelComp();
	    }
	    else if($i==1){
	        $pos_B = GetCentralSelComp();;
	    }
	    //print("中间位置坐标为: (" + $midX + ", " + $midY + ", " + $midZ + ")\n");
	}
	vector $center1=<<$pos_A[0],$pos_A[1],$pos_A[2]>>;
	vector $center2=<<$pos_B[0],$pos_B[1],$pos_B[2]>>;
	float $ZJ_points[] = calculateMidpoint($center1,$center2);
	string $zj_loc_name[] = `spaceLocator -p 0 0 0`;
	move -r $ZJ_points[0] $ZJ_points[1] $ZJ_points[2] $zj_loc_name[0];
	
	print($pos_A);
	print($pos_B);
	clear($pos_A);
	clear($pos_B);
	
	//////////////设置locator位置和旋转///////////////////
	vector $target = $center1; // 替换为目标坐标
	string $object = $zj_loc_name[0]; // 替换为你的物体名
	vector $pos = `xform -q -ws -t $object`; // 获取物体当前位置
	vector $dir = unit($target - $pos); // 计算方向向量
	float $angleb[] = `angleBetween -euler -v1 1 0 0 -v2 ($dir.x) ($dir.y) ($dir.z)`; // 计算角度
	rotate -a -ws $angleb[0] $angleb[1] $angleb[2] $object; // 应用旋转
	//select -cl  ;
	//将物体轴向匹配到loc
	if($obj_pp_loc == 1){
	    ThroughEconomicReformsRo($sel_obj_name[0],$object);
	}
	//删除辅助物体
	if($del_loc==0){
		delete $zj_loc_name[0]; 
	}
	select $sel_obj_name[0];
}

/////////在选择物体创建locator
global proc SelectObjectSel(){
	int $changeRoation = `checkBox -q -value obj_pp_loc_checkBoxC`;//是否匹配旋转
	string $objects[] = `ls -sl`; 
	int $objnum=size($objects);
	// 示例用法，调用全局过程并获取返回的坐标变量
	float $coords[];
	getSelectedObjectsCoordsA($coords);
	string $loc_name[] = `spaceLocator -p 0 0 0`;
	move -r $coords[0] $coords[1] $coords[2] $loc_name[0];
	if($objnum==1){
	    matchTransform $loc_name[0] $objects[0];
	}
	if($objnum==2){
		float $mubiaos[] = getWorldCenterA($objects[0]);
		vector $target = <<$mubiaos[0],$mubiaos[1],$mubiaos[2]>>; // 替换为目标坐标
		string $object = $loc_name[0]; // 替换为你的物体名
		vector $pos = `xform -q -ws -t $object`; // 获取物体当前位置
		vector $dir = unit($target - $pos); // 计算方向向量
		float $angleb[] = `angleBetween -euler -v1 1 0 0 -v2 ($dir.x) ($dir.y) ($dir.z)`; // 计算角度
		rotate -a -ws $angleb[0] $angleb[1] $angleb[2] $object; // 应用旋转
	}
	if ($changeRoation == 0) {
    setAttr ($loc_name[0]+".rotateZ") 0;
    setAttr ($loc_name[0]+".rotateX") 0;
    setAttr ($loc_name[0]+".rotateY") 0;
	}
	select $loc_name[0] ;
}
//在选择的组件创建locator，
global proc ComponentCreateLoc(){
	int $changeRoation = `checkBox -q -value obj_pp_loc_checkBoxC`;//是否匹配旋转
	setToolTo moveSuperContext;
	string $shapesel[] = `ls -sl -o`;
	string $objsel[] = `listRelatives -p $shapesel[0]`;
	string $vtxsel[]=`ls -sl`;
	float $trans[]=`manipMoveContext -q -p "Move"`;
	manipMoveContext -e -mode 10 "Move";
	float $ro[]=`manipMoveContext -q -oa "Move"`;
	$ro[0] = `rad_to_deg $ro[0]`;
	$ro[1] = `rad_to_deg $ro[1]`;
	$ro[2] = `rad_to_deg $ro[2]`;
	string $loc_name[] = `spaceLocator -p 0 0 0`;
	//select -r $loc_name[0]; 
	move -ws $trans[0] $trans[1] $trans[2] $loc_name[0];
	
		if($changeRoation == 1)
		{
			rotate -r ($ro[0]) ($ro[1]) ($ro[2]) $loc_name[0];
		}
}

//在组件或物体创建定位器（可多选物体）
global proc ComponentAndObjCreateLoc(){
    string $objectsA[] = `ls -sl -type "transform"`; // 筛选出变换节点（物体通常是 transform 类型）
    int $sclobjnum=size($objectsA);
    if($sclobjnum>0){
        SelectObjectSel;
    }
    else{
         ComponentCreateLoc;
    }
}
//select points
//将枢轴匹配到选择的组件，
global proc ZhouToSclPoint(){
	int $changeRoation = `checkBox -q -value obj_pp_loc_checkBoxD`;//是否匹配旋转
	setToolTo moveSuperContext;
	string $shapesel[] = `ls -sl -o`;
	string $objsel[] = `listRelatives -p $shapesel[0]`;
	string $vtxsel[]=`ls -sl`;
	float $trans[]=`manipMoveContext -q -p "Move"`;
	manipMoveContext -e -mode 10 "Move";
	float $ro[]=`manipMoveContext -q -oa "Move"`;
	$ro[0] = `rad_to_deg $ro[0]`;
	$ro[1] = `rad_to_deg $ro[1]`;
	$ro[2] = `rad_to_deg $ro[2]`;
	select -r $objsel[0]; 
	move -rpr -ws $trans[0] $trans[1] $trans[2] ($objsel[0]+".scalePivot") ($objsel[0]+".rotatePivot") ;
	string $loc_name[] = `spaceLocator -p 0 0 0`;//创建定位器
	move -ws $trans[0] $trans[1] $trans[2] $loc_name[0];
	rotate -r ($ro[0]) ($ro[1]) ($ro[2]) $loc_name[0];

		if($changeRoation >0 )
		{
			ThroughEconomicReformsRo($objsel[0],$loc_name[0]);
		}
		else
		{
			xform -ws -eu -ra ($ro[0]) ($ro[1]) ($ro[2]) $objsel[0];
			//manipMoveContext -e -mode 4;
		}
	delete $loc_name[0] ;//清理辅助物体
	select $objsel[0];

}












