{
	if ($List == 1)
	{
		// Statements;
	}else
	{
		string $Path = `text -q -label MFBShowPathtext`;
		$Path = toNativePath($Path);
		copyToClipboard($Path, 1);
	}
}

//ЪеВиТЗОЖ
global proc MFBFavoritePath ( int $List )
{
	if ($List == 1)
	{
		// Statements;
	}else
	{
		string $FavoritefilePath = `asInstallScriptLocation` + "PublicFiles/Settings/FavoritesPath.set";
		string $EachSettingline[] = freadAllLines($FavoritefilePath);
		string $Path = `text -q -label MFBShowPathtext`;
		if (`filetest -e $Path`)
		{
			int $FavoriteKey = 0;
			for ($Settingline in $EachSettingline)
			{
				if (`gmatch $Settingline ("*" + $Path)`)
				{
					$FavoriteKey = 1;
				}
			}
			if ($FavoriteKey == 1)
			{
				warning ("вбДцдкЪеВиЃК\n" + $Settingline);
			}else
			{
				string $content;
				if (`gmatch $Path "*://"`)
				{
					$content = "ДХХЬ" + `substring $Path 1 (size($Path)-3)` + "ЃК" + $Path + "\n";
				}else
				{
					$content = basename( $Path, "" ) + "ЃК" + $Path + "\n";
				}
				writeFile ( $FavoritefilePath, $content );
				MFBLoadFavoritesPath();
				warning ("ЪеВиГЩЙІЃЁЃЁЃЁ");
			}
		}else
		{
			warning ("ЗЧЗЈТЗОЖЃЁЃЁЃЁ");
		}
	}
}

//ЗЕЛиТЗОЖ
global proc MFBBeforePath ()
{
	global int $BackCount;
	global string $RememberPathString[];
	global string $KeepRememberPathString[];
	if ($BackCount == 0)
	{
		$RememberPathString = $KeepRememberPathString;
	}
	if ((size($RememberPathString)-1) == 0)
	{
		warning ("ЮоЗЕЛиТЗОЖЃЁЃЁЃЁ");
	}else
	{
		stringArrayRemoveAtIndex((size($RememberPathString)-1), $RememberPathString);
		$BackCount = ($BackCount + 1);
		textField -e -text $RememberPathString[size($RememberPathString)-1] MFBPathTextField;
		MFBnavigateToPath(0);
	}
}

//ЛжИДТЗОЖ
global proc MFBAfterPath ()
{
	global int $BackCount;
	global string $RememberPathString[];
	global string $KeepRememberPathString[];
	if ($BackCount == 0)
	{
		warning ("ЮоЛжИДТЗОЖЃЁЃЁЃЁ");
	}else
	{
		$BackCount = ($BackCount - 1);
		$RememberPathString[size($RememberPathString)] = $KeepRememberPathString[size($RememberPathString)];
		textField -e -text $RememberPathString[size($RememberPathString)-1] MFBPathTextField;
		MFBnavigateToPath(0);
	}
}

//ЩЯМЖТЗОЖ
global proc MFBUpPath ()
{
	string $UpPath = dirname(`textField -q -text MFBPathTextField`);
	textField -e -text $UpPath MFBPathTextField;
	MFBnavigateToPath(1);
}

//ЦєЖЏТЗОЖ
global proc MFBStartPath ()
{
	global string $BackStartPath;
	if($BackStartPath == "")
	{
		warning ("ЮоЦєЖЏТЗОЖ");
	}else
	{
		textField -e -text $BackStartPath MFBPathTextField;
		MFBnavigateToPath(1);
	}
}

//ИњЫцбЁдёВЂЛёШЁЮФМўДѓаЁ
global proc MFBtextScrollListSynchronize ( int $List )
{
	if ($List == 1)
	{
		int $SelectIndexed[] = `textScrollList -q -selectIndexedItem MFBPathDisplaytextScrollList`;
		textScrollList -e -selectIndexedItem $SelectIndexed[0] MFBFileDatetextScrollList;
	}
	if ($List == 2)
	{
		int $SelectIndexed[] = `textScrollList -q -selectIndexedItem MFBFileDatetextScrollList`;
		textScrollList -e -selectIndexedItem $SelectIndexed[0] MFBPathDisplaytextScrollList;
	}
	string $Path = `text -q -label MFBShowPathtext`;
	global string $KeeptextScrollListFileNames[];
	global string $MFBSettingInformation[];
	if ($MFBSettingInformation[0] == "1")
	{
		if (`gmatch $Path "ЕчФдДХХЬ"`)
		{
			string $SelectItem[] = `textScrollList -q -selectItem MFBPathDisplaytextScrollList`;
			string $Content = getFileSizeFormatted($SelectItem[0]);
			text -e -label $Content MFBFileSizetext;
		}else
		{
			if (`gmatch $Path "*://"`)
			{
				$Path = `substring $Path 1 (size($Path)-1)`;
			}
			if (!`gmatch $Path "*/"`)
			{
				$Path = $Path + "/";
			}
			int $SelectIndexed[] = `textScrollList -q -selectIndexedItem MFBPathDisplaytextScrollList`;
			$Path = $Path + $KeeptextScrollListFileNames[$SelectIndexed[0]-1];
			string $Content = getFileSizeFormatted($Path);
			text -e -label $Content MFBFileSizetext;
		}
	}else
	{
		text -e -label "ЮДЦєгУДѓаЁЖСШЁ" MFBFileSizetext;
	}
}

//НјШыЮФМўМа
global proc MFBtextScrollListOpen ()
{
	string $InputPath = `text -q -label MFBShowPathtext`;
	if (`gmatch $InputPath "*://"`)
	{
		$InputPath = `substring $InputPath 1 (size($InputPath)-1)`;
	}
	if (!`gmatch $InputPath "*/"`)
	{
		$InputPath = $InputPath + "/";
	}
	global string $KeeptextScrollListFileNames[];
	global string $textScrollListFileNames[];
	global int $CategoryNums[];
	string $Folders[] = {};
	for ($i=0; $i<$CategoryNums[0]; $i++)
	{
		$Folders[$i] = $textScrollListFileNames[$i];
	}
	int $SelectIndexed[] = `textScrollList -q -selectIndexedItem MFBPathDisplaytextScrollList`;
	int $IsFolders = stringArrayContains($KeeptextScrollListFileNames[$SelectIndexed[0]-1], $Folders);
	if ($IsFolders == 0)
	{
		string $SelectContent[] = `textScrollList -q -selectItem MFBPathDisplaytextScrollList`;
		if (`gmatch $SelectContent[0] "*://"`)
		{
			textField -e -text $SelectContent[0] MFBPathTextField;
			MFBnavigateToPath(1);
		}else
		{
			warning ("ЗЧЮФМўМаЃЁЃЁЃЁ");
		}
	}else
	{
		$InputPath = $InputPath + $KeeptextScrollListFileNames[$SelectIndexed[0]-1];
		textField -e -text $InputPath MFBPathTextField;
		MFBnavigateToPath(1);
	}
}

//ЫЂаТЯдЪОФкШн
global proc MFBReflushshowitems ()
{
	string $InputPath = `text -q -label MFBShowPathtext`;
	if ($InputPath == "ЕчФдДХХЬ")
	{
		MFBSystemDrives();
	}else
	{
		textField -e -text $InputPath MFBPathTextField;
		MFBnavigateToPath(0);
	}
}

//ИФБфЯдЪОРраЭ1
global proc ChangeOptionMenuCommand1 ()
{
	global string $KeeptextScrollListFileNames[];
	global string $KeeptextScrollListCreationTimes[];
	global string $KeeptextScrollListModificationTimes[];
	global string $KeeptextScrollListAccessTimes[];
	if (`optionMenu -q -select MFBFileInformationDisplayoptionMenu1` == 1)
	{
		MFBFileDisplaytextScrollList1($KeeptextScrollListFileNames);
	}
	if (`optionMenu -q -select MFBFileInformationDisplayoptionMenu1` == 2)
	{
		MFBFileDisplaytextScrollList1($KeeptextScrollListCreationTimes);
	}
	if (`optionMenu -q -select MFBFileInformationDisplayoptionMenu1` == 3)
	{
		MFBFileDisplaytextScrollList1($KeeptextScrollListModificationTimes);
	}
	if (`optionMenu -q -select MFBFileInformationDisplayoptionMenu1` == 4)
	{
		MFBFileDisplaytextScrollList1($KeeptextScrollListAccessTimes);
	}
}

//ИФБфЯдЪОРраЭ2
global proc ChangeOptionMenuCommand2 ()
{
	global string $KeeptextScrollListFileNames[];
	global string $KeeptextScrollListCreationTimes[];
	global string $KeeptextScrollListModificationTimes[];
	global string $KeeptextScrollListAccessTimes[];
	if (`optionMenu -q -select MFBFileInformationDisplayoptionMenu2` == 1)
	{
		MFBFileDisplaytextScrollList2($KeeptextScrollListFileNames);
	}
	if (`optionMenu -q -select MFBFileInformationDisplayoptionMenu2` == 2)
	{
		MFBFileDisplaytextScrollList2($KeeptextScrollListCreationTimes);
	}
	if (`optionMenu -q -select MFBFileInformationDisplayoptionMenu2` == 3)
	{
		MFBFileDisplaytextScrollList2($KeeptextScrollListModificationTimes);
	}
	if (`optionMenu -q -select MFBFileInformationDisplayoptionMenu2` == 4)
	{
		MFBFileDisplaytextScrollList2($KeeptextScrollListAccessTimes);
	}
}

//ЯдЪОЮФМўРраЭ
global proc showFileInBrowser ( string $Category )
{
	//ИФБфАДХЅзДЬЌ
	if (`button -q -ebg ("FileCategory" + $Category)` == 1)
	{
		button -e -ebg 0 -backgroundColor 0.265 0.265 0.265 ("FileCategory" + $Category);
	}else
	{
		button -e -ebg 1 -backgroundColor 0.3 0.6 0.3 ("FileCategory" + $Category);
	}
	//ЬоГ§ВЛЯдЪОФкШн
	global string $textScrollListFileNames[];
	global string $textScrollListCreationTimes[];
	global string $textScrollListModificationTimes[];
	global string $textScrollListAccessTimes[];
	global int $CategoryNums[];
	global string $KeeptextScrollListFileNames[];
	global string $KeeptextScrollListCreationTimes[];
	global string $KeeptextScrollListModificationTimes[];
	global string $KeeptextScrollListAccessTimes[];
	$KeeptextScrollListFileNames = {};
	$KeeptextScrollListCreationTimes = {};
	$KeeptextScrollListModificationTimes = {};
	$KeeptextScrollListAccessTimes = {};
	int $NewNum = 0;
	int $BaseNum = 0;
	string $CategoryName[] = `scrollLayout -q -ca MFBPathDisplayscrollLayout`;
	for ($i=0; $i<size($CategoryName); $i++)
	{
		if ($i != 0)
		{
			$BaseNum = $BaseNum + $CategoryNums[$i-1];
		}
		if (`button -q -ebg ("FileCategory" + $i)` == 1)
		{
				for ($a=0; $a<$CategoryNums[$i]; $a++)
				{
					$KeeptextScrollListFileNames[$NewNum] = $textScrollListFileNames[$BaseNum + $a];
					$KeeptextScrollListCreationTimes[$NewNum] = $textScrollListCreationTimes[$BaseNum + $a];
					$KeeptextScrollListModificationTimes[$NewNum] = $textScrollListModificationTimes[$BaseNum + $a];
					$KeeptextScrollListAccessTimes[$NewNum] = $textScrollListAccessTimes[$BaseNum + $a];
					$NewNum = $NewNum + 1;
				}
		}
	}
	ChangeOptionMenuCommand1();
	ChangeOptionMenuCommand2();
}

//зЊЕНТЗОЖ
global proc MFBnavigateToPath ( int $RememberPath )
{
	string $InputPath = `textField -q -text MFBPathTextField`;
	//ДІРэЪфШыТЗОЖ
	$InputPath = fromNativePath($InputPath);
	$InputPath = fromNativePath($InputPath);
	if (`gmatch $InputPath "*:/"`)
	{
		$InputPath = $InputPath + "/";
	}
	if (`gmatch $InputPath "*/"` && !`gmatch $InputPath "*://"`)
	{
		$InputPath = `substring $InputPath 1 (size($InputPath)-1)`;
	}
	if ($InputPath == "")
	{
		warning ("ЧыЪфШыТЗОЖЃЁЃЁ");
	}else if (!`filetest -e $InputPath`)
	{
		warning ("ТЗОЖВЛДцдкЃЁЃЁ");
	}else 
	{
		string $AllFileName[] = `getFileList -folder $InputPath`;
		button -e -backgroundColor 0.3 0.6 0.3 FileCategory0;
		textField -e -text $InputPath MFBPathTextField;
		text -e -label "ЯдЪОТЗОЖЃК" MFBStatusLabel;
		text -e -label $InputPath MFBShowPathtext;
		text -e -label (size($AllFileName) + "ИіЯюФП" + "ЁЁ|ЁЁ") MFBShowFileTotal;
		MFBaddCategory();
		MFBFileDisplayContent($InputPath);
		global string $textScrollListFileNames[];
		global string $textScrollListCreationTimes[];
		global string $textScrollListModificationTimes[];
		global string $textScrollListAccessTimes[];
		global string $KeeptextScrollListFileNames[];
		global string $KeeptextScrollListCreationTimes[];
		global string $KeeptextScrollListModificationTimes[];
		global string $KeeptextScrollListAccessTimes[];
		$KeeptextScrollListFileNames = $textScrollListFileNames;
		$KeeptextScrollListCreationTimes = $textScrollListCreationTimes;
		$KeeptextScrollListModificationTimes = $textScrollListModificationTimes;
		$KeeptextScrollListAccessTimes = $textScrollListAccessTimes;
		ChangeOptionMenuCommand1();
		ChangeOptionMenuCommand2();
	}
	global int $BackCount;
	global string $RememberPathString[];
	global string $KeepRememberPathString[];
	if ($RememberPath == 1)
	{
		//ГѕЪМЛЏТЗОЖДцДЂаХЯЂ
		$BackCount = 0;
		$RememberPathString = {};
		//РлМгДцДЂТЗОЖ
		$KeepRememberPathString[size($KeepRememberPathString)] = $InputPath;
	}
	if (`optionMenu -q -enable MFBFileInformationDisplayoptionMenu1` == 0)
	{
		optionMenu -e -enable 1 MFBFileInformationDisplayoptionMenu1;
	}
	if (`optionMenu -q -enable MFBFileInformationDisplayoptionMenu2` == 0)
	{
		optionMenu -e -enable 1 MFBFileInformationDisplayoptionMenu2;
	}
	if (`button -q -enable FileCategory0` == 0)
	{
		button -e -enable 1 FileCategory0;
	}
}

//аТдіЗжРр
global proc MFBaddCategory ()
{
	string $InputPath = `text -q -label MFBShowPathtext`;
	string $CategoryName[] = `scrollLayout -q -ca MFBPathDisplayscrollLayout`;
	string $getFoldersName[] = getFoldersInDirectory($InputPath);
	string $getCategoryName[] = getFileTypesWithCount($InputPath);
	button -e -label ("ЮФМўМа(" + size($getFoldersName) + ")") FileCategory0;
	if (size($CategoryName)>1)
	{
		for ($i=1; $i<size($CategoryName); $i++)
		{
			deleteUI ("FileCategory" + $i);
		}
	}
	for ($i=1; $i<size($getCategoryName); $i++)
	{
		string $getCategoryOnlyName[] = stringToStringArray($getCategoryName[$i], ".:");
		button -label ($getCategoryOnlyName[0] + "(" + $getCategoryOnlyName[1] + ")")
			-command ("showFileInBrowser(" + $i + ")")
			-ann ("НіЯдЪО" + $getCategoryOnlyName[0] + "ЮФМў")
			-ebg 1
			-width 76
			-height 20
			-backgroundColor 0.3 0.6 0.3 
			-parent MFBPathDisplayscrollLayout 
			("FileCategory" + $i);
	}
}

//ЛёШЁаХЯЂЯдЪОПђЯдЪОФкШн
global proc MFBFileDisplayContent ( string $InputPath )
{
	global string $textScrollListFileNames[];
	global string $textScrollListCreationTimes[];
	global string $textScrollListModificationTimes[];
	global string $textScrollListAccessTimes[];
	global int $CategoryNums[];
	$textScrollListFileNames = {};
	$textScrollListCreationTimes = {};
	$textScrollListModificationTimes = {};
	$textScrollListAccessTimes = {};
	$CategoryNums = {};
	//бЁдёЯдЪОЮФМўУћГЦ
		//ЛёШЁЮФМўМаУћ
			string $FoldersName[] = getFoldersInDirectory($InputPath);
			$CategoryNums[0] = size($FoldersName);
			if (size($FoldersName) != 0 )
			{
				$textScrollListFileNames = $FoldersName;
			}
		//ЛёШЁИїРрЮФМўУћ
			string $CategoryName[] = `scrollLayout -q -ca MFBPathDisplayscrollLayout`;
			for ($i=1; $i<size($CategoryName); $i++)
			{
				string $getCategoryOnlyName[] = stringToStringArray(`button -q -label ("FileCategory" + $i)`, "(");
				if ($getCategoryOnlyName[0] == "ЮДжЊ")
				{
					string $Unknown[] = `getFileList -folder $InputPath -filespec "*."`;
					$Unknown = getStringArrayDifference($Unknown, getFoldersInDirectory($InputPath));
					$CategoryNums[$i] = size($Unknown);
					$textScrollListFileNames = mergeStringArrays($textScrollListFileNames, $Unknown);
				}else
				{
					string $AddContent[] = `getFileList -folder $InputPath -filespec ("*." + $getCategoryOnlyName[0])`;
					$CategoryNums[$i] = size($AddContent);
					$textScrollListFileNames = mergeStringArrays($textScrollListFileNames, $AddContent);
				}
			}
	//бЁдёЯдЪОДДНЈЪБМф
		//ЛёШЁЮФМўМаДДНЈЪБМф
			if (size($FoldersName) != 0 )
			{
				for ($i=0; $i<size($FoldersName); $i++) 
				{
					string $FoldersNameTmp[] = getFileTimes(($InputPath + "/" + $FoldersName[$i]));
					$textScrollListCreationTimes[$i] = $FoldersNameTmp[0];
				}
			}
		//ЛёШЁИїРрЮФМўДДНЈЪБМф
			for ($i=1; $i<size($CategoryName); $i++)
			{
				string $getCategoryOnlyName[] = stringToStringArray(`button -q -label ("FileCategory" + $i)`, "(");
				if ($getCategoryOnlyName[0] == "ЮДжЊ")
				{
					string $Unknown[] = `getFileList -folder $InputPath -filespec "*."`;
					$Unknown = getStringArrayDifference($Unknown, getFoldersInDirectory($InputPath));
					for ($a=0; $a<size($Unknown); $a++) 
					{
						string $textScrollListCreationTimesTmp[] = getFileTimes(($InputPath + "/" + $Unknown[$a]));
						$Unknown[$a] = $textScrollListCreationTimesTmp[0];
					}
					$textScrollListCreationTimes = mergeStringArrays($textScrollListCreationTimes, $Unknown);
				}else
				{
					string $AddContent[] = `getFileList -folder $InputPath -filespec ("*." + $getCategoryOnlyName[0])`;
					for ($b=0; $b<size($AddContent); $b++) 
					{
						string $textScrollListCreationTimesTmp[] = getFileTimes(($InputPath + "/" + $AddContent[$b]));
						$AddContent[$b] = $textScrollListCreationTimesTmp[0];
					}
					$textScrollListCreationTimes = mergeStringArrays($textScrollListCreationTimes, $AddContent);
				}
			}
	//бЁдёЯдЪОаоИФЪБМф
		//ЛёШЁЮФМўМааоИФЪБМф
			if (size($FoldersName) != 0 )
			{
				for ($i=0; $i<size($FoldersName); $i++) 
				{
					string $FoldersNameTmp[] = getFileTimes(($InputPath + "/" + $FoldersName[$i]));
					$textScrollListModificationTimes[$i] = $FoldersNameTmp[1];
				}
			}
		//ЛёШЁИїРрЮФМўаоИФЪБМф
			for ($i=1; $i<size($CategoryName); $i++)
			{
				string $getCategoryOnlyName[] = stringToStringArray(`button -q -label ("FileCategory" + $i)`, "(");
				if ($getCategoryOnlyName[0] == "ЮДжЊ")
				{
					string $Unknown[] = `getFileList -folder $InputPath -filespec "*."`;
					$Unknown = getStringArrayDifference($Unknown, getFoldersInDirectory($InputPath));
					for ($a=0; $a<size($Unknown); $a++) 
					{
						string $textScrollListModificationTimesTmp[] = getFileTimes(($InputPath + "/" + $Unknown[$a]));
						$Unknown[$a] = $textScrollListModificationTimesTmp[1];
					}
					$textScrollListModificationTimes = mergeStringArrays($textScrollListModificationTimes, $Unknown);
				}else
				{
					string $AddContent[] = `getFileList -folder $InputPath -filespec ("*." + $getCategoryOnlyName[0])`;
					for ($b=0; $b<size($AddContent); $b++) 
					{
						string $textScrollListModificationTimesTmp[] = getFileTimes(($InputPath + "/" + $AddContent[$b]));
						$AddContent[$b] = $textScrollListModificationTimesTmp[1];
					}
					$textScrollListModificationTimes = mergeStringArrays($textScrollListModificationTimes, $AddContent);
				}
			}
	//бЁдёЯдЪОЗУЮЪЪБМф
		//ЛёШЁЮФМўМаЗУЮЪЪБМф
			if (size($FoldersName) != 0 )
			{
				for ($i=0; $i<size($FoldersName); $i++) 
				{
					string $FoldersNameTmp[] = getFileTimes(($InputPath + "/" + $FoldersName[$i]));
					$textScrollListAccessTimes[$i] = $FoldersNameTmp[2];
				}
			}
		//ЛёШЁИїРрЮФМўЗУЮЪЪБМф
			for ($i=1; $i<size($CategoryName); $i++)
			{
				string $getCategoryOnlyName[] = stringToStringArray(`button -q -label ("FileCategory" + $i)`, "(");
				if ($getCategoryOnlyName[0] == "ЮДжЊ")
				{
					string $Unknown[] = `getFileList -folder $InputPath -filespec "*."`;
					$Unknown = getStringArrayDifference($Unknown, getFoldersInDirectory($InputPath));
					for ($a=0; $a<size($Unknown); $a++) 
					{
						string $textScrollListAccessTimesTmp[] = getFileTimes(($InputPath + "/" + $Unknown[$a]));
						$Unknown[$a] = $textScrollListAccessTimesTmp[2];
					}
					$textScrollListAccessTimes = mergeStringArrays($textScrollListAccessTimes, $Unknown);
				}else
				{
					string $AddContent[] = `getFileList -folder $InputPath -filespec ("*." + $getCategoryOnlyName[0])`;
					for ($b=0; $b<size($AddContent); $b++) 
					{
						string $textScrollListAccessTimesTmp[] = getFileTimes(($InputPath + "/" + $AddContent[$b]));
						$AddContent[$b] = $textScrollListAccessTimesTmp[2];
					}
					$textScrollListAccessTimes = mergeStringArrays($textScrollListAccessTimes, $AddContent);
				}
			}
}

//аХЯЂЯдЪОПђЯдЪО1
global proc MFBFileDisplaytextScrollList1 ( string $Display[] )
{
	textScrollList -e -removeAll MFBPathDisplaytextScrollList;
	for ( $i = 0 ; $i < size($Display); $i++)
	{
		textScrollList -e -append $Display[$i] MFBPathDisplaytextScrollList;
	}
}

//аХЯЂЯдЪОПђЯдЪО2
global proc MFBFileDisplaytextScrollList2 ( string $Display[] )
{
	textScrollList -e -removeAll MFBFileDatetextScrollList;
	for ( $i = 0 ; $i < size($Display); $i++)
	{
		textScrollList -e -append $Display[$i] MFBFileDatetextScrollList;
	}
}