//ДАПк
global proc showFileBrowser ( string $ReturntextFieldInputflag, string $StartPath, string $ReturntextFieldInputName )
{
	global string $MFBSettingInformation[];
	$MFBSettingInformation[0] = "1";
	global string $BackStartPath;
	$BackStartPath = $StartPath;
	global string $ReturnStartflag;
	$ReturnStartflag = $ReturntextFieldInputflag;
	global string $ReturntextFieldName;
	$ReturntextFieldName = $ReturntextFieldInputName;
	if (`window -exists "MayaFileBrowserWindow"`)
	{
		deleteUI -window "MayaFileBrowserWindow";
	}
	window -title "ЮФМўзЪдДЙмРэЦї" -widthHeight 848 418 -sizeable 0 -minimizeButton true-maximizeButton true MayaFileBrowserWindow;
		columnLayout -columnAttach both 5 -adjustableColumn true MayaFileBrowsercolumnLayout;
			separator -height 5 -style "none";
			// ДДНЈЖЅВПЙЄОпРИ
			createToolbar();
			separator -height 5 -style "none";
			separator -height 2;
			// ДДНЈТЗОЖЯдЪОЧјгђ
			createPathInput();
			textField -e -tx $StartPath MFBPathTextField;
			separator -height 2;
			rowColumnLayout -numberOfColumns 3 
				-height 320
				-adjustableColumn 2 
				-columnWidth 1 140 //ВхМўдЄЩшКЭЪеВиФПТМ
				-columnWidth 2 490 //ЯдЪОФПТМКЭЗжРрЯдЪО
				-columnWidth 3 204 //БИзЂФкШн
				MFBMainDisplay;
				// ДДНЈжїФкШнЧјгђ
				createLeftDisplay();
				createPathDisplay();
				createRightDisplay();
			setParent ..;
			// ДДНЈЕзВПзДЬЌРИ
			separator -height 2;
			createStatusBar();
			separator -height 5 -style "none";
	showWindow MayaFileBrowserWindow;
	//ГѕЪМЛЏжЕ
	global string $KeepRememberPathString[];
	$KeepRememberPathString = {};
	textField -e -text $StartPath MFBPathTextField;
	MFBnavigateToPath(1);
	if ($ReturntextFieldName == 0)
	{
		button -e -en 0 MFBConfirmdisplaypath;
	}
}

//ЖЅРИ
global proc createToolbar ()
{
	rowColumnLayout -numberOfColumns 15 
		-height 24
		-columnWidth 1 65 
		-columnWidth 2 65 
		-columnWidth 3 20 
		-columnWidth 4 65 
		-columnWidth 5 65 
		-columnWidth 6 65 
		-columnWidth 7 65 
		-columnWidth 8 65 
		-columnWidth 9 65 
		-columnWidth 10 20 
		-columnWidth 11 65 
		-columnWidth 12 65 
		-columnWidth 13 65 
		-columnWidth 14 65 
		-columnWidth 15 14 
		MFBtoolbar;
		string $SettingPathimage = `asInstallScriptLocation` + "Icon/SettingPathSmall.svg";
		iconTextButton -command "еМЮЛЗћ" -ann "НјааВхМўЩшжУ" -style "iconAndTextHorizontal" -image1 $SettingPathimage -label "ЩшЁЁжУ";
		string $Diskimageimage = `asInstallScriptLocation` + "Icon/DiskSmall.svg";
		iconTextButton -command "MFBSystemDrives" -ann "ЯдЪОДХХЬТЗОЖ" -style "iconAndTextHorizontal" -image1 $Diskimageimage -label "ДХЁЁХЬ";
		string $Delimiterimage = `asInstallScriptLocation` + "Icon/DelimiterSmall.svg";
		image -image $Delimiterimage;
		string $EditSmallimage = `asInstallScriptLocation` + "Icon/EditSmall.svg";
		iconTextButton -command "MFBrenameSelected(0)" -ann "жиУќУћЕБЧАФПТМ" -style "iconAndTextHorizontal" -image1 $EditSmallimage -label "жиУќУћ";
		string $CopySmallimage = `asInstallScriptLocation` + "Icon/CopySmall.svg";
		iconTextButton -command "MFBcopySelected(0)" -ann "ИДжЦЕБЧАФПТМ" -style "iconAndTextHorizontal" -image1 $CopySmallimage -label "ИДЁЁжЦ";
		string $CutSmallimage = `asInstallScriptLocation` + "Icon/CutSmall.svg";
		iconTextButton -command "MFBcutSelected(0)" -ann "МєЧаЕБЧАФПТМ" -style "iconAndTextHorizontal" -image1 $CutSmallimage -label "МєЁЁЧа";
		string $PasteSmallimage = `asInstallScriptLocation` + "Icon/PasteSmall.svg";
		iconTextButton -command "MFBpasteSelected(0)" -ann "еГЬљИДжЦФПТМ" -style "iconAndTextHorizontal" -image1 $PasteSmallimage -label "еГЁЁЬљ";
		string $AddFileSmallimage = `asInstallScriptLocation` + "Icon/AddFileSmall.svg";
		iconTextButton -command "MFBcreateNewFolder" -ann "аТНЈЮФМўМа" -style "iconAndTextHorizontal" -image1 $AddFileSmallimage -label "аТЁЁНЈ";
		string $DeleteSmallimage = `asInstallScriptLocation` + "Icon/DeleteSmall.svg";
		iconTextButton -command "MFBdeleteSelected(0)" -ann "ЩОГ§ЕБЧАФПТМ" -style "iconAndTextHorizontal" -image1 $DeleteSmallimage -label "ЩОЁЁГ§";
		image -image $Delimiterimage;
		string $OpenFileSmallimage = `asInstallScriptLocation` + "Icon/OpenFileSmall.svg";
		iconTextButton -command "MFBopenFolder(0)" -ann "дкзЪдДЙмРэЦїжаДђПЊ" -style "iconAndTextHorizontal" -image1 $OpenFileSmallimage -label "ДђЁЁПЊ";
		string $LockSmallimage = `asInstallScriptLocation` + "Icon/LockSmall.svg";
		iconTextButton -command "MFBLockReadOnly(0)" -ann "ЩшжУЮФМўЪєадЮЊжЛЖС" -style "iconAndTextHorizontal" -image1 $LockSmallimage -label "ЫјЁЁЖЈ";//АбЮФМўЪєадИФЮЊжЛЖС
		string $UnlockSmallimage = `asInstallScriptLocation` + "Icon/UnlockSmall.svg";
		iconTextButton -command "MFBUnlockReadOnly(0)" -ann "НтГ§ЮФМўЪєадЮЊжЛЖС" -style "iconAndTextHorizontal" -image1 $UnlockSmallimage -label "НтЁЁЫј";//ШЁЯћЮФМўЪєаджЛЖС
		string $RefreshSmallimage = `asInstallScriptLocation` + "Icon/RefreshSmall.svg";
		iconTextButton -command "MFBReflushshowitems" -ann "ЫЂаТЮФМўСаБэ" -style "iconAndTextHorizontal" -image1 $RefreshSmallimage -label "ЫЂЁЁаТ";
		//ПЩЕїећДАПк
		string $SLetterimage = `asInstallScriptLocation` + "Icon/SLetterSmall.svg";
		symbolButton -command "if(`window -q -sizeable MayaFileBrowserWindow`==0){window -e -sizeable 1 MayaFileBrowserWindow;print (\"ДАПкПЩЕїНкЃЁ\\n\");}else{window -e -sizeable 0 MayaFileBrowserWindow;print (\"ДАПкЫјЖЈЃЁ\\n\");}" -ann "ИФБфДАПкЫјЖЈ" -height 14 -image $SLetterimage;
	setParent ..;
}

//ТЗОЖРИ
global proc createPathInput ()
{
	rowColumnLayout -numberOfColumns 9
		-adjustableColumn 2 
		-height 25
		-columnWidth 1 140 
		-columnWidth 2 490 
		-columnWidth 3 25 
		-columnWidth 4 25 
		-columnWidth 5 25 
		-columnWidth 6 25 
		-columnWidth 7 25 
		-columnWidth 8 25 
		-columnWidth 9 54 
		MFBPathDisplay;
		text -label "ЁЁ Ъф Шы фЏ РР ТЗ ОЖ ЃК";
		textField -editable true 
			-hlc 0.5 0.5 0.5 
			-text ""
			-enterCommand "MFBnavigateToPath(1)"
			MFBPathTextField;
		//ИДжЦЯдЪОЕФТЗОЖ
		string $CLetterimage = `asInstallScriptLocation` + "Icon/CLetter.svg";
		symbolButton -h 20 -ann "ИДжЦТЗОЖ" -image $CLetterimage -c "MFBCopyPath(0)";
		//ЪеВиЯдЪОЕФТЗОЖ
		string $Favoriteimage = `asInstallScriptLocation` + "Icon/Favorite.svg";
		symbolButton -h 20 -ann "ЪеВиТЗОЖ" -image $Favoriteimage -c "MFBFavoritePath(0)";
		//ЩЯвЛДЮЪфШыЕФТЗОЖ
		string $LeftArrowimage = `asInstallScriptLocation` + "Icon/LeftArrow.svg";
		symbolButton -h 20 -ann "ЗЕЛиТЗОЖ" -image $LeftArrowimage -c "MFBBeforePath";
		//ЯТвЛДЮЪфШыЕФТЗОЖ
		string $AfterPathimage = `asInstallScriptLocation` + "Icon/RightArrow.svg";
		symbolButton -h 20 -ann "ЛжИДТЗОЖ" -image $AfterPathimage -c "MFBAfterPath";
		//ЩЯМЖТЗОЖ
		string $UpArrowimage = `asInstallScriptLocation` + "Icon/UpArrow.svg";
		symbolButton -h 20 -ann "ЩЯМЖТЗОЖ" -image $UpArrowimage -c "MFBUpPath";
		//ЦєЖЏЪБТЗОЖ
		string $Returnimage = `asInstallScriptLocation` + "Icon/Return.svg";
		symbolButton -h 20 -ann "ЦєЖЏТЗОЖ" -image $Returnimage -c "MFBStartPath";
		button -label "ЧА Эљ" 
			   -command "MFBnavigateToPath(1)";
	setParent ..;
}

//ВхМўдЄЩшЃЈЛКДцЃЉКЭЪеВиФПТМРИ
global proc createLeftDisplay ()
{
	columnLayout -adjustableColumn true MFBLeftcolumnLayout;
		paneLayout -configuration "horizontal2" -height 315 MFBLeftpaneLayout;
			frameLayout -height 80 -cl 0 -cll 0 -label "дЄЩшФПТМ" MFBPreframeLayout;
				textScrollList -hlc 0.5 0.5 0.5 -sc "MFBGOPrePath" -allowMultiSelection 0 MFBPretextScrollList;
				MFBLoadPrePath();
			setParent ..;
			frameLayout -height 80 -cl 0 -cll 0 -label "ЪеВиФПТМ" MFBFavoritesframeLayout;
				textScrollList -hlc 0.5 0.5 0.5 -sc "MFBGOFavoritesPath" -allowMultiSelection 0 MFBFavoritestextScrollList;
				MFBLoadFavoritesPath();
			setParent ..;
		setParent ..;
	setParent ..;
}

//ЯдЪОФПТМРИКЭЗжРрРИ
global proc createPathDisplay ()
{
	rowColumnLayout -numberOfColumns 3 
		-height 320 
		-adjustableColumn 1 
		-columnWidth 1 400 
		-columnWidth 2 87 
		MFBPathDisplayrowcolumnLayout;
		paneLayout -paneSize 2 1 4 -configuration "vertical2" -width 400 MFBPathDisplaypaneLayout;
			columnLayout -width 80  -adjustableColumn true MFBFileInformationDisplaycolumnLayout1;
				optionMenu -changeCommand "ChangeOptionMenuCommand1" -height 20 MFBFileInformationDisplayoptionMenu1;
					MFBFileInformationDisplaymenuItem();
					optionMenu -edit -select 1 MFBFileInformationDisplayoptionMenu1;
				textScrollList -height 293 -hlc 0.5 0.5 0.5 -sc "MFBtextScrollListSynchronize(1)" -dcc "MFBtextScrollListOpen" -allowMultiSelection 0 MFBPathDisplaytextScrollList;
			setParent ..;
			columnLayout -width 80  -adjustableColumn true MFBFileInformationDisplaycolumnLayout2;
				optionMenu -changeCommand "ChangeOptionMenuCommand2" -height 20 MFBFileInformationDisplayoptionMenu2;
					MFBFileInformationDisplaymenuItem();
					optionMenu -edit -select 2 MFBFileInformationDisplayoptionMenu2;
				textScrollList -height 293 -hlc 0.5 0.5 0.5 -sc "MFBtextScrollListSynchronize(2)" -dcc "MFBtextScrollListOpen" -allowMultiSelection 0 MFBFileDatetextScrollList;
			setParent ..;
		setParent ..;
		columnLayout -width 87 -adjustableColumn true MFBCategorycolumnLayout;
			frameLayout -cl 0 -cll 0 -label "  ЁЁЗжЁЁРр" MFBCategoryframeLayout;
				scrollLayout -height 293 -width 85 -bv 1 MFBPathDisplayscrollLayout;
				//scrollLayout -q -numberOfChildren MFBPathDisplayscrollLayout;ВщбЏзгЖдЯѓЪ§СП
					button -label "ЮФМўМа(0)" 
						-command "showFileInBrowser(0)"
						-ann "ЯдЪОЮФМўМа"
						-ebg 1
						-width 76
						-height 20
						-backgroundColor 0.3 0.6 0.3//0.265 0.265 0.265 
						FileCategory0;
				setParent ..;
			setParent ..;
		setParent ..;
	setParent ..;
}

global proc MFBFileInformationDisplaymenuItem ()
{
	menuItem -label "ЮФМўУћГЦ" MFBFileInformationDisplaymenuItem0;
	menuItem -label "ДДНЈЪБМф" MFBFileInformationDisplaymenuItem1;
	menuItem -label "аоИФЪБМф" MFBFileInformationDisplaymenuItem2;
	menuItem -label "ЗУЮЪЪБМф" MFBFileInformationDisplaymenuItem3;
}

//БИзЂРИ
global proc createRightDisplay ()
{
	columnLayout -height 350 -adjustableColumn true MFBRightcolumnLayout;
		frameLayout -cl 0 -cll 0 -label "ЁЁЁЁЁЁЁЁЁЁЁЁ БИЁЁ зЂ" MFBFavoritesframeLayout;
			scrollField -height 260 -editable false -wordWrap true -text "" MFBRemarksTextField;
