//加载公共函数
eval ("source \"" + `asInstallScriptLocation` + "Scripts/ALLPublicScripts.mel\"");
//加载关键帧动画导入导出插件
if (!`window -exists "ImportExportKeyframesWindow"`)
{
	eval ("source \"" + `asInstallScriptLocation` + "Scripts/ImportExportKeyframes.mel\"");
	deleteUI -window "ImportExportKeyframesWindow";
}
//检测动画控制面板帮助窗口
global proc CACPHelp ()
{
	if (`window -exists "CACPHelpWindow"`)
	{
		deleteUI -window "CACPHelpWindow";
	}
	window -h 54 -w 432 -title "帮助" -rtf 1 -s 0 -tlb 0 CACPHelpWindow;// -h 251 -w 411
	columnLayout -columnAttach both 5 CACPHelpcolumnLayout;
		separator -height 5 -style "none";
		frameLayout -w 420 -ec "frameLayoutChangeWindowNewHeight(\"CACPHelpWindow\",\"CACPHelpframeLayout1\")" -pcc "frameLayoutChangeWindowBackHeight(\"CACPHelpWindow\",\"CACPHelpframeLayout1\")" -cl 1 -cll 1 -label "基础界面" CACPHelpframeLayout1;
			scrollLayout -w 400 -h 300 CACPHelpscrollLayout1;
				image -image (`asInstallScriptLocation` + "PublicFiles/Helps/AnimationCheckPanel/Helpimage1.svg");
				image -image (`asInstallScriptLocation` + "PublicFiles/Helps/AnimationCheckPanel/Helpimage2.svg");
				image -image (`asInstallScriptLocation` + "PublicFiles/Helps/AnimationCheckPanel/Helpimage3.svg");
				image -image (`asInstallScriptLocation` + "PublicFiles/Helps/AnimationCheckPanel/Helpimage4.svg");
				image -image (`asInstallScriptLocation` + "PublicFiles/Helps/AnimationCheckPanel/Helpimage5.svg");
				image -image (`asInstallScriptLocation` + "PublicFiles/Helps/AnimationCheckPanel/Helpimage6.svg");
				image -image (`asInstallScriptLocation` + "PublicFiles/Helps/AnimationCheckPanel/Helpimage7.svg");
			setParent ..;
		setParent ..;

		frameLayout -w 420 -ec "frameLayoutChangeWindowNewHeight(\"CACPHelpWindow\",\"CACPHelpframeLayout2\")" -pcc "frameLayoutChangeWindowBackHeight(\"CACPHelpWindow\",\"CACPHelpframeLayout2\")" -cl 1 -cll 1 -label "编辑界面" CACPHelpframeLayout2;
			scrollLayout -w 400 -h 300 CACPHelpscrollLayout2;
				image -image (`asInstallScriptLocation` + "PublicFiles/Helps/AnimationCheckPanel/Helpeditimage1.svg");
				image -image (`asInstallScriptLocation` + "PublicFiles/Helps/AnimationCheckPanel/Helpeditimage2.svg");
				image -image (`asInstallScriptLocation` + "PublicFiles/Helps/AnimationCheckPanel/Helpeditimage3.svg");
				image -image (`asInstallScriptLocation` + "PublicFiles/Helps/AnimationCheckPanel/Helpeditimage4.svg");
				image -image (`asInstallScriptLocation` + "PublicFiles/Helps/AnimationCheckPanel/Helpeditimage5.svg");
				image -image (`asInstallScriptLocation` + "PublicFiles/Helps/AnimationCheckPanel/Helpeditimage6.svg");
				image -image (`asInstallScriptLocation` + "PublicFiles/Helps/AnimationCheckPanel/Helpeditimage7.svg");
				image -image (`asInstallScriptLocation` + "PublicFiles/Helps/AnimationCheckPanel/Helpeditimage8.svg");
			setParent ..;
		setParent ..;
		separator -height 5 -style "none";
	setParent ..;
	showWindow CACPHelpWindow;
}

//检测编辑额外窗口
global proc CACPEidtExtra ()
{
	if (`window -exists "CACPEidtExtraWindow"`)
	{
		deleteUI -window "CACPEidtExtraWindow";
	}
	window -h 78 -w 100 -title "编辑" -rtf 1 -s 0 -tlb 1 CACPEidtExtraWindow;// -h 251 -w 411
	columnLayout -columnAttach both 5 CACPEidtExtracolumnLayout;
		separator -height 5 -style "none";
		intField -v 1000 -ann "下一部位增加值" CACPEidtExtratextField;
		button -h 25 -c "playbackOptions -e -ast `playbackOptions -q -max` -min `playbackOptions -q -max`;playbackOptions -e -aet (`playbackOptions -q -max` + `intField -q -v CACPEidtExtratextField`) -max (`playbackOptions -q -max` + `intField -q -v CACPEidtExtratextField`);" -ann "下一部位" -label "下一部位" CACPEidtExtraButton1;
		button -h 25 -c "playbackOptions -e -max `currentTime -q`;" -ann "将当前选中帧作为末尾帧" -label "选中末尾帧" CACPEidtExtraButton2;
		separator -height 5 -style "none";
	setParent ..;
	showWindow CACPEidtExtraWindow;
}
