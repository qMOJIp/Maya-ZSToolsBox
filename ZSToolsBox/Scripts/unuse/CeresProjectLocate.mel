//获取公盘预设目录的预设文件列表
global proc string[] getPublicPreFilesInCurrentDirectory()
{
	string $Project = `textField -q -tx CeresProjectTextField`;
	string $PublicPath = "//192.168.20.102/projects/CIDA_RG/020 绑定公共数据/Ceres版本管理软件项目路径预设/" + $Project + "/";
	
	string $fileList[] = `getFileList -folder $PublicPath -filespec "*.pre"`; // 获取匹配的文件列表

	// 提取文件名并存储到 LocPreFileName 数组中
	string $fileName;
	string $PublicPreFileName[];
	for ($i = 0; $i < size($fileList); $i++)
	{
		string $NewfileList[] = stringToStringArray($fileList[$i], ".");
		$fileList[$i] = $NewfileList[0];
		$fileName = $fileList[$i]; // 提取文件名
		$PublicPreFileName[$i] = $fileName;
	}
	
	return $PublicPreFileName;
}

//获取本地预设目录的预设文件列表
global proc string[] getPreFilesInCurrentDirectory()
{
	string $Project = `textField -q -tx CeresProjectTextField`;
	string $directoryPath = (`optionVar -q LocPrePath`) + "/" + $Project + "/";
	
	string $fileList[] = `getFileList -folder $directoryPath -filespec "*.pre"`; // 获取匹配的文件列表

	// 提取文件名并存储到 LocPreFileName 数组中
	string $fileName;
	string $LocPreFileName[];
	for ($i = 0; $i < size($fileList); $i++)
	{
		string $NewfileList[] = stringToStringArray($fileList[$i], ".");
		$fileList[$i] = $NewfileList[0];
		$fileName = $fileList[$i]; // 提取文件名
		$LocPreFileName[$i] = $fileName;
	}
	
	return $LocPreFileName;
}

