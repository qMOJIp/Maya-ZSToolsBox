//导入预设时刷新资产信息命令
global proc AssetImportCommend ( string $AssetCodeArray[] , string $AssetNoteArray[] , string $AssetPathArray[] )
{
	textScrollList -e -removeAll AssetCodetextScrollList;
	textScrollList -e -removeAll AssetNotetextScrollList;
	textScrollList -e -removeAll AssetPathtextScrollList;
	for ( $i = 0 ; $i < size($AssetCodeArray); $i++)
	{
		textScrollList -e -append $AssetCodeArray[$i] AssetCodetextScrollList;
		textScrollList -e -append $AssetNoteArray[$i] AssetNotetextScrollList;
		textScrollList -e -append $AssetPathArray[$i] AssetPathtextScrollList;
	}
}

//导入公盘预设
global proc PublicPreLoad ()
{
	string $scriptsPath = `internalVar -userScriptDir`;
	string $Project = `textField -q -tx CeresProjectTextField`;
	string $PublicPath = "//192.168.20.102/projects/CIDA_RG/020 绑定公共数据/Ceres版本管理软件项目路径预设/" + $Project + "/";
	string $SelectPre[] = `textScrollList -q -selectItem PublicPretextScrollList`;
