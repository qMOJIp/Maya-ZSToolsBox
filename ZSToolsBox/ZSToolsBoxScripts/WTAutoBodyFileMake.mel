//制作An的Weapon文件（ma）制作文件7
	//制作文件
global proc AnWeaponMaMake ( string $AnWeaponMaField , string $WTABFMcharactername , string $WTABFMcharacterskin , string $WTABFMweaponname ) 
{
	//将引用改为导入
	string $refs[] = `file -query -reference`;
	for ($ref in $refs)
	{
		file -importReference $ref;
	}

	//设置Pose
	SelectSetObjectInf ( ".weaponpose", $WTABFMcharactername , $WTABFMcharacterskin , $WTABFMweaponname );

	//刷新主视口，防止设置失效
	refresh -f -currentView;

	//删除无用显示层
	select -r `ls -type "displayLayer"`;
	select -d defaultLayer;
	doDelete;

	//删除无用骨骼
	DeleteUnKeepBone ( $WTABFMcharactername , $WTABFMcharacterskin , $WTABFMweaponname , "" );
	
	//路径不存在则创建
	if (!`file -exists -q (dirname($AnWeaponMaField))`)
	{
		system("mkdir \"" + dirname($AnWeaponMaField) + "\"");
		print("当前路径不存在但已创建。\n");
	}

	//选择导出对象
	if (`objExists "Weapon_LOD0"`)
	{
		parent -w Weapon_LOD0;
		if (`objExists "Weapon_LOD"`)
		{
			delete "Weapon_LOD";
		}
		group -n "LOD_0" Weapon_LOD0;
		group -n "Weapon_LOD" LOD_0;
		select -r "Weapon_LOD";
	}else
	{
		select -r "Weapon_PV";
	}
	select -add "Weapon_Group";
	select -add "weapon";
	file -f -options "v=0;" -typ "mayaAscii" -es $AnWeaponMaField;
	print ($AnWeaponMaField + "已制作完成！\n");
}


