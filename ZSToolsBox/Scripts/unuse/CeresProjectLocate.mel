}

//编辑窗口
global proc EditWindow ()
{
	if (`window -exists EditAssetPreWindow`)
	deleteUI -window EditAssetPreWindow;
	window -title "编辑预设" -h 100 -w 250  -rtf 1  -s 0 -tlb 1 EditAssetPreWindow;
	columnLayout -columnAttach both 5 -adjustableColumn true EditWindowcolumnLayout;
	separator -h 5 -style "none" -p EditWindowcolumnLayout;
	rowLayout -nc 2 -columnWidth2 125 125 -p EditWindowcolumnLayout;
		text -w 125 "资产代号";
		text -w 125 "资产备注";
	rowLayout -nc 2 -columnWidth2 125 125 -p EditWindowcolumnLayout;
		textField -w 125 -h 20 -tx "" -ann "编辑资产代号输入框" AssetCodeEditListtextField;
		textField -w 125 -h 20 -tx "" -ann "编辑资产备注输入框" AssetNoteEditListtextField;
	separator -h 5 -style "none" -p EditWindowcolumnLayout;
	text -p EditWindowcolumnLayout -w 250 "— — — — — —  预设路径  — — — — — —";
	separator -h 5 -style "none" -p EditWindowcolumnLayout;
	textField -p EditWindowcolumnLayout -w 125 -h 20 -tx "" -ann "资产预设路径编辑框" AssetPathEditListtextField;
	separator -h 5 -style "none" -p EditWindowcolumnLayout;
	button -p EditWindowcolumnLayout -w 250 -c "Confirmedit" -label "确认编辑";
	separator -h 5 -style "none" -p EditWindowcolumnLayout;
	showWindow;
	string $AssetCodeString[] = `textScrollList -q -selectItem AssetCodetextScrollList`;
	string $AssetNoteString[] = `textScrollList -q -selectItem AssetNotetextScrollList`;
	string $AssetPathString[] = `textScrollList -q -selectItem AssetPathtextScrollList`;
	textField -e -tx $AssetCodeString[0] AssetCodeEditListtextField;
	textField -e -tx $AssetNoteString[0] AssetNoteEditListtextField;
	textField -e -tx $AssetPathString[0] AssetPathEditListtextField;
}

//确认编辑
global proc Confirmedit ()
{
	//int $AssetPathselectIndexed[] = `textScrollList -q -selectIndexedItem AssetPathtextScrollList`;
	int $AssetCodeselectIndexed[] = `textScrollList -q -selectIndexedItem AssetCodetextScrollList`;
	//int $AssetNoteselectIndexed[] = `textScrollList -q -selectIndexedItem AssetNotetextScrollList`;
	string $AssetCodeEditString = strip(`textField -q -tx AssetCodeEditListtextField`);
	string $AssetNoteEditString = strip(`textField -q -tx AssetNoteEditListtextField`);
	string $AssetPathEditString = strip(`textField -q -tx AssetPathEditListtextField`);
	textScrollList -e -removeIndexedItem $AssetCodeselectIndexed[0] AssetCodetextScrollList;
	textScrollList -e -removeIndexedItem $AssetCodeselectIndexed[0] AssetNotetextScrollList;
	textScrollList -e -removeIndexedItem $AssetCodeselectIndexed[0] AssetPathtextScrollList;
	textScrollList -e -appendPosition $AssetCodeselectIndexed[0] $AssetCodeEditString AssetCodetextScrollList;
	textScrollList -e -appendPosition $AssetCodeselectIndexed[0] $AssetNoteEditString AssetNotetextScrollList;
	textScrollList -e -appendPosition $AssetCodeselectIndexed[0] $AssetPathEditString AssetPathtextScrollList;
	textScrollList -e -selectIndexedItem $AssetCodeselectIndexed[0] AssetCodetextScrollList;
	textScrollList -e -selectIndexedItem $AssetCodeselectIndexed[0] AssetNotetextScrollList;
	textScrollList -e -selectIndexedItem $AssetCodeselectIndexed[0] AssetPathtextScrollList;
	deleteUI -window EditAssetPreWindow;
}

//选择资产路径时资产备注跟随选择
global proc AssetPathtextselectCommand ()
{
	int $AssetPathselectIndexed[] = `textScrollList -q -selectIndexedItem AssetPathtextScrollList`;
	//int $AssetCodeselectIndexed[] = `textScrollList -q -selectIndexedItem AssetCodetextScrollList`;
	//int $AssetNoteselectIndexed[] = `textScrollList -q -selectIndexedItem AssetNotetextScrollList`;
	textScrollList -e -deselectAll AssetCodetextScrollList;
	textScrollList -e -deselectAll AssetNotetextScrollList;
	textScrollList -e -deselectAll AssetPathtextScrollList;
	textScrollList -e -selectIndexedItem $AssetPathselectIndexed[0] AssetCodetextScrollList;
	textScrollList -e -selectIndexedItem $AssetPathselectIndexed[0] AssetNotetextScrollList;
	textScrollList -e -selectIndexedItem $AssetPathselectIndexed[0] AssetPathtextScrollList;
}

//选择资产代号时资产备注跟随选择
global proc AssetCodetextselectCommand ()
{
	//int $AssetPathselectIndexed[] = `textScrollList -q -selectIndexedItem AssetPathtextScrollList`;
	int $AssetCodeselectIndexed[] = `textScrollList -q -selectIndexedItem AssetCodetextScrollList`;
	//int $AssetNoteselectIndexed[] = `textScrollList -q -selectIndexedItem AssetNotetextScrollList`;
	textScrollList -e -deselectAll AssetCodetextScrollList;
	textScrollList -e -deselectAll AssetNotetextScrollList;
	textScrollList -e -deselectAll AssetPathtextScrollList;
	textScrollList -e -selectIndexedItem $AssetCodeselectIndexed[0] AssetCodetextScrollList;
	textScrollList -e -selectIndexedItem $AssetCodeselectIndexed[0] AssetNotetextScrollList;
	textScrollList -e -selectIndexedItem $AssetCodeselectIndexed[0] AssetPathtextScrollList;
}

//选择资产备注时资产代号跟随选择
global proc AssetNotetextselectCommand ()
{
	//int $AssetPathselectIndexed[] = `textScrollList -q -selectIndexedItem AssetPathtextScrollList`;
	//int $AssetCodeselectIndexed[] = `textScrollList -q -selectIndexedItem AssetCodetextScrollList`;
	int $AssetNoteselectIndexed[] = `textScrollList -q -selectIndexedItem AssetNotetextScrollList`;
	textScrollList -e -deselectAll AssetCodetextScrollList;
	textScrollList -e -deselectAll AssetNotetextScrollList;
	textScrollList -e -deselectAll AssetPathtextScrollList;
	textScrollList -e -selectIndexedItem $AssetNoteselectIndexed[0] AssetCodetextScrollList;
	textScrollList -e -selectIndexedItem $AssetNoteselectIndexed[0] AssetNotetextScrollList;
	textScrollList -e -selectIndexedItem $AssetNoteselectIndexed[0] AssetPathtextScrollList;
}

//增加资产预设
global proc AssettextScrollListEdit ()
{
	$SelectedlocationKey = `checkBox -q -v Selectedlocation`;
	int $AssetCodeselectIndexed[] = `textScrollList -q -selectIndexedItem AssetCodetextScrollList`;
	string $AssetCodetextField = strip(`textField -q -tx AssetCodetextScrollListtextField`);
	string $AssetNotetextField = strip(`textField -q -tx AssetNotetextScrollListtextField`);
	string $AssetPathtextField = strip(`textField -q -tx AssetPathtextScrollListtextField`);
	if ($SelectedlocationKey == 1)
	{
		textScrollList -e -appendPosition ($AssetCodeselectIndexed[0]+1) $AssetCodetextField AssetCodetextScrollList;
		textScrollList -e -appendPosition ($AssetCodeselectIndexed[0]+1) $AssetNotetextField AssetNotetextScrollList;
		textScrollList -e -appendPosition ($AssetCodeselectIndexed[0]+1) $AssetPathtextField AssetPathtextScrollList;
	}else{
		textScrollList -e -append $AssetCodetextField AssetCodetextScrollList;
		textScrollList -e -append $AssetNotetextField AssetNotetextScrollList;
		textScrollList -e -append $AssetPathtextField AssetPathtextScrollList;
	}
}