PV_Chin11","FACIAL_R_12IPV_Chin11","FACIAL_L_12IPV_Chin12","FACIAL_R_12IPV_Chin12","FACIAL_L_12IPV_Chin13","FACIAL_R_12IPV_Chin13","FACIAL_L_12IPV_Chin14","FACIAL_R_12IPV_Chin14","FACIAL_C_Chin"
	};
	for ($i = 0;$i <size($seletion);$i++){
		print ("\n\n当前转移模型：" + $seletion[$i] + "\n");
		//添加缺失影响物
		select -r $seletion[$i];
		select -add $KeepBone;
		skinClusterInfluence 1 "-ug -dr 4 -ps 0 -ns 10 -lw true -wt 0";
		select -r $seletion[$i];
		WeightTransform ( $NeckChildBones , "Neck_M" , $seletion[$i] );
		print ("Neck_M骨骼转移完成\n");
		WeightTransform ( $Neck1ChildBones , "Neck1_M" , $seletion[$i] );
		print ("Neck1_M骨骼转移完成\n");
		WeightTransform ( $HeadChildBones , "Head_M" , $seletion[$i] );
		print ("Head_M骨骼转移完成\n");
		//返回位移编辑防止权重编辑下删除模型导致卡死
		TranslateToolWithSnapMarkingMenu;
		//移除未影响权重
		select -r $seletion[$i];
		removeUnusedInfluences;
	}
}


//插件疑问
global proc WTAutoBodyFileMakeQuestion_1()
{
	if (`window -exists "WTAutoBodyFileMakeQuestion_1Window"`)
	{  
		deleteUI -window "WTAutoBodyFileMakeQuestion_1Window";
	}  
	window -t "Rig ALL文件规范图" -w 292 -h 300 -rtf 1 -s 0 -tlb 1 WTAutoBodyFileMakeQuestion_1Window;
		columnLayout -w 280 -h 90 -columnAttach both 5 -adjustableColumn true HelpcolumnLayout;
		string $scriptsPath = `internalVar -userScriptDir`;
		string $CharacterName = `textField -q -tx WTABFMcharactername`;
		if ($CharacterName == "")
		{
			$CharacterName = "角色名";
		}
		separator -h 5 -style "none";
		frameLayout -w 280 -cl 1 -cll 1 -label "命名格式快速预览、检查与创建" -p HelpcolumnLayout LevelFrameLayout;
			treeView -p LevelFrameLayout -h 100 -numberOfButtons 1 -abr 1
			-addItem "Group" ""
				-addItem "MotionSystem" "Group"
					-addItem "AddCtrl" "MotionSystem"
			-addItem "UnrealRoot" ""
			-addItem "Parasite_PV" ""
			-addItem "Body_PV" ""
			-addItem "Facial_PV" ""
			-addItem ($CharacterName + "_LOD") ""
				-addItem "LOD_0" ($CharacterName + "_LOD")
					-addItem "Parasite_LOD0" "LOD_0"
					-addItem "Body_LOD0" "LOD_0"
					-addItem "Facial_LOD0" "LOD_0"
				-addItem "LOD_1" ($CharacterName + "_LOD")
					-addItem "Parasite_LOD1" "LOD_1"
					-addItem "Body_LOD1" "LOD_1"
					-addItem "Facial_LOD1" "LOD_1"
				-addItem "LOD_2" ($CharacterName + "_LOD")
					-addItem "Parasite_LOD2" "LOD_2"
					-addItem "Body_LOD2" "LOD_2"
					-addItem "Facial_LOD2" "LOD_2"
				-addItem "LOD_3" ($CharacterName + "_LOD")
					-addItem "Parasite_LOD3" "LOD_3"
					-addItem "Body_LOD3" "LOD_3"
					-addItem "Facial_LOD3" "LOD_3"
				-addItem "LOD_4" ($CharacterName + "_LOD")
					-addItem "Parasite_LOD4" "LOD_4"
					-addItem "Body_LOD4" "LOD_4"
					-addItem "Facial_LOD4" "LOD_4"
			;
		separator -h 3 -style "none" -p HelpcolumnLayout;
		string $Command1 = "launch -dir \"" + $scriptsPath + "ZSToolsBox/ZSToolsBoxScripts/RigDirectory.png\";";
		separator -h 5 -style "none" -p HelpcolumnLayout;
		button -w 280 -c $Command1 -ann "查看储存结构" -label "查看储存结构" -p HelpcolumnLayout;
		separator -h 5 -style "none" -p HelpcolumnLayout;
		button -w 280 -c "showHelp -absolute \"http://confluence.digisky.com/pages/viewpage.action?pageId=153489611\";" -ann "查看插件使用说明" -label "查看插件使用说明" -p HelpcolumnLayout;
		separator -h 5 -style "none" -p HelpcolumnLayout;
		button -w 280 -c "launch -dir \"//192.168.20.102/projects/CIDA_RG/020 绑定公共数据/RigAll角色数据/CharacterToAttachment/CharacterToWeapon.txt\"" -label "编辑角色武器关系" -p HelpcolumnLayout;
		separator -h 5 -style "none" -p HelpcolumnLayout;
		button -w 280 -c "launch -dir \"//192.168.20.102/projects/CIDA_RG/020 绑定公共数据/RigAll角色数据/CharacterToAttachment/CharacterToParasite.txt\"" -label "编辑角色变异体关系" -p HelpcolumnLayout;
	showWindow;  
}

//检查制作文件
global proc CheckMakeFile ( float $CheckFileNum )
{
	string $BodyAlltextField = `textField -q -tx BodyAlltextField`;
	string $WTABFMcharactername = `textField -q -tx WTABFMcharactername`;
	string $WTABFMweaponname = `textField -q -tx WTABFMweaponname`;
	string $WTABFMparasitename = `textField -q -tx WTABFMparasitename`;
	string $WTABFMcharacterskin = `textField -q -tx WTABFMcharacterskin`;
	
	string $FileMessage[] =
	{
		$BodyAlltextField,
		$WTABFMcharactername,
		$WTABFMweaponname,
		$WTABFMparasitename,
		$WTABFMcharacterskin
	};
	string $MakeField;
	if ($CheckFileNum == 1)
	{
		$MakeField = `optionVar -q WTFileName` + SkinChoosePath ($FileMessage,"Body","PV","fbx");
	}
	if ($CheckFileNum == 2)
	{
		$MakeField = `optionVar -q WTFileName` + SkinChoosePath ($FileMessage,"Body","Lod","fbx");
	}
	if ($CheckFileNum == 3)
	{
		$MakeField = `optionVar -q WTFileName` + SkinChoosePath ($FileMessage,"Skin","An","ma");
	}
	if ($CheckFileNum == 4)
	{
		$MakeField = `optionVar -q WTFileName` + SkinChoosePath ($FileMessage,"Skin","An","fbx");
	}
	if ($CheckFileNum == 5)
	{
		$MakeField = `optionVar -q WTFileName` + SkinChoosePath ($FileMessage,"Weapon","PV","fbx");
	}
	if ($CheckFileNum == 6)
	{
		$MakeField = `optionVar -q WTFileName` + SkinChoosePath ($FileMessage,"Weapon","Lod","fbx");
	}
	if ($CheckFileNum == 7)
	{
		$MakeField = `optionVar -q WTFileName` + SkinChoosePath ($FileMessage,"Weapon","An","ma");
	}
	if ($CheckFileNum == 8)
	{
		$MakeField = `optionVar -q WTFileName` + SkinChoosePath ($FileMessage,"Weapon","An","fbx");
	}
	if ($CheckFileNum == 9)
	{
		$MakeField = `optionVar -q WTFileName` + SkinChoosePath ($FileMessage,"Parasite","PV","fbx");
	}
	if ($CheckFileNum == 10)
	{
		$MakeField = `optionVar -q WTFileName` + SkinChoosePath ($FileMessage,"Parasite","Lod","fbx");
	}
	if ($CheckFileNum == 11)
	{
		$MakeField = `optionVar -q WTFileName` + dirname($FileMessage[0]) + "/SK_Player_" + $FileMessage[1] + "_Nake_Body_Rig_01.ma";
	}
	if ($CheckFileNum == 12.1)
	{
		//$MakeField = `optionVar -q WTFileName` + dirname($FileMessage[0]) + "/SK_Player_" + $FileMessage[1] + "_Nake_Body_Rig_01.ma";
	}
	if ($CheckFileNum == 12.2)
	{
		//$MakeField = `optionVar -q WTFileName` + dirname($FileMessage[0]) + "/SK_Player_" + $FileMessage[1] + "_Nake_Body_Rig_01.ma";
	}
	CheckMakePath ( $MakeField );
}

global proc CheckMakePath ( string $CheckMakePath )
{
	if (!`file -exists -q $CheckMakePath`)
	{
		error ("请先制作文件！\n");
	}else
	{
		if (`gmatch $CheckMakePath "*.ma"`)
		{
			file -f -open -options "v=0" $CheckMakePath;
			//居中场景
			viewSet -animate 0 -home;
			viewFit -animate 0 -all;
			print ("已成功打开：" + $CheckMakePath + "\n");
		}else if (`gmatch $CheckMakePath "*.fbx"`)
		{
			file -f -new;
			//设置场景Y轴朝上
			upAxis -ax y -rv;
			file -f -import -options "v=0" $CheckMakePath;
			//居中场景
			viewSet -animate 0 -home;
			viewFit -animate 0 -all;
			print ("已成功导入：" + $CheckMakePath + "\n");
		}
	}
}

//复制Ceres路径
global proc CopyCeresPath ( float $MakeFileNum )
{
	string $BodyAlltextField = `textField -q -tx BodyAlltextField`;
	string $WTABFMcharactername = `textField -q -tx WTABFMcharactername`;
	string $WTABFMweaponname = `textField -q -tx WTABFMweaponname`;
	string $WTABFMparasitename = `textField -q -tx WTABFMparasitename`;
	string $WTABFMcharacterskin = `textField -q -tx WTABFMcharacterskin`;
	string $WTABFMParasiteSkin;
	string $WTABFMParasiteSkin1 = `textField -q -tx WTABFMParasiteSkin1`;
	string $WTABFMParasiteSkin2 = `textField -q -tx WTABFMParasiteSkin2`;
	if ($MakeFileNum == 3.2)
	{
		$WTABFMParasiteSkin = $WTABFMParasiteSkin1;
	}
	if ($MakeFileNum == 4.2)
	{
		$WTABFMParasiteSkin = $WTABFMParasiteSkin2;
	}
	
	string $FileMessage[] =
	{
		$BodyAlltextField,
		$WTABFMcharactername,
		$WTABFMweaponname,
		$WTABFMparasitename,
		$WTABFMcharacterskin
	};
	string $ImportFileMessage[] =
	{
		$BodyAlltextField,
		$WTABFMcharactername,
		$WTABFMweaponname,
		$WTABFMparasitename,
		$WTABFMParasiteSkin
	};
	string $MakeField;
	string $scriptsPath = `internalVar -userScriptDir`;
	string $windowsscriptsPath = toNativePath( $scriptsPath );
	string $quickopenprojectfiletemp = $windowsscriptsPath + "ZSToolsBox/PublicFiles/quickopenprojectfiletemp.txt";
	if ($MakeFileNum == 1)
	{
		$MakeField = SkinChoosePath ($FileMessage,"Body","PV","fbx");
	}
	if ($MakeFileNum == 2)
	{
		$MakeField = SkinChoosePath ($FileMessage,"Body","Lod","fbx");
	}
	if ($MakeFileNum == 3)
	{
		$MakeField = SkinChoosePath ($FileMessage,"Skin","An","ma");
	}
	if ($MakeFileNum == 3.1)
	{
		$MakeField = dirname((dirname($FileMessage[0]))) + "/Facial/SK_Player_" + $FileMessage[1] + "_Origin_Facial_All_01.ma";
	}
	if ($MakeFileNum == 3.2)
	{
		$MakeField = SkinChoosePath ($ImportFileMessage,"Parasite","Lod","fbx");
	}
	if ($MakeFileNum == 4)
	{
		$MakeField = SkinChoosePath ($FileMessage,"Skin","An","fbx");
	}
	if ($MakeFileNum == 4.1)
	{
		$MakeField = dirname((dirname($FileMessage[0]))) + "/Facial/SK_Player_" + $FileMessage[1] + "_Origin_Facial_All_01.ma";
	}
	if ($MakeFileNum == 4.2)
	{
		$MakeField = SkinChoosePath ($ImportFileMessage,"Parasite","Lod","fbx");
	}
	if ($MakeFileNum == 5)
	{
		$MakeField = SkinChoosePath ($FileMessage,"Weapon","PV","fbx");
	}
	if ($MakeFileNum == 6)
	{
		$MakeField = SkinChoosePath ($FileMessage,"Weapon","Lod","fbx");
	}
	if ($MakeFileNum == 7)
	{
		$MakeField = SkinChoosePath ($FileMessage,"Weapon","An","ma");
	}
	if ($MakeFileNum == 8)
	{
		$MakeField = SkinChoosePath ($FileMessage,"Weapon","An","fbx");
	}
	if ($MakeFileNum == 9)
	{
		$MakeField = SkinChoosePath ($FileMessage,"Parasite","PV","fbx");
	}
	if ($MakeFileNum == 10)
	{
		$MakeField = SkinChoosePath ($FileMessage,"Parasite","Lod","fbx");
	}
	if ($MakeFileNum == 11.1)
	{
		$MakeField = dirname($FileMessage[0]) + "/SK_Player_" + $FileMessage[1] + "_Nake_Body_Rig_01.ma";
	}
	if ($MakeFileNum == 12.1)
	{
		//$MakeField = dirname($FileMessage[0]) + "/SK_Player_" + $FileMessage[1] + "_Nake_Body_Rig_01.ma";
	}
	if ($MakeFileNum == 12.2)
	{
		//$MakeField = dirname($FileMessage[0]) + "/SK_Player_" + $FileMessage[1] + "_Nake_Body_Rig_01.ma";
	}
	if ($MakeFileNum == 12.3)
	{
		//$MakeField = dirname($FileMessage[0]) + "/SK_Player_" + $FileMessage[1] + "_Nake_Body_Rig_01.ma";
	}
	$fileId=`fopen $quickopenprojectfiletemp "w"`;
	fprint $fileId ( $MakeField );
	fclose $fileId;
	system("start \"" + $windowsscriptsPath + "ZSToolsBox/PublicFiles/PathCopy.exe\"");
}

