global proc WTAutoBodyFileMake()  
{
	if (`window -exists "WTAutoBodyFileMakewindow"`)
	{
		deleteUI -window "WTAutoBodyFileMakewindow";
	}
	window -title "WT Rig All 相关文件制作" -h 530 -w 405 -rtf 1 -s 0 -tlb 0 WTAutoBodyFileMakewindow;
	//公用开头
		string $scriptsPath = `internalVar -userScriptDir`;
		string $filePath = $scriptsPath + "ZSToolsBox/PublicFiles/Projets.txt";
		$fileId=`fopen $filePath "r"`;
		string $TextLine = `fgetline $fileId`;
		fclose $fileId;
		string $ArrayTextLine[] = stringToStringArray( $TextLine, ";" );
		for ($i=0; $i<size($ArrayTextLine); $i++)
		{
			if (`gmatch $ArrayTextLine[$i] ("WT=*")` == 1){
				string $ProjetContent[] = stringToStringArray( $ArrayTextLine[$i], "=" );
				optionVar -sv WTFileName $ProjetContent[1];
			}
		}
	columnLayout -h 500 -w 390 -columnAttach both 5 -adjustableColumn true WTABFMcolumnLayout;
		separator -h 5 -style "none";
		rowLayout -adj 1 -p WTABFMcolumnLayout -nc 2 -columnWidth2 370 15; 
			text -h 20 -bgc 0.2 0.4 0.4 -label ("使用前确保对应制作文件为最新并按照规范导入或引用制作");
			button -h 20 -w 15 -c "WTAutoBodyFileMakeQuestion_1" -ann "点击查看图解" -label "?";
		setParent ..;
		separator -h 5 -style "none" -p WTABFMcolumnLayout;
		text -w 393 -p WTABFMcolumnLayout -label ("Rig All 文件Ceres路径");
		textField -w 393 -ec "WTABFMEnter1(\"\")" -tx "" BodyAlltextField;
		rowLayout -adj 4 -p WTABFMcolumnLayout -nc 4 -columnWidth4 96 97 96 96; 
			text -w 96 -label ("角色名字");
			text -w 96 -label ("武器名字");
			text -w 96 -label ("变异体名");
			text -w 96 -label ("文件类型");
		setParent ..;
		rowLayout -adj 4 -p WTABFMcolumnLayout -nc 4 -columnWidth4 96 97 96 96; 
			textField -ec "RefreshInf" -w 96 -tx "" WTABFMcharactername;
			textField -ec "RefreshInf" -w 96 -tx "" WTABFMweaponname;
				popupMenu -button 3 -sh 1 WeaponNameManagepopupMenu;
					menuItem -label "编辑预设" -c "launch -dir \"//192.168.20.102/projects/CIDA_RG/020 绑定公共数据/RigAll角色数据/CharacterToAttachment/CharacterToWeapon.txt\"" WeaponNameManagemenuItem1;
			textField -ec "RefreshInf" -w 96 -tx "" WTABFMparasitename;
				popupMenu -button 3 -sh 1 ParasiteNameManagepopupMenu;
					menuItem -label "编辑预设" -c "launch -dir \"//192.168.20.102/projects/CIDA_RG/020 绑定公共数据/RigAll角色数据/CharacterToAttachment/CharacterToParasite.txt\"" ParasiteNameManagemenuItem1;
			textField -ec "RefreshInf" -w 96 -tx "" WTABFMcharacterskin;
				popupMenu -button 3 -sh 1 FileTypePathManagepopupMenu;
					menuItem -label "编辑预设" -c "launch -dir \"//192.168.20.102/projects/CIDA_RG/020 绑定公共数据/RigAll角色数据/CharacterToAttachment/FileType.txt\"" FileTypePathManagemenuItem1;
				WTABFMAutoReadFileType ();
		setParent ..;
		separator -p WTABFMcolumnLayout -h 5 -style "none";
		button -p WTABFMcolumnLayout -h 20 -w 375 -c "OpenRigAll" -ann "打开 All Rig 文件" -label "打开 All Rig 文件" OpenAllRigBotton;
		separator -p WTABFMcolumnLayout -h 5 -style "none";

		scrollLayout -p WTABFMcolumnLayout -h 370 -w 390 WTABFMscrollLayout;
			//制作 PV 的 Body 文件（fbx）UI布局 文件1
			rowLayout -adj 2 -p WTABFMscrollLayout -nc 2 -columnWidth2 15 375 WTABFMrowLayout1;
			text -w 15 -h 20 -bgc 0.35 0.1 0.1 -label ("1") WTABFMframeLayouttext1;
			frameLayout -bgc 0.35 0.1 0.1 -pcc"WTABFMframeLayouttextCommend1(1)" -pec "WTABFMframeLayouttextCommend2(1)" -w 357 -cl 1 -cll 1 -ann "含Body_PV层级模型和全骨骼" -label "制作 SK_Player_角色名_皮肤名_Body_PV_版本.fbx" WTABFMframeLayout1;
				separator -parent WTABFMframeLayout1 -h 1 -style "none";
				rowLayout -adj 2 -p WTABFMframeLayout1 -nc 3 -columnWidth3 50 250 25; 
					text -h 20 -w 50 -label ("步骤一、");
					button -c "LocCeresPath(1)" -ann "通过项目文件快速打开插件在 Ceres 上定位到该文件以便快速检出" -label "检查是否检出制作文件";
					button -w 25 -c "CopyCeresPath(1)" -ann "复制该制作文件的Ceres路径" -label "C";
				separator -parent WTABFMframeLayout1 -h 1 -style "in";
				rowLayout -adj 2 -p WTABFMframeLayout1 -nc 3 -columnWidth3 50 250 25; 
					text -h 20 -w 50 -label ("步骤二、");
					button -c "WTABFMFileMakeUI ( 1 )" -ann "文件中需存在UnrealRoot和Body_PV"  -label "制作 SK_Player_角色名_皮肤名_Body_PV_版本.fbx 文件" WTABFMbutton1;
					button -bgc 0.265 0.265 0.265 -w 25 -ann "编辑An Pose" -c "EditAnPose(1,1,\".enginepose\")" -label "◆" ShowEditAnPoseframeLayout1button;
				separator -parent WTABFMframeLayout1 -h 1 -style "in" WTABFMframeLayout1separator1;
				rowLayout -adj 2 -p WTABFMframeLayout1 -nc 3 -columnWidth3 50 250 25 WTABFMframeLayout1EndrowLayout; 
					text -h 20 -w 50 -label ("步骤三、");
					button -c "CheckMakeFile(1)" -ann "新建场景导入 SK_Player_角色名_皮肤名_Body_PV_版本.fbx 文件" -label "新建场景并自动导入制作文件进行检查" WTABFMcheckbutton1;
					button -w 25 -c "OpenMakePath(1)" -ann "打开该制作文件的本地路径" -label "O";
				separator -bgc 0.35 0.1 0.1 -parent WTABFMframeLayout1 -h 3 -style "out" WTABFMframeLayout1separator2;
		
			//制作 Game 的 Body 文件（fbx）UI布局 文件2
			rowLayout -adj 2 -p WTABFMscrollLayout -nc 2 -columnWidth2 15 375 WTABFMrowLayout2; 
			text -w 15 -h 20 -bgc 0.45 0.2 0.2 -label ("2") WTABFMframeLayouttext2;
			frameLayout -bgc 0.45 0.2 0.2 -pcc"WTABFMframeLayouttextCommend1(2)" -pec "WTABFMframeLayouttextCommend2(2)" -w 357 -cl 1 -cll 1 -ann "含Body_LOD组模型和全骨骼" -label "制作 SK_Player_角色名_皮肤名_Body_Lod_版本.fbx" WTABFMframeLayout2;
				separator -parent WTABFMframeLayout2 -h 1 -style "none";
				rowLayout -adj 2 -p WTABFMframeLayout2 -nc 3 -columnWidth3 50 250 25; 
					text -h 20 -w 50 -label ("步骤一、");
					button -c "LocCeresPath(2)" -ann "通过项目文件快速打开插件在 Ceres 上定位到该文件以便快速检出" -label "检查是否检出制作文件";
					button -w 25 -c "CopyCeresPath(2)" -ann "复制该制作文件的Ceres路径" -label "C";
				separator -parent WTABFMframeLayout2 -h 1 -style "in";
				rowLayout -adj 2 -p WTABFMframeLayout2 -nc 3 -columnWidth3 50 250 25; 
					text -h 20 -w 50 -label ("步骤二、");
					button -c "WTABFMFileMakeUI ( 2 )" -ann "文件中需存在UnrealRoot和Body_LOD" -label "制作 SK_Player_角色名_皮肤名_Body_Lod_版本.fbx 文件" WTABFMbutton2;
					button -bgc 0.265 0.265 0.265 -w 25 -ann "编辑An Pose" -c "EditAnPose(2,2,\".enginepose\")" -label "◆" ShowEditAnPoseframeLayout2button;
				separator -parent WTABFMframeLayout2 -h 1 -style "in" WTABFMframeLayout2separator1;
				rowLayout -adj 2 -p WTABFMframeLayout2 -nc 3 -columnWidth3 50 250 25 WTABFMframeLayout2EndrowLayout;  
					text -h 20 -w 50 -label ("步骤三、");
					button -c "CheckMakeFile(2)" -ann "新建场景导入 SK_Player_角色名_皮肤名_Body_Lod_版本.fbx 文件" -label "新建场景并自动导入制作文件进行检查" WTABFMcheckbutton2;
					button -w 25 -c "OpenMakePath(2)" -ann "打开该制作文件的本地路径" -label "O";
				separator -bgc 0.45 0.2 0.2 -parent WTABFMframeLayout2 -h 3 -style "out" WTABFMframeLayout2separator2;
		
			//制作 An 的 Body 文件（Ma）UI布局 文件3
			rowLayout -adj 2 -p WTABFMscrollLayout -nc 2 -columnWidth2 15 375 WTABFMrowLayout3; 
			text -w 15 -h 20 -bgc 0.6 0.4 0.4 -label ("3") WTABFMframeLayouttext3;
			frameLayout -bgc 0.6 0.4 0.4 -pcc"WTABFMframeLayouttextCommend1(3)" -pec "WTABFMframeLayouttextCommend2(3)" -ec "HideEditAnPoseframeLayout1" -w 357 -cl 1 -cll 1 -ann "含Body_PV、Parasite_PV、Body_PV_Facial组模型和全骨骼以及控制器" -label "制作 SK_Player_角色名_皮肤名_An_版本.ma" WTABFMframeLayout3;
				separator -parent WTABFMframeLayout3 -h 1 -style "none";
				rowLayout -adj 2 -p WTABFMframeLayout3 -nc 3 -columnWidth3 50 250 25; 
					text -h 20 -w 50 -label ("步骤一、");
					button -c "LocCeresPath(3)" -ann "通过项目文件快速打开插件在 Ceres 上定位到该文件以便快速检出" -label "检查是否检出制作文件";
					button -w 25 -c "CopyCeresPath(3)" -ann "复制该制作文件的Ceres路径" -label "C";
				separator -parent WTABFMframeLayout3 -h 1 -style "in";
				rowLayout -adj 2 -p WTABFMframeLayout3 -nc 3 -columnWidth3 50 250 25; 
					text -h 20 -w 50 -label ("步骤二、");
					button -c "LocCeresPath(3.1)" -ann "通过项目文件快速打开插件在 Ceres 上定位到该文件以便快速检出" -label "检查是否获取最新的 Facial All 文件";
					button -w 25 -c "CopyCeresPath(3.1)" -ann "复制需求文件的Ceres路径" -label "C";
				separator -parent WTABFMframeLayout3 -h 1 -style "in";
				rowLayout -adj 2 -p WTABFMframeLayout3 -nc 4 -columnWidth4 50 200 50 25; 
					text -h 20 -w 50 -label ("步骤三、");
					button -c "LocCeresPath(3.2)" -ann "通过项目文件快速打开插件在 Ceres 上定位到该文件以便快速检出" -label "检查是否获取最新的 Parasite Lod 文件";
					textField -h 23 -w 50 -tx "Armor" WTABFMParasiteSkin1;
						popupMenu -button 3 -p WTABFMParasiteSkin1 WTABFMParasiteSkin1popupMenu;
						string $WTABFMFileTypePath = "//192.168.20.102/projects/CIDA_RG/020 绑定公共数据/RigAll角色数据/CharacterToAttachment/FileType.txt";
						//获取储存文件每行内容
						string $lines[];
						int $ParasiteSkin1fileId = `fopen $WTABFMFileTypePath "r"`;
						int $ParasiteSkin1i = 0;
						while (!`feof $ParasiteSkin1fileId`)
						{
							$lines[$ParasiteSkin1i] = `fgetline $ParasiteSkin1fileId`;
							if (`gmatch $lines[$ParasiteSkin1i] ("*Parasite*")`)
							{
								string $WTABFMFileTypePart[] = stringToStringArray($lines[$ParasiteSkin1i], "==>");
								string $WTABFMFileTypeSkin[] = stringToStringArray($WTABFMFileTypePart[1], ",");
								for ($a=0; $a<size($WTABFMFileTypeSkin); $a++)
								{
									$WTABFMFileTypeSkin[$a] = strip($WTABFMFileTypeSkin[$a]);
									menuItem -label $WTABFMFileTypeSkin[$a] -c ("textField -e -tx " + $WTABFMFileTypeSkin[$a] +  " WTABFMParasiteSkin1;textField -e -tx " + $WTABFMFileTypeSkin[$a] +  " WTABFMParasiteSkin2;") ("WTABFMParasiteSkin1MenuItem" + $ParasiteSkin1i + "_" + $a);
								}
								setParent -menu ..;
								$ParasiteSkin1i++;
							}
						}
					button -w 25 -c "CopyCeresPath(3.2)" -ann "复制需求文件的Ceres路径" -label "C";
				separator -parent WTABFMframeLayout3 -h 1 -style "in";
				rowLayout -adj 2 -p WTABFMframeLayout3 -nc 3 -columnWidth3 50 250 25; 
					text -h 20 -w 50 -label ("步骤四、");
					button -c "WTABFMFileMakeUI ( 3 )" -ann "文件中需存在UnrealRoot、Body_PV和Group" -label "制作 SK_Player_角色名_皮肤名_An_版本.ma 文件" WTABFMbutton3;
					button -bgc 0.265 0.265 0.265 -w 25 -ann "编辑An Pose" -c "EditAnPose(3,3,\".bodypose\")" -label "◆" ShowEditAnPoseframeLayout3button;	
				frameLayout -bgc 0.3 0.3 0.3 -labelIndent 138 -vis 0 -ann "An Pose 数据" -label "An Pose 数据" -p WTABFMframeLayout3 EditAnPoseframeLayout1;
					//编辑An PoseUI布局
					setParent EditAnPoseframeLayout1;
						//text -label " ―――――――――――――  An Pose 数据  ――――――――――――― ";
						scrollLayout -cr 30 -h 115 -w 355 EditAnPosescrollLayout1;
							rowLayout -nc 4 -columnWidth4 82 82 82 82 -parent EditAnPosescrollLayout1;
								text -h 20 -w 82 -label "名字";
								text -h 20 -w 82 -label "属性";
								text -h 20 -w 82 -label "参数";
								text -h 20 -w 82 -label "功能";
							for ($i = 0; $i < 4; $i++)
							{  
								string $EditObjectrowLayout = `rowLayout -nc 5 -columnWidth5 82 82 82 41 41 -parent EditAnPosescrollLayout1 ("EditObjectrowLayout" + $i)`;
								textField -w 82 -parent $EditObjectrowLayout ("EditObjectName" + $i);
								textField -w 82 -parent $EditObjectrowLayout ("EditObjectAttribute" + $i);
									popupMenu -button 3;
									string $PreAttributeShow[] = {"平移X","平移Y","平移Z","旋转X","旋转Y","旋转Z","缩放X","缩放Y","缩放Z"};
									string $PreAttribute[] = {"tx","ty","tz","rx","ry","rz","sx","sy","sz"};
									for ($a=0; $a<size($PreAttribute); $a++)
									{
										//stringToStringArray( $ArrayTextLine[$i], "=" );
										menuItem -label $PreAttributeShow[$a] -c ("textField -e -tx " + $PreAttribute[$a] +  " EditObjectAttribute" + $i);
									}
								textField -w 82 -parent $EditObjectrowLayout ("EditObjectInf" + $i);
								string $SelectEditObjectCmd = substituteAllString ("SelectEditObject(\"EditObjectName%d\");" , "%d" , $i);
								string $SelectGetObjectInfCmd = substituteAllString ("SelectGetObjectInf(\"EditObjectName%d\", \"EditObjectAttribute%d\", \"EditObjectInf%d\");" , "%d" , $i);
								button -h 17 -w 41 -parent $EditObjectrowLayout -ann "选择该对象" -c $SelectEditObjectCmd  -label "选择" ("SelectEditObjectCommend" + $i);
								button -h 17 -w 41 -parent $EditObjectrowLayout -ann "获取该对象参数" -c $SelectGetObjectInfCmd -label "获取" ("SelectGetObjectInfCommend" + $i);
							}
							//查询数据功能
					rowLayout -adj 5 -p EditAnPoseframeLayout1 -nc 5 -columnWidth5 57 26 38 39 182; 
						text -h 17 -w 57 -label "  数据总数：";
						textField -bgc 0.168 0.168 0.168 -editable false -w 25 -tx "4" EditAnPoseSum;
						button -h 17 -w 39 -ann "增加行" -c "AddEditObject" -label "增加" AddEditObjectbutton;
						button -h 17 -w 39 -ann "减少行" -c "DeleteEditObject" -label "减少" DeleteEditObjectbutton;
						rowLayout -adj 1 -nc 6 -columnWidth6 86 15 5 15 30 30; 
							textField -ann "输入对象名字" -w 82 SearchInftextField;
							text -ann "当前显示结果/结果总数" -w 15 -label "0" ResultSum1;
							text -ann "当前显示结果/结果总数" -w 5 -label "/" ResultSum2;
							text -ann "当前显示结果/结果总数" -w 15 -label "?" ResultSum3;
							button -h 17 -w 30 -ann "输入对象名字进行查找" -c "SearchEditObject" -label "查询" SearchInfbutton;
							optionVar -sv SearchInfCheck "";//清空之前查询对象
							button -h 17 -w 30 -ann "获取选中对象名字" -c "GetSelectObjectName" -label "获取" GetSearchInfbutton;
					button -h 17 -parent EditAnPoseframeLayout1 -ann "导出 An Pose 数据" -c "ExportEditObject" -label "导出";

				separator -parent WTABFMframeLayout3 -h 1 -style "in" WTABFMframeLayout3separator1;
				rowLayout -adj 2 -p WTABFMframeLayout3 -nc 3 -columnWidth3 50 250 25 WTABFMframeLayout3EndrowLayout; 
					text -h 20 -w 50 -label ("步骤五、");
					button -c "CheckMakeFile(3)" -ann "打开 SK_Player_角色名_皮肤名_An_版本.ma 文件" -label "打开制作文件进行检查" WTABFMcheckbutton3;
					button -w 25 -c "OpenMakePath(3)" -ann "打开该制作文件的本地路径" -label "O";
				separator -bgc 0.6 0.4 0.4 -parent WTABFMframeLayout3 -h 3 -style "out" WTABFMframeLayout3separator2;
		
			//制作 An 的 Body 文件（fbx）UI布局 文件4
			rowLayout -adj 2 -p WTABFMscrollLayout -nc 2 -columnWidth2 15 375 WTABFMrowLayout4; 
			text -w 15 -h 20 -bgc 0.7 0.5 0.5 -label ("4") WTABFMframeLayouttext4;
			frameLayout -bgc 0.7 0.5 0.5 -pcc"WTABFMframeLayouttextCommend1(4)" -pec "WTABFMframeLayouttextCommend2(4)" -ec "HideEditAnPoseframeLayout1" -w 357 -cl 1 -cll 1 -ann "含Body_PV、Parasite_PV、Body_PV_Facial组模型和全骨骼" -label "制作 SK_Player_角色名_皮肤名_An_版本.fbx" WTABFMframeLayout4;
				separator -parent WTABFMframeLayout4 -h 1 -style "none";
				rowLayout -adj 2 -p WTABFMframeLayout4 -nc 3 -columnWidth3 50 250 25; 
					text -h 20 -w 50 -label ("步骤一、");
					button -c "LocCeresPath(4)" -ann "通过项目文件快速打开插件在 Ceres 上定位到该文件以便快速检出" -label "检查是否检出制作文件";
					button -w 25 -c "CopyCeresPath(4)" -ann "复制该制作文件的Ceres路径" -label "C";
				separator -parent WTABFMframeLayout4 -h 1 -style "in";
				rowLayout -adj 2 -p WTABFMframeLayout4 -nc 3 -columnWidth3 50 250 25; 
					text -h 20 -w 50 -label ("步骤二、");
					button -c "LocCeresPath(4.1)" -ann "通过项目文件快速打开插件在 Ceres 上定位到该文件以便快速检出" -label "检查是否获取最新的 Facial All 文件";
					button -w 25 -c "CopyCeresPath(4.1)" -ann "复制需求文件的Ceres路径" -label "C";
				separator -parent WTABFMframeLayout4 -h 1 -style "in";
				rowLayout -adj 2 -p WTABFMframeLayout4 -nc 4 -columnWidth4 50 200 50 25; 
					text -h 20 -w 50 -label ("步骤三、");
					button -c "LocCeresPath(4.2)" -ann "通过项目文件快速打开插件在 Ceres 上定位到该文件以便快速检出" -label "检查是否获取最新的 Parasite Lod 文件";
					textField -h 23 -w 50 -tx "Armor" WTABFMParasiteSkin2;
						popupMenu -button 3 -p WTABFMParasiteSkin2 WTABFMParasiteSkin2popupMenu;
						//获取储存文件每行内容
						int $ParasiteSkin2fileId = `fopen $WTABFMFileTypePath "r"`;
						int $ParasiteSkin2i = 0;
						while (!`feof $ParasiteSkin2fileId`)
						{
							$lines[$ParasiteSkin2i] = `fgetline $ParasiteSkin2fileId`;
							if (`gmatch $lines[$ParasiteSkin2i] ("*Parasite*")`)
							{
								string $WTABFMFileTypePart[] = stringToStringArray($lines[$ParasiteSkin2i], "==>");
								string $WTABFMFileTypeSkin[] = stringToStringArray($WTABFMFileTypePart[1], ",");
								for ($a=0; $a<size($WTABFMFileTypeSkin); $a++)
								{
									$WTABFMFileTypeSkin[$a] = strip($WTABFMFileTypeSkin[$a]);
									menuItem -label $WTABFMFileTypeSkin[$a] -c ("textField -e -tx " + $WTABFMFileTypeSkin[$a] +  " WTABFMParasiteSkin1;textField -e -tx " + $WTABFMFileTypeSkin[$a] +  " WTABFMParasiteSkin2;") ("WTABFMParasiteSkin2MenuItem" + $ParasiteSkin2i + "_" + $a);
								}
								setParent -menu ..;
								$ParasiteSkin2i++;
							}
						}
					button -w 25 -c "CopyCeresPath(4.2)" -ann "复制需求文件的Ceres路径" -label "C";
				separator -parent WTABFMframeLayout4 -h 1 -style "in";
				rowLayout -adj 2 -p WTABFMframeLayout4 -nc 3 -columnWidth3 50 250 25;
					text -h 20 -w 50 -label ("步骤四、");
					button -c "WTABFMFileMakeUI ( 4 )" -ann "文件中需存在UnrealRoot和Body_PV" -label "制作 SK_Player_角色名_皮肤名_An_版本.fbx 文件" WTABFMbutton4;
					button -bgc 0.265 0.265 0.265 -w 25 -ann "编辑An Pose" -c "EditAnPose(4,4,\".bodypose\")" -label "◆" ShowEditAnPoseframeLayout4button;
				separator -parent WTABFMframeLayout4 -h 1 -style "in" WTABFMframeLayout4separator1;
				rowLayout -adj 2 -p WTABFMframeLayout4 -nc 3 -columnWidth3 50 250 25 WTABFMframeLayout4EndrowLayout; 
					text -h 20 -w 50 -label ("步骤五、");
					button -c "CheckMakeFile(4)" -ann "新建场景导入 SK_Player_角色名_皮肤名_An_版本.fbx 文件" -label "新建场景并自动导入制作文件进行检查" WTABFMcheckbutton4;
					button -w 25 -c "OpenMakePath(4)" -ann "打开该制作文件的本地路径" -label "O";
				separator -bgc 0.7 0.5 0.5 -parent WTABFMframeLayout4 -h 3 -style "out" WTABFMframeLayout4separator2;
		
			//制作 PV 的 Weapon 文件（fbx）UI布局 文件5
			rowLayout -adj 2 -p WTABFMscrollLayout -nc 2 -columnWidth2 15 375 WTABFMrowLayout5; 
			text -w 15 -h 20 -bgc 0.2 0.25 0.35 -label ("5") WTABFMframeLayouttext5;
			frameLayout -bgc 0.2 0.25 0.35 -pcc"WTABFMframeLayouttextCommend1(5)" -pec "WTABFMframeLayouttextCommend2(5)" -ec "HideEditAnPoseframeLayout1" -w 357 -cl 1 -cll 1 -ann "含Weapon_PV组模型和全骨骼以及控制器" -label "制作 SK_Weapon_武器名_皮肤名_PV_版本.fbx" WTABFMframeLayout5;
				separator -parent WTABFMframeLayout5 -h 1 -style "none";
				rowLayout -adj 2 -p WTABFMframeLayout5 -nc 3 -columnWidth3 50 250 25; 
