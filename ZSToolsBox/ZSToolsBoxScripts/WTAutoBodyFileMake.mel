		parent -w Weapon_LOD0;
		if (`objExists "Weapon_LOD"`)
		{
			delete "Weapon_LOD";
		}
		group -n "LOD_0" Weapon_LOD0;
		group -n "Weapon_LOD" LOD_0;
		select -r "Weapon_LOD";
	}else
	{
		select -r "Weapon_PV";
	}
	select -add "weapon";

	//刷新主视口，防止设置失效
	refresh -f -currentView;
	
	//删除无用材质-已确认导出不会包含无用材质所以无需清理
	//hyperShadePanelMenuCommand("hyperShadePanel1", "deleteUnusedNodes");
	RTEEFBXExport ( $RTEEExportSameNameArray[0] , $RTEEExportSamePath , 0 , 1 , 1 , 0 , 1 , 0 , 0 , 1 , 0);
}


//制作PV的Parasite文件（fbx）制作文件9
	//制作文件
global proc PVParasiteFbxMake ( string $PVParasiteFbxField , string $WTABFMcharactername , string $WTABFMcharacterskin , string $WTABFMparasitename ) 
{
	string $RTEEExportSamePath = `dirname $PVParasiteFbxField`;
	string $RTEEExportSamePathArray[] = stringToStringArray($PVParasiteFbxField, "/");
	string $RTEEExportSameNameArray[] = stringToStringArray(($RTEEExportSamePathArray[size($RTEEExportSamePathArray)-1]), ".");
	//将引用改为导入
	string $refs[] = `file -query -reference`;
	for ($ref in $refs)
	{
		file -importReference $ref;
	}

	//删除无用显示层
	select -r `ls -type "displayLayer"`;
	select -d defaultLayer;
	doDelete;

	//删除无用骨骼
	DeleteUnKeepBone ( $WTABFMcharactername , $WTABFMcharacterskin , "" , $WTABFMparasitename );

	//选择导出对象
	select -r "UnrealRoot";
	select -add "Parasite_PV";

	//刷新主视口，防止设置失效
	refresh -f -currentView;
	
	//删除无用材质-已确认导出不会包含无用材质所以无需清理
	//hyperShadePanelMenuCommand("hyperShadePanel1", "deleteUnusedNodes");
	RTEEFBXExport ( $RTEEExportSameNameArray[0] , $RTEEExportSamePath , 0 , 1 , 1 , 0 , 1 , 0 , 0 , 1 , 0);
}


