//引用对象
global proc SimpleTransfer()
{
	string $SourceAndTarget[] = `ls -sl`;
	select -r -hi $SourceAndTarget[0];
	string $Selections[] = `ls -sl`;
	for ($i = 0;$i < size($Selections); $i++)
	{
		if (`objectType $Selections[$i]` != "joint")
		{
			select -d $Selections[$i];
		}
	}
	$Selections = `ls -sl`;
	for ($i = 0;$i < size($Selections); $i++)
	{
		string $SourceObject = $Selections[$i];
		string $TargetObject = "Target:" + $Selections[$i];
		TransferConnection( $SourceObject, $TargetObject );
		TransferSubobjects( $SourceObject, $TargetObject );
	}
}

SimpleTransfer();