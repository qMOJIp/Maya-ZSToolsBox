//制作文件位置确定
global proc string SkinChoosePath (string $FileMessage[] , string $Part , string $FileLevel , string $WhatFile) 
{
	//获取Rig路径
	string $RigPath = substituteAllString($FileMessage[0], "/Rig/", "/Rig/@");
	string $RigPathArray[] = stringToStringArray($RigPath, "@");

	//获取文件版本
	string $FileVersionTmp[] = stringToStringArray($FileMessage[0], "_");
	string $FileVersion[] = stringToStringArray($FileVersionTmp[size($FileVersionTmp)-1], ".");

	//确定文件名开头
	string $FileTitle;
	string $FileName = $FileMessage[1];
	if ( $Part == "Weapon")
	{
		$FileTitle = "SK_Weapon_";
		$FileName = $FileMessage[2];
	}else
	{
		$FileTitle = "SK_Player_";
	}

	//确定文件部位
	string $FilePart = "";
	if ( $Part == "Body")
	{
		$FilePart = "Body_";
	}else if ( $Part == "Parasite")
	{
		if ( $FileMessage[3] == "")
		{
			$FilePart = "BYT_";
		}else
		{
			$FilePart = "BYT_" + $FileMessage[3] + "_";
		}
	}

	//确定最终路径
	string $PVBodyFbxField;
	if ( $FileLevel == "An" )
	{
		if ($FileMessage[4] == "Origin")
		{
			$PVBodyFbxField = $RigPathArray[0] + "AnimationUse/" + $FileTitle + $FileName + "_" + $FileMessage[4] + "_" + $FileLevel + "_" + $FileVersion[0] + "." + $WhatFile;
		}else
		{
			$PVBodyFbxField = $RigPathArray[0] + "AnimationUse/" + $Part + "/" + $FileMessage[4] + "/" + $FileTitle + $FileName + "_" + $FileMessage[4] + "_" + $FileLevel + "_" + $FileVersion[0] + "." + $WhatFile;
		}
	}else
	{
		$PVBodyFbxField = $RigPathArray[0] + "EngineUse/" + $Part + "/" + $FileMessage[4] + "/" + $FileTitle + $FileName + "_" + $FileMessage[4] + "_" + $FilePart + $FileLevel + "_" + $FileVersion[0] + "." + $WhatFile;
	}
	return $PVBodyFbxField;
}


//制作PV的Body文件（fbx）制作文件1
	//制作文件
global proc PVBodyMake ( string $PVBodyFbxField , string $WTABFMcharactername , string $WTABFMcharacterskin )
{
	string $RTEEExportSamePath = `dirname $PVBodyFbxField`;
	string $RTEEExportSamePathArray[] = stringToStringArray($PVBodyFbxField, "/");
	string $RTEEExportSameNameArray[] = stringToStringArray(($RTEEExportSamePathArray[size($RTEEExportSamePathArray)-1]), ".");
	//将引用改为导入
	string $refs[] = `file -query -reference`;
	for ($ref in $refs)
	{
		file -importReference $ref;
	}

	//设置Pose
	SelectSetObjectInf ( ".enginepose", $WTABFMcharactername , $WTABFMcharacterskin , "" );

	//删除无用显示层
	select -r `ls -type "displayLayer"`;
	select -d defaultLayer;
	doDelete;

	//选择导出对象
	select -r "UnrealRoot";
	select -add "Body_PV";
	if (`objExists "CSim_Group_PV"`)
	{
		select -add "CSim_Group_PV";
	}else if (`objExists "CSim_Group"` && !`objExists "CSim_Group_LOD"`)
	{
		select -add "CSim_Group";
	}

	//刷新主视口，防止设置失效
	refresh -f -currentView;
	
	RTEEFBXExport ( $RTEEExportSameNameArray[0] , $RTEEExportSamePath , 0 , 1 , 1 , 0 , 1 , 0 , 0 , 1 , 0);
}


//制作Game的Body文件（fbx）制作文件2
	//制作文件
global proc GameBodyMake ( string $GameBodyFbxField , string $WTABFMcharactername , string $WTABFMcharacterskin ) 
{
	string $RTEEExportSamePath = `dirname $GameBodyFbxField`;
	string $RTEEExportSamePathArray[] = stringToStringArray($GameBodyFbxField, "/");
	string $RTEEExportSameNameArray[] = stringToStringArray(($RTEEExportSamePathArray[size($RTEEExportSamePathArray)-1]), ".");
	//将引用改为导入
	string $refs[] = `file -query -reference`;
	for ($ref in $refs)
	{
		file -importReference $ref;
	}

	//设置Pose
	SelectSetObjectInf ( ".enginepose", $WTABFMcharactername , $WTABFMcharacterskin , "" );

	//删除无用显示层
	select -r `ls -type "displayLayer"`;
	select -d defaultLayer;
	doDelete;

	//选择导出对象
	select -r "UnrealRoot";
	select -add "Body_LOD0";
	if (`objExists "Body_LOD1"`)
	{
		select -add "Body_LOD1";
	}else
	{
		warning ("缺失 LOD1 ！！！\n");
	}
	if (`objExists "Body_LOD2"`)
	{
		select -add "Body_LOD2";
	}else
	{
		warning ("缺失 LOD2 ！！！\n");
	}
	if (`objExists "Body_LOD3"`)
	{
		select -add "Body_LOD3";
	}else
	{
		warning ("缺失 LOD3 ！！！\n");
	}
	if (`objExists "Body_LOD4"`)
	{
		select -add "Body_LOD4";
	}else
	{
		warning ("缺失 LOD4 ！！！\n");
	}
	if (`objExists "CSim_Group_LOD"`)
	{
		select -add "CSim_Group_LOD";
	}else if (`objExists "CSim_Group"` && !`objExists "CSim_Group_PV"`)
	{
		select -add "CSim_Group";
	}

	//刷新主视口，防止设置失效
	refresh -f -currentView;

	//删除无用材质-已确认导出不会包含无用材质所以无需清理
	//hyperShadePanelMenuCommand("hyperShadePanel1", "deleteUnusedNodes");
	RTEEFBXExport ( $RTEEExportSameNameArray[0] , $RTEEExportSamePath , 0 , 1 , 1 , 0 , 1 , 0 , 0 , 1 , 0);
}


//制作An的Body文件（ma）制作文件3
	//制作文件
global proc AnBodyMaMake ( string $AnBodyMaField , string $BodyAlltextField , string $WTABFMcharactername , string $WTABFMcharacterskin , string $ParasiteLodFile[] ) 
{
	//将引用改为导入
	string $refs[] = `file -query -reference`;
	for ($ref in $refs)
	{
		file -importReference $ref;
	}

	//导入所有变异体
	for ($i=0; $i<size($ParasiteLodFile); $i++)
	{
		file -namespace ":" -f -import -options "v=0" $ParasiteLodFile[$i];
		print ("导入:" + $ParasiteLodFile[$i] + "\n");
	}
	parent -w "Parasite_LOD0";

	//设置Pose
	SelectSetObjectInf ( ".bodypose", $WTABFMcharactername , $WTABFMcharacterskin , "" );

	//刷新主视口，防止设置失效
	refresh -f -currentView;

	//防止导出含LOD组
	parent -w "Body_LOD0";

	//获取动画用头
	string $FacialAllFile = `optionVar -q WTFileName` + dirname((dirname($BodyAlltextField))) + "/Facial/SK_Player_" + $WTABFMcharactername + "_Origin_Facial_All_01.ma";
	Faceweightshift ( $FacialAllFile , $WTABFMcharactername , "Facial_LOD0" , "Facial_LOD0" );

	//删除无用显示层
	select -r `ls -type "displayLayer"`;
	select -d defaultLayer;
	doDelete;
	
	//路径不存在则创建
	if (!`file -exists -q (dirname($AnBodyMaField))`)
	{
		system("mkdir \"" + dirname($AnBodyMaField) + "\"");
		print("当前路径不存在但已创建。\n");
	}

	//选择导出对象
	select -r "UnrealRoot";
	select -add "Group";
	select -add "Body_LOD0";
	select -add "Parasite_LOD0";
	select -add "Facial_LOD0";
	select -add -ne "Sets";
	file -f -options "v=0;" -typ "mayaAscii" -es $AnBodyMaField;

	//重新打开制作文件检查无关保存
	file -f -open -options "v=0;" $AnBodyMaField;

	SelectUserCreateRoot();
	select -d "UnrealRoot";
	select -d "Group";
	select -d "Body_LOD0";
	select -d "Parasite_LOD0";
	select -d "Facial_LOD0";
	select -d -ne "Sets";
	doDelete;
	SaveScene;
	print ($AnBodyMaField + "已制作完成！\n");
}


