"\t\tfrom shiboken6 import wrapInstance; from PySide6.QtGui import QIcon; from PySide6.QtWidgets import QWidget;\n" + 
"\t\twidget = wrapInstance(int(qw), QWidget); icon = QIcon(win_icon); widget.setWindowIcon(icon);\n" + 
"\texcept ImportError:\n" + "\t\ttry:\n" + 
"\t\t\tfrom shiboken2 import wrapInstance; from PySide2.QtGui import QIcon; from PySide2.QtWidgets import QWidget;\n" + 
"\t\t\twidget = wrapInstance(int(qw), QWidget); icon = QIcon(win_icon); widget.setWindowIcon(icon);\n" + 
"\t\texcept ImportError:\n" + "\t\t\tpass\n" + "");

}

