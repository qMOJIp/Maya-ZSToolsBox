global proc CopyFileToPre () 
{
	string $WTFileName = `optionVar -q WTFileName`;
	string $Charactername = `textField -q -tx charactername`;
	string $Characternum = `textField -q -tx characternum`;
	string $CeresRigtextField = `textField -q -tx CeresRigtextField`;
	string $AimPreFilePath = "Z:/WT/WT_maya/scenes/Rig/Player/" + $Characternum;
	//老版命名格式文件
	string $PreOldFilePaths[] = {
		$WTFileName + $CeresRigtextField + "/Origin/PV/SK_Player_" + $Charactername + "_White_Origin_Facial_PV_01.ma",
		$WTFileName + $CeresRigtextField + "/Origin/An/SK_Player_" + $Charactername + "_White_Origin_Facial_An_01.dna",
		$WTFileName + $CeresRigtextField + "/Origin/An/SK_Player_" + $Charactername + "_White_Origin_An_01.fbx",
		$WTFileName + $CeresRigtextField + "/Origin/An/SK_Player_" + $Charactername + "_White_Origin_An_01.ma"
	};

	//新版命名格式文件
	string $PreFilePaths[] = {
		$WTFileName + $CeresRigtextField + "/Origin/PV/SK_Player_" + $Charactername + "_Origin_Facial_PV_01.ma",
		$WTFileName + $CeresRigtextField + "/Origin/An/SK_Player_" + $Charactername + "_Origin_Facial_An_01.dna",
		$WTFileName + $CeresRigtextField + "/Origin/An/SK_Player_" + $Charactername + "_Origin_An_01.fbx",
		$WTFileName + $CeresRigtextField + "/Origin/An/SK_Player_" + $Charactername + "_Origin_An_01.ma"
	};

	if ($Charactername == "")
	{
		error ("请载入角色数据！\n");
	}else
	{
		string $FilePath = `textField -q -tx errorlog`;
		int $existsPath = `file -exists -q $FilePath`;
		if (!$existsPath) {
			system("mkdir \"" + $FilePath + "\"");
			warning("当前文件路径已创建并打开\n");
		}
		//检查拷贝的文件是否存在本地文件
		int $RunKey = 1;
		for ($i = 0 ; $i < size($PreFilePaths); $i++)
		{
			int $existsNewField = `file -exists -q $PreFilePaths[$i]`;
			int $existsOldField = `file -exists -q $PreOldFilePaths[$i]`;
			if (!$existsNewField && !$existsOldField)
			{
				$RunKey = 0;
				warning("本地未存在 " + $PreFilePaths[$i] + "或" + $PreOldFilePaths[$i] + "\n");
			}else
			{
				continue;
			}
		}
		
		if ($RunKey == 1){
			for ($i = 0 ; $i < size($PreFilePaths); $i++)
			{
				int $existsNewField = `file -exists -q $PreFilePaths[$i]`;
				if (!$existsNewField)
				{
					$PreOldFilePaths[$i] = toNativePath($PreOldFilePaths[$i]);
					$AimPreFilePath = toNativePath($AimPreFilePath);
					system("copy \"" + $PreOldFilePaths[$i] + "\" \"" + $AimPreFilePath + "\"");
				}else
				{
					$PreFilePaths[$i] = toNativePath($PreFilePaths[$i]);
					$AimPreFilePath = toNativePath($AimPreFilePath);
					system("copy \"" + $PreFilePaths[$i] + "\" \"" + $AimPreFilePath + "\"");
				}
			}
			print ("成功拷贝至" + $FilePath + "\n");
		}
	}
}

global proc openfilepath () 
{
	string $FilePath = `textField -q -tx errorlog`;
	int $existsPath = `file -exists -q $FilePath`;
	if (!$existsPath) {
		system("mkdir \"" + $FilePath + "\"");
		system("explorer \"" + $FilePath + "\"");
		warning("当前文件路径已创建路径并打开\n");
	} else {
		system("explorer \"" + $FilePath + "\"");
		print("打开预设文件路径\n");
	}
}

global proc flush () 
{
	string $Characternum = `textField -q -tx characternum`;
	string $FilePath = "Z:\\WT\\WT_maya\\scenes\\Rig\\Player\\" + $Characternum;
	textField -e -tx $FilePath errorlog; 
	print ("刷新日志路径完成！\n");
}

global proc MakeCheckBoxFile()  
{ 
	string $Characterfilename;
	string $Characternum = `textField -q -tx characternum`;
	string $Charactername = `textField -q -tx charactername`;
	int $StartKey = 1;
	string $AimPreFilePathWin = "Z:\\WT\\WT_maya\\scenes\\Rig\\Player\\" + $Characternum;
	string $AimPreFilePath = "Z:/WT/WT_maya/scenes/Rig/Player/" + $Characternum;
	string $SaveFacialAnMa = "Z:\\WT\\WT_maya\\scenes\\Rig\\Player\\" + $Characternum + "\\SK_Player_" + $Charactername + "_Origin_Facial_An_01.ma";
	string $SaveBodyWithFacialAnMa = "Z:\\WT\\WT_maya\\scenes\\Rig\\Player\\" + $Characternum + "\\SK_Player_" + $Charactername + "_Origin_BodyWithFacial_An_01.ma";
	$FacialKey = `checkBox -q -v FacialcheckBox`;
	$BodyWithFacialKey = `checkBox -q -v BodyWithFacialcheckBox`;

	//老版命名格式文件
	string $PreOldFilePaths[] = {
		"SK_Player_" + $Charactername + "_White_Origin_Facial_PV_01.ma",
		"SK_Player_" + $Charactername + "_White_Origin_Facial_An_01.dna",
		"SK_Player_" + $Charactername + "_White_Origin_An_01.fbx",
		"SK_Player_" + $Charactername + "_White_Origin_An_01.ma"
	};
	string $fullOldPaths[];
	for ($i = 0; $i < size($PreOldFilePaths); $i++) {
		$fullOldPaths[$i] = $AimPreFilePath + "/" + $PreOldFilePaths[$i];
	}

	//新版命名格式文件
	string $PreFilePaths[] = {
		"SK_Player_" + $Charactername + "_Origin_Facial_PV_01.ma",
		"SK_Player_" + $Charactername + "_Origin_Facial_An_01.dna",
		"SK_Player_" + $Charactername + "_Origin_An_01.fbx",
		"SK_Player_" + $Charactername + "_Origin_An_01.ma"
	};
	string $fullPaths[];
	for ($i = 0; $i < size($PreFilePaths); $i++) {
		$fullPaths[$i] = $AimPreFilePath + "/" + $PreFilePaths[$i];
	}

	//检测角色对应路径是否存在并创建
	int $existsPath = `file -exists -q $AimPreFilePathWin`;
	if (!$existsPath) {
		system("mkdir \"" + $AimPreFilePathWin + "\"");
		system("explorer \"" + $AimPreFilePathWin + "\"");
	} else {
		system("explorer \"" + $AimPreFilePathWin + "\"");
	}

	//检查预备文件是否存在
	for ($i = 0; $i < size($fullPaths); $i++) {
		int $existsOldNameFile = `file -exists -q $fullOldPaths[$i]`;
		int $existsNewNameFile = `file -exists -q $fullPaths[$i]`;
		if (!$existsNewNameFile && !$existsOldNameFile) {
			warning($PreOldFilePaths[$i] + " 或 " + $PreFilePaths[$i] + " 文件不存在，请从 Ceres 获取该文件并拷贝于 " + $AimPreFilePath + "\n");
			$StartKey = 0;
		}
	}
	
	//
	if ($StartKey == 1)
	{
		if ($FacialKey == 1)
		{
			//创建一个新场景
			file -f -new;
			
			//不带名称空间打开PVFacialMa文件
			int $existsOldNamePVFacialMa = `file -exists -q $fullOldPaths[0]`;
			if (!$existsOldNamePVFacialMa) {
				file -open -options "v=0;" $fullPaths[0];
			} else {
				file -open -options "v=0;" $fullOldPaths[0];
			}
			
			//设置场景Y轴朝上
			upAxis -ax y -rv;
			//设置关节旋转值
			setAttr "UnrealRoot.jointOrientX" -90;
			//居中场景
			viewSet -animate 0 -home;
			viewFit -animate 0 -all;
			
			//导入dna文件
			int $existsOldNameDNA = `file -exists -q $fullOldPaths[1]`;
			if (!$existsOldNameDNA) {
				python ("import sys\n" + "path_ = 'D:/Backup/Documents/Megascans Library/support/plugins/maya/7.2/MSLiveLink'\n" + "if path_ not in sys.path:" + "sys.path.append( path_ )\n" + "from DHI.RigSetup import RigBuilder\n" + "builder = RigBuilder()\n" + "builder.build( '" + $fullPaths[1] + "' )");
			} else {
				python ("import sys\n" + "path_ = 'D:/Backup/Documents/Megascans Library/support/plugins/maya/7.2/MSLiveLink'\n" + "if path_ not in sys.path:" + "sys.path.append( path_ )\n" + "from DHI.RigSetup import RigBuilder\n" + "builder = RigBuilder()\n" + "builder.build( '" + $fullOldPaths[1] + "' )");
			}

			//对导入dna数据产生的对象进行打组
			select -cl;
			select -r GRP_faceGUI GRP_C_eyesAim LOC_C_eyeDriver L_lookDirection R_lookDirection L_lookDirStartHandle L_lookDirEndHandle R_lookDirStartHandle R_lookDirEndHandle;
			group -w -name "DNA_Group";

			//获取Head_M的世界坐标并将其数据设置到CTRL_faceGUI
			vector $Head_MworldPos = `xform -q -ws -t Head_M`;
			setAttr CTRL_faceGUI.t 50 ($Head_MworldPos.y) ($Head_MworldPos.z);
			
			//添加PV和LOD的显示层
			select -cl;
			select -r LOD_PV;
			createDisplayLayer -name "PV" -number 1;
			select -cl;
			select -r ($Charactername + "_LOD");
			createDisplayLayer -name "LOD" -number 2;

			//保存文件
			file -force -pr -typ "mayaAscii" -ea $SaveFacialAnMa;
		}

		if ($BodyWithFacialKey == 1)
		{
			//创建一个新场景
			file -f -new;

			//带名称空间引用刚制作的ma文件
			string $FacialAnNamespace = $Charactername + "_Facial_An";
			file -reference -namespace $FacialAnNamespace $SaveFacialAnMa;
			
			//不带名称空间引用动捕文件
			int $existsANBodyFbx = `file -exists -q $fullOldPaths[2]`;
			if (!$existsANBodyFbx) {
				file -reference -namespace ":" $fullPaths[2];
			} else {
				file -reference -namespace ":" $fullOldPaths[2];
			}

			//带名称空间引用ANBodyMa
			int $existsANBodyMa = `file -exists -q $fullOldPaths[3]`;
			if (!$existsANBodyMa) {
				file -reference -namespace "" $fullPaths[3];
			} else {
				file -reference -namespace "" $fullOldPaths[3];
			}
			
			//选择所有模型对象
			select `ls -type mesh`;
			//取消选择除角色An版fbx文件的所有模型对象
			string $selection1[] = `ls -sl`;
			for ($i = 0; $i < size($selection1); $i++)
			{
				if(`gmatch $selection1[$i] ("*:*")` != 0) 
				{
					select -d $selection1[$i];
				}
			}
			$selection1 = `ls -sl`;
			//选择模型对象而不是mesh节点
			string $selection1mesh[] = `listRelatives -p  $selection1`;
			select $selection1mesh;
			//隐藏选定对象
			hide;

			//开始执行约束
			OnlyRunConstrain();
			
			//保存文件
			file -force -pr -typ "mayaAscii" -ea $SaveBodyWithFacialAnMa;
			
			//创建一个新场景
			//file -f -new;
			//
			//file -open -options "v=0;" $SaveBodyWithFacialAnMa;
		}
	}
}

global proc OnlyRunConstrain()  
{
	string $Characternum = `textField -q -tx characternum`;
	string $Charactername = `textField -q -tx charactername`;
	string $NewBodyAnMaPaths = "Z:/WT/WT_maya/scenes/Rig/Player/" + $Characternum + "/SK_Player_" + $Charactername + "_Origin_An_01.ma";
	int $existsNameSpace = `file -exists -q $NewBodyAnMaPaths`;
	string $NameSpace;
	if (!$existsNameSpace) {	
		$NameSpace = "SK_Player_" + $Charactername + "_White_Origin_An_01:";
	}else{
		$NameSpace = "SK_Player_" + $Charactername + "_Origin_An_01:";
	}
	//创建日志文件
	string $errorFileCreate = "Z:\\WT\\WT_maya\\scenes\\Rig\\Player\\" + $Characternum + "\\Error_Log.txt";
	int $existslog = `file -exists -q $errorFileCreate`;
	if ($existslog) {
		//清空日志内容
		$fileIdC=`fopen $errorFileCreate "w"`;
		fprint $fileIdC "";
		fclose $fileIdC;
	}
	//写入日志
	$fileId=`fopen $errorFileCreate "a"`;

	//“角色An版fbx文件”的骨骼 批量约束 “角色An版ma文件”的控制器
	string $jeuseanfbxboneSpace = "";
	string $jeuseanmactrlSpace = $NameSpace;
	string $jeuseanfbxbone[];
	string $jeuseanmactrl[];
	int $ConstrainBodyControlKey = 1;
	
	for ($i = 0; $i < 70; $i++)
	{
		$jeuseanfbxbone[$i] = `textField -q -tx ("sourceConstrain1" + $i)`;
		$jeuseanmactrl[$i] = `textField -q -tx ("targetConstrain1" + $i)`;
		string $parentsource = $jeuseanfbxboneSpace + $jeuseanfbxbone[$i];
		string $parenttarget = $jeuseanmactrlSpace + $jeuseanmactrl[$i];
		if ($jeuseanfbxbone[$i] == "" || $jeuseanmactrl[$i] == "")
		{
			continue;
		}else {
			if (objExists($parentsource)) 
			{
				print ("对象 " + $parentsource + " 存在。\n");
			}else{
				fprint $fileId ("对象 " + $parentsource + " 不存在。\n");
				warning ("对象 " + $parentsource + " 不存在。\n");
				$ConstrainBodyControlKey = 0;
			}
			if (objExists($parenttarget)) 
			{
				print ("对象 " + $parenttarget + " 存在。\n");
			}else{
				fprint $fileId ("对象 " + $parenttarget + " 不存在。\n");
				warning ("对象 " + $parenttarget + " 不存在。\n");
				$ConstrainBodyControlKey = 0;
			}
		}
	}

	//条件满足开始执行约束
	if ($ConstrainBodyControlKey ==1)
	{
		for ($i = 0; $i < 70; $i++)
		{
			$jeuseanfbxbone[$i] = `textField -q -tx ("sourceConstrain1" + $i)`;
			$jeuseanmactrl[$i] = `textField -q -tx ("targetConstrain1" + $i)`;
			string $parentsource = $jeuseanfbxboneSpace + $jeuseanfbxbone[$i];
			string $parenttarget = $jeuseanmactrlSpace + $jeuseanmactrl[$i];
			if ($jeuseanfbxbone[$i] == "" || $jeuseanmactrl[$i] == "")
			{
				continue;
			}else {
				if ($jeuseanfbxbone[$i] != "" && $jeuseanmactrl[$i] != "")
				{
					parentConstraint -mo -w 1.0 $parentsource $parenttarget;
				}
			}
			print ("成功执行约束：" + $parentsource + "和" + $parenttarget + "\n");
		}
	}

	//“角色An版ma文件”的骨骼 批量约束 “第2步制作的ma文件”的骨骼
	 
	string $jeuseanmaboneSpace = $NameSpace;
	//string $headmaboneSpace = "SK_Player_" + $Charactername + "_Origin_Facial_An_01:";
	string $headmaboneSpace = $Charactername + "_Facial_An:";
	string $jeuseanmabone[];
	string $headmabone[];
	int $ConstrainBodyToFacialKey = 1;
	 
	for ($i = 0; $i < 30; $i++) 
	{
		$jeuseanmabone[$i] = `textField -q -tx ("sourceConstrain2" + $i)`;
		$headmabone[$i] = `textField -q -tx ("targetConstrain2" + $i)`;
		string $parentsource1 = $jeuseanmaboneSpace + $jeuseanmabone[$i];
		string $parenttarget1 = $headmaboneSpace + $headmabone[$i];
		if ($jeuseanmabone[$i] == "" || $headmabone[$i] == "")
		{
			continue;
		}else {
			if (objExists($parentsource1)) 
			{
				print ("对象 " + $parentsource1 + " 存在。\n");
			}else{
				fprint $fileId ("对象 " + $parentsource1 + " 不存在。\n");
				warning ("对象 " + $parentsource1 + " 不存在。\n");
				$ConstrainBodyToFacialKey = 0;
			}
			if (objExists($parenttarget1)) 
			{
				print ("对象 " + $parenttarget1 + " 存在。\n");
			}else{
				fprint $fileId ("对象 " + $parenttarget1 + " 不存在。\n");
				warning ("对象 " + $parenttarget1 + " 不存在。\n");
				$ConstrainBodyToFacialKey = 0;
			}
		}
	}
	fclose $fileId;//写出完日志

	//条件满足开始执行约束
	if ($ConstrainBodyToFacialKey == 1)
	{
		for ($i = 0; $i < 30; $i++) 
		{
			$jeuseanmabone[$i] = `textField -q -tx ("sourceConstrain2" + $i)`;
			$headmabone[$i] = `textField -q -tx ("targetConstrain2" + $i)`;
			string $parentsource1 = $jeuseanmaboneSpace + $jeuseanmabone[$i];
			string $parenttarget1 = $headmaboneSpace + $headmabone[$i];
			if ($jeuseanmabone[$i] == "" || $headmabone[$i] == "")
			{
				continue;
			}else {
				if ($jeuseanfbxbone[$i] != "" && $jeuseanmactrl[$i] != "")
				{
					parentConstraint -mo -w 1.0 $parentsource1 $parenttarget1;
				}
			}
			print ("成功执行约束：" + $parentsource1 + "和" + $parenttarget1 + "\n");
		}
	}
}

WTAutoFacialFileMake;