//ЕзРИ
global proc createStatusBar ()
{
	rowColumnLayout -numberOfColumns 6 -adjustableColumn 3 -columnWidth 1 65 -columnWidth 2 55 -columnWidth 3 411 -columnWidth 4 100 -columnWidth 5 102 -columnWidth 6 101;
		text -label "ОЭаї" -align "left" MFBShowFileTotal;
		text -label "" -align "left" MFBStatusLabel;
		text -label "" -align "left" MFBShowPathtext;
		text -label "" MFBFileSizetext;
		button -label "ШЗЖЈЯдЪОТЗОЖ" -command "returnFileBrowser" MFBConfirmdisplaypath;
		button -label "ВйзїбЁжаЮФМў" -command "еМЮЛЗћ";
	setParent ..;
}

