		RefreshPath ();
	}
}

//自动读取文件类型
global proc WTABFMAutoReadFileType () 
{
	popupMenu -button 3 -p WTABFMcharacterskin FileTypePathpopupMenu;
	string $FileTypemenuItems[] = `popupMenu -query -itemArray FileTypePathpopupMenu`;
	for ($c=0; $c<size($FileTypemenuItems); $c++)
	{
		string $menuItems[] = `menu -query -itemArray ("WTABFMFileTypeMenuItem" + $c)`;
		for ($d=0; $d<size($menuItems); $d++)
		{
			deleteUI ("WTABFMFileTypeMenuItem" + $c + "_" + $d);
			deleteUI ("WTABFMFileTypeMenuItemoptionBox" + $c + "_" + $d);
		}
		deleteUI ("WTABFMFileTypeMenuItem" + $c);
	}
	string $WTABFMFileTypePath = "//192.168.20.102/projects/CIDA_RG/020 绑定公共数据/RigAll角色数据/CharacterToAttachment/FileType.txt";
	//获取储存文件每行内容
	string $lines[];
	int $fileId = `fopen $WTABFMFileTypePath "r"`;
	int $i = 0;
	while (!`feof $fileId`)
	{
		$lines[$i] = `fgetline $fileId`;
		string $WTABFMFileTypePart[] = stringToStringArray($lines[$i], "==>");
		string $WTABFMFileTypeSkin[] = stringToStringArray($WTABFMFileTypePart[1], ",");
		menuItem -label $WTABFMFileTypePart[0] -to 1 -subMenu 1 ("WTABFMFileTypeMenuItem" + $i);
		for ($a=0; $a<size($WTABFMFileTypeSkin); $a++)
		{
			$WTABFMFileTypeSkin[$a] = strip($WTABFMFileTypeSkin[$a]);
			menuItem -label $WTABFMFileTypeSkin[$a] -ann "按部位解锁/按皮肤解锁" -c ("textField -e -tx " + $WTABFMFileTypeSkin[$a] +  " WTABFMcharacterskin;RefreshInf;LockMakeFile (" + $i + ", \"\" )") ("WTABFMFileTypeMenuItem" + $i + "_" + $a);
			menuItem -label $WTABFMFileTypeSkin[$a] -ann "按部位解锁/按皮肤解锁" -optionBox 1 -c ("textField -e -tx " + $WTABFMFileTypeSkin[$a] +  " WTABFMcharacterskin;RefreshInf;LockMakeFile (" + $i + ", \"" + $WTABFMFileTypeSkin[$a] + "\" )") ("WTABFMFileTypeMenuItemoptionBox" + $i + "_" + $a);
		}
		setParent -menu ..;
		$i++;
	}
	menuItem -label "显示全部" -c ("LockMakeFile ( -1 , \"\" )") WTABFMFileTypeMenuItemoptionBoxShowAll;
}

//自动读取名称和皮肤
global proc string WTABFMEnter1 ( string $BodyAlltextField ) 
{
	string $ReturnValue;
	//获取RigAll路径
	if ($BodyAlltextField == "")
	{
		$BodyAlltextField = `textField -q -tx BodyAlltextField`;
	}else
	{
		$BodyAlltextField = $BodyAlltextField;
	}
	if ($BodyAlltextField == "")
	{
		error ("请输入 Rig All 文件 Ceres 路径！！！\n");
	}
	$BodyAlltextField = fromNativePath($BodyAlltextField);

	//获取设置角色和武器名字
	string $WTABFMweaponnamePath = "//192.168.20.102/projects/CIDA_RG/020 绑定公共数据/RigAll角色数据/CharacterToAttachment/CharacterToWeapon.txt";
	//获取储存文件每行内容
	global string $WeaponNameArray[];
	$WeaponNameArray = {};
	string $lines[];
	int $fileId;
	int $i = 0;
	if (`gmatch $BodyAlltextField ("*SK_Weapon_*")`)
	{
		string $BodyAlltextFieldArray[] = stringToStringArray( $BodyAlltextField, "/" );
		string $WeaponInfArray[] = stringToStringArray( $BodyAlltextFieldArray[size($BodyAlltextFieldArray)-1], "_" );
		string $WeaponName = $WeaponInfArray[2];
		for ($b = 3; $b < (size($WeaponInfArray)-3); $b++)
		{
			$WeaponName = $WeaponName + "_" + $WeaponInfArray[$b];
		}
		$fileId = `fopen $WTABFMweaponnamePath "r"`;
		while (!`feof $fileId`)
		{
			$lines[$i] = `fgetline $fileId`;
			if (`gmatch $lines[$i] ("*" + $WeaponName + "*")`)
			{
				string $WTABFMweaponname[] = stringToStringArray($lines[$i], "==>");
				$ReturnValue = $WTABFMweaponname[0];
			}
			$i++;
		}
		fclose $fileId;
		textField -e -tx $ReturnValue WTABFMcharactername;
		textField -e -tx $WeaponName WTABFMweaponname;
	}else
	{
		string $BodyAlltextFieldArray[] = stringToStringArray( $BodyAlltextField, "/" );
		string $CharacterInfArray[] = stringToStringArray( $BodyAlltextFieldArray[size($BodyAlltextFieldArray)-1], "_" );
		$ReturnValue = $CharacterInfArray[2];
		textField -e -tx $ReturnValue WTABFMcharactername;
	}
	$fileId = `fopen $WTABFMweaponnamePath "r"`;
	global int $a = 0;
	$i = 0;
	while (!`feof $fileId`)
	{
		$lines[$i] = `fgetline $fileId`;
		if (`gmatch $lines[$i] ("*" + $ReturnValue + "*")`)
		{
			string $WTABFMweaponname[] = stringToStringArray($lines[$i], "==>");
			$WeaponNameArray[$a] = strip($WTABFMweaponname[1]);
			$a = $a + 1;
		}
		$i++;
	}
	fclose $fileId;
	// 删除空项
	$WeaponNameArray = removeEmptyElements($WeaponNameArray);
	popupMenu -button 3 -p WTABFMweaponname weaponnamepopupMenu;
	string $weaponmenuItems[] = `popupMenu -query -itemArray weaponnamepopupMenu`;
	for ($c=0; $c<size($weaponmenuItems); $c++)
	{
		deleteUI ("weaponnamepopupMenu" + $c);
	}
	for ($c=0; $c<size($WeaponNameArray); $c++)
	{
		menuItem -label $WeaponNameArray[$c] -c ("textField -e -tx (strip(" + $WeaponNameArray[$c] +  ")) WTABFMweaponname;RefreshInf;") -p weaponnamepopupMenu ("weaponnamepopupMenu" + $c);
	}
	if (!`gmatch $BodyAlltextField ("*SK_Weapon_*")`)
	{
		textField -e -tx (strip($WeaponNameArray[0])) WTABFMweaponname;
	}

	//获取设置变异体名
	string $WTABFMparasitenamePath = "//192.168.20.102/projects/CIDA_RG/020 绑定公共数据/RigAll角色数据/CharacterToAttachment/CharacterToParasite.txt";
	//获取储存文件每行内容
	global string $ParasiteNameArray[];
	$ParasiteNameArray = {};
	string $Parasitelines[];
	int $ParasitefileId = `fopen $WTABFMparasitenamePath "r"`;
	int $Parasitei = 0;
	global int $Parasitea = 0;
	while (!`feof $ParasitefileId`)
	{
		$Parasitelines[$Parasitei] = `fgetline $ParasitefileId`;
		if (`gmatch $Parasitelines[$Parasitei] ("*" + $ReturnValue + "*")`)
		{
			string $WTABFMparasitename[] = stringToStringArray($Parasitelines[$Parasitei], "==>");
			$ParasiteNameArray[$Parasitea] = strip($WTABFMparasitename[1]);
			$Parasitea = $Parasitea + 1;
		}
		$Parasitei++;
	}
	fclose $ParasitefileId;
	// 删除空项
	$ParasiteNameArray = removeEmptyElements($ParasiteNameArray);
	popupMenu -button 3 -p WTABFMparasitename ParasitenamepopupMenu;
	string $ParasitemenuItems[] = `popupMenu -query -itemArray ParasitenamepopupMenu`;
	for ($c=0; $c<size($ParasitemenuItems); $c++)
	{
		deleteUI ("ParasitenamepopupMenu" + $c);
	}
	for ($c=0; $c<size($ParasiteNameArray); $c++)
	{
		menuItem -label $ParasiteNameArray[$c] -c ("textField -e -tx " + $ParasiteNameArray[$c] +  " WTABFMparasitename;RefreshInf;") -p ParasitenamepopupMenu ("ParasitenamepopupMenu" + $c);
	}
	textField -e -tx (strip($ParasiteNameArray[0])) WTABFMparasitename;
	RefreshInf ();
	//设定返回值
	return $ReturnValue;
}

//刷新数据
global proc RefreshInf () 
{
	string $WTABFMBodyAlltextField = `textField -q -tx BodyAlltextField`;
	string $WTABFMcharactername = `textField -q -tx WTABFMcharactername`;
	if ($WTABFMcharactername == "")
	{
		$WTABFMcharactername = "角色名";
	}
	string $WTABFMweaponname = `textField -q -tx WTABFMweaponname`;
	if ($WTABFMweaponname == "")
	{
		$WTABFMweaponname = "武器名";
	}
	string $WTABFMparasitename = `textField -q -tx WTABFMparasitename`;
	string $WTABFMcharacterskin = `textField -q -tx WTABFMcharacterskin`;
	if ($WTABFMcharacterskin == "")
	{
		$WTABFMcharacterskin = "皮肤名";
	}

	//获取文件版本
	string $FileVersion[] = {"版本"};
	if (`textField -q -tx BodyAlltextField` != "")
	{
		string $FileVersionTmp[] = stringToStringArray($WTABFMBodyAlltextField, "_");
		$FileVersion = stringToStringArray($FileVersionTmp[size($FileVersionTmp)-1], ".");
	}

	//检测是否有数据
	string $RigAllMessagePath = "//192.168.20.102/projects/CIDA_RG/020 绑定公共数据/RigAll角色数据/";
	string $AnPoseMessage1Path = $RigAllMessagePath + $WTABFMcharactername + "_" + $WTABFMcharacterskin + ".bodypose";
	string $AnPoseMessage2Path = $RigAllMessagePath + $WTABFMcharactername + "_" + $WTABFMcharacterskin + "_" + $WTABFMweaponname + ".weaponpose";
	string $AnPoseMessage3Path = $RigAllMessagePath + $WTABFMcharactername + "_" + $WTABFMcharacterskin + ".enginepose";
	string $KeepBoneMessage1Path = $RigAllMessagePath + $WTABFMcharactername + "_" + $WTABFMcharacterskin + "_" + $WTABFMweaponname + ".weaponkeepbone";
	string $KeepBoneMessage2Path;
	if (`textField -q -tx WTABFMparasitename` == "" )
	{
		$KeepBoneMessage2Path = $RigAllMessagePath + $WTABFMcharactername + "_" + $WTABFMcharacterskin + ".parasitekeepbone";
	}else
	{
		$KeepBoneMessage2Path = $RigAllMessagePath + $WTABFMcharactername + "_" + $WTABFMcharacterskin + "_" + $WTABFMparasitename + ".parasitekeepbone";
	}
	if (`file -exists -q $AnPoseMessage1Path`)
	{
		button -e -bgc 0.265 0 0 ShowEditAnPoseframeLayout3button;
		button -e -bgc 0.265 0 0 ShowEditAnPoseframeLayout4button;
	} else
	{
		button -e -bgc 0.265 0.265 0.265 ShowEditAnPoseframeLayout3button;
		button -e -bgc 0.265 0.265 0.265 ShowEditAnPoseframeLayout4button;
	}
	if (`file -exists -q $AnPoseMessage2Path`)
	{
		button -e -bgc 0.265 0 0 ShowEditAnPoseframeLayout5button;
		button -e -bgc 0.265 0 0 ShowEditAnPoseframeLayout6button;
		button -e -bgc 0.265 0 0 ShowEditAnPoseframeLayout7button;
		button -e -bgc 0.265 0 0 ShowEditAnPoseframeLayout8button;
	} else
	{
		button -e -bgc 0.265 0.265 0.265 ShowEditAnPoseframeLayout5button;
		button -e -bgc 0.265 0.265 0.265 ShowEditAnPoseframeLayout6button;
		button -e -bgc 0.265 0.265 0.265 ShowEditAnPoseframeLayout7button;
		button -e -bgc 0.265 0.265 0.265 ShowEditAnPoseframeLayout8button;
	}
	if (`file -exists -q $AnPoseMessage3Path`)
	{
		button -e -bgc 0.265 0 0 ShowEditAnPoseframeLayout1button;
		button -e -bgc 0.265 0 0 ShowEditAnPoseframeLayout2button;
		button -e -bgc 0.265 0 0 ShowEditAnPoseframeLayout9button;
		button -e -bgc 0.265 0 0 ShowEditAnPoseframeLayout10button;
	} else
	{
		button -e -bgc 0.265 0.265 0.265 ShowEditAnPoseframeLayout1button;
		button -e -bgc 0.265 0.265 0.265 ShowEditAnPoseframeLayout2button;
		button -e -bgc 0.265 0.265 0.265 ShowEditAnPoseframeLayout9button;
		button -e -bgc 0.265 0.265 0.265 ShowEditAnPoseframeLayout10button;
	}
	if (`file -exists -q $KeepBoneMessage1Path`)
	{
		button -e -bgc 0.265 0 0 ShowEditKeepBoneframeLayout1button;
		button -e -bgc 0.265 0 0 ShowEditKeepBoneframeLayout2button;
		button -e -bgc 0.265 0 0 ShowEditKeepBoneframeLayout3button;
		button -e -bgc 0.265 0 0 ShowEditKeepBoneframeLayout4button;
	} else
	{
		button -e -bgc 0.265 0.265 0.265 ShowEditKeepBoneframeLayout1button;
		button -e -bgc 0.265 0.265 0.265 ShowEditKeepBoneframeLayout2button;
		button -e -bgc 0.265 0.265 0.265 ShowEditKeepBoneframeLayout3button;
		button -e -bgc 0.265 0.265 0.265 ShowEditKeepBoneframeLayout4button;
	}
	if (`file -exists -q $KeepBoneMessage2Path`)
	{
		button -e -bgc 0.265 0 0 ShowEditKeepBoneframeLayout5button;
		button -e -bgc 0.265 0 0 ShowEditKeepBoneframeLayout6button;
	} else
	{
		button -e -bgc 0.265 0.265 0.265 ShowEditKeepBoneframeLayout5button;
		button -e -bgc 0.265 0.265 0.265 ShowEditKeepBoneframeLayout6button;
	}
	frameLayout -e -label ("制作 SK_Player_" + $WTABFMcharactername + "_" + $WTABFMcharacterskin + "_Body_PV_" + $FileVersion[0] + ".fbx") WTABFMframeLayout1;
	button -e -label ("制作 SK_Player_" + $WTABFMcharactername + "_" + $WTABFMcharacterskin + "_Body_PV_" + $FileVersion[0] + ".fbx") WTABFMbutton1;
	button -e -ann ("新建场景导入 SK_Player_" + $WTABFMcharactername + "_" + $WTABFMcharacterskin + "_Body_PV_" + $FileVersion[0] + ".fbx 文件") WTABFMcheckbutton1;
	frameLayout -e -label ("制作 SK_Player_" + $WTABFMcharactername + "_" + $WTABFMcharacterskin + "_Body_Lod_" + $FileVersion[0] + ".fbx") WTABFMframeLayout2;
	button -e -label ("制作 SK_Player_" + $WTABFMcharactername + "_" + $WTABFMcharacterskin + "_Body_Lod_" + $FileVersion[0] + ".fbx") WTABFMbutton2;
	button -e -ann ("新建场景导入 SK_Player_" + $WTABFMcharactername + "_" + $WTABFMcharacterskin + "_Body_Lod_" + $FileVersion[0] + ".fbx 文件") WTABFMcheckbutton2;
