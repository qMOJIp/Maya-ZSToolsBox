global proc SoftSelectToCluster_asInstallScriptLocator (){}

global proc string SoftSelectToCluster_asInstallScriptLocation ()
{
    string $Script_whatIs=`whatIs SoftSelectToCluster_asInstallScriptLocator`;
    string $Script_fullPath=`substring $Script_whatIs 25 999`;

    if ($Script_fullPath == "teractively.")
        {
            Running_Error;
        }

    string $Script_buffer[];
    string $Script_slash="/";
    if (`gmatch $Script_whatIs "*\\\\*"`)//sourced from ScriptEditor
        $Script_slash="\\";
    int $Script_numTok=`tokenize $Script_fullPath $Script_slash $Script_buffer`;
    int $Script_numLetters=size($Script_fullPath);
    int $Script_numLettersLastFolder=size($Script_buffer[$Script_numTok-1]);
    string $script_Location=`substring $Script_fullPath 1 ($Script_numLetters-$Script_numLettersLastFolder)`;
    return $script_Location;
}

global proc SoftSelectToCluster_AddToShelf()
{
    global string $gShelfTopLevel;
    string $current_Shelf = `tabLayout -query -st $gShelfTopLevel`;
    setParent $current_Shelf;
    string $Installscript_path=`SoftSelectToCluster_asInstallScriptLocation`;
    if (`gmatch $Installscript_path "*\*"`)
        $Installscript_path=`substituteAllString $Installscript_path "\\" "/"`;

    string $script_Name="ИнСЎФсґШ";
    
    string $shelfButtons[] = `shelfLayout -q -ca $current_Shelf`;
    int $buttonExists = 0;
    
    for ($button in $shelfButtons) {
        string $buttonType = `objectTypeUI $button`;
        if ($buttonType == "shelfButton") {
            string $buttonLabel = `shelfButton -q -label $button`;
            if ($buttonLabel == $script_Name) {
                $buttonExists = 1;
                break;
            }
        }
    }

    if ($buttonExists) {
        inViewMessage
            -a .9
            -smg ("<font color=\"orange\">ИнСЎФсґШ <font color=\"yellow\">"+ "ТСФЪ№¤ѕЯјЬЦРґжФЪ")
            -pos "topCenter"
            -bkc 0x00001100
            -fade
            -fadeInTime 100 -fadeStayTime 1200
            -fadeOutTime 600;
        return;
    }

    string $source_File=$Installscript_path+$script_Name+".mel";
    string $Script_Command=("//////// This script was created by Kreon ////////"+"\n\n"+
            "$source_cmd=\"source \\"+"\""+$source_File+"\\"+"\""+";"+"\""+";"+"\n\n"+
            "if (`file -q -ex \""+$source_File+"\"`)"+"\n"+
            "{"+"\n"+"\teval $source_cmd;"+"\n"+"}else{\n"+
            "\twarning -n (\"Г»УРХТµЅ:ИнСЎФсґШ.mel,"+
            "їЙДЬКЗЅЕ±ѕ±»ёДГыіЖ»тОДјюВ·ѕ¶±»ТЖ¶Ї\");"+"\n"+"}"+"\n\n"+
            "\t\t\t\t\t\t\t\t\t\t\t\t\t\t"+"/"+"/By Kreon");

    if (!`file -q -ex $source_File`)
             {
        warning ("\n"+"МнјУµЅ№¤ѕЯјЬК§°Ь, Г»УРХТµЅ: \""+$source_File+"\"");
             } else {
                shelfButton
                -stp "mel"
                -c $Script_Command
                -ann $script_Name
                -l $script_Name
                -iol $script_Name
                -i cluster.png
                -olb 0.2 0.2 0.2 1;
            }

    inViewMessage
        -a .9
        -smg ("<font color=\"orange\">ИнСЎФсґШ <font color=\"limegreen\">"+"ТСМнјУЦБ№¤ѕЯјЬ")
        -pos "topCenter"
        -bkc 0x00001100
        -fade
        -fadeInTime 100 -fadeStayTime 1200
        -fadeOutTime 600;
}