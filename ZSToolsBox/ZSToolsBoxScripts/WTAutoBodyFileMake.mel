		}else
		{
			textField -e -tx ("//192.168.20.102/projects/CIDA_RG/020 绑定公共数据/RigAll角色数据/" + `textField -q -tx WTABFMcharactername` + "_" + `textField -q -tx WTABFMcharacterskin` + "_" + `textField -q -tx WTABFMparasitename` + ".parasitekeepbone") KeepBoneINfField;
		}
	}else
	{
		textField -e -tx ("//192.168.20.102/projects/CIDA_RG/020 绑定公共数据/RigAll角色数据/" + `textField -q -tx WTABFMcharactername` + "_" + `textField -q -tx WTABFMcharacterskin` + "_" + `textField -q -tx WTABFMweaponname` + ".weaponkeepbone") KeepBoneINfField;
	}
}

//加载An Pose 数据
global proc LoadAnPoseMessage ( string $Type )
{
	string $RigAllMessagePath = "//192.168.20.102/projects/CIDA_RG/020 绑定公共数据/RigAll角色数据/";
	string $WTABFMcharactername = `textField -q -tx WTABFMcharactername`;
	string $WTABFMcharacterskin = `textField -q -tx WTABFMcharacterskin`;
	string $WTABFMweaponname = `textField -q -tx WTABFMweaponname`;
	string $AnPoseMessagePath = $RigAllMessagePath + $WTABFMcharactername + "_" + $WTABFMcharacterskin + $Type;
	if ($Type == ".weaponpose")
	{
		$AnPoseMessagePath = $RigAllMessagePath + $WTABFMcharactername + "_" + $WTABFMcharacterskin + "_" + $WTABFMweaponname + $Type;
	}
	if (`file -exists -q $AnPoseMessagePath`)
	{
		int $EditAnPoseSum = `textField -q -tx EditAnPoseSum`;
		//获取储存文件每行内容
		string $lines[];
		int $fileId = `fopen $AnPoseMessagePath "r"`;
		int $i = 0;
		while (!`feof $fileId`) {
			$lines[$i] = `fgetline $fileId`;
			$i++;
		}
		fclose $fileId;

		int $LoadEditAnPoseSum = $lines[0];
		string $EditObjectNameArray[] = stringToStringArray($lines[1], "@");
		string $EditObjectAttributeArray[] = stringToStringArray($lines[2], "@");
		string $EditObjectInfArray[] = stringToStringArray($lines[3], "@");
		
		if ($EditAnPoseSum < $LoadEditAnPoseSum)
		{
			for ($i = 0; $i < ($LoadEditAnPoseSum-$EditAnPoseSum); $i++)
			{
				AddEditObject ();
			}
		}
		if ($EditAnPoseSum > $LoadEditAnPoseSum)
		{
			for ($i = 0; $i < ($EditAnPoseSum-$LoadEditAnPoseSum); $i++)
			{
				DeleteEditObject ();
			}
		}
		for ($a = 0; $a < $LoadEditAnPoseSum; $a++)
		{
			$EditObjectNameArray[$a] = strip($EditObjectNameArray[$a]);
			$EditObjectAttributeArray[$a] = strip($EditObjectAttributeArray[$a]);
			$EditObjectInfArray[$a] = strip($EditObjectInfArray[$a]);
			textField -e -tx $EditObjectNameArray[$a] ("EditObjectName" + $a);
			textField -e -tx $EditObjectAttributeArray[$a] ("EditObjectAttribute" + $a);
			textField -e -tx $EditObjectInfArray[$a] ("EditObjectInf" + $a);
		}
	} else
	{
		int $EditAnPoseSum = `textField -q -tx EditAnPoseSum`;
		for ($i = 0; $i < $EditAnPoseSum; $i++)
		{
			DeleteEditObject ();
		}
		for ($i = 0; $i < 4; $i++)
		{
			AddEditObject ();
		}
	}
}

//打开RigAll
global proc OpenRigAll ()
{
	file -f -open -options "v=0;" (`optionVar -q WTFileName` + `textField -q -tx BodyAlltextField`);
}

//预设文件写入
global proc writeFile ( string $filename, string $addcontents )
{
	$fileId=`fopen $filename "a"`;
	fprint $fileId ( $addcontents );
	fclose $fileId;
}

//预设文件清空
global proc cleanFile ( string $cfilename )
{
	$cfileId=`fopen $cfilename "w"`;
	fprint $cfileId "";
	fclose $cfileId;
}

//选择An Pose数据导出
global proc ExportEditObject () 
{
	string $EditObjectNameArray[];
	string $EditObjectAttributeArray[];
	string $EditObjectInfArray[];
	string $EditObjectNameText;
	string $EditObjectAttributeText;
	string $EditObjectInfText;
	int $EditAnPoseSum = `textField -q -tx EditAnPoseSum`;
	string $RigAllMessagePath = "//192.168.20.102/projects/CIDA_RG/020 绑定公共数据/RigAll角色数据/";
	string $WTABFMcharactername = `textField -q -tx WTABFMcharactername`;
	string $WTABFMcharacterskin = `textField -q -tx WTABFMcharacterskin`;
	string $WTABFMweaponname = `textField -q -tx WTABFMweaponname`;
	string $AnPoseMessagePath;
	string $result = `confirmDialog -title "数据类型" -message "储存为武器数据还是身体数据，或是导入引擎文件的数据？" -button "身体" -button "武器" -button "引擎" -button "取消"`;// -defaultButton "继续" -cancelButton "取消"
	int $RunKey = 0;
	if ($result == "武器")
	{
		$AnPoseMessagePath = $RigAllMessagePath + $WTABFMcharactername + "_" + $WTABFMcharacterskin + "_" + $WTABFMweaponname + ".weaponpose";
		$RunKey = 1;
	} else if ($result == "身体")
	{
		$AnPoseMessagePath = $RigAllMessagePath + $WTABFMcharactername + "_" + $WTABFMcharacterskin + ".bodypose";
		$RunKey = 1;
	} else if ($result == "引擎")
	{
		$AnPoseMessagePath = $RigAllMessagePath + $WTABFMcharactername + "_" + $WTABFMcharacterskin + ".enginepose";
		$RunKey = 1;
	} else
	{
		$RunKey = 0;
	}
	for ($i = 0; $i < $EditAnPoseSum ; $i++)
	{
		$EditObjectNameArray[$i] = `textField -q -tx ("EditObjectName" + $i)`;
		$EditObjectAttributeArray[$i] = `textField -q -tx ("EditObjectAttribute" + $i)`;
		$EditObjectInfArray[$i] = `textField -q -tx ("EditObjectInf" + $i)`;
	}
	$EditAnPoseSumText = $EditAnPoseSum + "\n";
	$EditObjectNameText = stringArrayToString( $EditObjectNameArray , "@");
	$EditObjectNameText = substituteAllString($EditObjectNameText, "\n", "") + "\n";
	$EditObjectAttributeText = stringArrayToString( $EditObjectAttributeArray , "@");
	$EditObjectAttributeText = substituteAllString($EditObjectAttributeText, "\n", "") + "\n";
	$EditObjectInfText = stringArrayToString( $EditObjectInfArray , "@");
	$EditObjectInfText = substituteAllString($EditObjectInfText, "\n", "") + "\n";

	if (!`file -exists -q $AnPoseMessagePath` && $RunKey == 1)
	{
		writeFile ( $AnPoseMessagePath, $EditAnPoseSumText );
		writeFile ( $AnPoseMessagePath, $EditObjectNameText );
		writeFile ( $AnPoseMessagePath, $EditObjectAttributeText );
		writeFile ( $AnPoseMessagePath, $EditObjectInfText );
	} else if (`file -exists -q $AnPoseMessagePath` && $RunKey == 1)
	{
		string $result = `confirmDialog -title "警告" -message "确认覆盖已有文件？" -button "继续" -button "取消"`;// -defaultButton "继续" -cancelButton "取消"
		if ($result == "继续")
		{
			cleanFile ( $AnPoseMessagePath );
			writeFile ( $AnPoseMessagePath, $EditAnPoseSumText );
			writeFile ( $AnPoseMessagePath, $EditObjectNameText );
			writeFile ( $AnPoseMessagePath, $EditObjectAttributeText );
			writeFile ( $AnPoseMessagePath, $EditObjectInfText );
		} else
		{
			print("已取消导出。");
		}
	}
}

//选择An Pose数据查询获取大纲物体名
global proc GetSelectObjectName () 
{
	string $Selection[] = `ls -sl`;
	if (size($Selection) > 1)
	{
		warning ("仅获取选中的第一个对象！！！");
	}
	textField -e -tx $Selection[0] SearchInftextField;
}

//选择An Pose数据查询
global proc SearchEditObject () 
{
	string $SearchInftextField = `textField -q -tx SearchInftextField`;
	int $EditAnPoseSum = `textField -q -tx EditAnPoseSum`;
	int $ResultSum1int = `text -q -label ResultSum1`;
	int $ResultSum3int = `text -q -label ResultSum3`;
	string $EditObjectNameArray[];
	//string $EditObjectAttributeArray[];
	//string $EditObjectInfArray[];
	global int $ResultArray[];
	int $ResultSumNum;
	if ( $SearchInftextField != `optionVar -q SearchInfCheck` )
	{
		$ResultArray = {};
		$ResultSumNum = 0;
		for ($i = 0; $i < $EditAnPoseSum ; $i++)
		{
			$EditObjectNameArray[$i] = `textField -q -tx ("EditObjectName" + $i)`;
			if ($EditObjectNameArray[$i] == $SearchInftextField)
			{
				$ResultArray[$ResultSumNum] = $i;
				$ResultSumNum = $ResultSumNum + 1;
			}
		}
		optionVar -sv SearchInfCheck $SearchInftextField;
		text -e -label "1" ResultSum1;
		text -e -label $ResultSumNum ResultSum3;
		SearchEditObjectLoc ( $ResultArray[0] , $EditAnPoseSum);
		setFocus ("EditObjectName" + $ResultArray[0]);
	} else 
	{
		for ($i = 0; $i < $EditAnPoseSum ; $i++)
		{
			$EditObjectNameArray[$i] = `textField -q -tx ("EditObjectName" + $i)`;
			if ($EditObjectNameArray[$i] == $SearchInftextField)
			{
				$ResultArray[$ResultSumNum] = $i;
				$ResultSumNum = $ResultSumNum + 1;
			}
		}
		if ( $ResultSum1int < $ResultSum3int )
		{
			optionVar -sv SearchInfCheck $SearchInftextField;
			SearchEditObjectLoc ( $ResultArray[$ResultSum1int] , $EditAnPoseSum );
			setFocus ("EditObjectName" + $ResultArray[$ResultSum1int]);
			$ResultSum1int = $ResultSum1int + 1;
		}else
		{
			optionVar -sv SearchInfCheck $SearchInftextField;
			SearchEditObjectLoc ( $ResultArray[0] , $EditAnPoseSum );
			setFocus ("EditObjectName" + $ResultArray[0]);
			$ResultSum1int = 1;
		}
		text -e -label $ResultSum1int ResultSum1;
		text -e -label $ResultSumNum ResultSum3;
	}
}

//选择An Pose数据查询定位
global proc SearchEditObjectLoc ( int $ResultSumLoc , int $AllSum) 
{
	scrollLayout -e -scrollByPixel "up" ($AllSum*22) EditAnPosescrollLayout1;
	scrollLayout -e -scrollByPixel "down" (($ResultSumLoc+1)*22) EditAnPosescrollLayout1;
}

//选择An Pose数据减少
global proc DeleteEditObject () 
{
	string $EditAnPoseSum = `textField -q -tx EditAnPoseSum`;
	int $Num = int($EditAnPoseSum) - 1;
	deleteUI ("EditObjectrowLayout" + $Num);
	textField -e -tx $Num EditAnPoseSum;
}

//选择An Pose数据增加
global proc AddEditObject () 
{
	string $EditAnPoseSum = `textField -q -tx EditAnPoseSum`;
	int $Num = int($EditAnPoseSum) + 1;
	string $EditObjectrowLayout = `rowLayout -nc 5 -columnWidth5 82 82 82 41 41 -parent EditAnPosescrollLayout1 ("EditObjectrowLayout" + $EditAnPoseSum)`;
	textField -w 82 -parent $EditObjectrowLayout ("EditObjectName" + $EditAnPoseSum);
	textField -w 82 -parent $EditObjectrowLayout ("EditObjectAttribute" + $EditAnPoseSum);
		popupMenu -button 3;
		string $PreAttributeShow[] = {"平移X","平移Y","平移Z","旋转X","旋转Y","旋转Z","缩放X","缩放Y","缩放Z"};
		string $PreAttribute[] = {"tx","ty","tz","rx","ry","rz","sx","sy","sz"};
		for ($a=0; $a<size($PreAttribute); $a++)
		{
			//stringToStringArray( $ArrayTextLine[$EditAnPoseSum], "=" );
			menuItem -label $PreAttributeShow[$a] -c ("textField -e -tx " + $PreAttribute[$a] +  " EditObjectAttribute" + $EditAnPoseSum);
		}
	textField -w 82 -parent $EditObjectrowLayout ("EditObjectInf" + $EditAnPoseSum);
	string $SelectEditObjectCmd = substituteAllString ("SelectEditObject(\"EditObjectName%d\");" , "%d" , $EditAnPoseSum);
	string $SelectGetObjectInfCmd = substituteAllString ("SelectGetObjectInf(\"EditObjectName%d\", \"EditObjectAttribute%d\", \"EditObjectInf%d\");" , "%d" , $EditAnPoseSum);
	button -h 17 -w 41 -parent $EditObjectrowLayout -ann "选择该对象" -c $SelectEditObjectCmd  -label "选择" ("SelectEditObjectCommend" + $EditAnPoseSum);
	button -h 17 -w 41 -parent $EditObjectrowLayout -ann "获取该对象参数" -c $SelectGetObjectInfCmd -label "获取" ("SelectGetObjectInfCommend" + $EditAnPoseSum);
	textField -e -tx $Num EditAnPoseSum;
}

//选择An Pose数据对应对象
global proc SelectEditObject ( string $Name ) 
{
	string $NameText = `textField -q -tx $Name`;
	if ($NameText == "")
	{
		warning ("请输入对象名字！！！");
	} else
	{
		select -r $NameText;
	}
}

//获取An Pose数据对应对象的参数
global proc SelectGetObjectInf ( string $Name , string $Attribute , string $Inf ) 
{
	string $NameText = `textField -q -tx $Name`;
	string $AttributeText = `textField -q -tx $Attribute`;
	string $selection[] = `ls -sl`;
	string $getSelectedAttributes[] = getSelectedAttributes();
	string $getSelectedAttributesPrint = stringArrayToString($getSelectedAttributes, "/");
	string $getSelectedInf[];
	for ($i = 0; $i < size($getSelectedAttributes); $i++)
	{
		$getSelectedInf[$i] = `getAttr ( $selection[0] + "." + $getSelectedAttributes[$i] )`;
	}
	string $getSelectedInfPrint = stringArrayToString($getSelectedInf, "/");
	if (size($selection) > 1)
	{
		warning ("请选择一个对象！！！");
	} else
	{
		textField -e -tx $selection[0] $Name;
		textField -e -tx $getSelectedAttributesPrint $Attribute;
		textField -e -tx $getSelectedInfPrint $Inf;
	}
}

//设置An Pose数据对应对象的参数
global proc SelectSetObjectInf ( string $Type , string $WTABFMcharactername , string $WTABFMcharacterskin , string $WTABFMweaponname ) 
{
	string $RigAllMessagePath = "//192.168.20.102/projects/CIDA_RG/020 绑定公共数据/RigAll角色数据/";
	string $AnPoseMessagePath = $RigAllMessagePath + $WTABFMcharactername + "_" + $WTABFMcharacterskin + $Type;
	if ($Type == ".weaponpose")
	{
		$AnPoseMessagePath = $RigAllMessagePath + $WTABFMcharactername + "_" + $WTABFMcharacterskin + "_" + $WTABFMweaponname + $Type;
	}
	if (`file -exists -q $AnPoseMessagePath`)
	{
		//获取储存文件每行内容
		string $lines[];
		int $fileId = `fopen $AnPoseMessagePath "r"`;
		int $i = 0;
		while (!`feof $fileId`) {
			$lines[$i] = `fgetline $fileId`;
			$i++;
		}
		fclose $fileId;

		int $LoadEditAnPoseSum = $lines[0];
		string $EditObjectNameArray[] = stringToStringArray($lines[1], "@");
		string $EditObjectAttributeArray[] = stringToStringArray($lines[2], "@");
		string $EditObjectInfArray[] = stringToStringArray($lines[3], "@");

		//上数据
		for ($i = 0 ; $i < $LoadEditAnPoseSum ; $i++)
		{
			string $SetNameText = strip($EditObjectNameArray[$i]);
			string $SetAttributeText = strip($EditObjectAttributeArray[$i]);
			string $SetInfText = strip($EditObjectInfArray[$i]);
			if ($SetNameText == "")
			{
				continue;
			}else
			{
				string $SetAttributesArray[] = stringToStringArray($SetAttributeText, "/");
				string $SetInfArray[] = stringToStringArray($SetInfText, "/");
				for ($a = 0; $a < size($SetAttributesArray); $a++)
				{
					float $SetInffloat = $SetInfArray[$a];
					setAttr ($SetNameText + "." + $SetAttributesArray[$a]) $SetInffloat;
				}
			}
		}
	}else
	{
		print ("无 An Pose 数据。");
	}
}

//获取通道盒(Channel Box)中选中的属性id
global proc string[] getSelectedAttributes()
{
	string $selectedAttrs[] = {};
	
	// 获取通道盒中选中的属性
	string $channelBox = "mainChannelBox";
	string $attrs[] = `channelBox -q -selectedMainAttributes $channelBox`;
	
	// 如果没有在通道盒选中，尝试获取属性编辑器中的选择
	if (size($attrs) == 0) {
		$attrs = `channelBox -q -selectedShapeAttributes $channelBox`;
	}
	
	return $attrs;
}

	//制作文件标识长度同步1
global proc WTABFMframeLayouttextCommend1 ( int $Number ) 
{
	text -e -h 20 ("WTABFMframeLayouttext" + $Number);
}

	//制作文件标识长度同步2
global proc WTABFMframeLayouttextCommend2 ( int $Number ) 
{
	text -e -h 146 ("WTABFMframeLayouttext" + $Number);
	if ($Number == 3)
	{
		text -e -h 226 WTABFMframeLayouttext3;
	}
	if ($Number == 4)
	{
		text -e -h 226 WTABFMframeLayouttext4;
	}
	if ($Number == 11)
	{
		text -e -h 186 WTABFMframeLayouttext11;
	}
	if ($Number == 12)
	{
		text -e -h 266 WTABFMframeLayouttext12;
	}
}

