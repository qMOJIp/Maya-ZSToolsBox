string $Selections[] = `ls -os`;
for ($i = 0;$i < size($Selections); $i = $i+2)
{
	select -cl;
	select -r $Selections[$i];
	select -add $Selections[$i+1];
	MatchTransform;
	print ("쉥" + $Selections[$i] + "튈토돕" + $Selections[$i+1] + "\n");
}
select -cl;
for ($i = 1;$i < size($Selections); $i = $i+2)
{
	select -add $Selections[$i];
}
print ("綠朞嶝杰唐커깃뚤蹶\n");