	//检查文件
global proc GameFacialCheck () 
{
	string $WTFileName = `optionVar -q WTFileName`;
	string $Charactername = `textField -q -tx charactername`;
	string $CeresRigtextField = `textField -q -tx CeresRigtextField`;
	string $GameFacialFbxField = $WTFileName + $CeresRigtextField + "/Origin/Game/SK_Player_" + $Charactername + "_Origin_Facial_Lod_01.fbx";
	if ($Charactername == "")
	{
		error ("请载入角色数据！\n");
	}else
	{
		if (`file -exists -q $GameFacialFbxField` == 0)
		{
			error ("请先制作文件！\n");
		}else
		{
			file -f -new;
			//设置场景Y轴朝上
			upAxis -ax y -rv;
			file -f -import -f -options "v=0" $GameFacialFbxField;
			//居中场景
			viewSet -animate 0 -home;
			viewFit -animate 0 -all;
			print ("已成功导入：" + $GameFacialFbxField + "\n");
		}
	}
}

	//ceres定位
global proc GameFacialCeres () 
{
	string $Charactername = `textField -q -tx charactername`;
	string $CeresRigtextField = `textField -q -tx CeresRigtextField`;
	string $GameFacialFbxField = $CeresRigtextField + "/Origin/Game/SK_Player_" + $Charactername + "_Origin_Facial_Lod_01.fbx";
	if ($Charactername == "")
	{
		error ("请载入角色数据！\n");
	}else
	{
		textField -e -tx $GameFacialFbxField quickopenFilePath;
		textField -e -tx "WT" ProjectTextField;
		optionVar -sv NowProject (`optionVar -q WTFileName`);
		changetoCeres ();
		print ("开始定位！\n");
	}
}

