global string $KeeptextScrollListModificationTimes[];
global string $KeeptextScrollListAccessTimes[];

//МгдидЄЩшФПТМ
global proc MFBLoadPrePath ()
{
	textScrollList -e -removeAll MFBPretextScrollList;
	//МгдидЄЩшХфжУ
	string $SettingfilePath = `asInstallScriptLocation` + "PublicFiles/Settings/Setting.set";
	string $EachSettingline[] = freadAllLines($SettingfilePath);
	for ($i=0; $i<size($EachSettingline); $i++)
	{
		string $Information[];
		tokenize($EachSettingline[$i],"ЃК",$Information);
		textScrollList -e -append $Information[0] MFBPretextScrollList;
	}
}

//МгдиЪеВиФПТМ
global proc MFBLoadFavoritesPath ()
{
	textScrollList -e -removeAll MFBFavoritestextScrollList;
	//МгдиЪеВиХфжУ
	string $FavoritesfilePath = `asInstallScriptLocation` + "PublicFiles/Settings/FavoritesPath.set";
	$EachSettingline = freadAllLines($FavoritesfilePath);
	for ($i=0; $i<size($EachSettingline); $i++)
	{
		string $Information[];
		tokenize($EachSettingline[$i],"ЃК",$Information);
		textScrollList -e -append $Information[0] MFBFavoritestextScrollList;
	}
}

//ЯдЪОДХХЬТЗОЖ
global proc MFBSystemDrives ()
{
	global string $KeeptextScrollListFileNames[];
	global string $KeeptextScrollListCreationTimes[];
	global string $KeeptextScrollListModificationTimes[];
	global string $KeeptextScrollListAccessTimes[];
	$KeeptextScrollListFileNames = {};
	$KeeptextScrollListCreationTimes = {};
	$KeeptextScrollListModificationTimes = {};
	$KeeptextScrollListAccessTimes = {};
	string $DriveNames[] = getSystemDrives();
	textScrollList -e -removeAll MFBPathDisplaytextScrollList;
	textScrollList -e -removeAll MFBFileDatetextScrollList;
	for ($i=0; $i<size($DriveNames); $i++)
	{
		textScrollList -e -append $DriveNames[$i] MFBPathDisplaytextScrollList;
		textScrollList -e -append $DriveNames[$i] MFBFileDatetextScrollList;
	}
	optionMenu -e -enable 0 MFBFileInformationDisplayoptionMenu1;
	optionMenu -e -enable 0 MFBFileInformationDisplayoptionMenu2;
	button -e -enable 0 -backgroundColor 0.265 0.265 0.265  -label "ЮФМўМа(0)" FileCategory0;
	textField -e -text "SystemDisks" MFBPathTextField;
	text -e -label (size($DriveNames) + "ИіДХХЬ" + "ЁЁ|ЁЁ") MFBShowFileTotal;
	text -e -label "ЕчФдДХХЬ" MFBShowPathtext;
	MFBaddCategory();
}

//дЄЩшФПТМ
global proc MFBGOPrePath ()
{
	string $SettingfilePath = `asInstallScriptLocation` + "PublicFiles/Settings/Setting.set";
	string $EachSettingline[] = freadAllLines($SettingfilePath);
	int $SelectIndexed[] = `textScrollList -q -selectIndexedItem MFBPretextScrollList`;
	string $Information[];
	tokenize($EachSettingline[$SelectIndexed[0]-1],"ЃК",$Information);
	textField -e -text $Information[1] MFBPathTextField;
	MFBnavigateToPath(1);
}

//ЪеВиФПТМ
global proc MFBGOFavoritesPath ()
{
	string $FavoritesfilePath = `asInstallScriptLocation` + "PublicFiles/Settings/FavoritesPath.set";
	string $EachSettingline[] = freadAllLines($FavoritesfilePath);
	int $SelectIndexed[] = `textScrollList -q -selectIndexedItem MFBFavoritestextScrollList`;
	string $Information[];
	tokenize($EachSettingline[$SelectIndexed[0]-1],"ЃК",$Information);
	textField -e -text $Information[1] MFBPathTextField;
	MFBnavigateToPath(1);
	warning ("вбО­ЧАЭљЪеВиФПТМЃЁЃЁЃЁ");
}

//ЗЕЛиаХЯЂ
global proc returnFileBrowser ()
{
	global string $ReturnStartflag;
	global string $ReturntextFieldName;
	string $Path =$ReturnStartflag + "\"" + `text -q -label MFBShowPathtext` + "\"" + "-e " + $ReturntextFieldName;
	eval $Path;
	if (`window -exists "MayaFileBrowserWindow"`)
	{
		deleteUI -window "MayaFileBrowserWindow";
	}
}

