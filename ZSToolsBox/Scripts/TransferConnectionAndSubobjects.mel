//转移连接
global proc TransferConnection( string $SourceObject, string $TargetObject )
{
	string $CurrentConnectionpFrom[] = `listConnections -s 1 -d 0 -c 1 -p 1 $SourceObject`;
	string $CurrentConnectionpTo[] = `listConnections -s 0 -d 1 -c 1 -p 1 $SourceObject`;
	//处理被连接
		//断掉旧连接
	//for ($i=1; $i<size($CurrentConnectionpFrom); $i=$i+2)
	//{
	//	disconnectAttr $CurrentConnectionpFrom[$i] $CurrentConnectionpFrom[$i-1];
	//	
	//}
		//创建新连接
	for ($i=0; $i<size($CurrentConnectionpFrom); $i=$i+2)
	{
		$CurrentConnectionpFrom[$i] = `substituteAllString $CurrentConnectionpFrom[$i] $SourceObject $TargetObject`;
	}
	for ($i=1; $i<size($CurrentConnectionpFrom); $i=$i+2)
	{
		connectAttr -f $CurrentConnectionpFrom[$i] $CurrentConnectionpFrom[$i-1];
		
	}
	//处理连接
		//替换连接
	for ($i=0; $i<size($CurrentConnectionpTo); $i=$i+2)
	{
		$CurrentConnectionpTo[$i] = `substituteAllString $CurrentConnectionpTo[$i] $SourceObject $TargetObject`;
	}
	for ($i=0; $i<size($CurrentConnectionpTo); $i=$i+2)
	{
		connectAttr -f $CurrentConnectionpTo[$i] $CurrentConnectionpTo[$i+1];
		
	}
}

//转移子对象
global proc TransferSubobjects( string $SourceObject, string $TargetObject )
{
	string $ChildObject[] = `listRelatives -children $SourceObject`;
	for ($i=0; $i<size($ChildObject); $i++)
	{
		parent $ChildObject[$i] $TargetObject;
	}
	delete $SourceObject;
}

