global proc WTAutoFacialFileMake()  
{  
	if (`window -exists "WTAutoFacialFileMakewindow"`)
	{  
		deleteUI -window "WTAutoFacialFileMakewindow";
	}  
	window -title "WT Facial All 相关文件制作" -h 530 -w 405 -rtf 1 -s 0 -tlb 0 WTAutoFacialFileMakewindow;
	//公用开头
		string $scriptsPath = `internalVar -userScriptDir`;
		string $filePath = $scriptsPath + "ZSToolsBox/PublicFiles/Projets.txt";
		$fileId=`fopen $filePath "r"`;
		string $TextLine = `fgetline $fileId`;
		fclose $fileId;
		string $ArrayTextLine[] = stringToStringArray( $TextLine, ";" );
		for ($i=0; $i<size($ArrayTextLine); $i++)
		{
			if (`gmatch $ArrayTextLine[$i] ("WT=*")` == 1){
				string $ProjetContent[] = stringToStringArray( $ArrayTextLine[$i], "=" );
				optionVar -sv WTFileName $ProjetContent[1];
			}
		}
		columnLayout -h 500 -w 390 -columnAttach both 5 -adjustableColumn true WTAFFMcolumnLayout;
			separator -h 5 -style "none";
			rowLayout -adj 1 -p WTAFFMcolumnLayout -nc 2 -columnWidth2 370 15; 
			text -h 20 -bgc 0.2 0.4 0.4 -label ("使用前确保对应角色的 Facial All 文件已获取且按照规范制作");
			button -h 20 -w 15 -c "WTAutoFacialFileMakeQuestion_1" -ann "点击查看图解" -label "?";
			separator -h 5 -style "none" -p WTAFFMcolumnLayout;
			scrollLayout -p WTAFFMcolumnLayout -h 470 -w 390 WTAFFMscrollLayout;
				text -w 375 -p WTAFFMscrollLayout -label ("Facial All 文件Ceres路径");
				textField -ec "WTAFFMEnter1" -w 375 -p WTAFFMscrollLayout -tx "" CeresRigtextField;
				rowLayout -adj 1 -p WTAFFMscrollLayout -nc 2 -columnWidth2 186 186; 
					text -w 186 -label ("角色名字");
					text -w 186 -label ("角色代号");
					rowLayout -adj 1 -p WTAFFMscrollLayout -nc 2 -columnWidth2 186 186; 
					textField -ec "WTAFFMRefreshInf" -w 186 -tx "" charactername;
					textField -ec "WTAFFMRefreshInf" -w 186 -tx "" characternum;
			
			//制作 PV 的 Facial 文件（fbx）UI布局
			rowLayout -adj 2 -p WTAFFMscrollLayout -nc 2 -columnWidth2 15 375; 
			text -w 15 -h 20 -bgc 0.3 0 0 -label ("1") WTAFFMframeLayouttext1;
			frameLayout -bgc 0.3 0 0 -pcc"WTAFFMframeLayouttextCommend1(1)" -pec "WTAFFMframeLayouttextCommend2(1)" -w 357 -cl 1 -cll 1 -ann "含Facial_PV层级模型和855根骨骼" -label "制作 SK_Player_角色名_Origin_Facial_PV_01.fbx" WTAFFMframeLayout1;
				separator -parent WTAFFMframeLayout1 -h 1 -style "none";
				rowLayout -adj 2 -p WTAFFMframeLayout1 -nc 3 -columnWidth3 50 250 25; 
					text -h 20 -w 50 -label ("步骤一、");
					button -c "WTAFFMLocCeresPath(1)" -ann "通过项目文件快速打开插件在 Ceres 上定位到该文件以便快速检出" -label "Ceres 定位制作文件，检出迭代旧文件";
					button -w 25 -c "WTAFFMCopyCeresPath(1)" -ann "复制该制作文件的Ceres路径" -label "C";
				separator -parent WTAFFMframeLayout1 -h 1 -style "in";
				rowLayout -adj 2 -p WTAFFMframeLayout1 -nc 2 -columnWidth2 50 275; 
					text -h 20 -w 50 -label ("步骤二、");
					button -c "PVFacialMake" -ann "文件中需存在UnrealRoot和Facial_PV"  -label "制作 SK_Player_角色名_Origin_Facial_PV_01.fbx 文件" WTAFFMframeLayout1button1;
				separator -parent WTAFFMframeLayout1 -h 1 -style "in";
				rowLayout -adj 2 -p WTAFFMframeLayout1 -nc 3 -columnWidth3 50 250 25; 
					text -h 20 -w 50 -label ("步骤三、");
					button -c "PVFacialCheck" -ann "新建场景导入 SK_Player_角色名_Origin_Facial_PV_01.fbx 文件" -label "新建场景并自动导入制作文件进行检查" WTAFFMframeLayout1button2;
					button -w 25 -c "WTAFFMOpenMakePath(1)" -ann "打开该制作文件的本地路径" -label "O";
				separator -bgc 0.3 0 0 -parent WTAFFMframeLayout1 -h 3 -style "out";
			
			//制作 Game 的 Facial 文件（fbx）UI布局
			rowLayout -adj 2 -p WTAFFMscrollLayout -nc 2 -columnWidth2 15 375; 
			text -w 15 -h 20 -bgc 0 0.3 0 -label ("2") WTAFFMframeLayouttext2;
			frameLayout -bgc 0 0.3 0 -pcc"WTAFFMframeLayouttextCommend1(2)" -pec "WTAFFMframeLayouttextCommend2(2)" -w 357 -cl 1 -cll 1 -ann "除Facial_PV层级模型和98根骨骼" -label "制作 SK_Player_角色名_Origin_Facial_Lod_01.fbx" WTAFFMframeLayout2;
				separator -parent WTAFFMframeLayout2 -h 1 -style "none";
				rowLayout -adj 2 -p WTAFFMframeLayout2 -nc 3 -columnWidth3 50 250 25; 
					text -h 20 -w 50 -label ("步骤一、");
					button -c "WTAFFMLocCeresPath(2)" -ann "通过项目文件快速打开插件在 Ceres 上定位到该文件以便快速检出" -label "Ceres 定位制作文件，检出迭代旧文件";
					button -w 25 -c "WTAFFMCopyCeresPath(2)" -ann "复制该制作文件的Ceres路径" -label "C";
				separator -parent WTAFFMframeLayout2 -h 1 -style "in";
				rowLayout -adj 2 -p WTAFFMframeLayout2 -nc 2 -columnWidth2 50 275; 
					text -h 20 -w 50 -label ("步骤二、");
					button -c "GameFacialMake" -ann "文件中需存在UnrealRoot和角色名_LOD" -label "制作 SK_Player_角色名_Origin_Facial_Lod_01.fbx 文件" WTAFFMframeLayout2button1;
				separator -parent WTAFFMframeLayout2 -h 1 -style "in";
				rowLayout -adj 2 -p WTAFFMframeLayout2 -nc 3 -columnWidth3 50 250 25; 
					text -h 20 -w 50 -label ("步骤三、");
					button -c "GameFacialCheck" -ann "新建场景导入 SK_Player_角色名_Origin_Facial_Lod_01.fbx 文件" -label "新建场景并自动导入制作文件进行检查" WTAFFMframeLayout2button2;
					button -w 25 -c "WTAFFMOpenMakePath(2)" -ann "打开该制作文件的本地路径" -label "O";
				separator -bgc 0 0.3 0 -parent WTAFFMframeLayout2 -h 3 -style "out";
			
			//制作An的Facial和BodyWithFacial文件（ma）UI布局
			rowLayout -adj 2 -p WTAFFMscrollLayout -nc 2 -columnWidth2 15 375; 
			text -w 15 -h 20 -bgc 0 0 0.3 -label ("3") WTAFFMframeLayouttext3;
			frameLayout -bgc 0 0 0.3 -pcc"WTAFFMframeLayouttextCommend1(3)" -pec "WTAFFMframeLayouttextCommend2(3)" -w 357 -ec "HideConstrainframeLayout" -cl 1 -cll 1 -ann "制作储存于公盘的动画师所用的BodyWithFacial文件" -label "制作 SK_Player_角色名_Origin_BodyWithFacial_An_01.ma" WTAFFMframeLayout3;
				//准备文件提示
				separator -parent WTAFFMframeLayout3 -h 1 -style "none";
				text -h 20 -label ("步骤一、从Ceres上获取以下文件最新版本");
				rowLayout -adj 1 -p WTAFFMframeLayout3 -nc 3 -columnWidth3 310 15 15; 
					text -h 15 -w 320 -label ("SK_Player_角色名_Origin_Facial_All_01.ma（All脸模MA文件）") WTAFFMframeLayout3text1;
					button -w 15 -h 19 -ann "在Ceres上定位" -label "L" -c "WTAFFMLocCeresPath(3.1)";
					button -w 15 -h 19 -ann "复制Ceres路径" -label "C" -c "WTAFFMCopyCeresPath(3.1)";
				rowLayout -adj 1 -p WTAFFMframeLayout3 -nc 3 -columnWidth3 310 15 15; 
					text -h 15 -w 320 -label ("SK_Player_角色名_Origin_Facial_An_01.dna（脸模DNA文件）") WTAFFMframeLayout3text2;
					button -w 15 -h 19 -ann "在Ceres上定位" -label "L" -c "WTAFFMLocCeresPath(3.2)";
					button -w 15 -h 19 -ann "复制Ceres路径" -label "C" -c "WTAFFMCopyCeresPath(3.2)";
				rowLayout -adj 1 -p WTAFFMframeLayout3 -nc 3 -columnWidth3 310 15 15; 
					text -h 15 -w 320 -label ("SK_Player_角色名_Origin_An_01.fbx（AN身体FBX文件）") WTAFFMframeLayout3text3;
					button -w 15 -h 19 -ann "在Ceres上定位" -label "L" -c "WTAFFMLocCeresPath(3.3)";
					button -w 15 -h 19 -ann "复制Ceres路径" -label "C" -c "WTAFFMCopyCeresPath(3.3)";
				rowLayout -adj 1 -p WTAFFMframeLayout3 -nc 3 -columnWidth3 310 15 15; 
					text -h 15 -w 320 -label ("SK_Player_角色名_Origin_An_01.ma（AN身体MA文件）") WTAFFMframeLayout3text4;
					button -w 15 -h 19 -ann "在Ceres上定位" -label "L" -c "WTAFFMLocCeresPath(3.4)";
					button -w 15 -h 19 -ann "复制Ceres路径" -label "C" -c "WTAFFMCopyCeresPath(3.4)";
				separator -parent WTAFFMframeLayout3 -h 1 -style "in";
			
				text -p WTAFFMframeLayout3 -h 20 -label "步骤二、拷贝获取文件至制作文件夹";
				//运行按钮
				button -ann "将文件拷贝到文件制作路径" -c "CopyFileToPre" -label "拷贝文件至制作文件夹" -parent WTAFFMframeLayout3;
				setParent WTAFFMframeLayout3;
					rowLayout -adj 2 -nc 4 -columnWidth4 55 240 30 30;
					text -label ("制作路径：");
					textField -w 240 -tx "" errorlog;
					button -w 30 -h 20 -ann "刷新制作路径" -label "刷新" -c "flush";
					button -w 30 -h 20 -ann "打开制作路径" -label "打开" -c "openfilepath";
				separator -parent WTAFFMframeLayout3 -h 1 -style "in";
			
				text -p WTAFFMframeLayout3 -h 20 -label "步骤三、制作相关文件";
				rowLayout -adj 1 -p WTAFFMframeLayout3 -nc 3 -columnWidth3 50 50 50;
					button -c "MakeCheckBoxFile" -ann "开始制作勾选需制作的文件" -label "制作勾选文件";
					checkBox -v 1 -label "Facial" -cc "TogetherBodyWithFacial" -ann "制作 Facial 文件" FacialcheckBox;
					checkBox -v 0 -label "BodyWithFacial" -cc "TogetherFacial" -ann "制作 BodyWithFacial 文件" BodyWithFacialcheckBox;
				separator -parent WTAFFMframeLayout3 -h 1 -style "in";
			
				text -p WTAFFMframeLayout3 -h 20 -label "步骤四、排除约束错误";
				button -p WTAFFMframeLayout3 -ann "读取错误日志" -c "ReadErrorLog" -label "读取错误日志";
				rowLayout -adj 1 -p WTAFFMframeLayout3 -nc 2 -columnWidth2 50 50;
				button -ann "若出现约束失败修复后点击此按钮约束即可" -c "OnlyRunConstrain" -label "仅执行后续约束";
				button -w 25 -ann "展开约束组" -c "ShowConstrainframeLayout" -label "◆" ShowConstrainframeLayoutbutton;
				frameLayout -vis 0 -ann "展开约束组" -label "展开约束组" -p WTAFFMframeLayout3 OnlyRunConstrainframeLayout;
				//约束组一UI布局
				setParent OnlyRunConstrainframeLayout;
					text " ―――――――――――――    约束组一    ――――――――――――― ";
					scrollLayout -cr 30 -h 115 -w 350 scrollLayout1;
					for ($i = 0; $i < 70; $i++)
						{  
							string $rowLayout = `rowLayout -adj 2 -nc 4 -columnWidth4 55 115 55 110 -parent scrollLayout1`;
						
							text -label ("约束对象：") -parent $rowLayout;
							textField -w 110 -parent $rowLayout ("sourceConstrain1" + $i);
							text -label ("目标对象：") -parent $rowLayout;
							textField -w 110 -parent $rowLayout ("targetConstrain1" + $i);
						}
					//约束组一初始数据输入
					string $jeuseanfbxbone[] = {"Wrist_R","Wrist_L","Ankle_R","Ankle_L","Root_M","Spine1_M","Spine2_M","Chest_M","Neck_M","Neck1_M","Head_M","Hip_R","Knee_R","Ankle_R","Toes_R","Scapula_R","Shoulder_R","Elbow_R","Wrist_R","Hip_L","Knee_L","Ankle_L","Toes_L","Scapula_L","Shoulder_L","Elbow_L","Wrist_L","MiddleFinger1_R","MiddleFinger2_R","MiddleFinger3_R","ThumbFinger1_R","ThumbFinger2_R","ThumbFinger3_R","IndexFinger1_R","IndexFinger2_R","IndexFinger3_R","RingFinger1_R","RingFinger2_R","RingFinger3_R","PinkyFinger1_R","PinkyFinger2_R","PinkyFinger3_R","MiddleFinger1_L","MiddleFinger2_L","MiddleFinger3_L","ThumbFinger1_L","ThumbFinger2_L","ThumbFinger3_L","IndexFinger1_L","IndexFinger2_L","IndexFinger3_L","RingFinger1_L","RingFinger2_L","RingFinger3_L","PinkyFinger1_L","PinkyFinger2_L","PinkyFinger3_L"};
					string $jeuseanmactrl[] = {"IKArm_R","IKArm_L","IKLeg_R","IKLeg_L","RootX_M","FKSpine1_M","FKSpine2_M","FKChest_M","FKNeck_M","FKNeck1_M","FKHead_M","FKHip_R","FKKnee_R","FKAnkle_R","FKToes_R","FKScapula_R","FKShoulder_R","FKElbow_R","FKWrist_R","FKHip_L","FKKnee_L","FKAnkle_L","FKToes_L","FKScapula_L","FKShoulder_L","FKElbow_L","FKWrist_L","FKMiddleFinger1_R","FKMiddleFinger2_R","FKMiddleFinger3_R","FKThumbFinger1_R","FKThumbFinger2_R","FKThumbFinger3_R","FKIndexFinger1_R","FKIndexFinger2_R","FKIndexFinger3_R","FKRingFinger1_R","FKRingFinger2_R","FKRingFinger3_R","FKPinkyFinger1_R","FKPinkyFinger2_R","FKPinkyFinger3_R","FKMiddleFinger1_L","FKMiddleFinger2_L","FKMiddleFinger3_L","FKThumbFinger1_L","FKThumbFinger2_L","FKThumbFinger3_L","FKIndexFinger1_L","FKIndexFinger2_L","FKIndexFinger3_L","FKRingFinger1_L","FKRingFinger2_L","FKRingFinger3_L","FKPinkyFinger1_L","FKPinkyFinger2_L","FKPinkyFinger3_L"};
					for ($a = 0; $a < size($jeuseanfbxbone); $a++)  
						{  
							textField -e -tx $jeuseanfbxbone[$a] ("sourceConstrain1" + $a); 
							textField -e -tx $jeuseanmactrl[$a] ("targetConstrain1" + $a); 
						}
				//约束组二UI布局
				setParent OnlyRunConstrainframeLayout;
					text " ―――――――――――――    约束组二    ――――――――――――― ";
					scrollLayout -cr 30 -h 115 -w 350 scrollLayout2;
					for ($i = 0; $i < 30; $i++)  
						{  
							string $rowLayout = `rowLayout -adj 2 -nc 4 -columnWidth4 55 115 55 110 -parent scrollLayout2`;  
						
							text -label ("约束对象：") -parent $rowLayout;  
							textField -w 110 -parent $rowLayout ("sourceConstrain2" + $i);  
							text -label ("目标对象：") -parent $rowLayout;  
							textField -w 110 -parent $rowLayout ("targetConstrain2" + $i);  
						}
					//约束组二初始数据输入
					string $jeuseanmabone[] = {"UnrealRoot","Root_M","Spine1_M","Spine2_M","Chest_M","Neck_M","Neck1_M","Head_M","Scapula_L","Scapula_R","Shoulder_L","Shoulder_R"};
					string $headmabone[] = {"UnrealRoot","Root_M","Spine1_M","Spine2_M","Chest_M","Neck_M","Neck1_M","Head_M","Scapula_L","Scapula_R","Shoulder_L","Shoulder_R"};
					for ($a = 0; $a < size($jeuseanmabone); $a++)  
						{  
							textField -e -tx $jeuseanmabone[$a] ("sourceConstrain2" + $a); 
							textField -e -tx $headmabone[$a] ("targetConstrain2" + $a); 
						}
				separator -parent WTAFFMframeLayout3 -h 1 -style "in";
			
				text -p WTAFFMframeLayout3 -h 20 -label "步骤五、拷贝文件至上传目录";
				rowLayout -adj 1 -p WTAFFMframeLayout3 -nc 3 -columnWidth3 335 15 15; 
					button -ann "将勾选文件拷贝到上传路径" -c "CopyFileToSend" -label "拷贝勾选文件至上传目录";
					button -w 15 -ann "在Ceres上定位FacialAnMa" -label "L" -c "WTAFFMLocCeresPath(3.5)";
					button -w 15 -ann "在Ceres上定位FacialAnMa" -label "C" -c "WTAFFMCopyCeresPath(3.5)";
				separator -bgc 0 0 0.3 -parent WTAFFMframeLayout3 -h 3 -style "out";
			
			//显示更新日期
	separator -h 5 -style "doubleDash" -p WTAFFMcolumnLayout;
	text -h 20 -fn tinyBoldLabelFont -hlc 1 1 1 -label ("2025年7月11日 v.1") -p WTAFFMcolumnLayout;
	showWindow;  
}

//自动读取名称和代号
global proc WTAFFMEnter1 () 
{
	string $CeresRigtextField = `textField -q -tx CeresRigtextField`;
	$CeresRigtextField = fromNativePath($CeresRigtextField);
	//获取文件名
	string $CeresRigtextFieldArray[] = stringToStringArray( $CeresRigtextField, "/" );
	string $CharacterInfArray[] = stringToStringArray( $CeresRigtextFieldArray[size($CeresRigtextFieldArray)-1], "_" );
	//获取角色名
	textField -e -tx $CharacterInfArray[2] charactername;
	string $CharacterNameList[] = {"Winston","Dean","Veronica","Winona","Antonio","Cate","Jules","BernardClouzot","AshlinByrne","AndrewOlson","JeffMiller","LamSoeng","ThaliaSmith","KeiraCollins","LouisJohnson","Kajak","SimonBaruch","EmiliaWhite"};
	string $CharacterNumList[] = {"Char_A","Char_B","Char_C","Char_D","Char_E","Char_F","Char_G","Char_H","Char_I","Char_J","Char_N","Char_O","Char_P","Char_L","Char_M","Char_K","Char_Q","Char_R"};
	for ($i=0; $i<size($CharacterNameList); $i++)
	{
		if ($CharacterInfArray[2] == $CharacterNameList[$i])
		{
			textField -e -tx $CharacterNumList[$i] characternum;
		}
	}
	WTAFFMRefreshInf ();
	flush ();
}

//制作文件标识长度同步1
global proc WTAFFMframeLayouttextCommend1 ( int $Number ) 
{
	text -e -h 20 ("WTAFFMframeLayouttext" + $Number);
}

//制作文件标识长度同步2
global proc WTAFFMframeLayouttextCommend2 ( int $Number ) 
{
	text -e -h 146 ("WTAFFMframeLayouttext" + $Number);
	if ($Number == 3)
	{
		text -e -h 498 ("WTAFFMframeLayouttext" + $Number);
	}
}

//UI字符同步
global proc WTAFFMRefreshInf () 
{
	string $charactername = `textField -q -tx charactername`;
	frameLayout -e -label ("制作 SK_Player_" + $charactername + "_Origin_Facial_PV_01.fbx") WTAFFMframeLayout1;
	button -e -label ("制作 SK_Player_" + $charactername + "_Origin_Facial_PV_01.fbx 文件") WTAFFMframeLayout1button1;
	button -e -ann ("新建场景导入 SK_Player_" + $charactername + "_Origin_Facial_PV_01.fbx 文件") WTAFFMframeLayout1button2;
	frameLayout -e -label ("制作 SK_Player_" + $charactername + "_Origin_Facial_Lod_01.fbx") WTAFFMframeLayout2;
	button -e -label ("制作 SK_Player_" + $charactername + "_Origin_Facial_Lod_01.fbx 文件") WTAFFMframeLayout2button1;
	button -e -ann ("新建场景导入 SK_Player_" + $charactername + "_Origin_Facial_Lod_01.fbx 文件") WTAFFMframeLayout2button2;
	frameLayout -e -label ("制作 SK_Player_" + $charactername + "_Origin_BodyWithFacial_An_01.ma") WTAFFMframeLayout3;
	text -e -label ("SK_Player_" + $charactername + "_Origin_Facial_All_01.ma（All脸模MA文件）") WTAFFMframeLayout3text1;
	text -e -label ("SK_Player_" + $charactername + "_Origin_Facial_An_01.dna（脸模DNA文件）") WTAFFMframeLayout3text2;
	text -e -label ("SK_Player_" + $charactername + "_Origin_An_01.fbx（AN身体FBX文件）") WTAFFMframeLayout3text3;
	text -e -label ("SK_Player_" + $charactername + "_Origin_An_01.ma（AN身体MA文件）") WTAFFMframeLayout3text4;
}

//绑定路径转对等引擎路径+文件名
global proc string RigPathToEnginePath ( string $ExportFileName ) 
{
	string $CeresRigtextField = `textField -q -tx CeresRigtextField`;
	$CeresRigtextField = fromNativePath($CeresRigtextField);
	$CeresRigtextField = dirname($CeresRigtextField);
	string $EnginePath = substituteAllString($CeresRigtextField, "RigUse", "EngineUse") + "/" + $ExportFileName;
	return $EnginePath;
}

//绑定路径转动画路径+文件所在剩余路径
global proc string RigPathToAnimationPath ( string $ExportFileName ) 
{
	string $CeresRigtextField = `textField -q -tx CeresRigtextField`;
	$CeresRigtextField = fromNativePath($CeresRigtextField);
	$CeresRigtextField = dirname($CeresRigtextField);
	string $AnimationPath[] = stringToStringArray(substituteAllString($CeresRigtextField, "RigUse", "AnimationUse*"), "*");
	return $AnimationPath[0] + $ExportFileName;
}

//展开文件3时隐藏约束组
global proc HideConstrainframeLayout () 
{
	frameLayout -e -vis 0 OnlyRunConstrainframeLayout;
	button -e -label "◆" ShowConstrainframeLayoutbutton;
}

//文件3展开约束组
global proc ShowConstrainframeLayout () 
{
	int $ConstrainHeightGet = `frameLayout -q -vis OnlyRunConstrainframeLayout`;
	if ($ConstrainHeightGet == 0)
	{
		button -e -label "▼" ShowConstrainframeLayoutbutton;
		frameLayout -e -vis 1 OnlyRunConstrainframeLayout;
		text -e -h 798 WTAFFMframeLayouttext3;
	}else{
		button -e -label "◆" ShowConstrainframeLayoutbutton;
		frameLayout -e -vis 0 OnlyRunConstrainframeLayout;
		text -e -h 498 WTAFFMframeLayouttext3;
	}
}

//制作PV的Facial文件（fbx）文件1
	//制作文件
global proc PVFacialMake () 
{
	string $PVFacialField = `optionVar -q WTFileName` + `textField -q -tx CeresRigtextField`;
	string $PVFacialFbxField = `optionVar -q WTFileName` + RigPathToEnginePath(("SK_Player_" + `textField -q -tx charactername` + "_Origin_Facial_PV_01.fbx"));
	string $charactername = `textField -q -tx charactername`;
	string $PVFacialFbxFielddirname = dirname($PVFacialFbxField);
	$PVFacialFbxFielddirname = toNativePath($PVFacialFbxFielddirname);
	if (!`file -exists -q $PVFacialFbxFielddirname`)
	{
		warning("制作文件路径不存在。\n");
		system("mkdir \"" + $PVFacialFbxFielddirname + "\"");
		//system("explorer \"" + $PVFacialFbxFielddirname + "\"");
		print("制作文件路径已创建。\n");
	}
	if (`textField -q -tx CeresRigtextField` == "")
	{
		error ("请载入角色数据！\n");
	}else
	{
		//file -f -new;
		//设置场景Z轴朝上
		//upAxis -ax z -rv;
		file -f -open -options "v=0;" $PVFacialField;
		delete ($charactername + "_LOD");
		//不烘焙动画
		FBXExportAnimationOnly -v false;
		//导出平滑组
		FBXExportSmoothingGroups -v true;
		//导出Z轴向上
		string $NowupAxis = `upAxis -q -ax`;
		FBXExportUpAxis $NowupAxis;
		FBXExport -f $PVFacialFbxField;
		print ($PVFacialFbxField + "已制作完成！\n");
	}
}
	//检查文件
global proc PVFacialCheck () 
{
	string $PVFacialFbxField = `optionVar -q WTFileName` + RigPathToEnginePath(("SK_Player_" + `textField -q -tx charactername` + "_Origin_Facial_PV_01.fbx"));
	if (`textField -q -tx CeresRigtextField` == "")
	{
		error ("请载入角色数据！\n");
	}else
	{
		if (`file -exists -q $PVFacialFbxField` == 0)
		{
			error ("请先制作文件！\n");
		}else
		{
			file -f -new;
			//设置场景Y轴朝上
			upAxis -ax y -rv;
			file -f -import -options "v=0" $PVFacialFbxField;
			//居中场景
			viewSet -animate 0 -home;
			viewFit -animate 0 -all;
			print ("已成功导入：" + $PVFacialFbxField + "\n");
		}
	}
}

//制作 Lod 的 Facial 文件（fbx）文件2
	//制作文件
global proc GameFacialMake () 
{
	string $PVFacialField = `optionVar -q WTFileName` + `textField -q -tx CeresRigtextField`;
	string $GameFacialFbxField = `optionVar -q WTFileName` + RigPathToEnginePath(("SK_Player_" + `textField -q -tx charactername` + "_Origin_Facial_Lod_01.fbx"));
	string $GameFacialFbxFielddirname = dirname($GameFacialFbxField);
	$GameFacialFbxFielddirname = toNativePath($GameFacialFbxFielddirname);
	if (!`file -exists -q $GameFacialFbxFielddirname`)
	{
		warning("制作文件路径不存在。\n");
		system("mkdir \"" + $GameFacialFbxFielddirname + "\"");
		//system("explorer \"" + $GameFacialFbxFielddirname + "\"");
		print("制作文件路径已创建。\n");
	}
	if (`textField -q -tx CeresRigtextField` == "")
	{
		error ("请载入角色数据！\n");
	}else
	{
		//file -f -new;
