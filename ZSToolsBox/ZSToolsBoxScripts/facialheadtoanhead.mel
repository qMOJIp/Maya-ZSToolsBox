global proc FacialHeadToANHead()  
{
	if (`window -exists "FHtAHWindow"`)
	{  
		deleteUI -window "FHtAHWindow";
	}  
window -title "去除头模分支骨骼权重V.3" -h 170 -w 200 -rtf 1 -s 0 -tlb 1 FHtAHWindow;
columnLayout -h 170 -w 200 -columnAttach both 5 -adjustableColumn true FHtAHcolumnLayout;
	separator -h 5 -style "none";
	text -label "选择各层级Head模型后点击执行";
	separator -h 5 -style "none";
	button -c "AutoSelectHead" -label "选择" -ann "自动选择Head模型对象，非规范命名会导致缺漏" -p FHtAHcolumnLayout;
	button -c "ANFacialBoneTransformHead" -label "执行" -ann "保留Shoulder_R，Scapula_R，Shoulder_L，Scapula_L，Chest_M，Neck_M，Neck1_M，Head_M骨骼" -p FHtAHcolumnLayout;
	button -c "ANFacialBoneTransformHeadForLod" -label "增加保留Adams" -ann "在制作各lod权重时用到" -p FHtAHcolumnLayout;
	separator -h 5 -style "none";
	text -label "选择各层级附件模型后点击执行";
	separator -h 5 -style "none";
	button -c "AutoSelectAnnex" -label "选择" -ann "自动选择Head附件模型对象，非规范命名会导致缺漏，仅支持常规7附件和胡子和眉毛" -p FHtAHcolumnLayout;
	button -c "ANFacialBoneTransformAnnex" -label "执行" -ann "保留Neck_M，Neck1_M，Head_M骨骼" -p FHtAHcolumnLayout;
	separator -h 5 -style "none";
showWindow;
}

global proc AutoSelectAnnex () 
{
	string $SelectMesh[] = `ls -g -ni "*?eeth*"`;
	$SelectMesh = `listRelatives -p $SelectMesh`;
	select -r $SelectMesh;
	$SelectMesh = `ls -g -ni "*?ye?dge*"`;
	$SelectMesh = `listRelatives -p $SelectMesh`;
	select -add $SelectMesh;
	$SelectMesh = `ls -g -ni "*?ye?ight*"`;
	$SelectMesh = `listRelatives -p $SelectMesh`;
	select -add $SelectMesh;
	$SelectMesh = `ls -g -ni "*?ye?eft*"`;
	$SelectMesh = `listRelatives -p $SelectMesh`;
	select -add $SelectMesh;
	$SelectMesh = `ls -g -ni "*?aliva*"`;
	$SelectMesh = `listRelatives -p $SelectMesh`;
	select -add $SelectMesh;
	$SelectMesh = `ls -g -ni "*?ye?hell*"`;
	$SelectMesh = `listRelatives -p $SelectMesh`;
	select -add $SelectMesh;
	$SelectMesh = `ls -g -ni "*?ye?ashes*"`;
	$SelectMesh = `listRelatives -p $SelectMesh`;
	select -add $SelectMesh;
	$SelectMesh = `ls -g -ni "*?eard*"`;
	$SelectMesh = `listRelatives -p $SelectMesh`;
	select -add $SelectMesh;
	$SelectMesh = `ls -g -ni "*?row*"`;
	$SelectMesh = `listRelatives -p $SelectMesh`;
	select -add $SelectMesh;
}

