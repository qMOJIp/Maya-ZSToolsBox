if (`workspaceControl -exists RigUseToEngineUseExportWorkspaceControl`)
{
	deleteUI RigUseToEngineUseExportWorkspaceControl;
	workspaceControl -visible 1 -hp free -ih 100 -iw 250 -rsh 250 -rsw 250 -dtc Outliner bottom -retain false -floating 0 -uiScript "RigUseToEngineUseExportuiScript" -label "FBX导出插件" RigUseToEngineUseExportWorkspaceControl;
}else
{
	workspaceControl -visible 1 -hp free -ih 100 -iw 250 -rsh 250 -rsw 250 -dtc Outliner bottom -retain false -floating 0 -uiScript "RigUseToEngineUseExportuiScript" -label "FBX导出插件" RigUseToEngineUseExportWorkspaceControl;
}
global proc RigUseToEngineUseExportuiScript()
{
	columnLayout -columnAttach both 5 -adjustableColumn true RTEEcolumnLayout;
		rowLayout -nc 3 -columnWidth3 60 1 180 -adj 3 -p RTEEcolumnLayout RTEEExportFileNamerowLayout;
			text -w 60 "文件名称：";
			textField -w 1 -editable 0 -tx "" RTEEExportFileNameLock;
				popupMenu -button 3;
					menuItem -label "刷新路径" -c "RTEERefreshTextField";
			textField -w 180 -tx "" RTEEExportFileName;// -editable false -bgc 0.265 0.265 0.265
				popupMenu -button 3;
					menuItem -label "刷新路径" -c "RTEERefreshTextField";
		rowLayout -nc 3 -columnWidth3 60 1 180 -adj 3 -p RTEEcolumnLayout RTEEExportFilePathrowLayout;
			text -w 60 "导出路径：";
			textField -w 1 -editable 0 -tx "" RTEEExportFilePathLock;
				popupMenu -button 3;
					menuItem -label "打开路径" -c "RTEEOpenFilePath";
					menuItem -label "刷新路径" -c "RTEERefreshTextField";
			textField -w 180 -tx "" RTEEExportFilePath;// -editable false -bgc 0.265 0.265 0.265
				popupMenu -button 3;
					menuItem -label "打开路径" -c "RTEEOpenFilePath";
					menuItem -label "刷新路径" -c "RTEERefreshTextField";
		rowLayout -nc 4 -columnWidth4 1 79 79 79 -adj 1 -p RTEEcolumnLayout;
			text "";
			checkBox -ofc "RTEEExportSameNameONOFF" -onc "RTEEExportSameNameONOFF" -w 79 -v 0 -label "导相同名称" RTEEExportSameName;
			checkBox -ofc "RTEEExportSamePathONOFF" -onc "RTEEExportSamePathONOFF" -w 79 -v 0 -label "导相同路径" RTEEExportSamePath;
			checkBox -ofc "RTEEExportEnginePathONOFF" -onc "RTEEExportEnginePathONOFF" -w 79 -v 0 -label "导引擎路径" RTEEExportEnginePath;
		rowLayout -nc 3 -columnWidth3 112 112 20 -adj 1 -p RTEEcolumnLayout;
			button -c "RTEEFBXExportBotton(\"ma\");RTEESaveExportSetting();" -w 112 -ann "导出MA文件" -label "导出MA";
				popupMenu -button 3;
					menuItem -label "打开检查" -c "RTEECheckFile(\"ma\")";
			button -c "RTEEFBXExportBotton(\"fbx\");RTEESaveExportSetting();" -w 112 -ann "导出FBX文件" -label "导出FBX";
				popupMenu -button 3;
					menuItem -label "打开检查" -c "RTEECheckFile(\"fbx\")";
			button -c "RTEEExportSetting" -w 20 -ann "展开导出设置" -label "◆" RTEEExportSettingButton;
	frameLayout -vis 0 -bv 1 -labelIndent 100 -label "导出设置" -p RTEEcolumnLayout RTEEExportSettingframeLayout;
		rowLayout -nc 3 -columnWidth3 15 120 110 -adj 1 -p RTEEExportSettingframeLayout;
			text -w 10 "";
			checkBox -w 120 -v 1 -label "去除约束后导出" RTEERemoveConstraint;
			checkBox -w 110 -v 1 -label "仅导出选择对象" RTEEExportSelect;
		rowLayout -nc 3 -columnWidth3 15 120 110 -adj 1 -p RTEEExportSettingframeLayout;
			text -w 10 "";
			checkBox -w 120 -v 0 -label "导出时烘焙动画" -ann "仅影响导出FBX" RTEEExportAnimation;
			checkBox -w 110 -v 1 -label "导出包含平滑组" -ann "仅影响导出FBX" RTEEExportSmoothingGroups;
		rowLayout -nc 4 -columnWidth4 1 79 79 79 -adj 1 -p RTEEExportSettingframeLayout;
			text "";
			checkBox -ofc "RTEEYUpAxisONOFF" -onc "RTEEYUpAxisONOFF" -ann "仅影响导出FBX" -w 79 -v 0 -label "以 Y 轴导出" RTEEYUpAxis;
			checkBox -ofc "RTEEZUpAxisONOFF" -onc "RTEEZUpAxisONOFF" -ann "仅影响导出FBX" -w 79 -v 0 -label "以 Z 轴导出" RTEEZUpAxis;
			checkBox -ofc "RTEESceneUpAxisONOFF" -onc "RTEESceneUpAxisONOFF" -ann "仅影响导出FBX" -w 79 -v 1 -label "与场景同轴" RTEESceneUpAxis;
		button -c "RTEESaveExportSetting" -label "保存导出设置" -p RTEEExportSettingframeLayout;
		RTEEAPIBackExportSetting ();
}

//导出文本
global proc writeFile ( string $filename, string $addcontents )
{
	$fileId=`fopen $filename "a"`;
	fprint $fileId ( $addcontents );
	fclose $fileId;
}

//清理文本
global proc cleanFile ( string $cfilename )
{
	$cfileId=`fopen $cfilename "w"`;
	fprint $cfileId "";
	fclose $cfileId;
}

