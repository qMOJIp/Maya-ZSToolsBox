global proc WTAutoBodyFileMake()  
{
	if (`window -exists "WTAutoBodyFileMakewindow"`)
	{
		deleteUI -window "WTAutoBodyFileMakewindow";
	}
	window -title "WT Rig All ЯрЙиЮФМўжЦзї" -h 530 -w 405 -rtf 1 -s 0 -tlb 0 WTAutoBodyFileMakewindow;



}
//дЄЩшЮФМўаДШы
global proc writeFile ( string $filename, string $addcontents )
{
	$fileId=`fopen $filename "a"`;
	fprint $fileId ( $addcontents );
	fclose $fileId;
}

//дЄЩшЮФМўЧхПе
global proc cleanFile ( string $cfilename )
{
	$cfileId=`fopen $cfilename "w"`;
	fprint $cfileId "";
	fclose $cfileId;
}
//ЕМГіСЌНг
global proc ExportConnection( string $SourceObject , string $ExportPath )
{
	string $CurrentConnectionpFrom[] = `listConnections -s 1 -d 0 -c 1 -p 1 $SourceObject`;
	string $CurrentConnectionpFromText = stringArrayToString($CurrentConnectionpFrom , "\n");
	string $CurrentConnectionpTo[] = `listConnections -s 0 -d 1 -c 1 -p 1 $SourceObject`;
	string $CurrentConnectionpToText = stringArrayToString($CurrentConnectionpTo , "\n");
	string $ExportFromFile = $ExportPath + "/" + $SourceObject + ".from";
	string $ExportToFile = $ExportPath + "/" + $SourceObject + ".to";
	if (!`file -exists -q $ExportFromFile`)
	{
		writeFile ( $ExportFromFile, $CurrentConnectionpFromText );
		print("ГЩЙІЕМГі" + $ExportFromFile + "\n");
	}
	else if (`file -exists -q $ExportFromFile`)
	{
		cleanFile ( $ExportFromFile );
		writeFile ( $ExportFromFile, $CurrentConnectionpFromText );
		print("ГЩЙІИВИЧ" + $ExportFromFile + "\n");
	}
	if (!`file -exists -q $ExportToFile`)
	{
		writeFile ( $ExportToFile, $CurrentConnectionpToText );
		print("ГЩЙІЕМГі" + $ExportToFile + "\n");
	}
	else if (`file -exists -q $ExportToFile`)
	{
		cleanFile ( $ExportToFile );
		writeFile ( $ExportToFile, $CurrentConnectionpToText );
		print("ГЩЙІИВИЧ" + $ExportToFile + "\n");
	}
}

//ЕМШыСЌНг
global proc ImportConnection( string $SourceObject , string $ExportPath )
{
	string $ExportFromFile = $ExportPath + "/" + $SourceObject + ".from";
	string $ExportToFile = $ExportPath + "/" + $SourceObject + ".to";
	string $CurrentConnectionpFrom[];
	string $CurrentConnectionpTo[];
	if (`file -exists -q $ExportFromFile`)
	{
		int $fileId = `fopen $ExportFromFile "r"`;
		int $i = 0;
		while (!`feof $fileId`)
		{
			string $line = `fgetline $fileId`;
			if ($line != "") 
			{
				$CurrentConnectionpFrom[$i] = strip($line);
				$i++;
			}
		}
	}else
	{
		error ($ExportFromFile + "ЮФМўШБЪЇЃЁЃЁ\n");
	}
	if (`file -exists -q $ExportToFile`)
	{
		int $fileId = `fopen $ExportToFile "r"`;
		int $i = 0;
		while (!`feof $fileId`)
		{
			string $line = `fgetline $fileId`;
			if ($line != "") 
			{
				$CurrentConnectionpTo[$i] = strip($line);
				$i++;
			}
		}
	}else
	{
		error ($ExportToFile + "ЮФМўШБЪЇЃЁЃЁ\n");
	}
	//ДІРэБЛСЌНг
	for ($i=1; $i<size($CurrentConnectionpFrom); $i=$i+2)
	{
		connectAttr -f $CurrentConnectionpFrom[$i] $CurrentConnectionpFrom[$i-1];
	}
	//ДІРэСЌНг
	for ($i=0; $i<size($CurrentConnectionpTo); $i=$i+2)
	{
		connectAttr -f $CurrentConnectionpTo[$i] $CurrentConnectionpTo[$i+1];
	}
}

//ЖЯПЊСЌНг
global proc BreakConnection( string $SourceObject , string $ExportPath )
{
	duplicate -n ($SourceObject + "_TMP") $SourceObject;
	string $ExportFromFile = $ExportPath + "/" + $SourceObject + ".from";
	string $ExportToFile = $ExportPath + "/" + $SourceObject + ".to";
	string $CurrentConnectionpFrom[];
	string $CurrentConnectionpTo[];
	if (`file -exists -q $ExportFromFile`)
	{
		int $fileId = `fopen $ExportFromFile "r"`;
		int $i = 0;
		while (!`feof $fileId`)
		{
			string $line = `fgetline $fileId`;
			if ($line != "") 
			{
				$CurrentConnectionpFrom[$i] = strip($line);
				$i++;
			}
		}
	}else
	{
		error ($ExportFromFile + "ЮФМўШБЪЇЃЁЃЁ\n");
	}
	if (`file -exists -q $ExportToFile`)
	{
		int $fileId = `fopen $ExportToFile "r"`;
		int $i = 0;
		while (!`feof $fileId`)
		{
			string $line = `fgetline $fileId`;
			if ($line != "") 
			{
				$CurrentConnectionpTo[$i] = strip($line);
				$i++;
			}
		}
	}else
	{
		error ($ExportToFile + "ЮФМўШБЪЇЃЁЃЁ\n");
	}
	//ДІРэБЛСЌНг
	for ($i=1; $i<size($CurrentConnectionpFrom); $i=$i+2)
	{
		if (`objExists $CurrentConnectionpFrom[$i]` && `objExists $CurrentConnectionpFrom[$i-1]`) 
		{
			if (`isConnected $CurrentConnectionpFrom[$i] $CurrentConnectionpFrom[$i-1]`)
			{
				disconnectAttr $CurrentConnectionpFrom[$i] $CurrentConnectionpFrom[$i-1];
				print ("вЦГ§СЌНг " + $CurrentConnectionpFrom[$i] + " КЭ " + $CurrentConnectionpFrom[$i-1] + "\n");
			}
		}
	}
	//ДІРэСЌНг
	for ($i=0; $i<size($CurrentConnectionpTo); $i=$i+2)
	{
		if (`objExists $CurrentConnectionpTo[$i]` && `objExists $CurrentConnectionpTo[$i+1]`) 
		{
			if (`isConnected $CurrentConnectionpTo[$i] $CurrentConnectionpTo[$i+1]`)
			{
				disconnectAttr $CurrentConnectionpTo[$i] $CurrentConnectionpTo[$i+1];
				print ("вЦГ§СЌНг " + $CurrentConnectionpTo[$i] + " КЭ " + $CurrentConnectionpTo[$i+1] + "\n");
			}
		}
	}
	delete $SourceObject;
	rename ($SourceObject + "_TMP") $SourceObject;
}

global proc BatchExportConnection()
{
	string $SourceAndTarget[] = `ls -sl`;
	for ($i = 0;$i < size($SourceAndTarget); $i++)
	{
		ExportConnection( $SourceAndTarget[$i] , "E:/Connections preset");
	}
}

global proc BatchImportConnection()
{
	string $SourceAndTarget[] = `ls -sl`;
	for ($i = 0;$i < size($SourceAndTarget); $i++)
	{
		ImportConnection( $SourceAndTarget[$i] , "E:/Connections preset");
	}
}

global proc BatchBreakConnection()
{
	string $SourceAndTarget[] = `ls -sl`;
	for ($i = 0;$i < size($SourceAndTarget); $i++)
	{
		BreakConnection( $SourceAndTarget[$i] , "E:/Connections preset");
	}
}

BatchExportConnection();
BatchImportConnection();
BatchBreakConnection();