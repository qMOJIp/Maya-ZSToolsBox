global proc CustomPluginPanel ()
{
	if (`window -exists "CustomPluginPanelWindow"`)
	{
		deleteUI -window "CustomPluginPanelWindow";
	}
	window -title "Ľý”ŕ»®÷ō‘ľ Ý" -h 50 -w 200 -rtf 1 -s 0 -tlb 0 CustomPluginPanelWindow;
		columnLayout -columnAttach both 5 -adjustableColumn true ConstrainByJointscolumnLayout;
	showWindow CustomPluginPanelWindow;
}
CustomPluginPanel();