	}
}
	//读取错误日志
global proc ReadErrorLog()  
{
	if (`window -exists "ReadErrorLogWindow"`)
	{  
		deleteUI -window "ReadErrorLogWindow";
	}  
	window -t "错误日志" -rtf 1 -s 1 -tlb 1 ReadErrorLogWindow;
		columnLayout -columnAttach both 5 -adjustableColumn true ReadErrorLogcolumnLayout;
		string $Charactername = `textField -q -tx charactername`;
		separator -h 5 -style "none";
		text -fn boldLabelFont -bgc 0.5 0.2 0.2 -label ($Charactername + "约束报错");
		scrollLayout ReadErrorLogscrollLayout;
		separator -h 5 -style "none";
		string $Characternum = `textField -q -tx characternum`;
		string $ErrorLogFilePath = "Z:\\WT\\WT_maya\\scenes\\Rig\\Player\\" + $Characternum + "\\Error_Log.txt";
		$ErrorLogId=`fopen $ErrorLogFilePath "r"`;
		string $ErrorLogLine = `fgetline $ErrorLogId`;
		while ( size( $ErrorLogLine ) > 0 ) 
		{
			text -label $ErrorLogLine -p ReadErrorLogscrollLayout;
			//print ( $ErrorLogLine );
			$ErrorLogLine = `fgetline $ErrorLogId`;
		}
		fclose $ErrorLogId;
	showWindow;  
}
	//仅执行约束
global proc OnlyRunConstrain()  
{
	string $Charactername = `textField -q -tx charactername`;
	string $NameSpace = "SK_Player_" + $Charactername + "_Origin_An_01:";

	//创建日志文件
	string $errorFileCreate = "Z:\\WT\\WT_maya\\scenes\\Rig\\Player\\" + `textField -q -tx characternum` + "\\Error_Log.txt";
	int $existslog = `file -exists -q $errorFileCreate`;
	if ($existslog) {
		//清空日志内容
		$fileIdC=`fopen $errorFileCreate "w"`;
		fprint $fileIdC "";
		fclose $fileIdC;
	}
	//写入日志
	$fileId=`fopen $errorFileCreate "a"`;

	//“角色An版fbx文件”的骨骼 批量约束 “角色An版ma文件”的控制器
	string $jeuseanfbxboneSpace = "";
	string $jeuseanmactrlSpace = $NameSpace;
	string $jeuseanfbxbone[];
	string $jeuseanmactrl[];
	int $ConstrainBodyControlKey = 1;
	
	for ($i = 0; $i < 70; $i++)
	{
		$jeuseanfbxbone[$i] = `textField -q -tx ("sourceConstrain1" + $i)`;
		$jeuseanmactrl[$i] = `textField -q -tx ("targetConstrain1" + $i)`;
		string $parentsource = $jeuseanfbxboneSpace + $jeuseanfbxbone[$i];
		string $parenttarget = $jeuseanmactrlSpace + $jeuseanmactrl[$i];
		if ($jeuseanfbxbone[$i] == "" || $jeuseanmactrl[$i] == "")
		{
			continue;
		}else {
			if (objExists($parentsource)) 
			{
				print ("对象 " + $parentsource + " 存在。\n");
			}else{
				fprint $fileId ("对象 " + $parentsource + " 不存在。\n");
				warning ("对象 " + $parentsource + " 不存在。\n");
				$ConstrainBodyControlKey = 0;
			}
			if (objExists($parenttarget)) 
			{
				print ("对象 " + $parenttarget + " 存在。\n");
			}else{
				fprint $fileId ("对象 " + $parenttarget + " 不存在。\n");
				warning ("对象 " + $parenttarget + " 不存在。\n");
				$ConstrainBodyControlKey = 0;
			}
		}
	}

	//条件满足开始执行约束
	if ($ConstrainBodyControlKey ==1)
	{
		for ($i = 0; $i < 70; $i++)
		{
			$jeuseanfbxbone[$i] = `textField -q -tx ("sourceConstrain1" + $i)`;
			$jeuseanmactrl[$i] = `textField -q -tx ("targetConstrain1" + $i)`;
			string $parentsource = $jeuseanfbxboneSpace + $jeuseanfbxbone[$i];
			string $parenttarget = $jeuseanmactrlSpace + $jeuseanmactrl[$i];
			if ($jeuseanfbxbone[$i] == "" || $jeuseanmactrl[$i] == "")
			{
				continue;
			}else {
				if ($jeuseanfbxbone[$i] != "" && $jeuseanmactrl[$i] != "")
				{
					parentConstraint -mo -w 1.0 $parentsource $parenttarget;
				}
			}
			print ("成功执行约束：" + $parentsource + "和" + $parenttarget + "\n");
		}
	}

	//“角色An版ma文件”的骨骼 批量约束 “第2步制作的ma文件”的骨骼
	 
	string $jeuseanmaboneSpace = $NameSpace;
	string $headmaboneSpace = $Charactername + "_Facial_An:";
	string $jeuseanmabone[];
	string $headmabone[];
	int $ConstrainBodyToFacialKey = 1;
	 
	for ($i = 0; $i < 30; $i++) 
	{
		$jeuseanmabone[$i] = `textField -q -tx ("sourceConstrain2" + $i)`;
		$headmabone[$i] = `textField -q -tx ("targetConstrain2" + $i)`;
		string $parentsource1 = $jeuseanmaboneSpace + $jeuseanmabone[$i];
		string $parenttarget1 = $headmaboneSpace + $headmabone[$i];
		if ($jeuseanmabone[$i] == "" || $headmabone[$i] == "")
		{
			continue;
		}else {
			if (objExists($parentsource1)) 
			{
				print ("对象 " + $parentsource1 + " 存在。\n");
			}else{
				fprint $fileId ("对象 " + $parentsource1 + " 不存在。\n");
				warning ("对象 " + $parentsource1 + " 不存在。\n");
				$ConstrainBodyToFacialKey = 0;
			}
			if (objExists($parenttarget1)) 
			{
				print ("对象 " + $parenttarget1 + " 存在。\n");
			}else{
				fprint $fileId ("对象 " + $parenttarget1 + " 不存在。\n");
				warning ("对象 " + $parenttarget1 + " 不存在。\n");
				$ConstrainBodyToFacialKey = 0;
			}
		}
	}
	fclose $fileId;//写出完日志

	//条件满足开始执行约束
	if ($ConstrainBodyToFacialKey == 1)
	{
		for ($i = 0; $i < 30; $i++) 
		{
			$jeuseanmabone[$i] = `textField -q -tx ("sourceConstrain2" + $i)`;
			$headmabone[$i] = `textField -q -tx ("targetConstrain2" + $i)`;
			string $parentsource1 = $jeuseanmaboneSpace + $jeuseanmabone[$i];
			string $parenttarget1 = $headmaboneSpace + $headmabone[$i];
			if ($jeuseanmabone[$i] == "" || $headmabone[$i] == "")
			{
				continue;
			}else {
				if ($jeuseanfbxbone[$i] != "" && $jeuseanmactrl[$i] != "")
				{
					parentConstraint -mo -w 1.0 $parentsource1 $parenttarget1;
				}
			}
			print ("成功执行约束：" + $parentsource1 + "和" + $parenttarget1 + "\n");
		}
	}
}
	//拷贝勾选文件至上传目录
global proc CopyFileToSend () 
{
	string $FacialSendFilePath = `optionVar -q WTFileName` + RigPathToAnimationPath ( "" );
	string $BodyWithFacialSendFile = "//192.168.20.102/projects/CIDA_RG/临时文件/WT角色身体+表情文件/SK_Player_" + `textField -q -tx charactername` + "_Origin_BodyWithFacial_An_01.ma";
	string $BodyWithFacialSendFilePath = "//192.168.20.102/projects/CIDA_RG/临时文件/WT角色身体+表情文件";
	string $SaveFacialAnMa = "Z:/WT/WT_maya/scenes/Rig/Player/" + `textField -q -tx characternum` + "/SK_Player_" + `textField -q -tx charactername` + "_Origin_Facial_An_01.ma";
	string $SaveBodyWithFacialAnMa = "Z:/WT/WT_maya/scenes/Rig/Player/" + `textField -q -tx characternum` + "/SK_Player_" + `textField -q -tx charactername` + "_Origin_BodyWithFacial_An_01.ma";
	if (`checkBox -q -v FacialcheckBox` == 1)
	{
		$SaveFacialAnMa = toNativePath($SaveFacialAnMa);
		$FacialSendFilePath = toNativePath($FacialSendFilePath);
		system("copy \"" + $SaveFacialAnMa + "\" \"" + $FacialSendFilePath + "\"");
	}
	if (`checkBox -q -v BodyWithFacialcheckBox` == 1)
	{
		if (`file -exists -q $BodyWithFacialSendFile`)
		{
			string $result = `confirmDialog -title "警告" -message "该文件已制作，非必要不替换，点击继续将强制替换并为新文件加上“只读”属性！！" -button "继续" -button "取消"`;// -defaultButton "继续" -cancelButton "取消"
			if ($result == "继续")
			{
				$SaveBodyWithFacialAnMa = toNativePath($SaveBodyWithFacialAnMa);
				$BodyWithFacialSendFilePath = toNativePath($BodyWithFacialSendFilePath);
				$BodyWithFacialSendFile = toNativePath($BodyWithFacialSendFile);
				system("del /F \"" + $BodyWithFacialSendFile + "\"");
				system("copy \"" + $SaveBodyWithFacialAnMa + "\" \"" + $BodyWithFacialSendFilePath + "\"");
				system("attrib +R \"" + $BodyWithFacialSendFile + "\"");
			} else
			{
				print("已取消替换。");
			}
		}else
		{
			$SaveBodyWithFacialAnMa = toNativePath($SaveBodyWithFacialAnMa);
			$BodyWithFacialSendFilePath = toNativePath($BodyWithFacialSendFilePath);
			$BodyWithFacialSendFile = toNativePath($BodyWithFacialSendFile);
			system("copy \"" + $SaveBodyWithFacialAnMa + "\" \"" + $BodyWithFacialSendFilePath + "\"");
			system("attrib +R \"" + $BodyWithFacialSendFile + "\"");
		}
	}
}


global proc WTAFFMCopyCeresPath ( float $MakeFileNum )
{
	string $MakeField;
	string $scriptsPath = `internalVar -userScriptDir`;
	string $windowsscriptsPath = toNativePath( $scriptsPath );
	string $quickopenprojectfiletemp = $windowsscriptsPath + "ZSToolsBox/PublicFiles/quickopenprojectfiletemp.txt";
	if ($MakeFileNum == 1)
	{
		$MakeField = RigPathToEnginePath(("SK_Player_" + `textField -q -tx charactername` + "_Origin_Facial_PV_01.fbx"));
	}
	if ($MakeFileNum == 2)
	{
		$MakeField = RigPathToEnginePath(("SK_Player_" + `textField -q -tx charactername` + "_Origin_Facial_Lod_01.fbx"));
	}
	if ($MakeFileNum == 3.1)
	{
		$MakeField = `textField -q -tx CeresRigtextField`;
	}
	if ($MakeFileNum == 3.2)
	{
		$MakeField = RigPathToAnimationPath ( "/SK_Player_" + `textField -q -tx charactername` + "_Origin_Facial_An_01.dna" );
	}
	if ($MakeFileNum == 3.3)
	{
		$MakeField = RigPathToAnimationPath ( "/SK_Player_" + `textField -q -tx charactername` + "_Origin_An_01.fbx" );
	}
	if ($MakeFileNum == 3.4)
	{
		$MakeField = RigPathToAnimationPath ( "/SK_Player_" + `textField -q -tx charactername` + "_Origin_An_01.ma" );
	}
	if ($MakeFileNum == 3.5)
	{
		$MakeField = RigPathToAnimationPath ( "/SK_Player_" + `textField -q -tx charactername` + "_Origin_Facial_An_01.ma" );
	}
	$fileId=`fopen $quickopenprojectfiletemp "w"`;
	fprint $fileId ( $MakeField );
	fclose $fileId;
	system("start \"" + $windowsscriptsPath + "ZSToolsBox/PublicFiles/PathCopy.exe\"");
}

global proc WTAFFMOpenMakePath ( float $MakeFileNum )
{
	string $MakeField;
	if ($MakeFileNum == 1)
	{
		$MakeField = RigPathToEnginePath(("SK_Player_" + `textField -q -tx charactername` + "_Origin_Facial_PV_01.fbx"));
	}
	if ($MakeFileNum == 2)
	{
		$MakeField = RigPathToEnginePath(("SK_Player_" + `textField -q -tx charactername` + "_Origin_Facial_Lod_01.fbx"));
	}
	$MakeField = dirname($MakeField);
	$MakeField = toNativePath($MakeField);
	system("explorer \"" + $MakeField + "\"");
}

global proc WTAFFMLocCeresPath ( float $MakeFileNum )
{
	string $WhatFile;
	string $CeresLocFile;
	if ($MakeFileNum == 1)
	{
		$CeresLocFile = RigPathToEnginePath(("SK_Player_" + `textField -q -tx charactername` + "_Origin_Facial_PV_01.fbx"));
	}
	if ($MakeFileNum == 2)
	{
		$CeresLocFile = RigPathToEnginePath(("SK_Player_" + `textField -q -tx charactername` + "_Origin_Facial_Lod_01.fbx"));
	}
	if ($MakeFileNum == 3.1)
	{
		$CeresLocFile = `textField -q -tx CeresRigtextField`;
	}
	if ($MakeFileNum == 3.2)
	{
		$CeresLocFile = RigPathToAnimationPath ( "/SK_Player_" + `textField -q -tx charactername` + "_Origin_Facial_An_01.dna" );
	}
	if ($MakeFileNum == 3.3)
	{
		$CeresLocFile = RigPathToAnimationPath ( "/SK_Player_" + `textField -q -tx charactername` + "_Origin_An_01.fbx" );
	}
	if ($MakeFileNum == 3.4)
	{
		$CeresLocFile = RigPathToAnimationPath ( "/SK_Player_" + `textField -q -tx charactername` + "_Origin_An_01.ma" );
	}
	if ($MakeFileNum == 3.5)
	{
		$CeresLocFile = RigPathToAnimationPath ( "/SK_Player_" + `textField -q -tx charactername` + "_Origin_Facial_An_01.ma" );
	}
	if (`textField -q -tx CeresRigtextField` == "")
	{
		error ("请载入角色数据！\n");
	}else
	{
		textField -e -tx $CeresLocFile quickopenFilePath;
		textField -e -tx "WT" ProjectTextField;
		optionVar -sv NowProject (`optionVar -q WTFileName`);
		changetoCeres ();
		print ("开始定位！\n");
	}
}

