// GN Import run command
global proc GN_Import()
{
	python("from GN_ImportExport.GN_scripts import GN_Import");
	python("GN_Import.GN_Import(optionBox=False)");
}

// GN Import option box
global proc GN_ImportOptions()
{
	python("from GN_ImportExport.GN_scripts import GN_Import");
	python("GN_Import.GN_Import(optionBox=True)");
}

// GN Export run command
global proc GN_Export()
{	
	python("from GN_ImportExport.GN_scripts import GN_Export");
	python("GN_Export.GN_Export(optionBox=False)");
}

// GN Export option box
global proc GN_ExportOptions()
{
	python("from GN_ImportExport.GN_scripts import GN_Export");
	python("GN_Export.GN_Export(optionBox=True)");
}

// GN Clean Cache
global proc GN_ImportExportCleanup()
{
	python("from GN_ImportExport.GN_scripts import GN_ImportExportCleanup");
	python("GN_ImportExportCleanup.GN_ImportExportCleanup()");
}

// Command to close GN Import/Export menu
global proc IE_CloseMenu()
{
    for ($menu in `lsUI -m`)
    {
        if (`menu -q -l $menu` == "GN Import/Export")
        {
            deleteUI $menu;
            break;
        }
    }
}

