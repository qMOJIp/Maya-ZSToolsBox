//制作NakeBody文件（ma）制作文件11
	//制作文件
global proc NakeBodyMake ( string $BodyAlltextField , string $CharacterName ) 
{
	string $NakeBodyFile = `optionVar -q WTFileName` + dirname($BodyAlltextField) + "/SK_Player_" + $CharacterName + "_Nake_Body_Rig_01.ma";
	string $FacialAllFile = `optionVar -q WTFileName` + dirname((dirname($BodyAlltextField))) + "/Facial/SK_Player_" + $CharacterName + "_Origin_Facial_All_01.ma";
	if (!`file -exists -q $NakeBodyFile`)
	{
		eval ("source \"" + `internalVar -userScriptDir` + "ZSToolsBox/ZSToolsBoxScripts/facialheadtoanhead.mel\"");
		warning("该文件为首次制作请手动制作,已为你打开手动制作所需插件。\n");
	}
	//打开之前的NakeBody文件
	file -f -open -options "v=0" $NakeBodyFile;
	if (`objExists "BasicFacial"`)
	{
		delete BasicFacial;
	}
	//删除无用材质
	hyperShadePanelMenuCommand("hyperShadePanel1", "deleteUnusedNodes");

	//处理头模
	Faceweightshift ( $FacialAllFile , $CharacterName , "Facial_PV" , "BasicFacial" );
	//报存场景
	SaveScene;
	print ($NakeBodyFile + "已制作完成！\n");
}

//删除无用骨骼
global proc DeleteUnKeepBone ( string $WTABFMcharactername , string $WTABFMcharacterskin , string $WTABFMweaponname , string $WTABFMparasitename ) 
{
	//删除无用骨骼
	string $RigAllMessagePath = "//192.168.20.102/projects/CIDA_RG/020 绑定公共数据/RigAll角色数据/";
	string $KeepBoneMessagePath;
	if ($WTABFMweaponname == "" )
	{
		if ($WTABFMparasitename == "" )
		{
			$KeepBoneMessagePath = $RigAllMessagePath + $WTABFMcharactername + "_" + $WTABFMcharacterskin + ".parasitekeepbone";
		}else
		{
			$KeepBoneMessagePath = $RigAllMessagePath + $WTABFMcharactername + "_" + $WTABFMcharacterskin + "_" + $WTABFMparasitename + ".parasitekeepbone";
		}
	}else
	{
		$KeepBoneMessagePath = $RigAllMessagePath + $WTABFMcharactername + "_" + $WTABFMcharacterskin + "_" + $WTABFMweaponname + ".weaponkeepbone";
	}
	if (`file -exists -q $KeepBoneMessagePath`)
	{
		select -r `ls -type "joint"`;
		string $SelectKeepBoneArray[] = {};
		int $fileId = `fopen $KeepBoneMessagePath "r"`;
		int $i = 0;
		while (!`feof $fileId`)
		{
			string $line = `fgetline $fileId`;
			if ($line != "") 
			{
				$SelectKeepBoneArray[$i] = $line;
				$i++;
			}
		}
		select -d $SelectKeepBoneArray;
		doDelete;
	}
}

//facialall文件处理
global proc Faceweightshift ( string $FacialAllFile , string $CharacterName , string $RetainMesh , string $NewName ) 
{
	//给身体骨架加前缀
	select -hi UnrealRoot;
	string $PreFixArray[] = `ls -sl`;
	for ($i=size($PreFixArray)-1;$i>=0;$i--)
	{
		string $PreFixArrayNew[] = stringToStringArray($PreFixArray[$i], "|");
		rename $PreFixArray[$i] ("TMPprefix_" + $PreFixArrayNew[size($PreFixArrayNew)-1]);
	}
	//导入facialall文件
	file -namespace ":" -f -import -options "v=0" $FacialAllFile;
	if (`gmatch $RetainMesh "*LOD*"`)
	{
		parent -w $RetainMesh;
		//delete ($CharacterName + "_LOD");
	}else
	{
		delete ($CharacterName + "_LOD");
	}
	//选择头模
	string $FacialPVChild[] = `listRelatives -children $RetainMesh`;
	select -r $FacialPVChild;
	$FacialPVChild = `ls -sl`;
	//转移权重
	ANFacialBoneTransformHead ();
	//转移骨骼
	duplicate -n ("TMP_" + $NewName) -rr $RetainMesh;
	select -hi ("TMP_" + $NewName);
	$PreFixArray = `ls -sl`;
	for ($i=size($PreFixArray)-1;$i>=0;$i--)
	{
		string $PreFixArrayNew[] = stringToStringArray($PreFixArray[$i], "|");
		rename $PreFixArray[$i] ("NEW_" + $PreFixArrayNew[size($PreFixArrayNew)-1]);
	}
	//选择新头模
	string $NEWFacialPVChild[] = `listRelatives -children ("NEW_TMP_" + $NewName)`;
	select -r $NEWFacialPVChild;
	select -add TMPprefix_Shoulder_R TMPprefix_Scapula_R TMPprefix_Shoulder_L TMPprefix_Scapula_L TMPprefix_Chest_M TMPprefix_Neck_M TMPprefix_Neck1_M TMPprefix_Head_M;
	newSkinCluster "-toSelectedBones -bindMethod 0  -normalizeWeights 1 -weightDistribution 0 -mi 4 -omi true -dr 4 -rui true  , multipleBindPose, 0";
	//拷贝权重
	for($i = 0; $i < size($FacialPVChild); $i++)
	{
		select -r $FacialPVChild[$i];
		select -add $NEWFacialPVChild[$i];
		copySkinWeights -noMirror -surfaceAssociation closestPoint -influenceAssociation oneToOne;
	}
	//返回位移编辑防止权重编辑下删除模型导致卡死
	TranslateToolWithSnapMarkingMenu;
	//移除未影响权重
	select -r $NEWFacialPVChild;
	removeUnusedInfluences;
	
	//删除原头模
	delete $RetainMesh;
	//删除Facial all的骨骼
	delete UnrealRoot;

	//给身体骨架去前缀
	select -r TMPprefix_UnrealRoot ;
	searchReplaceNames "TMPprefix_" "$" "hierarchy";
	//给头模去前缀
	select -r ("NEW_TMP_" + $NewName) ;
	searchReplaceNames "NEW_" "$" "hierarchy";
	rename ("TMP_" + $NewName) $NewName;

	//删除无用材质-已确认导出不会包含无用材质所以无需清理
	hyperShadePanelMenuCommand("hyperShadePanel1", "deleteUnusedNodes");
}

//制作文件
	//UI用
global proc WTABFMFileMakeUI ( int $MakeFileNum )
{
	//获取基础信息
	string $BodyAlltextField = `textField -q -tx BodyAlltextField`;
	string $CharacterName = WTABFMEnter1 ( $BodyAlltextField );
	string $WeaponName = `textField -q -tx WTABFMweaponname`;
	string $ParasiteName = `textField -q -tx WTABFMparasitename`;
	string $WTABFMParasiteSkin;
	string $WTABFMParasiteSkin1 = `textField -q -tx WTABFMParasiteSkin1`;
	string $WTABFMParasiteSkin2 = `textField -q -tx WTABFMParasiteSkin2`;
	if ($MakeFileNum == 3)
	{
		$WTABFMParasiteSkin = $WTABFMParasiteSkin1;
	}
	if ($MakeFileNum == 4)
	{
		$WTABFMParasiteSkin = $WTABFMParasiteSkin2;
	}

	//获取设置变异体名
	string $WTABFMparasitenamePath = "//192.168.20.102/projects/CIDA_RG/020 绑定公共数据/RigAll角色数据/CharacterToAttachment/CharacterToParasite.txt";
	//获取储存文件每行内容
	global string $AllParasiteName[];
	$AllParasiteName = {};
	string $Parasitelines[];
	int $ParasitefileId = `fopen $WTABFMparasitenamePath "r"`;
	int $Parasitei = 0;
	global int $Parasitea = 0;
	while (!`feof $ParasitefileId`)
	{
		$Parasitelines[$Parasitei] = `fgetline $ParasitefileId`;
		if (`gmatch $Parasitelines[$Parasitei] ("*" + $CharacterName + "*")`)
		{
			string $WTABFMParasiteName[] = stringToStringArray($Parasitelines[$Parasitei], "==>");
			$AllParasiteName[$Parasitea] = strip($WTABFMParasiteName[1]);
			$Parasitea = $Parasitea + 1;
		}
		$Parasitei++;
	}
	fclose $ParasitefileId;
	// 删除空项
	$AllParasiteName = removeEmptyElements($AllParasiteName);
	if (size($AllParasiteName) == 0)
	{
		$AllParasiteName = {""};
	}
	string $CharacterSkin = `textField -q -tx WTABFMcharacterskin`;
	WTABFMFileMake ( $MakeFileNum , $BodyAlltextField , $CharacterName , $WeaponName , $ParasiteName , $AllParasiteName , $CharacterSkin , $WTABFMParasiteSkin );
}

global proc WTABFMFileMake ( int $MakeFileNum , string $BodyAlltextField , string $CharacterName , string $WeaponName , string $ParasiteName , string $AllParasiteName[] , string $CharacterSkin , string $ImportFileCharacterSkin )
{
	if ($BodyAlltextField == "")
	{
		error ("请载入角色数据！\n");
	}
	
	string $FileMessage[] =
	{
		$BodyAlltextField,
		$CharacterName,
		$WeaponName,
		$ParasiteName,
		$CharacterSkin
	};
	string $ParasiteLodFile[];
	for ($i=0; $i<size($AllParasiteName); $i++)
	{
		string $ImportFileMessage[] =
		{
			$BodyAlltextField,
			$CharacterName,
			$WeaponName,
			$AllParasiteName[$i],
			$ImportFileCharacterSkin
		};
		$ParasiteLodFile[$i] = `optionVar -q WTFileName` + SkinChoosePath ($ImportFileMessage,"Parasite","Lod","fbx");
	}
	string $MakefilePath;
	if ($MakeFileNum == 1)
	{
		OpenRigAll ();
		$MakefilePath = `optionVar -q WTFileName` +  SkinChoosePath ($FileMessage,"Body","PV","fbx");
		PVBodyMake ( $MakefilePath , $FileMessage[1] , $FileMessage[4] );
	}
	if ($MakeFileNum == 2)
	{
		OpenRigAll ();
		$MakefilePath = `optionVar -q WTFileName` +  SkinChoosePath ($FileMessage,"Body","Lod","fbx");
		GameBodyMake ( $MakefilePath , $FileMessage[1] , $FileMessage[4] );
	}
	if ($MakeFileNum == 3)
	{
		OpenRigAll ();
		$MakefilePath = `optionVar -q WTFileName` +  SkinChoosePath ($FileMessage,"Skin","An","ma");
		AnBodyMaMake ( $MakefilePath , $FileMessage[0] , $FileMessage[1] , $FileMessage[4] , $ParasiteLodFile );
	}
	if ($MakeFileNum == 4)
	{
		OpenRigAll ();
		$MakefilePath = `optionVar -q WTFileName` +  SkinChoosePath ($FileMessage,"Skin","An","fbx");
		AnBodyFbxMake ( $MakefilePath , $FileMessage[0] , $FileMessage[1] , $FileMessage[4] , $ParasiteLodFile );
	}
	if ($MakeFileNum == 5)
	{
		OpenRigAll ();
		$MakefilePath = `optionVar -q WTFileName` +  SkinChoosePath ($FileMessage,"Weapon","PV","fbx");
		PVWeaponFbxMake ( $MakefilePath , $FileMessage[1] , $FileMessage[4] , $FileMessage[2] );
	}
	if ($MakeFileNum == 6)
	{
		OpenRigAll ();
		$MakefilePath = `optionVar -q WTFileName` +  SkinChoosePath ($FileMessage,"Weapon","Lod","fbx");
		LodWeaponFbxMake ( $MakefilePath , $FileMessage[1] , $FileMessage[4] , $FileMessage[2] );
	}
	if ($MakeFileNum == 7)
	{
		OpenRigAll ();
		$MakefilePath = `optionVar -q WTFileName` +  SkinChoosePath ($FileMessage,"Weapon","An","ma");
		AnWeaponMaMake ( $MakefilePath , $FileMessage[1] , $FileMessage[4] , $FileMessage[2] );
	}
	if ($MakeFileNum == 8)
	{
		OpenRigAll ();
		$MakefilePath = `optionVar -q WTFileName` +  SkinChoosePath ($FileMessage,"Weapon","An","fbx");
		AnWeaponFbxMake ( $MakefilePath , $FileMessage[1] , $FileMessage[4] , $FileMessage[2] );
	}
	if ($MakeFileNum == 9)
	{
		OpenRigAll ();
		$MakefilePath = `optionVar -q WTFileName` +  SkinChoosePath ($FileMessage,"Parasite","PV","fbx");
		PVParasiteFbxMake ( $MakefilePath , $FileMessage[1] , $FileMessage[4] , $FileMessage[3] );
	}
	if ($MakeFileNum == 10)
	{
		OpenRigAll ();
		$MakefilePath = `optionVar -q WTFileName` +  SkinChoosePath ($FileMessage,"Parasite","Lod","fbx");
		LodParasiteFbxMake ( $MakefilePath , $FileMessage[1] , $FileMessage[4] , $FileMessage[3] );
	}
	if ($MakeFileNum == 11)
	{
		OpenRigAll ();
		NakeBodyMake ( $FileMessage[0] , $FileMessage[1] );
	}
	if ($MakeFileNum == 12)
	{
		OpenRigAll ();
	}
}

//单个权重转移逻辑
global proc WeightTransform ( string $Bone[] , string $targetBone , string $mesh )
{
	string $skinCluster = `findRelatedSkinCluster($mesh)`;
	string $influences[] = `skinCluster -q -inf $skinCluster`;
	string $AllBone[] = `ls -type joint`;
	//初始化权重工具
	ArtPaintSkinWeightsTool;
	artAttrPaintOperation artAttrSkinPaintCtx Replace;
	//print ("设置绘制模式为替换完成。\n");
	artAttrSkinPaintCtx -e -opacity 1 `currentCtx`;
	//print ("设置笔刷透明度完成。\n");
	artSkinSetSelectionValue 1 false artAttrSkinPaintCtx artAttrSkin;
	//print ("设置笔刷权重值完成。\n");
	doNormalizeWeightsArgList 1 {"2"};
	//print ("归一化选中模型权重完成。\n");
	print ("初始化完成！！\n");
	//锁定所有骨骼权重
	for ($i = 0; $i < size($AllBone); $i++)
	{
		for ($c = 0; $c < size($influences); $c++)
		{
			if ($AllBone[$i] == $influences[$c])
			{
				setAttr ($AllBone[$i] + ".liw") 1;
				break;
			}else
			{
				continue;
			}	
		}
	}
	//解锁需转移骨骼权重
	for ($i = 0; $i < size($Bone); $i++)
	{
		for ($c = 0; $c < size($influences); $c++)
		{
			if ($Bone[$i] == $influences[$c])
			{
				setAttr ($Bone[$i] + ".liw") 0;
				break;
			}else
			{
				continue;
			}	
		}
	}
	//解锁需目标骨骼权重
	print ("当前转移骨骼：" + $targetBone + "\n");
	setAttr ($targetBone + ".liw") 0;
	artSkinInflListChanging ($targetBone) 1;
	artSkinInflListChanged artAttrSkinPaintCtx;
	artAttrSkinPaintCtx -e -clear `currentCtx`;
}

global proc ANFacialBoneTransformHead () 
{
	string $seletion[] = `ls -sl`;
	string $KeepBone[] = {
		"Shoulder_R","Scapula_R","Shoulder_L","Scapula_L","Chest_M","Neck_M","Neck1_M","Head_M"
	};
	string $NeckChildBones[] = {
		"FACIAL_C_Neck1Root","FACIAL_C_NeckB","FACIAL_L_NeckB1","FACIAL_R_NeckB1","FACIAL_L_NeckB2","FACIAL_R_NeckB2","FACIAL_C_12IPV_NeckB1","FACIAL_C_12IPV_NeckB2","FACIAL_L_12IPV_NeckB3","FACIAL_R_12IPV_NeckB3","FACIAL_L_12IPV_NeckB4","FACIAL_R_12IPV_NeckB4","FACIAL_L_12IPV_NeckB5","FACIAL_R_12IPV_NeckB5","FACIAL_L_12IPV_NeckB6","FACIAL_R_12IPV_NeckB6","FACIAL_L_12IPV_NeckB7","FACIAL_R_12IPV_NeckB7","FACIAL_C_NeckBackB","FACIAL_L_NeckBackB","FACIAL_R_NeckBackB","FACIAL_C_12IPV_NeckBackB1","FACIAL_C_12IPV_NeckBackB2","FACIAL_L_12IPV_NeckBackB1","FACIAL_R_12IPV_NeckBackB1","FACIAL_L_12IPV_NeckBackB2","FACIAL_R_12IPV_NeckBackB2"
	};
	string $Neck1ChildBones[] = {
		"FACIAL_C_Neck2Root","FACIAL_C_AdamsApple","FACIAL_C_12IPV_AdamsA1","FACIAL_C_12IPV_AdamsA2","FACIAL_L_NeckA1","FACIAL_R_NeckA1","FACIAL_L_NeckA2","FACIAL_R_NeckA2","FACIAL_L_NeckA3","FACIAL_R_NeckA3","FACIAL_L_12IPV_NeckA1","FACIAL_R_12IPV_NeckA1","FACIAL_L_12IPV_NeckA2","FACIAL_R_12IPV_NeckA2","FACIAL_L_12IPV_NeckA3","FACIAL_R_12IPV_NeckA3","FACIAL_L_12IPV_NeckA4","FACIAL_R_12IPV_NeckA4","FACIAL_L_12IPV_NeckA5","FACIAL_R_12IPV_NeckA5","FACIAL_L_12IPV_NeckA6","FACIAL_R_12IPV_NeckA6","FACIAL_C_NeckBackA","FACIAL_L_NeckBackA","FACIAL_R_NeckBackA","FACIAL_C_12IPV_NeckBackA1","FACIAL_C_12IPV_NeckBackA2","FACIAL_L_12IPV_NeckBackA1","FACIAL_R_12IPV_NeckBackA1","FACIAL_L_12IPV_NeckBackA2","FACIAL_R_12IPV_NeckBackA2"
