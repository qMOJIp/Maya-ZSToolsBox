		checkBox -e -v  1 FacialcheckBox;
	}
}
	//取消勾选Facial时同时取消勾选BodyWithFacial
global proc TogetherBodyWithFacial () 
{
	if (`checkBox -q -v FacialcheckBox` == 0)
	{
