	};
	for ($i = 0;$i <size($seletion);$i++){
		print ("\n\n当前转移模型：" + $seletion[$i] + "\n");
		//添加缺失影响物
		select -r $seletion[$i];
		select -add $KeepBone;
		skinClusterInfluence 1 "-ug -dr 4 -ps 0 -ns 10 -lw true -wt 0";
		select -r $seletion[$i];
		WeightTransform ( $NeckChildBones , "Neck_M" , $seletion[$i] );
		print ("Neck_M骨骼转移完成\n");
		WeightTransform ( $Neck1ChildBones , "Neck1_M" , $seletion[$i] );
		print ("Neck1_M骨骼转移完成\n");
		WeightTransform ( $HeadChildBones , "Head_M" , $seletion[$i] );
		print ("Head_M骨骼转移完成\n");
		//返回位移编辑防止权重编辑下删除模型导致卡死
		TranslateToolWithSnapMarkingMenu;
		//移除未影响权重
		select -r $seletion[$i];
		removeUnusedInfluences;
	}
}

//单个权重转移逻辑
global proc WeightTransform ( string $Bone[] , string $targetBone , string $mesh )
{
	string $skinCluster = `findRelatedSkinCluster($mesh)`;
	string $influences[] = `skinCluster -q -inf $skinCluster`;
	string $AllBone[] = `ls -type joint`;
	//初始化权重工具
	ArtPaintSkinWeightsTool;
	artAttrPaintOperation artAttrSkinPaintCtx Replace;
	//print ("设置绘制模式为替换完成。\n");
	artAttrSkinPaintCtx -e -opacity 1 `currentCtx`;
	//print ("设置笔刷透明度完成。\n");
	artSkinSetSelectionValue 1 false artAttrSkinPaintCtx artAttrSkin;
	//print ("设置笔刷权重值完成。\n");
	doNormalizeWeightsArgList 1 {"2"};
	//print ("归一化选中模型权重完成。\n");
	print ("初始化完成！！\n");
	//锁定所有骨骼权重
	for ($i = 0; $i < size($AllBone); $i++)
	{
		for ($c = 0; $c < size($influences); $c++)
		{
			if ($AllBone[$i] == $influences[$c])
			{
				setAttr ($AllBone[$i] + ".liw") 1;
				break;
			}else
			{
				continue;
			}	
		}
	}
	//解锁需转移骨骼权重
	for ($i = 0; $i < size($Bone); $i++)
	{
		for ($c = 0; $c < size($influences); $c++)
		{
			if ($Bone[$i] == $influences[$c])
			{
				setAttr ($Bone[$i] + ".liw") 0;
				break;
			}else
			{
				continue;
			}	
		}
	}
	//解锁需目标骨骼权重
	print ("当前转移骨骼：" + $targetBone + "\n");
	setAttr ($targetBone + ".liw") 0;
	artSkinInflListChanging ($targetBone) 1;
	artSkinInflListChanged artAttrSkinPaintCtx;
	artAttrSkinPaintCtx -e -clear `currentCtx`;
}
FacialHeadToANHead();
