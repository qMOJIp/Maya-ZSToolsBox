//检查所有
global proc CACPCheckAll ()
{
	float $MinKey = 0;
	float $MaxKey = 0;
	string $KeyedObjects[] = GetAllKeyedObjects ();
	for ($KeyedObject in $KeyedObjects)
	{
		float $keyTimes[] = getObjectKeyframeRange ( $KeyedObject );
		if ($keyTimes[0] < $MinKey)
		{
			$MinKey = $keyTimes[0];
		}
		if ($keyTimes[1] > $MaxKey)
		{
			$MaxKey = $keyTimes[1];
		}
	}
	playbackOptions -ast $MinKey -aet $MaxKey -min $MinKey -max $MaxKey;
}

//播放图标改变
global proc CACPChangePlayIcon ( string $direction )
{
	string $Oppositedirection = "L";
	if ($direction == "L")
	{
		$Oppositedirection = "R";
	}
	if (`symbolButton -q -image  ("CACPPlay" + $direction)` == (`asInstallScriptLocation` + "Icon/Play_" + $direction + ".svg"))
	{
		if (`symbolButton -q -image  ("CACPPlay" + $Oppositedirection)` == (`asInstallScriptLocation` + "Icon/Play_" + $Oppositedirection + ".svg"))
		{
			symbolButton -e-image (`asInstallScriptLocation` + "Icon/RoundedSquares.svg") ("CACPPlay" + $direction);
		}else
		{
			if ($direction == "L")
			{
				playButtonStepForward;
			}else
			{
				playButtonStepBackward;
			}
			symbolButton -e-image (`asInstallScriptLocation` + "Icon/Play_" + $Oppositedirection + ".svg") ("CACPPlay" + $Oppositedirection);
			symbolButton -e-image (`asInstallScriptLocation` + "Icon/RoundedSquares.svg") ("CACPPlay" + $direction);
		}
	}else
	{
		symbolButton -e-image (`asInstallScriptLocation` + "Icon/Play_" + $direction + ".svg") ("CACPPlay" + $direction);
	}
}
//保存所有数据
global proc CACPPart1SaveCom ()
{
	global string $CACPDatePath;
	string $CACPDateConfigPath = `substring $CACPDatePath 1 (size($CACPDatePath)-4)` + "config";
	string $Content = "";
	//获取多选数据分组
	string $CACPEdittabLayoutChilds[] = `tabLayout -q -childArray CACPEdittabLayout`;
	$CACPEdittabLayoutChilds = sort($CACPEdittabLayoutChilds);
	for ($CACPEdittabLayoutChild in $CACPEdittabLayoutChilds)
	{
		$Content = $Content + `substitute "CACPPart" $CACPEdittabLayoutChild ""` + ";";
	}
	$Content = $Content + "\n";
	fwriteAllText ( $CACPDateConfigPath, $Content );
	//获取基础数据
	string $CACPButtonEidtNnames[] = `scrollLayout -q -childArray CACPPart1scrollLayout`;
	$Content = "";
	for ($CACPButtonEidtNname in $CACPButtonEidtNnames)
	{
		$Content = $Content + "1;";
		$Content = $Content + `textFieldButtonGrp -q -label ($CACPButtonEidtNname + "1")` + ";";
		$Content = $Content + `intField -q -value ($CACPButtonEidtNname + "2")`;
		$Content = $Content + "-";
		$Content = $Content + `intField -q -value ($CACPButtonEidtNname + "4")` + ";";
		$Content = $Content + `textFieldButtonGrp -q -text ($CACPButtonEidtNname + "1")` + ";\n";
	}
	writeFile ( $CACPDateConfigPath, $Content );
	//获取多选数据
	for ($CACPEdittabLayoutChild in $CACPEdittabLayoutChilds)
	{
		if ($CACPEdittabLayoutChild != "CACPPart1")
		{
			int $PartNum = `substitute "CACPPart" $CACPEdittabLayoutChild ""`;
			$Content = "";
			string $CACPMultipleEidtNnames[] = `scrollLayout -q -childArray ($CACPEdittabLayoutChild + "scrollLayout")`;
			for ($CACPMultipleEidtNname in $CACPMultipleEidtNnames)
			{
				if (`textFieldButtonGrp -q -text ($CACPMultipleEidtNname + "1")` == "")
				{
					continue;
				}else
				{
					$Content = $Content + $PartNum + ";";
					$Content = $Content + `textFieldButtonGrp -q -text ($CACPMultipleEidtNname + "1")` + ";";
					$Content = $Content + `intField -q -value ($CACPMultipleEidtNname + "2")`;
					$Content = $Content + "-";
					$Content = $Content + `intField -q -value ($CACPMultipleEidtNname + "4")` + ";";
					$Content = $Content + ";\n";
				}
			}
			writeFile ( $CACPDateConfigPath, $Content );
		}
	}
	CACPLoadAimDate ( $CACPDateConfigPath );
}
//确认按钮显示名
global proc CACPPart1ConfirmCom ()
{
	//获取当前已有额外部位数量
	$CACPButtonNum = `gridLayout -q -numberOfChildren CACPgridLayout`;
	for ($i=0; $i<$CACPButtonNum; $i++)
	{
		string $ButtonName = `textFieldButtonGrp -q -text ("CACPButton" + $i + "Edit1")`;
		button -e -label $ButtonName ("CACPButton" + $i);
	}
}
//清除本次加载数据路径
global proc CACPCleanNowDate ()
{
	global string $CACPDatePath;
	$CACPDatePath = "";
	if (`window -exists "CACPEidtExtraWindow"`)
	{
		deleteUI -window "CACPEidtExtraWindow";
	}
	if (`window -exists "CACPHelpWindow"`)
	{
		deleteUI -window "CACPHelpWindow";
	}
}
//增加额外部位
global proc CACPPart1AddCom ()
{
	//获取当前已有额外部位数量
	int $CACPButtonNum = `gridLayout -q -numberOfChildren CACPgridLayout`;
	button -po 0 -bgc 0.5 0.5 0.5 -c ("CACPFilterParts ( \"CACPButton" + $CACPButtonNum + "\" )") -p CACPgridLayout ("CACPButton" + $CACPButtonNum);
	rowColumnLayout -adj 1 -numberOfColumns 4 -columnWidth 1 230 -columnWidth 2 40 -columnWidth 3 10 -columnWidth 4 40 -p CACPPart1scrollLayout ("CACPButton" + $CACPButtonNum + "Edit");
	textFieldButtonGrp -columnWidth3 110 80 40 -columnAlign 1 center -ann "设置按钮显示名/获取帧区间" -label ("CACPButton" + $CACPButtonNum) -text "" -buttonLabel "获取" -buttonCommand ("CACPGetKeyScale(\"CACPButton" + $CACPButtonNum + "\")") -p ("CACPButton" + $CACPButtonNum + "Edit") ("CACPButton" + $CACPButtonNum + "Edit1");
	intField -h 25 -w 40 -ann "设置最小帧" -value 0 -p ("CACPButton" + $CACPButtonNum + "Edit") ("CACPButton" + $CACPButtonNum + "Edit2");
	text -label "-" -p ("CACPButton" + $CACPButtonNum + "Edit") ("CACPButton" + $CACPButtonNum + "Edit3");
	intField -h 25 -w 40 -ann "设置最大帧" -value 0 -p ("CACPButton" + $CACPButtonNum + "Edit") ("CACPButton" + $CACPButtonNum + "Edit4");
}
//减少额外部位
global proc CACPPart1ReduceCom ()
{
	//获取当前已有额外部位数量
	int $CACPButtonNum = `gridLayout -q -numberOfChildren CACPgridLayout` -1;
	if ($CACPButtonNum<0)
	{
		warning ("已无额外部位！！！\n");
	}else{
		deleteUI -control ("CACPButton" + $CACPButtonNum);
		deleteUI -control ("CACPButton" + $CACPButtonNum + "Edit4");
		deleteUI -control ("CACPButton" + $CACPButtonNum + "Edit3");
		deleteUI -control ("CACPButton" + $CACPButtonNum + "Edit2");
		deleteUI -control ("CACPButton" + $CACPButtonNum + "Edit1");
		deleteUI -layout ("CACPButton" + $CACPButtonNum + "Edit");
	}
}
//重置基础数据
global proc CACPPart1DefaultCom ()
{
	//获取当前已有额外部位数量
	int $CACPButtonNum = `gridLayout -q -numberOfChildren CACPgridLayout`;
	for ($i=0; $i<$CACPButtonNum; $i++)
	{
		deleteUI -control ("CACPButton" + $i);
	}
	//获取当前已有的额外部位编辑数据数量
	int $CACPButtonEidtNum = `scrollLayout -q -numberOfChildren CACPPart1scrollLayout` -10;
	for ($i=0; $i<$CACPButtonEidtNum; $i++)
	{
		deleteUI -control ("CACPButton" + $i + "Edit4");
		deleteUI -control ("CACPButton" + $i + "Edit3");
		deleteUI -control ("CACPButton" + $i + "Edit2");
		deleteUI -control ("CACPButton" + $i + "Edit1");
		deleteUI -layout ("CACPButton" + $i + "Edit");
	}
	//获取当前已有多选数据数量
	string $CACPEdittabLayoutChilds[] = `tabLayout -q -childArray CACPEdittabLayout`;
	for ($CACPEdittabLayoutChild in $CACPEdittabLayoutChilds) 
	{
		if($CACPEdittabLayoutChild != "CACPPart1")
		{
			deleteUI -layout $CACPEdittabLayoutChild;
		}
	}
	global string $CACPDatePath;
	if ($CACPDatePath != "")
	{
		string $CACPDateConfigPath = `substring $CACPDatePath 1 (size($CACPDatePath)-4)` + "config";
		if (`filetest -f $CACPDateConfigPath`)
		{
			CACPLoadAimDate ( $CACPDateConfigPath );
			//获取基础数据
			//获取当前已有额外部位数量
			$CACPButtonNum = `gridLayout -q -numberOfChildren CACPgridLayout`;
			for ($i=0; $i<$CACPButtonNum; $i++)
			{
				rowColumnLayout -adj 1 -numberOfColumns 4 -columnWidth 1 230 -columnWidth 2 40 -columnWidth 3 10 -columnWidth 4 40 -p CACPPart1scrollLayout ("CACPButton" + $i + "Edit");
				textFieldButtonGrp -columnWidth3 110 80 40 -columnAlign 1 center -ann "设置按钮显示名/获取帧区间" -label ("CACPButton" + $i) -text "" -buttonLabel "获取" -buttonCommand ("CACPGetKeyScale(\"CACPButton" + $i + "\")") -p ("CACPButton" + $i + "Edit") ("CACPButton" + $i + "Edit1");
				intField -h 25 -w 40 -ann "设置最小帧" -value 0 -p ("CACPButton" + $i + "Edit") ("CACPButton" + $i + "Edit2");
				text -label "-" -p ("CACPButton" + $i + "Edit") ("CACPButton" + $i + "Edit3");
				intField -h 25 -w 40 -ann "设置最大帧" -value 0 -p ("CACPButton" + $i + "Edit") ("CACPButton" + $i + "Edit4");
			}
			global string $CACPLoadAimDateType1[];
			global string $CACPLoadAimDateTime1[];
			global string $CACPLoadAimDateName1[];
			for ($i=0; $i<size($CACPLoadAimDateType1); $i++)
			{
				string $TimeScale[];
				tokenize($CACPLoadAimDateTime1[$i],"-",$TimeScale);
				int $MinValue = $TimeScale[0];
				int $MaxValue = $TimeScale[1];
				if (`gmatch $CACPLoadAimDateType1[$i] "*Button*"`)
				{
					textFieldButtonGrp -e -text $CACPLoadAimDateName1[$i] ($CACPLoadAimDateType1[$i] + "Edit1");
				}
				intField -e -value $MinValue ($CACPLoadAimDateType1[$i] + "Edit2");
				intField -e -value $MaxValue ($CACPLoadAimDateType1[$i] + "Edit4");
			}
			//获取多选数据
			int $CACPCheckPartNumCount = `optionMenu -q -numberOfItems CACPCheckPartNum`;
			for ($i=0; $i<$CACPCheckPartNumCount; $i++)
			{
				int $PartValue = `menuItem -q -label ("CACPCheckPartNummenuItem" + $i)`;
				if ($PartValue != 1)
				{
					intField -e -value $PartValue CACPMultipleintField;
					CACPMultipleAddCom();
					CACPMultipDefaultCom ( $PartValue );
				}
			}
		}
	}
}
//增加多选数据
global proc CACPMultipleAddCom ()
{
	//获取多选数据多选部位数
	int $parts = `intField -q -value CACPMultipleintField`;
	string $CACPEdittabLayoutChilds[] = `tabLayout -q -childArray CACPEdittabLayout`;
	//查询是否已经存在该数据
	int $Exist = stringArrayFind ( ("CACPPart" + $parts), 0 , $CACPEdittabLayoutChilds );
	if ($parts < 2)
	{
		warning ("多选值需大于1！！！\n");
	}else
	{
		if ($Exist == 1)
		{
			warning ("已存在多部位(" + $parts + ")数据！！！\n");
		}else
		{
			rowColumnLayout -w 401 -numberOfColumns 2 -columnWidth 1 340 -columnWidth 2 55 -p CACPEdittabLayout ("CACPPart" + $parts);
				scrollLayout -w 340 -h 200 -p ("CACPPart" + $parts) ("CACPPart" + $parts + "scrollLayout");
				columnLayout -p ("CACPPart" + $parts) ("CACPPart" + $parts + "columnLayout");
					button -p ("CACPPart" + $parts + "columnLayout") -c ("CACPMultipAddCom( " + $parts + ")") -width 55 -height 45 -ann "增加多选数据" -label "增加" ("CACPPart" + $parts + "Add");
					separator -p ("CACPPart" + $parts + "columnLayout") -height 10 -style "none";
					button -p ("CACPPart" + $parts + "columnLayout") -c ("CACPMultipReduceCom( " + $parts + ")") -width 55 -height 45 -ann "减少多选数据" -label "减少" ("CACPPart" + $parts + "Reduce");
					separator -p ("CACPPart" + $parts + "columnLayout") -height 10 -style "none";
					button -p ("CACPPart" + $parts + "columnLayout") -c ("CACPMultipDefaultCom( " + $parts + ")") -width 55 -height 45 -ann "重置多选数据" -label "重置" ("CACPPart" + $parts + "Default");
					text -p ("CACPPart" + $parts + "columnLayout") -height 13 -width 55 -label " - - - - - - - ";
					button -p ("CACPPart" + $parts + "columnLayout") -c ("CACPMultipDeleteCom( " + $parts + ")") -width 55 -height 30 -ann "删除多选数据" -label "删除" ("CACPPart" + $parts + "Delete");
			tabLayout -edit -tabLabel ("CACPPart" + $parts) ("多部位(" + $parts + ")") CACPEdittabLayout;
		}
	}
}
//增加多选数据
global proc CACPMultipAddCom ( int $Num )
{
	int $DateNum = `scrollLayout -q -numberOfChildren ("CACPPart" + $Num + "scrollLayout")`;
	rowColumnLayout -p ("CACPPart" + $Num + "scrollLayout") -adj 1 -numberOfColumns 4 -columnWidth 1 230 -columnWidth 2 40 -columnWidth 3 10 -columnWidth 4 40 ("CACPCACPPart" + $Num + "Date" + $DateNum + "Edit");
		textFieldButtonGrp -p ("CACPCACPPart" + $Num + "Date" + $DateNum + "Edit") -columnWidth3 60 130 40 -columnAlign 1 center -ann "获取启动按键和帧区间" -label "启动按键：" -text "" -buttonLabel "获取" -buttonCommand ("CACPGetMultipDate(" + $Num + ", " + $DateNum + ")") ("CACPCACPPart" + $Num + "Date" + $DateNum + "Edit1");
		intField -p ("CACPCACPPart" + $Num + "Date" + $DateNum + "Edit") -h 25 -w 40 -ann "设置最小帧" -value 0 ("CACPCACPPart" + $Num + "Date" + $DateNum + "Edit2");
		text -p ("CACPCACPPart" + $Num + "Date" + $DateNum + "Edit") -label "-" ("CACPCACPPart" + $Num + "Date" + $DateNum + "Edit3");
		intField -p ("CACPCACPPart" + $Num + "Date" + $DateNum + "Edit") -h 25 -w 40 -ann "设置最大帧" -value 0 ("CACPCACPPart" + $Num + "Date" + $DateNum + "Edit4");
}
//减少多选数据
global proc CACPMultipReduceCom ( int $Num )
{
	//获取当前已有额外部位数量
	int $DateNum = `scrollLayout -q -numberOfChildren ("CACPPart" + $Num + "scrollLayout")` -1;
	if ($DateNum<0)
	{
		warning ("已无额外部位！！！\n");
	}else{
		deleteUI -control ("CACPCACPPart" + $Num + "Date" + $DateNum + "Edit4");
		deleteUI -control ("CACPCACPPart" + $Num + "Date" + $DateNum + "Edit3");
		deleteUI -control ("CACPCACPPart" + $Num + "Date" + $DateNum + "Edit2");
		deleteUI -control ("CACPCACPPart" + $Num + "Date" + $DateNum + "Edit1");
		deleteUI -layout ("CACPCACPPart" + $Num + "Date" + $DateNum + "Edit");
	}
}
//重置多选数据
global proc CACPMultipDefaultCom ( int $Num )
{
	string $CACPPartChilds[] = `scrollLayout -q -childArray ("CACPPart" + $Num + "scrollLayout")`;
	for ($i=0; $i<size($CACPPartChilds); $i++) 
	{
		deleteUI -layout ("CACPCACPPart" + $Num + "Date" + $i + "Edit");
	}
	global string $CACPLoadAimDateTypeNow[];
	global string $CACPLoadAimDateTimeNow[];
	$CACPLoadAimDateTypeNow = {};
	$CACPLoadAimDateTimeNow = {};
	eval ("global string $CACPLoadAimDateType" + $Num + "[];");
	eval ("global string $CACPLoadAimDateTime" + $Num + "[];");
	eval ("$CACPLoadAimDateTypeNow = $CACPLoadAimDateType" + $Num + ";");
	eval ("$CACPLoadAimDateTimeNow = $CACPLoadAimDateTime" + $Num + ";");
	for ($a=0; $a<size($CACPLoadAimDateTypeNow); $a++)
	{
		string $TimeScale[];
		tokenize($CACPLoadAimDateTimeNow[$a],"-",$TimeScale);
		int $MinValue = $TimeScale[0];
		int $MaxValue = $TimeScale[1];
		CACPMultipAddCom($Num);
		textFieldButtonGrp -e -text $CACPLoadAimDateTypeNow[$a] ("CACPCACPPart" + $Num + "Date" + $a + "Edit1");
		intField -e -value $MinValue ("CACPCACPPart" + $Num + "Date" + $a + "Edit2");
		intField -e -value $MaxValue ("CACPCACPPart" + $Num + "Date" + $a + "Edit4");
	}
}
//删除多选数据面板
global proc CACPMultipDeleteCom ( int $Num )
{
	deleteUI -layout ("CACPPart" + $Num);
}
//移除多选数据
global proc CACPMultipleReduceCom ()
{
	int $parts = `intField -q -value CACPMultipleintField`;
	CACPMultipDeleteCom ( $parts );
}
//获取多选部位按钮和帧区间
global proc CACPGetMultipDate ( int $PlaneNum, int $DateNum )
{
	global string $DownButtonNames[];
	if (size($DownButtonNames) == $PlaneNum)
	{
		string $TextDownButtonNames = stringArrayToString( $DownButtonNames, ",");
		int $MinValue = `playbackOptions -q -min`;
		int $MaxValue = `playbackOptions -q -max`;
		textFieldButtonGrp -e -text $TextDownButtonNames ("CACPCACPPart" + $PlaneNum + "Date" + $DateNum + "Edit1");
		intField -e -value $MinValue ("CACPCACPPart" + $PlaneNum + "Date" + $DateNum + "Edit2");
		intField -e -value $MaxValue ("CACPCACPPart" + $PlaneNum + "Date" + $DateNum + "Edit4");
	}
	if (size($DownButtonNames) < $PlaneNum)
	{
		warning ("当前选取按钮不足！！！");
	}
	if (size($DownButtonNames) > $PlaneNum)
	{
		warning ("当前选取按钮过多！！！");
	}
}
//获取部位帧区间
global proc CACPGetKeyScale ( string $Name )
{
	int $MinValue = `playbackOptions -q -min`;
	int $MaxValue = `playbackOptions -q -max`;
	intField -e -value $MinValue ($Name + "Edit2");
	intField -e -value $MaxValue ($Name + "Edit4");
}
//动画数据列表
global proc CACPoptionMenuAdd ()
{
	menuItem -label "外部数据" -ann "外部数据" CACPmenuItem0;
	string $CACPDatePath = `asInstallScriptLocation` + "PublicFiles/Dates/AnimationCheckPanel/";
	string $DateNames[] = `getFileList -folder $CACPDatePath -filespec "*.json"`;
	for ($i=1; $i<=size($DateNames); $i++)
	{
		menuItem -label $DateNames[$i-1] -ann $DateNames[$i-1] ("CACPmenuItem" + $i);
	}
}
global string $CACPDatePath;
//加载外部动画数据
global proc LoadOutAimDate ()
{
	global string $CACPDatePath;
	int $SelectNum = `optionMenu -q -select CACPoptionMenu`;
	if ($SelectNum != 1)
	{
		$CACPDatePath = `asInstallScriptLocation` + "PublicFiles/Dates/AnimationCheckPanel/" + `menuItem -q -label ("CACPmenuItem" + ($SelectNum-1))`;
		string $CACPDateConfigPath = `substring $CACPDatePath 1 (size($CACPDatePath)-4)` + "config";
		if (!`filetest -e $CACPDateConfigPath`)
		{
			$result = `confirmDialog -messageAlign "center" -title "警告！" -message "由于未知原因插件中内置的配置文件丢失，是否继续。" -button "继续" -button "取消" -icon warning`;
			if ($result == "继续")
			{
				ImportSelectedKeyframes ( $CACPDatePath );
			}else{
				warning ("已取消载入数据！\n");
			}
		}else
		{
			ImportSelectedKeyframes ( $CACPDatePath );
			CACPLoadAimDate ( $CACPDateConfigPath );
		}
	}else
	{
		$CACPDatePath = `fileDialog -title "载入外部数据" -directoryMask "/usr/u//*.json"`;
		if ($CACPDatePath == "")
		{
			warning ("已取消载入外部数据！\n");
		}else
		{
			string $importfileConfigPath = `substring $CACPDatePath 1 (size($CACPDatePath)-4)` + "config";
			if (!`filetest -e $importfileConfigPath`)
			{
				$result = `confirmDialog -messageAlign "center" -title "警告！" -message "该外部数据同目录下无对应配置（.config）文件，是否继续。" -button "继续" -button "取消" -icon warning`;
				if ($result == "继续")
				{
					ImportSelectedKeyframes ( $CACPDatePath );
				}else{
					warning ("已取消载入数据！\n");
				}
			}else
			{
				ImportSelectedKeyframes ( $CACPDatePath );
				CACPLoadAimDate ( $importfileConfigPath );
			}
		}
	}
}
//卸载动画
global proc CACPUnLoadAimDate ()
{
	eval ("source \"" + `asInstallScriptLocation` + "Scripts/DeleteAllKey.mel\"");
}
//启动编辑模式
global proc CACPEditAimDate ()
{
	if (`button -q -po CACPEditAimDate` == 0)
	{
		global string $CACPDatePath;
		if ($CACPDatePath == "")
		{

			$result = `confirmDialog -messageAlign "center" -title "警告！" -message "当前并未导入动画数据，请载入一个数据文件或创建一个空数据文件后编辑！" -button "载入" -button "创建" -button "取消" -icon warning`;
			if ($result == "载入")
			{
				$CACPDatePath = `fileDialog -title "载入外部数据" -directoryMask "/usr/u//*.json"`;
				if ($CACPDatePath == "")
				{
					warning ("已取消载入外部数据！\n");
				}else
				{
					string $importfileConfigPath = `substring $CACPDatePath 1 (size($CACPDatePath)-4)` + "config";
					if (!`filetest -e $importfileConfigPath`)
					{
						$result = `confirmDialog -messageAlign "center" -title "警告！" -message "该外部数据同目录下无对应配置（.config）文件，是否继续。" -button "继续" -button "取消" -icon warning`;
						if ($result == "继续")
						{
							ImportSelectedKeyframes ( $CACPDatePath );
							button -e -po 1 -bgc 0.176 0.789 0.176 CACPEditAimDate;
							tabLayout -e -visible 1 CACPEdittabLayout;
							window -e -s 1 CheckAnimationCtrlPanelWindow;
							CACPPart1DefaultCom ();
							CACPEidtExtra ();
						}else{
							warning ("已取消载入数据！\n");
						}
					}else
					{
						ImportSelectedKeyframes ( $CACPDatePath );
						CACPLoadAimDate ( $importfileConfigPath );
					}
				}
			}
			if ($result == "创建")
			{
				string $exportfilePath[] = `fileDialog2 -caption "创建空数据" -fileFilter "JSON Files (*.json)"`;
				if (size($exportfilePath) == 0 || $exportfilePath[0] == "")
				{
					warning ("已取消创建！\n");
				}else
				{
					$CACPDatePath = $exportfilePath[0];
					button -e -po 1 -bgc 0.176 0.789 0.176 CACPEditAimDate;
					tabLayout -e -visible 1 CACPEdittabLayout;
					window -e -s 1 CheckAnimationCtrlPanelWindow;
					CACPPart1DefaultCom ();
					CACPEidtExtra ();
				}
			}
		}else
		{
			button -e -po 1 -bgc 0.176 0.789 0.176 CACPEditAimDate;
			tabLayout -e -visible 1 CACPEdittabLayout;
			window -e -s 1 CheckAnimationCtrlPanelWindow;
			CACPPart1DefaultCom ();
			CACPEidtExtra ();
		}
	}else
	{
		button -e -po 0 -bgc 0.366 0.366 0.366 CACPEditAimDate;
		tabLayout -e -visible 0 CACPEdittabLayout;
		window -e -h (`rowColumnLayout -q -h CACProwColumnLayout1` + `rowColumnLayout -q -h CACProwColumnLayout2` + 9) CheckAnimationCtrlPanelWindow;
		window -e -s 0 CheckAnimationCtrlPanelWindow;
		if (`window -exists "CACPEidtExtraWindow"`)
		{
			deleteUI -window "CACPEidtExtraWindow";
		}
	}
}
//恢复按键默认状态
global proc CACPRestoreDefault ()
{
	//恢复按键默认状态
	symbolButton -e -po 0 -en 1 -image (`asInstallScriptLocation` + "Icon/CACPHandIconLeft.svg") CACPHandIconLeft;
	symbolButton -e -po 0 -en 1 -image (`asInstallScriptLocation` + "Icon/CACPHandIconRight.svg") CACPHandIconRight;
	symbolButton -e -po 0 -en 1 -image (`asInstallScriptLocation` + "Icon/CACPElbowIconLeft.svg") CACPElbowIconLeft;
	symbolButton -e -po 0 -en 1 -image (`asInstallScriptLocation` + "Icon/CACPElbowIconRight.svg") CACPElbowIconRight;
	symbolButton -e -po 0 -en 1 -image (`asInstallScriptLocation` + "Icon/CACPFootIconLeft.svg") CACPFootIconLeft;
	symbolButton -e -po 0 -en 1 -image (`asInstallScriptLocation` + "Icon/CACPFootIconRight.svg") CACPFootIconRight;
	symbolButton -e -po 0 -en 1 -image (`asInstallScriptLocation` + "Icon/CACPHipIconLeft.svg") CACPHipIconLeft;
	symbolButton -e -po 0 -en 1 -image (`asInstallScriptLocation` + "Icon/CACPHipIconRight.svg") CACPHipIconRight;
	symbolButton -e -po 0 -en 1 -image (`asInstallScriptLocation` + "Icon/CACPHeadIcon.svg") CACPHeadIcon;
	symbolButton -e -po 0 -en 1 -image (`asInstallScriptLocation` + "Icon/CACPSpineIcon.svg") CACPSpineIcon;
	button -e -po 0 -bgc 0.5 0.5 0.5 CACPAllButton;
	global int $DownButtonNum;
	global string $PreButtonNames[];
	global string $DownButtonNames[];
	$DownButtonNum = 0;
	$PreButtonNames = {};
	$DownButtonNames = {};
	string $CACPButtonName[] = `gridLayout -q -childArray CACPgridLayout`;
	for ($Name in $CACPButtonName)
	{
		button -e -po 0 -en 1 -bgc 0.5 0.5 0.5 $Name;
	}
}
global string $CACPLoadAimDateType1[];
global string $CACPLoadAimDateTime1[];
global string $CACPLoadAimDateName1[];
$CACPLoadAimDateType1 = {};
$CACPLoadAimDateTime1 = {};
$CACPLoadAimDateName1 = {};
//载入动画数据
global proc CACPLoadAimDate ( string $Path )
{
	//初始化
	CACPRestoreDefault ();
	string $CACPButtonName[] = `gridLayout -q -childArray CACPgridLayout`;
	for ($Name in $CACPButtonName)
	{
		deleteUI -control $Name;
	}
	int $CACPCheckPartNumCount = `optionMenu -q -numberOfItems CACPCheckPartNum`;
	for ($i=0; $i<$CACPCheckPartNumCount; $i++)
	{
		deleteUI -menuItem ("CACPCheckPartNummenuItem" + $i);
	}

	string $CheckPastNum[] = {};
	string $AllLines[] = `freadAllLines($Path)`;
	tokenize($AllLines[0],";",$CheckPastNum);
	for ($i=0; $i<size($CheckPastNum); $i++)
	{
		if (`whatIs ("$CACPLoadAimDateType" + $CheckPastNum[$i])` != "string[] variable")
		{
			eval ("global string $CACPLoadAimDateType" + $CheckPastNum[$i] + "[];"); 
		}else
		{
			//eval ("global string $CACPLoadAimDateType" + $CheckPastNum[$i] + "[];"); 
			eval ("$CACPLoadAimDateType" + $CheckPastNum[$i] + " = {};"); 
		}
		if (`whatIs ("$CACPLoadAimDateTime" + $CheckPastNum[$i])` != "string[] variable")
		{
			eval ("global string $CACPLoadAimDateTime" + $CheckPastNum[$i] + "[];"); 
		}else
		{
			//eval ("global string $CACPLoadAimDateTime" + $CheckPastNum[$i] + "[];"); 
			eval ("$CACPLoadAimDateTime" + $CheckPastNum[$i] + " = {};"); 
		}
		menuItem -p CACPCheckPartNum -label $CheckPastNum[$i] ("CACPCheckPartNummenuItem" + $i);
	}
	global string $CACPLoadAimDateName1[];
	$CACPLoadAimDateName1 = {};
	for ($i=1; $i<size($AllLines); $i++)
	{
		string $LineInformation[];
		tokenize($AllLines[$i],";",$LineInformation);
		eval ("$CACPLoadAimDateType" + $LineInformation[0] + "[size($CACPLoadAimDateType" + $LineInformation[0] + ")] = \"" + $LineInformation[1] + "\";"); 
		eval ("$CACPLoadAimDateTime" + $LineInformation[0] + "[size($CACPLoadAimDateTime" + $LineInformation[0] + ")] = \"" + $LineInformation[2] + "\";");
		//$CheckPastNum[size($CheckPastNum)] = $LineInformation[0];
		if ($LineInformation[0] == 1)
		{
			$CACPLoadAimDateName1[size($CACPLoadAimDateName1)] = $LineInformation[3];
		}
		if (`gmatch $LineInformation[1] "CACPButton?"` && $LineInformation[0] == 1)
		{
			button -po 0 -label $LineInformation[3] -bgc 0.5 0.5 0.5 -c ("CACPFilterParts ( \"" + $LineInformation[1] + "\" )") -p CACPgridLayout $LineInformation[1];
		}
	}
	//$CheckPastNum = stringArrayRemoveDuplicates($CheckPastNum);
}
global int $DownButtonNum = 0;
global int $DownButtonIndexs[] = {};
global string $DownButtonNames[] = {};
global string $PreButtonNames[] = {};
global string $CACPLoadAimDateTypeNow[];
global string $CACPLoadAimDateTimeNow[];
//显示部位
global proc CACPFilterParts ( string $ButtonName )
{
	//非编辑模式
	if (`button -q -po CACPEditAimDate` == 0)
	{
		global int $DownButtonNum;
		global string $CACPLoadAimDateType1[];
		global string $CACPLoadAimDateTime1[];
		int $SelectType = `optionMenu -q -value CACPCheckPartNum`;
		if ( $SelectType == 1 )
		{
			if (`gmatch $ButtonName "*Icon*"`)
			{
				if ($DownButtonNum == 0)
				{
					symbolButton -e -po 1 -image (`asInstallScriptLocation` + "Icon/" + $ButtonName + "ON.svg") $ButtonName;
					$DownButtonNum = $DownButtonNum +1;
				}else
				{
					for ($element in $CACPLoadAimDateType1)
					{
						if (`gmatch $element "*Icon*"`)
						{
							symbolButton -e -po 0 -image (`asInstallScriptLocation` + "Icon/" + $element + ".svg") $element;
						}else
						{
							button -e -po 0 -bgc 0.5 0.5 0.5 $element;
						}
					}
					symbolButton -e -po 1 -image (`asInstallScriptLocation` + "Icon/" + $ButtonName + "ON.svg") $ButtonName;
				}
			}
			if (`gmatch $ButtonName "*Button*"`)
			{
				if ($DownButtonNum == 0)
				{
					button -e -po 1 -bgc 0.176 0.789 0.176 $ButtonName;
					$DownButtonNum = $DownButtonNum +1;
				}else
				{
					for ($element in $CACPLoadAimDateType1)
					{
						if (`gmatch $element "*Icon*"`)
						{
							symbolButton -e -po 0 -image (`asInstallScriptLocation` + "Icon/" + $element + ".svg") $element;
						}else
						{
							button -e -po 0 -bgc 0.5 0.5 0.5 $element;
						}
					}
					button -e -po 1 -bgc 0.176 0.789 0.176 $ButtonName;
				}
			}
			int $ButtonIndex[] = findStringIndexInArray ( $CACPLoadAimDateType1, $ButtonName, 0 );
			string $TimeScale[];
			tokenize($CACPLoadAimDateTime1[$ButtonIndex[0]],"-",$TimeScale);
			playbackOptions -ast $TimeScale[0] -aet $TimeScale[1] -min $TimeScale[0] -max $TimeScale[1];
		}else
		{
			global string $CACPLoadAimDateTypeNow[];
			global string $CACPLoadAimDateTimeNow[];
			$CACPLoadAimDateTypeNow = {};
			$CACPLoadAimDateTimeNow = {};
			global string $DownButtonNames[];
			eval ("global string $CACPLoadAimDateType" + $SelectType + "[];");
			eval ("global string $CACPLoadAimDateTime" + $SelectType + "[];");
			eval ("$CACPLoadAimDateTypeNow = $CACPLoadAimDateType" + $SelectType + ";");
			eval ("$CACPLoadAimDateTimeNow = $CACPLoadAimDateTime" + $SelectType + ";");
			if (`gmatch $ButtonName "*Icon*"`)
			{
				if ($DownButtonNum <= $SelectType)
				{
					if (`symbolButton -q -po $ButtonName` == 1)
					{
						string $ButtonNameTmp[];
						$ButtonNameTmp[0] = $ButtonName;
						string $DownButtonNamesTmp[];
						$DownButtonNamesTmp = $DownButtonNames;
						//refresh;
						symbolButton -e -po 0 -image (`asInstallScriptLocation` + "Icon/" + $ButtonName + ".svg") $ButtonName;
						//$DownButtonNum = $DownButtonNum -1;
						global int $DownButtonIndexs[];
						$DownButtonIndexs = {};
						$DownButtonNum = 0;
						CACPRestoreDefault ();
						$DownButtonNames = stringArrayRemoveExact($ButtonNameTmp,$DownButtonNamesTmp);
						//print $DownButtonNames;
						for ($DownButtonName in $DownButtonNames)
						{
							if (`gmatch $DownButtonName "*Icon*"`)
							{
								symbolButton -e -po 1 -image (`asInstallScriptLocation` + "Icon/" + $DownButtonName + "ON.svg") $DownButtonName;
							}else
							{
								button -e -po 1 -bgc 0.176 0.789 0.176 $DownButtonName;
							}
							$DownButtonNum = $DownButtonNum +1;
							//获取提示可选部位
								//获取可选部位数据
							int $ButtonIndex[];
							//获取当前部位的可选部位
							$ButtonIndex = findStringIndexInArray ( $CACPLoadAimDateTypeNow, $DownButtonName, 1 );
							//保留相同可选部位
							if ($DownButtonNum != 1)
							{
								$DownButtonIndexs = keepCommonIntInArray ( $DownButtonIndexs, $ButtonIndex );
							}else
							{
								$DownButtonIndexs = $ButtonIndex;
							}
								//print $DownButtonIndexs;
								//解析可选部位数据
							global string $PreButtonNames[];
							$PreButtonNames = {};
							for ($Index in $DownButtonIndexs)
							{
								string $PartsTemp[];
								tokenize($CACPLoadAimDateTypeNow[$Index],",",$PartsTemp);
								for ($i=0; $i<size($PartsTemp); $i++)
								{
									$PreButtonNames[size($PreButtonNames)] = $PartsTemp[$i];
								}
							}
							$PreButtonNames = stringArrayRemoveDuplicates($PreButtonNames);
								//禁用不可选对象
							for ($element in $CACPLoadAimDateType1)
							{
								if (`gmatch $element "*Icon*"`)
								{
									if (`symbolButton -q -po $element` == 0)
									{
										symbolButton -e -en 0 -image (`asInstallScriptLocation` + "Icon/" + $element + ".svg") $element;
									}
								}else
								{
									if (`button -q -po $element` == 0)
									{
										button -e -en 0 -bgc 0.3 0.3 0.3 $element;
									}
								}
							}
							if (size($PreButtonNames) != 0)
							{
								for ($PreButtonName in $PreButtonNames)
								{
									if (`gmatch $PreButtonName "*Icon*"`)
									{
										if (`symbolButton -q -po $PreButtonName` == 0)
										{
											symbolButton -e -en 1 -image (`asInstallScriptLocation` + "Icon/" + $PreButtonName + "PRE.svg") $PreButtonName;
										}
									}else
									{
										if (`button -q -po $PreButtonName` == 0)
										{
											button -e -en 1 -bgc 0.480 0.594 0.699 $PreButtonName;
										}
									}
								}
							}
						}
					}else if (`symbolButton -q -po $ButtonName` == 0 && $DownButtonNum < $SelectType)
					{
						symbolButton -e -po 1 -image (`asInstallScriptLocation` + "Icon/" + $ButtonName + "ON.svg") $ButtonName;
						$DownButtonNum = $DownButtonNum +1;
						$DownButtonNames[size($DownButtonNames)] = $ButtonName;
						//获取提示可选部位
							//获取可选部位数据
						global int $DownButtonIndexs[];
						int $ButtonIndex[];
						//获取当前部位的可选部位
						$ButtonIndex = findStringIndexInArray ( $CACPLoadAimDateTypeNow, $ButtonName, 1 );
						//保留相同可选部位
						if ($DownButtonNum != 1)
						{
							$DownButtonIndexs = keepCommonIntInArray ( $DownButtonIndexs, $ButtonIndex );
						}else
						{
							$DownButtonIndexs = $ButtonIndex;
						}
							//解析可选部位数据
						global string $PreButtonNames[];
						$PreButtonNames = {};
						for ($Index in $DownButtonIndexs)
						{
							string $PartsTemp[];
							tokenize($CACPLoadAimDateTypeNow[$Index],",",$PartsTemp);
							for ($i=0; $i<size($PartsTemp); $i++)
							{
								$PreButtonNames[size($PreButtonNames)] = $PartsTemp[$i];
							}
						}
						$PreButtonNames = stringArrayRemoveDuplicates($PreButtonNames);
							//禁用不可选对象
						for ($element in $CACPLoadAimDateType1)
						{
							if (`gmatch $element "*Icon*"`)
							{
								if (`symbolButton -q -po $element` == 0)
								{
									symbolButton -e -en 0 -image (`asInstallScriptLocation` + "Icon/" + $element + ".svg") $element;
								}
							}else
							{
								if (`button -q -po $element` == 0)
								{
									button -e -en 0 -bgc 0.3 0.3 0.3 $element;
								}
							}
						}
						//print $PreButtonNames;
						if (size($PreButtonNames) != 0)
						{
							for ($PreButtonName in $PreButtonNames)
							{
								if (`gmatch $PreButtonName "*Icon*"`)
								{
									if (`symbolButton -q -po $PreButtonName` == 0)
									{
										symbolButton -e -en 1 -image (`asInstallScriptLocation` + "Icon/" + $PreButtonName + "PRE.svg") $PreButtonName;
									}
								}else
								{
									if (`button -q -po $PreButtonName` == 0)
									{
										button -e -en 1 -bgc 0.480 0.594 0.699 $PreButtonName;
									}
								}
							}
						}
						if ($DownButtonNum == $SelectType)
						{
							string $TimeScale[];
							tokenize($CACPLoadAimDateTimeNow[$DownButtonIndexs[0]],"-",$TimeScale);
							playbackOptions -ast $TimeScale[0] -aet $TimeScale[1] -min $TimeScale[0] -max $TimeScale[1];
						}
					}
				}else
				{
					$result = `confirmDialog -messageAlign "center" -title "警告！" -message "已超出同时检查部位上限，是否重新选择检查部位。(注：正常情况该窗口不会出现！！)" -button "重选" -button "取消" -icon warning`;
					if ($result == "重选")
					{
						for ($element in $CACPLoadAimDateType1)
						{
							if (`gmatch $element "*Icon*"`)
							{
								symbolButton -e -po 0 -en 1 -image (`asInstallScriptLocation` + "Icon/" + $element + ".svg") $element;
							}else
							{
								button -e -po 0 -en 1 -bgc 0.5 0.5 0.5 $element;
							}
						}
						$DownButtonNum = 0;
					}
				}
			}
			if (`gmatch $ButtonName "*Button*"`)
			{
				if ($DownButtonNum <= $SelectType)
				{
					if (`button -q -po $ButtonName` == 1)
					{
						string $ButtonNameTmp[];
						$ButtonNameTmp[0] = $ButtonName;
						string $DownButtonNamesTmp[];
						$DownButtonNamesTmp = $DownButtonNames;
						//refresh;
						button -e -po 0 -bgc 0.5 0.5 0.5 $ButtonName;
						//$DownButtonNum = $DownButtonNum -1;
						global int $DownButtonIndexs[];
						$DownButtonIndexs = {};
						$DownButtonNum = 0;
						CACPRestoreDefault ();
						$DownButtonNames = stringArrayRemoveExact($ButtonNameTmp,$DownButtonNamesTmp);
						//print $DownButtonNames;
						for ($DownButtonName in $DownButtonNames)
						{
							if (`gmatch $DownButtonName "*Icon*"`)
							{
								symbolButton -e -po 1 -image (`asInstallScriptLocation` + "Icon/" + $DownButtonName + "ON.svg") $DownButtonName;
							}else
							{
								button -e -po 1 -bgc 0.176 0.789 0.176 $DownButtonName;
							}
							$DownButtonNum = $DownButtonNum +1;
							//获取提示可选部位
								//获取可选部位数据
							int $ButtonIndex[];
							//获取当前部位的可选部位
							$ButtonIndex = findStringIndexInArray ( $CACPLoadAimDateTypeNow, $DownButtonName, 1 );
							//保留相同可选部位
							if ($DownButtonNum != 1)
							{
								$DownButtonIndexs = keepCommonIntInArray ( $DownButtonIndexs, $ButtonIndex );
							}else
							{
								$DownButtonIndexs = $ButtonIndex;
							}
								//print $DownButtonIndexs;
								//解析可选部位数据
							global string $PreButtonNames[];
							$PreButtonNames = {};
							for ($Index in $DownButtonIndexs)
							{
								string $PartsTemp[];
								tokenize($CACPLoadAimDateTypeNow[$Index],",",$PartsTemp);
								for ($i=0; $i<size($PartsTemp); $i++)
								{
									$PreButtonNames[size($PreButtonNames)] = $PartsTemp[$i];
								}
							}
							$PreButtonNames = stringArrayRemoveDuplicates($PreButtonNames);
								//禁用不可选对象
							for ($element in $CACPLoadAimDateType1)
							{
								if (`gmatch $element "*Icon*"`)
								{
									if (`symbolButton -q -po $element` == 0)
									{
										symbolButton -e -en 0 -image (`asInstallScriptLocation` + "Icon/" + $element + ".svg") $element;
									}
								}else
								{
									if (`button -q -po $element` == 0)
									{
										button -e -en 0 -bgc 0.3 0.3 0.3 $element;
									}
								}
							}
							if (size($PreButtonNames) != 0)
							{
								for ($PreButtonName in $PreButtonNames)
								{
									if (`gmatch $PreButtonName "*Icon*"`)
									{
										if (`symbolButton -q -po $PreButtonName` == 0)
										{
											symbolButton -e -en 1 -image (`asInstallScriptLocation` + "Icon/" + $PreButtonName + "PRE.svg") $PreButtonName;
										}
									}else
									{
										if (`button -q -po $PreButtonName` == 0)
										{
											button -e -en 1 -bgc 0.480 0.594 0.699 $PreButtonName;
										}
									}
								}
							}
						}
					}else if (`button -q -po $ButtonName` == 0 && $DownButtonNum < $SelectType)
					{
						button -e -po 1 -bgc 0.176 0.789 0.176 $ButtonName;
						$DownButtonNum = $DownButtonNum +1;
						$DownButtonNames[size($DownButtonNames)] = $ButtonName;
						//获取提示可选部位
							//获取可选部位数据
						global int $DownButtonIndexs[];
						int $ButtonIndex[];
						//获取当前部位的可选部位
						$ButtonIndex = findStringIndexInArray ( $CACPLoadAimDateTypeNow, $ButtonName, 1 );
						//保留相同可选部位
						if ($DownButtonNum != 1)
						{
							$DownButtonIndexs = keepCommonIntInArray ( $DownButtonIndexs, $ButtonIndex );
						}else
						{
							$DownButtonIndexs = $ButtonIndex;
						}
							//解析可选部位数据
						global string $PreButtonNames[];
						$PreButtonNames = {};
						for ($Index in $DownButtonIndexs)
						{
							string $PartsTemp[];
							tokenize($CACPLoadAimDateTypeNow[$Index],",",$PartsTemp);
							for ($i=0; $i<size($PartsTemp); $i++)
							{
								$PreButtonNames[size($PreButtonNames)] = $PartsTemp[$i];
							}
						}
						$PreButtonNames = stringArrayRemoveDuplicates($PreButtonNames);
							//禁用不可选对象
						for ($element in $CACPLoadAimDateType1)
						{
							if (`gmatch $element "*Icon*"`)
							{
								if (`symbolButton -q -po $element` == 0)
								{
									symbolButton -e -en 0 -image (`asInstallScriptLocation` + "Icon/" + $element + ".svg") $element;
								}
							}else
							{
								if (`button -q -po $element` == 0)
								{
									button -e -en 0 -bgc 0.3 0.3 0.3 $element;
								}
							}
						}
						//print $PreButtonNames;
						if (size($PreButtonNames) != 0)
						{
							for ($PreButtonName in $PreButtonNames)
							{
								if (`gmatch $PreButtonName "*Icon*"`)
								{
									if (`symbolButton -q -po $PreButtonName` == 0)
									{
										symbolButton -e -en 1 -image (`asInstallScriptLocation` + "Icon/" + $PreButtonName + "PRE.svg") $PreButtonName;
									}
								}else
								{
									if (`button -q -po $PreButtonName` == 0)
									{
										button -e -en 1 -bgc 0.480 0.594 0.699 $PreButtonName;
									}
								}
							}
						}
						if ($DownButtonNum == $SelectType)
						{
							string $TimeScale[];
							tokenize($CACPLoadAimDateTimeNow[$DownButtonIndexs[0]],"-",$TimeScale);
							playbackOptions -ast $TimeScale[0] -aet $TimeScale[1] -min $TimeScale[0] -max $TimeScale[1];
						}
					}
					//if (`button -q -po $ButtonName` == 1)
					//{
					//	button -e -po 0 -bgc 0.5 0.5 0.5 $ButtonName;
					//	$DownButtonNum = $DownButtonNum -1;
					//}else
					//{
					//	button -e -po 1 -bgc 0.176 0.789 0.176 $ButtonName;
					//	$DownButtonNum = $DownButtonNum +1;
					//}
				}else
				{
					$result = `confirmDialog -messageAlign "center" -title "警告！" -message "已超出同时检查部位上限，是否重新选择检查部位。(注：正常情况该窗口不会出现！！)" -button "重选" -button "取消" -icon warning`;
					if ($result == "重选")
					{
						for ($element in $CACPLoadAimDateType1)
						{
							if (`gmatch $element "*Icon*"`)
							{
								symbolButton -e -po 0 -en 1 -image (`asInstallScriptLocation` + "Icon/" + $element + ".svg") $element;
							}else
							{
								button -e -po 0 -en 1 -bgc 0.5 0.5 0.5 $element;
							}
						}
						$DownButtonNum = 0;
					}
				}
			}
		}
	}else
	//编辑模式
	{
		global string $DownButtonNames[];
		if (`gmatch $ButtonName "*Icon*"`)
		{
			if (`symbolButton -q -po $ButtonName` == 0)
			{
				symbolButton -e -po 1 -image (`asInstallScriptLocation` + "Icon/" + $ButtonName + "ON.svg") $ButtonName;
				$DownButtonNames[size($DownButtonNames)] = $ButtonName;
			}else
			{
				symbolButton -e -po 0 -image (`asInstallScriptLocation` + "Icon/" + $ButtonName + ".svg") $ButtonName;
				string $ButtonNameTmp[];
				$ButtonNameTmp[0] = $ButtonName;
				string $DownButtonNamesTmp[];
				$DownButtonNamesTmp = $DownButtonNames;
				$DownButtonNames = stringArrayRemoveExact($ButtonNameTmp,$DownButtonNamesTmp);
			}
		}
		if (`gmatch $ButtonName "*Button*"`)
		{
			if (`button -q -po $ButtonName` == 0)
			{
				button -e -po 1 -bgc 0.176 0.789 0.176 $ButtonName;
				$DownButtonNames[size($DownButtonNames)] = $ButtonName;
			}else
			{
				button -e -po 0 -bgc 0.5 0.5 0.5 $ButtonName;
				string $ButtonNameTmp[];
				$ButtonNameTmp[0] = $ButtonName;
				string $DownButtonNamesTmp[];
				$DownButtonNamesTmp = $DownButtonNames;
				$DownButtonNames = stringArrayRemoveExact($ButtonNameTmp,$DownButtonNamesTmp);
			}
		}
	}
}
